/-- **R + TтВЕ algebraic decomposition**: extends `R_eq_neg_deg5_residual` by
canceling the deg-5 leading RтВЕ = -TтВЕ. Each RHS piece is deg-6+ in s.
Foundation for the combined `(z┬╖R+R┬╖z) + T22 + T_extra` bound at deg-7+. -/
private theorem R_plus_T5_eq_neg_deg6_residual (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (ea eb a b : ЁЭФ╕) :
    let DтВБ : ЁЭФ╕ := ea - 1 - a
