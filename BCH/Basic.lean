/-- Norm bound for `I‚ÇÇ residual` (post `(3:ùïÇ)‚Åª¬π` scalar factor):
inner sum ‚â§ 50¬∑s‚Å∂ for `s < 1/10`. -/
private theorem norm_I2_residual_inner_le (z P T‚ÇÇ T‚ÇÉ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hs_small : s ‚â§ 1 / 10)
    (hz : ‚Äñz‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2)
    (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) (hPmT‚ÇÇmT‚ÇÉ : ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ ‚â§ 5 * s ^ 4) :
    ‚Äñz ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z + (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2 +
     z * (P ^ 2 - T‚ÇÇ ^ 2) + (P * z * P - T‚ÇÇ * z * T‚ÇÇ) +
     (P ^ 2 - T‚ÇÇ ^ 2) * z + P ^ 3‚Äñ ‚â§ 50 * s ^ 6 := by
  -- Helper bounds
  have hP2T22 := norm_P2_sub_T22_le P T‚ÇÇ hs_nn hP hT‚ÇÇ hPmT‚ÇÇ
  have hPzP := norm_PzP_sub_T2zT2_le z P T‚ÇÇ hs_nn hs_small hz hT‚ÇÇ hPmT‚ÇÇ
  -- Term 1: z¬≤ ¬∑ (P-T‚ÇÇ-T‚ÇÉ) ‚â§ s¬≤¬∑5s‚Å¥ = 5s‚Å∂
  have h1 : ‚Äñz ^ 2 * (P - T‚ÇÇ - T‚ÇÉ)‚Äñ ‚â§ s ^ 2 * (5 * s ^ 4) :=
    calc _ ‚â§ ‚Äñz ^ 2‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñz‚Äñ ^ 2 * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := by gcongr; exact norm_pow_le z 2
      _ ‚â§ s ^ 2 * (5 * s ^ 4) := mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hz 2)
          hPmT‚ÇÇmT‚ÇÉ (norm_nonneg _) (by positivity)
  -- Term 2: z ¬∑ (P-T‚ÇÇ-T‚ÇÉ) ¬∑ z ‚â§ s¬∑5s‚Å¥¬∑s = 5s‚Å∂
  have h2 : ‚Äñz * (P - T‚ÇÇ - T‚ÇÉ) * z‚Äñ ‚â§ s * (5 * s ^ 4) * s :=
    calc _ ‚â§ ‚Äñz * (P - T‚ÇÇ - T‚ÇÉ)‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñz‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ) * ‚Äñz‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s * (5 * s ^ 4)) * s := by
          apply mul_le_mul _ hz (norm_nonneg _) (by positivity)
          exact mul_le_mul hz hPmT‚ÇÇmT‚ÇÉ (norm_nonneg _) (by positivity)
  -- Term 3: (P-T‚ÇÇ-T‚ÇÉ) ¬∑ z¬≤ ‚â§ 5s‚Å¥¬∑s¬≤ = 5s‚Å∂
  have h3 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z ^ 2‚Äñ ‚â§ (5 * s ^ 4) * s ^ 2 :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ * ‚Äñz‚Äñ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ ‚â§ (5 * s ^ 4) * s ^ 2 := mul_le_mul hPmT‚ÇÇmT‚ÇÉ
          (pow_le_pow_left‚ÇÄ (norm_nonneg _) hz 2) (by positivity) (by positivity)
  -- Term 4: z ¬∑ (P¬≤-T‚ÇÇ¬≤) ‚â§ s¬∑10s‚Åµ = 10s‚Å∂
  have h4 : ‚Äñz * (P ^ 2 - T‚ÇÇ ^ 2)‚Äñ ‚â§ s * (10 * s ^ 5) :=
    calc _ ‚â§ ‚Äñz‚Äñ * ‚ÄñP ^ 2 - T‚ÇÇ ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ s * (10 * s ^ 5) := mul_le_mul hz hP2T22 (norm_nonneg _) hs_nn
  -- Term 5: PzP - T‚ÇÇzT‚ÇÇ ‚â§ 13s‚Å∂
  -- (already have hPzP)
  -- Term 6: (P¬≤-T‚ÇÇ¬≤) ¬∑ z ‚â§ 10s‚Åµ¬∑s = 10s‚Å∂
  have h6 : ‚Äñ(P ^ 2 - T‚ÇÇ ^ 2) * z‚Äñ ‚â§ (10 * s ^ 5) * s :=
    calc _ ‚â§ ‚ÄñP ^ 2 - T‚ÇÇ ^ 2‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (10 * s ^ 5) * s := mul_le_mul hP2T22 hz (norm_nonneg _) (by positivity)
  -- Term 7: P¬≥ ‚â§ s‚Å∂
  have h7 : ‚ÄñP ^ 3‚Äñ ‚â§ (s ^ 2) ^ 3 :=
    calc _ ‚â§ ‚ÄñP‚Äñ ^ 3 := norm_pow_le P 3
      _ ‚â§ (s ^ 2) ^ 3 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 3
  -- Sum 7 terms via norm_add_le chain
  have ha1 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z +
    (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2 + z * (P ^ 2 - T‚ÇÇ ^ 2) + (P * z * P - T‚ÇÇ * z * T‚ÇÇ) +
    (P ^ 2 - T‚ÇÇ ^ 2) * z) (P ^ 3)
  have ha2 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z +
    (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2 + z * (P ^ 2 - T‚ÇÇ ^ 2) + (P * z * P - T‚ÇÇ * z * T‚ÇÇ))
    ((P ^ 2 - T‚ÇÇ ^ 2) * z)
  have ha3 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z +
    (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2 + z * (P ^ 2 - T‚ÇÇ ^ 2)) (P * z * P - T‚ÇÇ * z * T‚ÇÇ)
  have ha4 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z +
    (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2) (z * (P ^ 2 - T‚ÇÇ ^ 2))
  have ha5 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) + z * (P - T‚ÇÇ - T‚ÇÉ) * z)
    ((P - T‚ÇÇ - T‚ÇÉ) * z ^ 2)
  have ha6 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ)) (z * (P - T‚ÇÇ - T‚ÇÉ) * z)
  -- Sum: 5+5+5+10+13+10+1 = 49 ‚â§ 50
  nlinarith [pow_nonneg hs_nn 6]

