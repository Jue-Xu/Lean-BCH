-- `bch_octic_term` equals the `Finset.sum` over `Fin 124` of `bchOcticTerm`.
set_option maxHeartbeats 16000000 in
set_option maxRecDepth 2000 in
private theorem bch_octic_term_eq_sum (a b : ЁЭФ╕) :
    bch_octic_term ЁЭХВ a b = тИС i : Fin 124, bchOcticTerm (ЁЭХВ := ЁЭХВ) a b i := by
  unfold bch_octic_term bchOcticTerm
  rw [Fin.sum_univ_eq_sum_range (fun k => bchOcticTermN (ЁЭХВ := ЁЭХВ) a b k)]
  simp only [Finset.sum_range_succ, Finset.sum_range_zero, bchOcticTermN, zero_add]
  try abel

