  have hc_nn : 0 тЙд |c| := abs_nonneg c
  have hcs_lt : |c| * s < 1 / 4 := by
    calc |c| * s тЙд 1 * s := by gcongr
      _ = s := one_mul s
      _ < 1 / 4 := hs14
  have hcs_14 : тАЦ((тЖСc : ЁЭХВ) тАв a)тАЦ + тАЦ((тЖСc : ЁЭХВ) тАв b)тАЦ < 1 / 4 :=
    lt_of_le_of_lt hnorm_scale hcs_lt
