/-- Helper: a 6-letter product `xтВБ┬╖xтВВ┬╖xтВГ┬╖xтВД┬╖xтВЕ┬╖xтВЖ` with each `xс╡в тИИ {a, b}`
has norm тЙд `(тАЦaтАЦ+тАЦbтАЦ)тБ╢`. -/
private lemma norm_six_word_le {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕] (a b : ЁЭФ╕)
    (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ : ЁЭФ╕)
    (hтВБ : тАЦxтВБтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ) (hтВВ : тАЦxтВВтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ)
    (hтВГ : тАЦxтВГтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ) (hтВД : тАЦxтВДтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ)
    (hтВЕ : тАЦxтВЕтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ) (hтВЖ : тАЦxтВЖтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ) :
    тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖтАЦ тЙд (тАЦaтАЦ + тАЦbтАЦ) ^ 6 := by
  set s := тАЦaтАЦ + тАЦbтАЦ
  have hs_nn : 0 тЙд s := add_nonneg (norm_nonneg _) (norm_nonneg _)
  calc тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖтАЦ
      тЙд тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕтАЦ * тАЦxтВЖтАЦ := norm_mul_le _ _
    _ тЙд тАЦxтВБ * xтВВ * xтВГ * xтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ := by
        gcongr; exact norm_mul_le _ _
    _ тЙд тАЦxтВБ * xтВВ * xтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ := by
        gcongr; exact norm_mul_le _ _
    _ тЙд тАЦxтВБ * xтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ := by
        gcongr; exact norm_mul_le _ _
    _ тЙд тАЦxтВБтАЦ * тАЦxтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ := by
        gcongr; exact norm_mul_le _ _
    _ тЙд s * s * s * s * s * s := by gcongr
    _ = s ^ 6 := by ring

