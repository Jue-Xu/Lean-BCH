      _ = (2 : ℝ)⁻¹ * ‖R₁ * a' - a' * R₁‖ := by rw [h2_inv]
      _ ≤ (2 : ℝ)⁻¹ * (2 * ‖R₁‖ * ‖a'‖) := by
