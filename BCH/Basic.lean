            _ тЙд _ := mul_le_mul_of_nonneg_left (le_trans hDтВВ_le hDb2) h╬▒_nn
        have hDтВБb : тАЦDтВБ * bтАЦ тЙд ╬▒ ^ 2 * ╬▓ :=
