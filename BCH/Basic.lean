        + z * z * TтВВ * TтВВ * z
        + z * z * TтВГ_SPI * z * z
        + z * TтВВ * z * z * TтВВ
        + z * TтВВ * z * TтВВ * z
        + z * TтВВ * TтВВ * z * z
        + z * TтВГ_SPI * z * z * z
        + TтВВ * z * z * z * TтВВ
        + TтВВ * z * z * TтВВ * z
        + TтВВ * z * TтВВ * z * z
        + TтВВ * TтВВ * z * z * z
        + TтВГ_SPI * z * z * z * z
    let y6_7 : ЁЭФ╕ :=
        z * z * z * z * z * TтВВ
        + z * z * z * z * TтВВ * z
        + z * z * z * TтВВ * z * z
        + z * z * TтВВ * z * z * z
        + z * TтВВ * z * z * z * z
        + TтВВ * z * z * z * z * z
    let y : ЁЭФ╕ := exp a * exp b - 1
    let corrтВБ : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) -
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВГ_QPI + TтВГ_QPI * z) - (2 : ЁЭХВ)тБ╗┬╣ тАв TтВВ ^ 2
    let corrтВВ : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2)
    let corrтВБ_5 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W5
    let corrтВВ_5 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_5
    let corrтВБ_6 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W6
    let corrтВВ_6 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_6
    let corrтВБ_7 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W7
    let corrтВВ_7 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_7
    -- pieceB'''' (extends pieceB''' by +тЕРyтБ╖ - CтВЗ)
    y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
      (3 : ЁЭХВ)тБ╗┬╣ тАв y ^ 3 - (4 : ЁЭХВ)тБ╗┬╣ тАв y ^ 4 + (5 : ЁЭХВ)тБ╗┬╣ тАв y ^ 5 -
      (6 : ЁЭХВ)тБ╗┬╣ тАв y ^ 6 + (7 : ЁЭХВ)тБ╗┬╣ тАв y ^ 7 -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b -
      bch_septic_term ЁЭХВ a b =
    -- RHS: 6 pieces
    ((y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
        (3 : ЁЭХВ)тБ╗┬╣ тАв z ^ 3 - bch_cubic_term ЁЭХВ a b) -
        corrтВБ - corrтВБ_5 - corrтВБ_6 - corrтВБ_7) +
    ((3 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 3 - z ^ 3) - corrтВВ - corrтВВ_5 - corrтВВ_6 - corrтВВ_7) -
    (4 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 4 - z ^ 4 - y4_5 - y4_6 - y4_7) +
    (5 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 5 - z ^ 5 - y5_6 - y5_7) -
    (6 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 6 - z ^ 6 - y6_7) +
    (7 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 7 - z ^ 7) := by
  intro z TтВВ TтВГ_QPI TтВГ_SPI TтВД TтВЕ TтВЖ W5 W6 W7 y3_5 y3_6 y3_7 y4_5 y4_6 y4_7
    y5_6 y5_7 y6_7 y
    corrтВБ corrтВВ corrтВБ_5 corrтВВ_5 corrтВБ_6 corrтВВ_6 corrтВБ_7 corrтВВ_7
  -- Use QPI + SPI + Septic + Octic
  have hQPI := quintic_pure_identity ЁЭХВ a b
  have hSPI := sextic_pure_identity ЁЭХВ a b
  have hSeptic := septic_pure_identity ЁЭХВ a b
  have hOctic := octic_pure_identity ЁЭХВ a b
  linear_combination (norm := module) hQPI + hSPI + hSeptic + hOctic

/-- Norm bound for the RHS of `I2_octic_residual_decomp_eq`.

Given precomputed bounds for the 4 input pieces (with parameterized constants
K_PmT5, K_P2', K_PzP', K_P3'), bounds the RHS by
`(3┬╖K_PmT5 + 2┬╖K_P2' + K_PzP' + K_P3')┬╖sтБ╕`.

Per-term contributions:
- 3 weight-1 (P-TтВВ-TтВГ-TтВД-TтВЕ) middle terms: each тЙд K_PmT5┬╖sтБ╕ (using s┬▓┬╖K┬╖sтБ╢ etc.).
- 2 compound `z┬╖(P┬▓-TтВВ┬▓-TтВВTтВГ-TтВГTтВВ-TтВВTтВД-TтВГ┬▓-TтВДTтВВ)`-style terms: each тЙд K_P2'┬╖sтБ╕.
- 1 sandwich `PzP-TтВВzTтВВ-TтВВzTтВГ-TтВГzTтВВ-TтВВzTтВД-TтВГzTтВГ-TтВДzTтВВ` term: тЙд K_PzP'┬╖sтБ╕.
- 1 (P┬│-TтВВ┬│-TтВВ┬▓TтВГ-TтВВTтВГTтВВ-TтВГTтВВ┬▓) term: тЙд K_P3'┬╖sтБ╕.

The user supplies the parameterized bounds; this wrapper combines via
triangle inequality. Analog of `norm_I2_septic_residual_RHS_le` at one
degree higher. -/
private theorem norm_I2_octic_residual_RHS_le (z P TтВВ TтВГ TтВД TтВЕ : ЁЭФ╕)
    {s K_PmT5 K_P2' K_PzP' K_P3' : тДЭ} (hs_nn : 0 тЙд s)
    (hK_PmT5_nn : 0 тЙд K_PmT5) (hK_P2'_nn : 0 тЙд K_P2')
    (hK_PzP'_nn : 0 тЙд K_PzP') (hK_P3'_nn : 0 тЙд K_P3')
    (hz : тАЦzтАЦ тЙд s)
    (hPmT5_le : тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ тЙд K_PmT5 * s ^ 6)
    (hP2'_le :
        тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
            TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВтАЦ тЙд K_P2' * s ^ 7)
    (hPzP'_le :
        тАЦP * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
            TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВтАЦ тЙд K_PzP' * s ^ 8)
    (hP3'_le :
        тАЦP ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2тАЦ тЙд
            K_P3' * s ^ 8) :
    тАЦz ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) + z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
      (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2 +
      z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
           TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) +
      (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
           TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ) +
      (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
           TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) * z +
      (P ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2)тАЦ тЙд
      (3 * K_PmT5 + 2 * K_P2' + K_PzP' + K_P3') * s ^ 8 := by
  -- Bound each of the 7 outer terms.
  have h1 : тАЦz ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ тЙд s ^ 2 * (K_PmT5 * s ^ 6) :=
    calc _ тЙд тАЦz ^ 2тАЦ * тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ := norm_mul_le _ _
      _ тЙд тАЦzтАЦ ^ 2 * тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ := by gcongr; exact norm_pow_le z 2
      _ тЙд s ^ 2 * (K_PmT5 * s ^ 6) :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hz 2)
            hPmT5_le (norm_nonneg _) (by positivity)
  have h2 : тАЦz * (P - TтВВ - TтВГ - TтВД - TтВЕ) * zтАЦ тЙд s * (K_PmT5 * s ^ 6) * s :=
    calc _ тЙд тАЦz * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦzтАЦ * тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ) * тАЦzтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s * (K_PmT5 * s ^ 6)) * s := by
          apply mul_le_mul _ hz (norm_nonneg _) (by positivity)
          exact mul_le_mul hz hPmT5_le (norm_nonneg _) (by positivity)
  have h3 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2тАЦ тЙд (K_PmT5 * s ^ 6) * s ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ * тАЦzтАЦ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ тЙд (K_PmT5 * s ^ 6) * s ^ 2 :=
          mul_le_mul hPmT5_le (pow_le_pow_leftтВА (norm_nonneg _) hz 2)
            (by positivity) (by positivity)
  have h4 : тАЦz * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
                  TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ)тАЦ тЙд s * (K_P2' * s ^ 7) :=
    calc _ тЙд тАЦzтАЦ * тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
                TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВтАЦ := norm_mul_le _ _
      _ тЙд s * (K_P2' * s ^ 7) := mul_le_mul hz hP2'_le (norm_nonneg _) (by positivity)
  have h6 : тАЦ(P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
              TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) * zтАЦ тЙд (K_P2' * s ^ 7) * s :=
    calc _ тЙд тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
                TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (K_P2' * s ^ 7) * s := mul_le_mul hP2'_le hz (norm_nonneg _) (by positivity)
  -- Sum 7 terms via triangle inequality (6 norm_add_le).
  have ha1 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) +
    z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
    (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
         TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) * z)
    (P ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2)
  have ha2 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) +
    z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
    (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
         TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ))
    ((P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) * z)
  have ha3 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) +
    z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
    (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ))
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
         TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ)
  have ha4 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) +
    z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
    (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2)
    (z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
          TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ))
  have ha5 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) +
    z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z)
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2)
  have ha6 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ))
    (z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z)
  -- Sum: 3┬╖K_PmT5 + 2┬╖K_P2' + K_PzP' + K_P3' (in units of sтБ╕).
  nlinarith [pow_nonneg hs_nn 8]

/-- Norm bound `тАЦP - TтВВ - TтВГтАЦ тЙд 5┬╖sтБ┤` where P = exp(a)*exp(b)-1-(a+b),
TтВВ = ab+┬╜a┬▓+┬╜b┬▓, TтВГ = тЕЩa┬│+┬╜a┬▓b+┬╜ab┬▓+тЕЩb┬│. Algebraic identity:
`P - TтВВ - TтВГ = FтВБ + FтВВ + a┬╖EтВВ + EтВБ┬╖b + DтВБ┬╖DтВВ` where each piece has deg-4+
structure. -/
private theorem norm_P_sub_T2_sub_T3_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs34 : s < 3 / 4) (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦexp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3)тАЦ тЙд 5 * s ^ 4 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have hs56 : s < 5 / 6 := by linarith
  -- Set up D, E, F variables
  set DтВБ := exp a - 1 - a with hDтВБ_def
  set DтВВ := exp b - 1 - b with hDтВВ_def
  set EтВБ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 with hEтВБ_def
  set EтВВ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2 with hEтВВ_def
  set FтВБ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 with hFтВБ_def
  set FтВВ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 with hFтВВ_def
  -- Algebraic identity: P - TтВВ - TтВГ = FтВБ + FтВВ + a┬╖EтВВ + EтВБ┬╖b + DтВБ┬╖DтВВ
  have h_alg : exp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) =
      FтВБ + FтВВ + a * EтВВ + EтВБ * b + DтВБ * DтВВ := by
    simp only [hFтВБ_def, hFтВВ_def, hEтВБ_def, hEтВВ_def, hDтВБ_def, hDтВВ_def]
    noncomm_ring
  rw [h_alg]
  -- Bounds for D, E, F
  have hDтВБ_le : тАЦDтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ := norm_exp_sub_one_sub_le (ЁЭХВ := ЁЭХВ) a
  have hDтВВ_le : тАЦDтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ := norm_exp_sub_one_sub_le (ЁЭХВ := ЁЭХВ) b
  have hDa_nn : 0 тЙд Real.exp ╬▒ - 1 - ╬▒ := by
    linarith [Real.quadratic_le_exp_of_nonneg h╬▒_nn, sq_nonneg ╬▒]
  have hDb_nn : 0 тЙд Real.exp ╬▓ - 1 - ╬▓ := by
    linarith [Real.quadratic_le_exp_of_nonneg h╬▓_nn, sq_nonneg ╬▓]
  have hDa2 : Real.exp ╬▒ - 1 - ╬▒ тЙд ╬▒ ^ 2 := by
    have h := Real.norm_exp_sub_one_sub_id_le
      (show тАЦ╬▒тАЦ тЙд 1 by rw [Real.norm_eq_abs, abs_of_nonneg h╬▒_nn]; linarith)
    rwa [Real.norm_eq_abs, abs_of_nonneg hDa_nn,
         Real.norm_eq_abs, abs_of_nonneg h╬▒_nn] at h
  have hDb2 : Real.exp ╬▓ - 1 - ╬▓ тЙд ╬▓ ^ 2 := by
    have h := Real.norm_exp_sub_one_sub_id_le
      (show тАЦ╬▓тАЦ тЙд 1 by rw [Real.norm_eq_abs, abs_of_nonneg h╬▓_nn]; linarith)
    rwa [Real.norm_eq_abs, abs_of_nonneg hDb_nn,
         Real.norm_eq_abs, abs_of_nonneg h╬▓_nn] at h
  have hEтВБ_le : тАЦEтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hEтВВ_le : тАЦEтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hEa3 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 тЙд ╬▒ ^ 3 :=
    real_exp_third_order_le_cube h╬▒_nn (lt_of_le_of_lt h╬▒_le hs56)
  have hEb3 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 тЙд ╬▓ ^ 3 :=
    real_exp_third_order_le_cube h╬▓_nn (lt_of_le_of_lt h╬▓_le hs56)
  have hFтВБ_le : тАЦFтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hFтВВ_le : тАЦFтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hFa4 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 тЙд ╬▒ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hFb4 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 тЙд ╬▓ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  -- Component bounds
  have hFтВБs : тАЦFтВБтАЦ тЙд s ^ 4 := le_trans (le_trans hFтВБ_le hFa4)
    (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 4)
  have hFтВВs : тАЦFтВВтАЦ тЙд s ^ 4 := le_trans (le_trans hFтВВ_le hFb4)
    (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 4)
  have h_aEтВВ : тАЦa * EтВВтАЦ тЙд s ^ 4 :=
    calc _ тЙд тАЦaтАЦ * тАЦEтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ * ╬▓ ^ 3 := mul_le_mul_of_nonneg_left
          (le_trans hEтВВ_le hEb3) h╬▒_nn
      _ тЙд s * s ^ 3 := mul_le_mul h╬▒_le (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3)
          (by positivity) hs_nn
      _ = s ^ 4 := by ring
  have h_EтВБb : тАЦEтВБ * bтАЦ тЙд s ^ 4 :=
    calc _ тЙд тАЦEтВБтАЦ * тАЦbтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 3 * ╬▓ := mul_le_mul (le_trans hEтВБ_le hEa3) le_rfl
          h╬▓_nn (by positivity)
      _ тЙд s ^ 3 * s := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3)
          h╬▓_le (by positivity) (by positivity)
      _ = s ^ 4 := by ring
  have h_DтВБDтВВ : тАЦDтВБ * DтВВтАЦ тЙд s ^ 4 :=
    calc _ тЙд тАЦDтВБтАЦ * тАЦDтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 2 * ╬▓ ^ 2 := mul_le_mul (le_trans hDтВБ_le hDa2)
          (le_trans hDтВВ_le hDb2) (norm_nonneg _) (by positivity)
      _ тЙд s ^ 2 * s ^ 2 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 2)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 2) (by positivity) (by positivity)
      _ = s ^ 4 := by ring
  -- Triangle inequality
  have ha1 := norm_add_le (FтВБ + FтВВ + a * EтВВ + EтВБ * b) (DтВБ * DтВВ)
  have ha2 := norm_add_le (FтВБ + FтВВ + a * EтВВ) (EтВБ * b)
  have ha3 := norm_add_le (FтВБ + FтВВ) (a * EтВВ)
  have ha4 := norm_add_le FтВБ FтВВ
  linarith

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **P тИТ TтВВ тИТ TтВГ тИТ TтВД algebraic decomposition**: pure ring identity in
`(ea, eb, a, b)` expressing `P - TтВВ - TтВГ - TтВД` as a sum of 7 deg-5+ terms.
Used in `norm_P_sub_T2_sub_T3_sub_T4_le`.

Derived from `R_eq_neg_deg5_residual` via the auxiliary fact
`P - TтВВ = EтВБ + EтВВ + Q` (which expands `P - TтВВ` as the deg-3+ part). -/
private theorem P_sub_T2_sub_T3_sub_T4_decomp_eq (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (ea eb a b : ЁЭФ╕) :
    let DтВБ : ЁЭФ╕ := ea - 1 - a
    let DтВВ : ЁЭФ╕ := eb - 1 - b
    let EтВБ : ЁЭФ╕ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2
    let EтВВ : ЁЭФ╕ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let FтВБ : ЁЭФ╕ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3
    let FтВВ : ЁЭФ╕ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let GтВБ : ЁЭФ╕ := FтВБ - (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4
    let GтВВ : ЁЭФ╕ := FтВВ - (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    ea * eb - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4) =
    GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ) := by
  have hR := R_eq_neg_deg5_residual ЁЭХВ ea eb a b
  dsimp only at hR тКв
  -- The bridge from hR (TтВГ - EтВБ - EтВВ - Q + TтВД = -(...)) to our identity
  -- (P - TтВВ - TтВГ - TтВД = ...) requires the auxiliary `P - TтВВ = EтВБ + EтВВ + Q`.
  -- We embed this as a single `linear_combination` step.
  linear_combination (norm := (simp only [smul_sub, smul_add, smul_neg, smul_smul,
    mul_smul_comm, smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul]; noncomm_ring))
    -hR

/-- Norm bound `тАЦP - TтВВ - TтВГ - TтВДтАЦ тЙд 6┬╖sтБ╡` where P = exp(a)┬╖exp(b)-1-(a+b) and
TтВВ, TтВГ, TтВД are the deg-2, 3, 4 contributions to P. Algebraic identity:
`P - TтВВ - TтВГ - TтВД = GтВБ + GтВВ + a┬╖FтВВ + FтВБ┬╖b + EтВБ┬╖EтВВ + ┬╜┬╖EтВБ┬╖b┬▓ + ┬╜┬╖a┬▓┬╖EтВВ` where
each piece has deg-5+ structure. Used for the I2 septic residual bound. -/
private theorem norm_P_sub_T2_sub_T3_sub_T4_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs34 : s < 3 / 4) (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦexp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4)тАЦ тЙд 6 * s ^ 5 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have hs56 : s < 5 / 6 := by linarith
  -- Set up D, E, F, G variables
  set DтВБ := exp a - 1 - a with hDтВБ_def
  set DтВВ := exp b - 1 - b with hDтВВ_def
  set EтВБ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 with hEтВБ_def
  set EтВВ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2 with hEтВВ_def
  set FтВБ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 with hFтВБ_def
  set FтВВ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 with hFтВВ_def
  set GтВБ := FтВБ - (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 with hGтВБ_def
  set GтВВ := FтВВ - (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 with hGтВВ_def
  -- Algebraic identity:
  -- P - TтВВ - TтВГ - TтВД = GтВБ + GтВВ + a┬╖FтВВ + FтВБ┬╖b + EтВБ┬╖EтВВ + (1/2)┬╖EтВБ┬╖b┬▓ + (1/2)┬╖a┬▓┬╖EтВВ
  have h_alg : exp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4) =
      GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ) := by
    have h := P_sub_T2_sub_T3_sub_T4_decomp_eq ЁЭХВ (exp a) (exp b) a b
    simp only [hGтВБ_def, hGтВВ_def, hFтВБ_def, hFтВВ_def, hEтВБ_def, hEтВВ_def,
      hDтВБ_def, hDтВВ_def] at h
    convert h using 1
  rw [h_alg]
  -- Bounds for E, F, G via existing exp tail helpers
  have hEтВБ_le : тАЦEтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hEтВВ_le : тАЦEтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hFтВБ_le : тАЦFтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hFтВВ_le : тАЦFтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hGтВБ_le : тАЦGтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hGтВВ_le : тАЦGтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  -- Real bound transitions
  have hEa3 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 тЙд ╬▒ ^ 3 :=
    real_exp_third_order_le_cube h╬▒_nn (lt_of_le_of_lt h╬▒_le hs56)
  have hEb3 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 тЙд ╬▓ ^ 3 :=
    real_exp_third_order_le_cube h╬▓_nn (lt_of_le_of_lt h╬▓_le hs56)
  have hFa4 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 тЙд ╬▒ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hFb4 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 тЙд ╬▓ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  have hGa5 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 тЙд ╬▒ ^ 5 :=
    real_exp_fifth_order_le_quintic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hGb5 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 тЙд ╬▓ ^ 5 :=
    real_exp_fifth_order_le_quintic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  -- Component bounds (each of the 7 RHS pieces тЙд sтБ╡ or sтБ╢)
  have hGтВБs : тАЦGтВБтАЦ тЙд s ^ 5 := le_trans (le_trans hGтВБ_le hGa5)
    (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 5)
  have hGтВВs : тАЦGтВВтАЦ тЙд s ^ 5 := le_trans (le_trans hGтВВ_le hGb5)
    (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 5)
  have h_aFтВВ : тАЦa * FтВВтАЦ тЙд s ^ 5 :=
    calc _ тЙд тАЦaтАЦ * тАЦFтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ * ╬▓ ^ 4 := mul_le_mul_of_nonneg_left
          (le_trans hFтВВ_le hFb4) h╬▒_nn
      _ тЙд s * s ^ 4 := mul_le_mul h╬▒_le (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 4)
          (by positivity) hs_nn
      _ = s ^ 5 := by ring
  have h_FтВБb : тАЦFтВБ * bтАЦ тЙд s ^ 5 :=
    calc _ тЙд тАЦFтВБтАЦ * тАЦbтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 4 * ╬▓ := mul_le_mul (le_trans hFтВБ_le hFa4) le_rfl
          h╬▓_nn (by positivity)
      _ тЙд s ^ 4 * s := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 4)
          h╬▓_le (by positivity) (by positivity)
      _ = s ^ 5 := by ring
  -- EтВБ┬╖EтВВ тЙд sтБ╢ (deg-3 ├Ч deg-3)
  have h_EтВБEтВВ : тАЦEтВБ * EтВВтАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦEтВБтАЦ * тАЦEтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 3 * ╬▓ ^ 3 := mul_le_mul (le_trans hEтВБ_le hEa3)
          (le_trans hEтВВ_le hEb3) (norm_nonneg _) (by positivity)
      _ тЙд s ^ 3 * s ^ 3 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  -- (1/2)┬╖EтВБ┬╖b┬▓ тЙд sтБ╡/2
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h_EтВБb2_norm : тАЦEтВБ * b ^ 2тАЦ тЙд s ^ 5 :=
    calc _ тЙд тАЦEтВБтАЦ * тАЦb ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦEтВБтАЦ * тАЦbтАЦ ^ 2 := by gcongr; exact norm_pow_le b 2
      _ тЙд ╬▒ ^ 3 * ╬▓ ^ 2 := mul_le_mul (le_trans hEтВБ_le hEa3) le_rfl
          (by positivity) (by positivity)
      _ тЙд s ^ 3 * s ^ 2 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 2) (by positivity) (by positivity)
      _ = s ^ 5 := by ring
  have h_EтВБb2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2)тАЦ тЙд s ^ 5 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦEтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 5 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_EтВБb2_norm (by norm_num)
      _ = s ^ 5 / 2 := by ring
  -- (1/2)┬╖a┬▓┬╖EтВВ тЙд sтБ╡/2
  have h_a2EтВВ_norm : тАЦa ^ 2 * EтВВтАЦ тЙд s ^ 5 :=
    calc _ тЙд тАЦa ^ 2тАЦ * тАЦEтВВтАЦ := norm_mul_le _ _
      _ тЙд тАЦaтАЦ ^ 2 * тАЦEтВВтАЦ := by gcongr; exact norm_pow_le a 2
      _ тЙд ╬▒ ^ 2 * ╬▓ ^ 3 := mul_le_mul le_rfl
          (le_trans hEтВВ_le hEb3) (norm_nonneg _) (by positivity)
      _ тЙд s ^ 2 * s ^ 3 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 2)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3) (by positivity) (by positivity)
      _ = s ^ 5 := by ring
  have h_a2EтВВ_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ)тАЦ тЙд s ^ 5 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * EтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 5 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2EтВВ_norm (by norm_num)
      _ = s ^ 5 / 2 := by ring
  -- Triangle inequality. Total тЙд 4┬╖sтБ╡ + sтБ╢ + sтБ╡ тЙд 5┬╖sтБ╡ + sтБ╡ = 6┬╖sтБ╡ (using sтБ╢ тЙд sтБ╡).
  have hs1 : s тЙд 1 := by linarith
  have h_s6 : s ^ 6 тЙд s ^ 5 := by
    have h_eq : s ^ 6 = s ^ 5 * s := by ring
    rw [h_eq]
    nlinarith [pow_nonneg hs_nn 5]
  have ha1 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ))
  have ha2 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ)
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2))
  have ha3 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b) (EтВБ * EтВВ)
  have ha4 := norm_add_le (GтВБ + GтВВ + a * FтВВ) (FтВБ * b)
  have ha5 := norm_add_le (GтВБ + GтВВ) (a * FтВВ)
  have ha6 := norm_add_le GтВБ GтВВ
  linarith [pow_nonneg hs_nn 5, pow_nonneg hs_nn 6]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Algebraic decomposition for `P - TтВВ - TтВГ - TтВД - TтВЕ`**: pure ring identity in
`(ea, eb, a, b)` expressing `P - TтВВ - TтВГ - TтВД - TтВЕ` as a sum of 7 deg-6+ terms.
Used in `norm_P_sub_T2_sub_T3_sub_T4_sub_T5_le`. Deg-9 analog of
`P_sub_T2_sub_T3_sub_T4_decomp_eq` at one degree higher.

Derived from `R_plus_T5_eq_neg_deg6_residual` via the auxiliary fact
`P - TтВВ = EтВБ + EтВВ + Q` (which expands `P - TтВВ` as the deg-3+ part). -/
private theorem P_sub_T2_sub_T3_sub_T4_sub_T5_decomp_eq (ЁЭХВ : Type*) [RCLike ЁЭХВ]
    {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (ea eb a b : ЁЭФ╕) :
    let DтВБ : ЁЭФ╕ := ea - 1 - a
    let DтВВ : ЁЭФ╕ := eb - 1 - b
    let EтВБ : ЁЭФ╕ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2
    let EтВВ : ЁЭФ╕ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let FтВБ : ЁЭФ╕ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3
    let FтВВ : ЁЭФ╕ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let GтВБ : ЁЭФ╕ := FтВБ - (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4
    let GтВВ : ЁЭФ╕ := FтВВ - (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    let HтВБ : ЁЭФ╕ := GтВБ - (120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5
    let HтВВ : ЁЭФ╕ := GтВВ - (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5
    ea * eb - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4) -
      ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5) =
    HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) := by
  have hR := R_plus_T5_eq_neg_deg6_residual ЁЭХВ ea eb a b
  dsimp only at hR тКв
  linear_combination (norm := (simp only [smul_sub, smul_add, smul_neg, smul_smul,
    mul_smul_comm, smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul]; noncomm_ring))
    -hR

/-- Norm bound `тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ тЙд 6┬╖sтБ╢` where P = exp(a)┬╖exp(b)-1-(a+b)
and TтВВ, TтВГ, TтВД, TтВЕ are the deg-2..5 contributions to P. Algebraic identity:
`P - TтВВ - TтВГ - TтВД - TтВЕ = HтВБ + HтВВ + a┬╖GтВВ + GтВБ┬╖b + EтВБ┬╖EтВВ + ┬╜┬╖FтВБ┬╖b┬▓ + ┬╜┬╖a┬▓┬╖FтВВ`
where each piece has deg-6+ structure. Used for the I2 octic residual bound
(provides K_PmT5 = 6 input for `norm_I2_octic_residual_RHS_le`). -/
private theorem norm_P_sub_T2_sub_T3_sub_T4_sub_T5_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs34 : s < 3 / 4) (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦexp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4) -
      ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5)тАЦ тЙд 6 * s ^ 6 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have hs56 : s < 5 / 6 := by linarith
  -- Set up D, E, F, G, H variables
  set DтВБ := exp a - 1 - a with hDтВБ_def
  set DтВВ := exp b - 1 - b with hDтВВ_def
  set EтВБ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 with hEтВБ_def
  set EтВВ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2 with hEтВВ_def
  set FтВБ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 with hFтВБ_def
  set FтВВ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 with hFтВВ_def
  set GтВБ := FтВБ - (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 with hGтВБ_def
  set GтВВ := FтВВ - (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 with hGтВВ_def
  set HтВБ := GтВБ - (120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 with hHтВБ_def
  set HтВВ := GтВВ - (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5 with hHтВВ_def
  -- Algebraic identity
  have h_alg : exp a * exp b - 1 - (a + b) -
      (a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2) -
      ((6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4) -
      ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5) =
      HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) := by
    have h := P_sub_T2_sub_T3_sub_T4_sub_T5_decomp_eq ЁЭХВ (exp a) (exp b) a b
    simp only [hHтВБ_def, hHтВВ_def, hGтВБ_def, hGтВВ_def, hFтВБ_def, hFтВВ_def,
      hEтВБ_def, hEтВВ_def, hDтВБ_def, hDтВВ_def] at h
    convert h using 1
  rw [h_alg]
  -- Real tail bounds
  have hEтВБ_le : тАЦEтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hEтВВ_le : тАЦEтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hFтВБ_le : тАЦFтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hFтВВ_le : тАЦFтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hGтВБ_le : тАЦGтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hGтВВ_le : тАЦGтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  have hHтВБ_le : тАЦHтВБтАЦ тЙд Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 - ╬▒ ^ 5 / 120 :=
    norm_exp_sub_one_sub_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) a
  have hHтВВ_le : тАЦHтВВтАЦ тЙд Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 - ╬▓ ^ 5 / 120 :=
    norm_exp_sub_one_sub_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) b
  -- Real bound transitions
  have hEa3 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 тЙд ╬▒ ^ 3 :=
    real_exp_third_order_le_cube h╬▒_nn (lt_of_le_of_lt h╬▒_le hs56)
  have hEb3 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 тЙд ╬▓ ^ 3 :=
    real_exp_third_order_le_cube h╬▓_nn (lt_of_le_of_lt h╬▓_le hs56)
  have hFa4 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 тЙд ╬▒ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hFb4 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 тЙд ╬▓ ^ 4 :=
    real_exp_fourth_order_le_quartic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  have hGa5 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 тЙд ╬▒ ^ 5 :=
    real_exp_fifth_order_le_quintic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hGb5 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 тЙд ╬▓ ^ 5 :=
    real_exp_fifth_order_le_quintic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  have hHa6 : Real.exp ╬▒ - 1 - ╬▒ - ╬▒ ^ 2 / 2 - ╬▒ ^ 3 / 6 - ╬▒ ^ 4 / 24 - ╬▒ ^ 5 / 120 тЙд ╬▒ ^ 6 :=
    real_exp_sixth_order_le_sextic h╬▒_nn (lt_of_le_of_lt h╬▒_le hs34)
  have hHb6 : Real.exp ╬▓ - 1 - ╬▓ - ╬▓ ^ 2 / 2 - ╬▓ ^ 3 / 6 - ╬▓ ^ 4 / 24 - ╬▓ ^ 5 / 120 тЙд ╬▓ ^ 6 :=
    real_exp_sixth_order_le_sextic h╬▓_nn (lt_of_le_of_lt h╬▓_le hs34)
  -- Component bounds (each of the 7 RHS pieces тЙд sтБ╢)
  have hHтВБs : тАЦHтВБтАЦ тЙд s ^ 6 := le_trans (le_trans hHтВБ_le hHa6)
    (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 6)
  have hHтВВs : тАЦHтВВтАЦ тЙд s ^ 6 := le_trans (le_trans hHтВВ_le hHb6)
    (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 6)
  have h_aGтВВ : тАЦa * GтВВтАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦaтАЦ * тАЦGтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ * ╬▓ ^ 5 := mul_le_mul_of_nonneg_left
          (le_trans hGтВВ_le hGb5) h╬▒_nn
      _ тЙд s * s ^ 5 := mul_le_mul h╬▒_le (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 5)
          (by positivity) hs_nn
      _ = s ^ 6 := by ring
  have h_GтВБb : тАЦGтВБ * bтАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦGтВБтАЦ * тАЦbтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 5 * ╬▓ := mul_le_mul (le_trans hGтВБ_le hGa5) le_rfl
          h╬▓_nn (by positivity)
      _ тЙд s ^ 5 * s := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 5)
          h╬▓_le (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have h_EтВБEтВВ : тАЦEтВБ * EтВВтАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦEтВБтАЦ * тАЦEтВВтАЦ := norm_mul_le _ _
      _ тЙд ╬▒ ^ 3 * ╬▓ ^ 3 := mul_le_mul (le_trans hEтВБ_le hEa3)
          (le_trans hEтВВ_le hEb3) (norm_nonneg _) (by positivity)
      _ тЙд s ^ 3 * s ^ 3 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h_FтВБb2_norm : тАЦFтВБ * b ^ 2тАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦFтВБтАЦ * тАЦb ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦFтВБтАЦ * тАЦbтАЦ ^ 2 := by gcongr; exact norm_pow_le b 2
      _ тЙд ╬▒ ^ 4 * ╬▓ ^ 2 := mul_le_mul (le_trans hFтВБ_le hFa4) le_rfl
          (by positivity) (by positivity)
      _ тЙд s ^ 4 * s ^ 2 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 4)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 2) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have h_FтВБb2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦFтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_FтВБb2_norm (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_a2FтВВ_norm : тАЦa ^ 2 * FтВВтАЦ тЙд s ^ 6 :=
    calc _ тЙд тАЦa ^ 2тАЦ * тАЦFтВВтАЦ := norm_mul_le _ _
      _ тЙд тАЦaтАЦ ^ 2 * тАЦFтВВтАЦ := by gcongr; exact norm_pow_le a 2
      _ тЙд ╬▒ ^ 2 * ╬▓ ^ 4 := mul_le_mul le_rfl
          (le_trans hFтВВ_le hFb4) (norm_nonneg _) (by positivity)
      _ тЙд s ^ 2 * s ^ 4 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 2)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 4) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have h_a2FтВВ_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * FтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2FтВВ_norm (by norm_num)
      _ = s ^ 6 / 2 := by ring
  -- Triangle inequality. Total тЙд 5┬╖sтБ╢ + sтБ╢ = 6┬╖sтБ╢.
  have ha1 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ))
  have ha2 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ)
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2))
  have ha3 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b) (EтВБ * EтВВ)
  have ha4 := norm_add_le (HтВБ + HтВВ + a * GтВВ) (GтВБ * b)
  have ha5 := norm_add_le (HтВБ + HтВВ) (a * GтВВ)
  have ha6 := norm_add_le HтВБ HтВВ
  linarith [pow_nonneg hs_nn 6]

/-- Norm bound `тАЦP┬▓ - TтВВ┬▓ - TтВВTтВГ - TтВГTтВВ - TтВВTтВД - TтВГ┬▓ - TтВДTтВВтАЦ тЙд 16┬╖sтБ╖`
for `s тЙд 1/10`. Decomposes via `P = TтВВ + TтВГ + TтВД + DтВЕ` (DтВЕ = P-TтВВ-TтВГ-TтВД,
тАЦDтВЕтАЦ тЙд 6┬╖sтБ╡) into 10 deg-7+ terms.

The deg-7 P┬▓-residual cluster тАФ deg-9 analog of `norm_T22_sub_P2_etc_le`
at one degree higher. Provides the K_P2' = 16 input bound for
`norm_I2_octic_residual_RHS_le`. -/
private theorem norm_P2_etc_octic_le (P TтВВ TтВГ TтВД : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3) (hTтВД : тАЦTтВДтАЦ тЙд s ^ 4)
    (hD5 : тАЦP - TтВВ - TтВГ - TтВДтАЦ тЙд 6 * s ^ 5) :
    тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
        TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВтАЦ тЙд 16 * s ^ 7 := by
  have heq : P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ - TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ =
      TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВВ +
      TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВГ +
      TтВД * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВД +
      (P - TтВВ - TтВГ - TтВД) ^ 2 := by
    have hP : P = TтВВ + TтВГ + TтВД + (P - TтВВ - TтВГ - TтВД) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  -- 10 component bounds
  have h_T3T4 : тАЦTтВГ * TтВДтАЦ тЙд s ^ 3 * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hTтВД (norm_nonneg _) (by positivity))
  have h_T4T3 : тАЦTтВД * TтВГтАЦ тЙд s ^ 4 * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hTтВГ (norm_nonneg _) (by positivity))
  have h_T2D5 : тАЦTтВВ * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 2 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВВ hD5 (norm_nonneg _) (by positivity))
  have h_D5T2 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВВтАЦ тЙд (6 * s ^ 5) * s ^ 2 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВВ (norm_nonneg _) (by positivity))
  have h_T4_2 : тАЦTтВД ^ 2тАЦ тЙд s ^ 4 * s ^ 4 :=
    calc _ тЙд тАЦTтВДтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (s ^ 4) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hTтВД 2
      _ = s ^ 4 * s ^ 4 := by ring
  have h_T3D5 : тАЦTтВГ * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 3 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hD5 (norm_nonneg _) (by positivity))
  have h_D5T3 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВГтАЦ тЙд (6 * s ^ 5) * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВГ (norm_nonneg _) (by positivity))
  have h_T4D5 : тАЦTтВД * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 4 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hD5 (norm_nonneg _) (by positivity))
  have h_D5T4 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВДтАЦ тЙд (6 * s ^ 5) * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВД (norm_nonneg _) (by positivity))
  have h_D5_2 : тАЦ(P - TтВВ - TтВГ - TтВД) ^ 2тАЦ тЙд (6 * s ^ 5) ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГ - TтВДтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (6 * s ^ 5) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hD5 2
  -- Triangle inequality on 10-term sum.
  have ha1 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ + TтВД * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВД) ((P - TтВВ - TтВГ - TтВД) ^ 2)
  have ha2 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ + TтВД * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВД)
  have ha3 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ) (TтВД * (P - TтВВ - TтВГ - TтВД))
  have ha4 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВГ)
  have ha5 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2) (TтВГ * (P - TтВВ - TтВГ - TтВД))
  have ha6 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ) (TтВД ^ 2)
  have ha7 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВВ)
  have ha8 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ) (TтВВ * (P - TтВВ - TтВГ - TтВД))
  have ha9 := norm_add_le (TтВГ * TтВД) (TтВД * TтВГ)
  -- Sum: 2┬╖sтБ╖ + 12┬╖sтБ╖ + sтБ╕ + 12┬╖sтБ╕ + 12┬╖sтБ╣ + 36┬╖s┬╣тБ░
  --   = 14┬╖sтБ╖ + 13┬╖sтБ╕ + 12┬╖sтБ╣ + 36┬╖s┬╣тБ░
  -- For s тЙд 1/10: тЙд 14 + 1.3 + 0.12 + 0.0036 тЙИ 15.4 тЙд 16
  nlinarith [pow_nonneg hs_nn 7, pow_nonneg hs_nn 8, pow_nonneg hs_nn 9,
    pow_nonneg hs_nn 10, mul_nonneg (pow_nonneg hs_nn 7) hs_nn,
    mul_nonneg (pow_nonneg hs_nn 7) (sq_nonneg s),
    mul_nonneg (pow_nonneg hs_nn 7) (pow_nonneg hs_nn 3)]

/-- Norm bound `тАЦPzP - TтВВzTтВВ - TтВВzTтВГ - TтВГzTтВВ - TтВВzTтВД - TтВГzTтВГ - TтВДzTтВВтАЦ тЙд 16┬╖sтБ╕`
for `s тЙд 1/10`. Decomposes via `P = TтВВ + TтВГ + TтВД + DтВЕ` (DтВЕ = P-TтВВ-TтВГ-TтВД,
тАЦDтВЕтАЦ тЙд 6┬╖sтБ╡) into 10 deg-8+ terms.

The deg-8 PzP-residual sandwich тАФ deg-9 analog of `norm_PzP_sub_T2zT2_etc_le`
at one degree higher. Provides the K_PzP' = 16 input bound for
`norm_I2_octic_residual_RHS_le`. -/
private theorem norm_PzP_etc_octic_le (z P TтВВ TтВГ TтВД : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hz : тАЦzтАЦ тЙд s)
    (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3) (hTтВД : тАЦTтВДтАЦ тЙд s ^ 4)
    (hD5 : тАЦP - TтВВ - TтВГ - TтВДтАЦ тЙд 6 * s ^ 5) :
    тАЦP * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
        TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВтАЦ тЙд 16 * s ^ 8 := by
  have heq : P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
      TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ =
      TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
      TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД +
      TтВД * z * (P - TтВВ - TтВГ - TтВД) +
      (P - TтВВ - TтВГ - TтВД) * z * TтВВ + (P - TтВВ - TтВГ - TтВД) * z * TтВГ +
      (P - TтВВ - TтВГ - TтВД) * z * TтВД +
      (P - TтВВ - TтВГ - TтВД) * z * (P - TтВВ - TтВГ - TтВД) := by
    have hP : P = TтВВ + TтВГ + TтВД + (P - TтВВ - TтВГ - TтВД) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  -- 10 component bounds (each `тАЦX * z * YтАЦ тЙд тАЦXтАЦ┬╖тАЦzтАЦ┬╖тАЦYтАЦ`)
  have h_T2zD5 : тАЦTтВВ * z * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 2 * s * (6 * s ^ 5) :=
    calc _ тЙд тАЦTтВВ * zтАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВВтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГ - TтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 2 * s) * (6 * s ^ 5) := by
          apply mul_le_mul _ hD5 (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hz (norm_nonneg _) (by positivity)
  have h_T3zT4 : тАЦTтВГ * z * TтВДтАЦ тЙд s ^ 3 * s * s ^ 4 :=
    calc _ тЙд тАЦTтВГ * zтАЦ * тАЦTтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВГтАЦ * тАЦzтАЦ) * тАЦTтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 3 * s) * s ^ 4 := by
          apply mul_le_mul _ hTтВД (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВГ hz (norm_nonneg _) (by positivity)
  have h_T3zD5 : тАЦTтВГ * z * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 3 * s * (6 * s ^ 5) :=
    calc _ тЙд тАЦTтВГ * zтАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВГтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГ - TтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 3 * s) * (6 * s ^ 5) := by
          apply mul_le_mul _ hD5 (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВГ hz (norm_nonneg _) (by positivity)
  have h_T4zT3 : тАЦTтВД * z * TтВГтАЦ тЙд s ^ 4 * s * s ^ 3 :=
    calc _ тЙд тАЦTтВД * zтАЦ * тАЦTтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВДтАЦ * тАЦzтАЦ) * тАЦTтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 4 * s) * s ^ 3 := by
          apply mul_le_mul _ hTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВД hz (norm_nonneg _) (by positivity)
  have h_T4zT4 : тАЦTтВД * z * TтВДтАЦ тЙд s ^ 4 * s * s ^ 4 :=
    calc _ тЙд тАЦTтВД * zтАЦ * тАЦTтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВДтАЦ * тАЦzтАЦ) * тАЦTтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 4 * s) * s ^ 4 := by
          apply mul_le_mul _ hTтВД (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВД hz (norm_nonneg _) (by positivity)
  have h_T4zD5 : тАЦTтВД * z * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 4 * s * (6 * s ^ 5) :=
    calc _ тЙд тАЦTтВД * zтАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВДтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГ - TтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 4 * s) * (6 * s ^ 5) := by
          apply mul_le_mul _ hD5 (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВД hz (norm_nonneg _) (by positivity)
  have h_D5zT2 : тАЦ(P - TтВВ - TтВГ - TтВД) * z * TтВВтАЦ тЙд (6 * s ^ 5) * s * s ^ 2 :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ - TтВД) * zтАЦ * тАЦTтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦzтАЦ) * тАЦTтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((6 * s ^ 5) * s) * s ^ 2 := by
          apply mul_le_mul _ hTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hD5 hz (norm_nonneg _) (by positivity)
  have h_D5zT3 : тАЦ(P - TтВВ - TтВГ - TтВД) * z * TтВГтАЦ тЙд (6 * s ^ 5) * s * s ^ 3 :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ - TтВД) * zтАЦ * тАЦTтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦzтАЦ) * тАЦTтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((6 * s ^ 5) * s) * s ^ 3 := by
          apply mul_le_mul _ hTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hD5 hz (norm_nonneg _) (by positivity)
  have h_D5zT4 : тАЦ(P - TтВВ - TтВГ - TтВД) * z * TтВДтАЦ тЙд (6 * s ^ 5) * s * s ^ 4 :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ - TтВД) * zтАЦ * тАЦTтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦzтАЦ) * тАЦTтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((6 * s ^ 5) * s) * s ^ 4 := by
          apply mul_le_mul _ hTтВД (norm_nonneg _) (by positivity)
          exact mul_le_mul hD5 hz (norm_nonneg _) (by positivity)
  have h_D5zD5 : тАЦ(P - TтВВ - TтВГ - TтВД) * z * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд
      (6 * s ^ 5) * s * (6 * s ^ 5) :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ - TтВД) * zтАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГ - TтВДтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((6 * s ^ 5) * s) * (6 * s ^ 5) := by
          apply mul_le_mul _ hD5 (norm_nonneg _) (by positivity)
          exact mul_le_mul hD5 hz (norm_nonneg _) (by positivity)
  -- Triangle inequality on 10-term sum.
  have ha1 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД +
    TтВД * z * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * z * TтВВ + (P - TтВВ - TтВГ - TтВД) * z * TтВГ +
    (P - TтВВ - TтВГ - TтВД) * z * TтВД)
    ((P - TтВВ - TтВГ - TтВД) * z * (P - TтВВ - TтВГ - TтВД))
  have ha2 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД +
    TтВД * z * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * z * TтВВ + (P - TтВВ - TтВГ - TтВД) * z * TтВГ)
    ((P - TтВВ - TтВГ - TтВД) * z * TтВД)
  have ha3 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД +
    TтВД * z * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * z * TтВВ)
    ((P - TтВВ - TтВГ - TтВД) * z * TтВГ)
  have ha4 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД +
    TтВД * z * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * z * TтВВ)
  have ha5 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ + TтВД * z * TтВД)
    (TтВД * z * (P - TтВВ - TтВГ - TтВД))
  have ha6 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД) + TтВД * z * TтВГ) (TтВД * z * TтВД)
  have ha7 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД +
    TтВГ * z * (P - TтВВ - TтВГ - TтВД)) (TтВД * z * TтВГ)
  have ha8 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД) + TтВГ * z * TтВД)
    (TтВГ * z * (P - TтВВ - TтВГ - TтВД))
  have ha9 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ - TтВД)) (TтВГ * z * TтВД)
  -- Sum bounds: 6sтБ╕ + sтБ╕ + 6sтБ╣ + sтБ╕ + sтБ╣ + 6s┬╣тБ░ + 6sтБ╕ + 6sтБ╣ + 6s┬╣тБ░ + 36s┬╣┬╣
  --   = 14┬╖sтБ╕ + 13┬╖sтБ╣ + 12┬╖s┬╣тБ░ + 36┬╖s┬╣┬╣
  -- For s тЙд 1/10: тЙд 14 + 1.3 + 0.12 + 0.036 тЙИ 15.46 тЙд 16
  nlinarith [pow_nonneg hs_nn 8, pow_nonneg hs_nn 9, pow_nonneg hs_nn 10,
    pow_nonneg hs_nn 11, mul_nonneg (pow_nonneg hs_nn 8) hs_nn,
    mul_nonneg (pow_nonneg hs_nn 8) (sq_nonneg s),
    mul_nonneg (pow_nonneg hs_nn 8) (pow_nonneg hs_nn 3)]

/-- Norm bound `тАЦP┬│ - TтВВ┬│ - TтВВ┬▓TтВГ - TтВВTтВГTтВВ - TтВГTтВВ┬▓тАЦ тЙд 105┬╖sтБ╕` for `s тЙд 1/10`.
Decomposes via `P = TтВВ + V'` (V' = P-TтВВ, тАЦV'тАЦ тЙд 5┬╖s┬│) and refines the deg-7
contributions by subtracting `TтВВ┬▓TтВГ + TтВВTтВГTтВВ + TтВГTтВВ┬▓` to use V = P-TтВВ-TтВГ
(тАЦVтАЦ тЙд 5┬╖sтБ┤). 7-term decomposition:

  P┬│ - TтВВ┬│ - TтВВ┬▓TтВГ - TтВВTтВГTтВВ - TтВГTтВВ┬▓ =
    TтВВ┬▓┬╖V + TтВВ┬╖V┬╖TтВВ + V┬╖TтВВ┬▓ +
    TтВВ┬╖V'┬▓ + V'┬╖TтВВ┬╖V' + V'┬▓┬╖TтВВ +
    V'┬│

Per-term bounds with s тЙд 1/10:
  3┬╖5sтБ╕ + 3┬╖25sтБ╕ + 125sтБ╣ = 15sтБ╕ + 75sтБ╕ + 12.5sтБ╕ = 102.5sтБ╕ тЙд 105┬╖sтБ╕.

Deg-9 analog of `norm_P3_sub_T23_le` at one degree higher.
Provides the K_P3' = 105 input bound for `norm_I2_octic_residual_RHS_le`. -/
private theorem norm_P3_etc_octic_le (P TтВВ TтВГ : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hP : тАЦPтАЦ тЙд s ^ 2) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3)
    (hPmTтВВmTтВГ : тАЦP - TтВВ - TтВГтАЦ тЙд 5 * s ^ 4) :
    тАЦP ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2тАЦ тЙд 105 * s ^ 8 := by
  have heq : P ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2 =
      TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ + (P - TтВВ - TтВГ) * TтВВ ^ 2 +
      TтВВ * (P - TтВВ) ^ 2 + (P - TтВВ) * TтВВ * (P - TтВВ) + (P - TтВВ) ^ 2 * TтВВ +
      (P - TтВВ) ^ 3 := by
    have hP : P = TтВВ + (P - TтВВ) := by abel
    have hVp : P - TтВВ = TтВГ + (P - TтВВ - TтВГ) := by abel
    -- We expand P^3 = (TтВВ+V')^3 = TтВВ^3 + TтВВ^2 V' + TтВВ V' TтВВ + V' TтВВ^2
    --   + TтВВ V'^2 + V' TтВВ V' + V'^2 TтВВ + V'^3.
    -- Then TтВВ^2 V' = TтВВ^2 TтВГ + TтВВ^2 V where V = P-TтВВ-TтВГ, similarly for conjugates.
    rw [hP]; noncomm_ring
  rw [heq]
  -- 7 component bounds
  have h_T22V : тАЦTтВВ ^ 2 * (P - TтВВ - TтВГ)тАЦ тЙд (s ^ 2) ^ 2 * (5 * s ^ 4) :=
    calc _ тЙд тАЦTтВВ ^ 2тАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд тАЦTтВВтАЦ ^ 2 * тАЦP - TтВВ - TтВГтАЦ := by gcongr; exact norm_pow_le TтВВ 2
      _ тЙд (s ^ 2) ^ 2 * (5 * s ^ 4) :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hTтВВ 2) hPmTтВВmTтВГ
            (norm_nonneg _) (by positivity)
  have h_T2VT2 : тАЦTтВВ * (P - TтВВ - TтВГ) * TтВВтАЦ тЙд s ^ 2 * (5 * s ^ 4) * s ^ 2 :=
    calc _ тЙд тАЦTтВВ * (P - TтВВ - TтВГ)тАЦ * тАЦTтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВВтАЦ * тАЦP - TтВВ - TтВГтАЦ) * тАЦTтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 2 * (5 * s ^ 4)) * s ^ 2 := by
          apply mul_le_mul _ hTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
  have h_VT22 : тАЦ(P - TтВВ - TтВГ) * TтВВ ^ 2тАЦ тЙд (5 * s ^ 4) * (s ^ 2) ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГтАЦ * тАЦTтВВ ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВ - TтВГтАЦ * тАЦTтВВтАЦ ^ 2 := by gcongr; exact norm_pow_le TтВВ 2
      _ тЙд (5 * s ^ 4) * (s ^ 2) ^ 2 :=
          mul_le_mul hPmTтВВmTтВГ (pow_le_pow_leftтВА (norm_nonneg _) hTтВВ 2)
            (by positivity) (by positivity)
  have h_T2Vp2 : тАЦTтВВ * (P - TтВВ) ^ 2тАЦ тЙд s ^ 2 * (5 * s ^ 3) ^ 2 :=
    calc _ тЙд тАЦTтВВтАЦ * тАЦ(P - TтВВ) ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦTтВВтАЦ * тАЦP - TтВВтАЦ ^ 2 := by gcongr; exact norm_pow_le (P - TтВВ) 2
      _ тЙд s ^ 2 * (5 * s ^ 3) ^ 2 := mul_le_mul hTтВВ
          (pow_le_pow_leftтВА (norm_nonneg _) hPmTтВВ 2) (by positivity) (by positivity)
  have h_VpT2Vp : тАЦ(P - TтВВ) * TтВВ * (P - TтВВ)тАЦ тЙд (5 * s ^ 3) * s ^ 2 * (5 * s ^ 3) :=
    calc _ тЙд тАЦ(P - TтВВ) * TтВВтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВтАЦ * тАЦTтВВтАЦ) * тАЦP - TтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 3) * s ^ 2) * (5 * s ^ 3) := by
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВ hTтВВ (norm_nonneg _) (by positivity)
  have h_Vp2T2 : тАЦ(P - TтВВ) ^ 2 * TтВВтАЦ тЙд (5 * s ^ 3) ^ 2 * s ^ 2 :=
    calc _ тЙд тАЦ(P - TтВВ) ^ 2тАЦ * тАЦTтВВтАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВтАЦ ^ 2 * тАЦTтВВтАЦ := by gcongr; exact norm_pow_le (P - TтВВ) 2
      _ тЙд (5 * s ^ 3) ^ 2 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hPmTтВВ 2) hTтВВ
            (by positivity) (by positivity)
  have h_Vp3 : тАЦ(P - TтВВ) ^ 3тАЦ тЙд (5 * s ^ 3) ^ 3 :=
    calc _ тЙд тАЦP - TтВВтАЦ ^ 3 := norm_pow_le (P - TтВВ) 3
      _ тЙд (5 * s ^ 3) ^ 3 := pow_le_pow_leftтВА (norm_nonneg _) hPmTтВВ 3
  -- Triangle inequality on 7-term sum.
  have ha1 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ +
    (P - TтВВ - TтВГ) * TтВВ ^ 2 + TтВВ * (P - TтВВ) ^ 2 +
    (P - TтВВ) * TтВВ * (P - TтВВ) + (P - TтВВ) ^ 2 * TтВВ) ((P - TтВВ) ^ 3)
  have ha2 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ +
    (P - TтВВ - TтВГ) * TтВВ ^ 2 + TтВВ * (P - TтВВ) ^ 2 +
    (P - TтВВ) * TтВВ * (P - TтВВ)) ((P - TтВВ) ^ 2 * TтВВ)
  have ha3 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ +
    (P - TтВВ - TтВГ) * TтВВ ^ 2 + TтВВ * (P - TтВВ) ^ 2)
    ((P - TтВВ) * TтВВ * (P - TтВВ))
  have ha4 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ +
    (P - TтВВ - TтВГ) * TтВВ ^ 2) (TтВВ * (P - TтВВ) ^ 2)
  have ha5 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ) + TтВВ * (P - TтВВ - TтВГ) * TтВВ)
    ((P - TтВВ - TтВГ) * TтВВ ^ 2)
  have ha6 := norm_add_le (TтВВ ^ 2 * (P - TтВВ - TтВГ)) (TтВВ * (P - TтВВ - TтВГ) * TтВВ)
  -- Sum: 3┬╖5sтБ╕ + 3┬╖25sтБ╕ + 125sтБ╣ = 90sтБ╕ + 125sтБ╣
  -- For s тЙд 1/10: 90 + 12.5 = 102.5 тЙд 105
  nlinarith [pow_nonneg hs_nn 8, pow_nonneg hs_nn 9,
    mul_nonneg (pow_nonneg hs_nn 8) hs_nn]

/-- Norm bound `тАЦR+TтВЕ+TтВЖ residual sumтАЦ тЙд 7┬╖sтБ╖` from precomputed component bounds.
The 9 terms come from `R_plus_T5_plus_T6_eq_neg_deg7_residual`:
I_a+I_b+a┬╖HтВВ+HтВБ┬╖b+FтВБ┬╖FтВВ+тЕЩ┬╖FтВБ┬╖b┬│+тЕЩ┬╖a┬│┬╖FтВВ+┬╜┬╖GтВБ┬╖b┬▓+┬╜┬╖a┬▓┬╖GтВВ.

Analog of `norm_R_plus_T5_residual_sum_le` at one degree higher.
All inputs are deg-7+ (or deg-8+ for FтВБ┬╖FтВВ); requires `s тЙд 1` to fold
the sтБ╕ piece into sтБ╖. -/
private theorem norm_R_plus_T5_plus_T6_residual_sum_le
    (I_a I_b HтВБ HтВВ GтВБ GтВВ FтВБ FтВВ a b : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_le_one : s тЙд 1)
    (hI_a_le : тАЦI_aтАЦ тЙд s ^ 7) (hI_b_le : тАЦI_bтАЦ тЙд s ^ 7)
    (h_aHтВВ_le : тАЦa * HтВВтАЦ тЙд s ^ 7) (h_HтВБb_le : тАЦHтВБ * bтАЦ тЙд s ^ 7)
    (h_FтВБFтВВ_le : тАЦFтВБ * FтВВтАЦ тЙд s ^ 8)
    (h_FтВБb3_le : тАЦFтВБ * b ^ 3тАЦ тЙд s ^ 7)
    (h_a3FтВВ_le : тАЦa ^ 3 * FтВВтАЦ тЙд s ^ 7)
    (h_GтВБb2_le : тАЦGтВБ * b ^ 2тАЦ тЙд s ^ 7)
    (h_a2GтВВ_le : тАЦa ^ 2 * GтВВтАЦ тЙд s ^ 7) :
    тАЦI_a + I_b + a * HтВВ + HтВБ * b + FтВБ * FтВВ +
      (6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * FтВВ) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * GтВВ)тАЦ тЙд 7 * s ^ 7 := by
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h6eq : тАЦ(6 : ЁЭХВ)тБ╗┬╣тАЦ = (6 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have hs7_le_s7 : s ^ 8 тЙд s ^ 7 := by
    have h : s ^ 8 = s ^ 7 * s := by ring
    rw [h]
    nlinarith [pow_nonneg hs_nn 7]
  have h_FтВБb3_smul : тАЦ(6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3)тАЦ тЙд s ^ 7 / 6 := by
    calc _ тЙд тАЦ(6 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦFтВБ * b ^ 3тАЦ := norm_smul_le _ _
      _ тЙд (6 : тДЭ)тБ╗┬╣ * s ^ 7 := by
          rw [h6eq]; exact mul_le_mul_of_nonneg_left h_FтВБb3_le (by norm_num)
      _ = s ^ 7 / 6 := by ring
  have h_a3FтВВ_smul : тАЦ(6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * FтВВ)тАЦ тЙд s ^ 7 / 6 := by
    calc _ тЙд тАЦ(6 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 3 * FтВВтАЦ := norm_smul_le _ _
      _ тЙд (6 : тДЭ)тБ╗┬╣ * s ^ 7 := by
          rw [h6eq]; exact mul_le_mul_of_nonneg_left h_a3FтВВ_le (by norm_num)
      _ = s ^ 7 / 6 := by ring
  have h_GтВБb2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 2)тАЦ тЙд s ^ 7 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦGтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 7 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_GтВБb2_le (by norm_num)
      _ = s ^ 7 / 2 := by ring
  have h_a2GтВВ_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * GтВВ)тАЦ тЙд s ^ 7 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * GтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 7 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2GтВВ_le (by norm_num)
      _ = s ^ 7 / 2 := by ring
  -- 8-term sum via triangle inequality (8 norm_add_le).
  have ha1 := norm_add_le (I_a + I_b + a * HтВВ + HтВБ * b + FтВБ * FтВВ +
    (6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * FтВВ) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 2)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * GтВВ))
  have ha2 := norm_add_le (I_a + I_b + a * HтВВ + HтВБ * b + FтВБ * FтВВ +
    (6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * FтВВ))
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 2))
  have ha3 := norm_add_le (I_a + I_b + a * HтВВ + HтВБ * b + FтВБ * FтВВ +
    (6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3)) ((6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * FтВВ))
  have ha4 := norm_add_le (I_a + I_b + a * HтВВ + HтВБ * b + FтВБ * FтВВ)
    ((6 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 3))
  have ha5 := norm_add_le (I_a + I_b + a * HтВВ + HтВБ * b) (FтВБ * FтВВ)
  have ha6 := norm_add_le (I_a + I_b + a * HтВВ) (HтВБ * b)
  have ha7 := norm_add_le (I_a + I_b) (a * HтВВ)
  have ha8 := norm_add_le I_a I_b
  -- Sum: 4┬╖sтБ╖ + sтБ╕ + 2┬╖sтБ╖/6 + sтБ╖ = 4sтБ╖ + 1/3┬╖sтБ╖ + sтБ╖ + ╬╡ = 16/3┬╖sтБ╖ + sтБ╕ тЙд 7┬╖sтБ╖
  linarith [pow_nonneg hs_nn 7]

/-- Norm bound `тАЦTтВДтАЦ тЙд sтБ┤` where TтВД = (1/24)┬╖aтБ┤ + (1/6)┬╖a┬│b + (1/4)┬╖a┬▓b┬▓ +
(1/6)┬╖ab┬│ + (1/24)┬╖bтБ┤ is the deg-4 contribution of `exp(a)┬╖exp(b)-1`.
Sum of |coefficients| = 16/24 = 2/3 тЙд 1, so тАЦTтВДтАЦ тЙд (2/3)┬╖sтБ┤ тЙд sтБ┤. -/
private theorem norm_T4_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦ(24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
      (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
      (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4тАЦ тЙд s ^ 4 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have h4eq : тАЦ(4 : ЁЭХВ)тБ╗┬╣тАЦ = (4 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h6eq : тАЦ(6 : ЁЭХВ)тБ╗┬╣тАЦ = (6 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h24eq : тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ = (24 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have hT1 : тАЦ(24:ЁЭХВ)тБ╗┬╣ тАв a ^ 4тАЦ тЙд ╬▒ ^ 4 / 24 := by
    calc _ тЙд тАЦ(24:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 4тАЦ := norm_smul_le _ _
      _ тЙд (24:тДЭ)тБ╗┬╣ * ╬▒ ^ 4 := by
          rw [h24eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = ╬▒ ^ 4 / 24 := by ring
  have hT2 : тАЦ(6:ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b)тАЦ тЙд ╬▒ ^ 3 * ╬▓ / 6 :=
    calc _ тЙд тАЦ(6:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 3 * bтАЦ := norm_smul_le _ _
      _ тЙд (6:тДЭ)тБ╗┬╣ * (╬▒ ^ 3 * ╬▓) := by
          rw [h6eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) le_rfl h╬▓_nn
              (by positivity))) (by norm_num)
      _ = ╬▒ ^ 3 * ╬▓ / 6 := by ring
  have hT3 : тАЦ(4:ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2)тАЦ тЙд ╬▒ ^ 2 * ╬▓ ^ 2 / 4 :=
    calc _ тЙд тАЦ(4:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (4:тДЭ)тБ╗┬╣ * (╬▒ ^ 2 * ╬▓ ^ 2) := by
          rw [h4eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = ╬▒ ^ 2 * ╬▓ ^ 2 / 4 := by ring
  have hT4 : тАЦ(6:ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3)тАЦ тЙд ╬▒ * ╬▓ ^ 3 / 6 :=
    calc _ тЙд тАЦ(6:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa * b ^ 3тАЦ := norm_smul_le _ _
      _ тЙд (6:тДЭ)тБ╗┬╣ * (╬▒ * ╬▓ ^ 3) := by
          rw [h6eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul le_rfl (norm_pow_le _ _)
              (by positivity) h╬▒_nn)) (by norm_num)
      _ = ╬▒ * ╬▓ ^ 3 / 6 := by ring
  have hT5 : тАЦ(24:ЁЭХВ)тБ╗┬╣ тАв b ^ 4тАЦ тЙд ╬▓ ^ 4 / 24 :=
    calc _ тЙд тАЦ(24:ЁЭХВ)тБ╗┬╣тАЦ * тАЦb ^ 4тАЦ := norm_smul_le _ _
      _ тЙд (24:тДЭ)тБ╗┬╣ * ╬▓ ^ 4 := by
          rw [h24eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = ╬▓ ^ 4 / 24 := by ring
  have ha1 := norm_add_le ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
    (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3)) ((24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4)
  have ha2 := norm_add_le ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
    (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2)) ((6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3))
  have ha3 := norm_add_le ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b))
    ((4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2))
  have ha4 := norm_add_le ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4) ((6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b))
  -- ╬▒^k┬╖╬▓^(4-k) тЙд s^4 for each k = 0, 1, 2, 3, 4.
  have ha4s : ╬▒ ^ 4 тЙд s ^ 4 := pow_le_pow_leftтВА h╬▒_nn h╬▒_le 4
  have hb4s : ╬▓ ^ 4 тЙд s ^ 4 := pow_le_pow_leftтВА h╬▓_nn h╬▓_le 4
  have ha3bs : ╬▒ ^ 3 * ╬▓ тЙд s ^ 4 := by
    calc ╬▒ ^ 3 * ╬▓ тЙд s ^ 3 * s := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3) h╬▓_le
          h╬▓_nn (by positivity)
      _ = s ^ 4 := by ring
  have ha2b2s : ╬▒ ^ 2 * ╬▓ ^ 2 тЙд s ^ 4 := by
    calc ╬▒ ^ 2 * ╬▓ ^ 2 тЙд s ^ 2 * s ^ 2 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 2)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 2) (by positivity) (by positivity)
      _ = s ^ 4 := by ring
  have hab3s : ╬▒ * ╬▓ ^ 3 тЙд s ^ 4 := by
    calc ╬▒ * ╬▓ ^ 3 тЙд s * s ^ 3 := mul_le_mul h╬▒_le (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3)
          (by positivity) hs_nn
      _ = s ^ 4 := by ring
  -- Sum: ╬▒тБ┤/24 + ╬▒┬│╬▓/6 + ╬▒┬▓╬▓┬▓/4 + ╬▒╬▓┬│/6 + ╬▓тБ┤/24 тЙд sтБ┤┬╖(1/24+1/6+1/4+1/6+1/24) = (2/3)┬╖sтБ┤ тЙд sтБ┤.
  nlinarith [pow_nonneg hs_nn 4]

/-- Norm bound `тАЦTтВЕтАЦ тЙд sтБ╡` where TтВЕ = (1/120)┬╖aтБ╡ + (1/24)┬╖aтБ┤b + (1/12)┬╖a┬│b┬▓ +
(1/12)┬╖a┬▓b┬│ + (1/24)┬╖abтБ┤ + (1/120)┬╖bтБ╡ is the deg-5 contribution of
`exp(a)┬╖exp(b)-1`. Sum of |coefficients| = 32/120 = 4/15 тЙд 1, so
тАЦTтВЕтАЦ тЙд (4/15)┬╖sтБ╡ тЙд sтБ╡. -/
private theorem norm_T5_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦ(120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
      (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
      (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5тАЦ тЙд s ^ 5 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have h12eq : тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ = (12 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h24eq : тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ = (24 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h120eq : тАЦ(120 : ЁЭХВ)тБ╗┬╣тАЦ = (120 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have hT1 : тАЦ(120:ЁЭХВ)тБ╗┬╣ тАв a ^ 5тАЦ тЙд ╬▒ ^ 5 / 120 :=
    calc _ тЙд тАЦ(120:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 5тАЦ := norm_smul_le _ _
      _ тЙд (120:тДЭ)тБ╗┬╣ * ╬▒ ^ 5 := by
          rw [h120eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = ╬▒ ^ 5 / 120 := by ring
  have hT2 : тАЦ(24:ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b)тАЦ тЙд ╬▒ ^ 4 * ╬▓ / 24 :=
    calc _ тЙд тАЦ(24:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 4 * bтАЦ := norm_smul_le _ _
      _ тЙд (24:тДЭ)тБ╗┬╣ * (╬▒ ^ 4 * ╬▓) := by
          rw [h24eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) le_rfl h╬▓_nn
              (by positivity))) (by norm_num)
      _ = ╬▒ ^ 4 * ╬▓ / 24 := by ring
  have hT3 : тАЦ(12:ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2)тАЦ тЙд ╬▒ ^ 3 * ╬▓ ^ 2 / 12 :=
    calc _ тЙд тАЦ(12:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 3 * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (12:тДЭ)тБ╗┬╣ * (╬▒ ^ 3 * ╬▓ ^ 2) := by
          rw [h12eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = ╬▒ ^ 3 * ╬▓ ^ 2 / 12 := by ring
  have hT4 : тАЦ(12:ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3)тАЦ тЙд ╬▒ ^ 2 * ╬▓ ^ 3 / 12 :=
    calc _ тЙд тАЦ(12:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * b ^ 3тАЦ := norm_smul_le _ _
      _ тЙд (12:тДЭ)тБ╗┬╣ * (╬▒ ^ 2 * ╬▓ ^ 3) := by
          rw [h12eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = ╬▒ ^ 2 * ╬▓ ^ 3 / 12 := by ring
  have hT5 : тАЦ(24:ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4)тАЦ тЙд ╬▒ * ╬▓ ^ 4 / 24 :=
    calc _ тЙд тАЦ(24:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa * b ^ 4тАЦ := norm_smul_le _ _
      _ тЙд (24:тДЭ)тБ╗┬╣ * (╬▒ * ╬▓ ^ 4) := by
          rw [h24eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul le_rfl (norm_pow_le _ _)
              (by positivity) h╬▒_nn)) (by norm_num)
      _ = ╬▒ * ╬▓ ^ 4 / 24 := by ring
  have hT6 : тАЦ(120:ЁЭХВ)тБ╗┬╣ тАв b ^ 5тАЦ тЙд ╬▓ ^ 5 / 120 :=
    calc _ тЙд тАЦ(120:ЁЭХВ)тБ╗┬╣тАЦ * тАЦb ^ 5тАЦ := norm_smul_le _ _
      _ тЙд (120:тДЭ)тБ╗┬╣ * ╬▓ ^ 5 := by
          rw [h120eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = ╬▓ ^ 5 / 120 := by ring
  have ha1 := norm_add_le ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
    (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
    (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4)) ((120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5)
  have ha2 := norm_add_le ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
    (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3))
    ((24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4))
  have ha3 := norm_add_le ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
    (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2)) ((12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3))
  have ha4 := norm_add_le ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b))
    ((12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2))
  have ha5 := norm_add_le ((120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5) ((24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b))
  -- ╬▒^k┬╖╬▓^(5-k) тЙд s^5.
  have ha5s : ╬▒ ^ 5 тЙд s ^ 5 := pow_le_pow_leftтВА h╬▒_nn h╬▒_le 5
  have hb5s : ╬▓ ^ 5 тЙд s ^ 5 := pow_le_pow_leftтВА h╬▓_nn h╬▓_le 5
  have ha4bs : ╬▒ ^ 4 * ╬▓ тЙд s ^ 5 := by
    calc ╬▒ ^ 4 * ╬▓ тЙд s ^ 4 * s := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 4) h╬▓_le
          h╬▓_nn (by positivity)
      _ = s ^ 5 := by ring
  have ha3b2s : ╬▒ ^ 3 * ╬▓ ^ 2 тЙд s ^ 5 := by
    calc ╬▒ ^ 3 * ╬▓ ^ 2 тЙд s ^ 3 * s ^ 2 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 3)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 2) (by positivity) (by positivity)
      _ = s ^ 5 := by ring
  have ha2b3s : ╬▒ ^ 2 * ╬▓ ^ 3 тЙд s ^ 5 := by
    calc ╬▒ ^ 2 * ╬▓ ^ 3 тЙд s ^ 2 * s ^ 3 := mul_le_mul (pow_le_pow_leftтВА h╬▒_nn h╬▒_le 2)
          (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 3) (by positivity) (by positivity)
      _ = s ^ 5 := by ring
  have hab4s : ╬▒ * ╬▓ ^ 4 тЙд s ^ 5 := by
    calc ╬▒ * ╬▓ ^ 4 тЙд s * s ^ 4 := mul_le_mul h╬▒_le (pow_le_pow_leftтВА h╬▓_nn h╬▓_le 4)
          (by positivity) hs_nn
      _ = s ^ 5 := by ring
  -- Sum: ╬▒тБ╡/120 + ╬▒тБ┤╬▓/24 + ╬▒┬│╬▓┬▓/12 + ╬▒┬▓╬▓┬│/12 + ╬▒╬▓тБ┤/24 + ╬▓тБ╡/120 тЙд sтБ╡┬╖(1/120+1/24+1/12+1/12+1/24+1/120)
  --       = sтБ╡┬╖(1+5+10+10+5+1)/120 = 32/120┬╖sтБ╡ = (4/15)┬╖sтБ╡ тЙд sтБ╡.
  nlinarith [pow_nonneg hs_nn 5]

/-- Norm bound `тАЦTтВЖтАЦ тЙд sтБ╢` where TтВЖ = (1/720)┬╖aтБ╢ + (1/120)┬╖aтБ╡b + (1/48)┬╖aтБ┤b┬▓ +
(1/36)┬╖a┬│b┬│ + (1/48)┬╖a┬▓bтБ┤ + (1/120)┬╖abтБ╡ + (1/720)┬╖bтБ╢ is the deg-6
contribution of `exp(a)┬╖exp(b)-1`. Sum of |coefficients| =
(1+6+15+20+15+6+1)/720 = 64/720 = 4/45 тЙд 1, so тАЦTтВЖтАЦ тЙд (4/45)┬╖sтБ╢ тЙд sтБ╢. -/
private theorem norm_T6_le (a b : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (h╬▒_le : тАЦaтАЦ тЙд s) (h╬▓_le : тАЦbтАЦ тЙд s) :
    тАЦ(720 : ЁЭХВ)тБ╗┬╣ тАв a ^ 6 + (120 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b) +
      (48 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b ^ 2) + (36 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 3) +
      (48 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 5) +
      (720 : ЁЭХВ)тБ╗┬╣ тАв b ^ 6тАЦ тЙд s ^ 6 := by
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have h36eq : тАЦ(36 : ЁЭХВ)тБ╗┬╣тАЦ = (36 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h48eq : тАЦ(48 : ЁЭХВ)тБ╗┬╣тАЦ = (48 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h120eq : тАЦ(120 : ЁЭХВ)тБ╗┬╣тАЦ = (120 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h720eq : тАЦ(720 : ЁЭХВ)тБ╗┬╣тАЦ = (720 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have hT1 : тАЦ(720:ЁЭХВ)тБ╗┬╣ тАв a ^ 6тАЦ тЙд ╬▒ ^ 6 / 720 :=
    calc _ тЙд тАЦ(720:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 6тАЦ := norm_smul_le _ _
      _ тЙд (720:тДЭ)тБ╗┬╣ * ╬▒ ^ 6 := by
          rw [h720eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = ╬▒ ^ 6 / 720 := by ring
  have hT2 : тАЦ(120:ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b)тАЦ тЙд ╬▒ ^ 5 * ╬▓ / 120 :=
    calc _ тЙд тАЦ(120:ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 5 * bтАЦ := norm_smul_le _ _
      _ тЙд (120:тДЭ)тБ╗┬╣ * (╬▒ ^ 5 * ╬▓) := by
          rw [h120eq]
          exact mul_le_mul_of_nonneg_left
