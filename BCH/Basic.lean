  set DтВВ := exp b - 1 - b with hDтВВ_def
  set P := y - (a + b) with hP_def
  set EтВБ := exp a - 1 - a - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 with hEтВБ_def
  set EтВВ := exp b - 1 - b - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2 with hEтВВ_def
  set FтВБ := exp a - 1 - a - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 with hFтВБ_def
