      _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz‚Äñ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ ‚â§ (5 * s ^ 3) * s ^ 2 := mul_le_mul hPmT‚ÇÇ
