/-! ### Lie bracket formulation of BCH results -/

/-- The Lie bracket `тБЕa, bтБЖ` in an associative ring equals the ring commutator `a*b - b*a`.
This is `LieRing.of_associative_ring_bracket` from Mathlib, restated here for convenience. -/
theorem lie_eq_commutator (a b : ЁЭФ╕) : тБЕa, bтБЖ = a * b - b * a :=
  LieRing.of_associative_ring_bracket a b

include ЁЭХВ in
/-- **BCH commutator extraction (Lie bracket form)**:
`bch(a,b) = a + b + ┬╜тБЕa,bтБЖ + O(s┬│)`. -/
theorem norm_bch_sub_add_sub_lie_le (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв тБЕa, bтБЖтАЦ тЙд
      10 * (тАЦaтАЦ + тАЦbтАЦ) ^ 3 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  rw [lie_eq_commutator]
  exact norm_bch_sub_add_sub_bracket_le (ЁЭХВ := ЁЭХВ) a b hab

include ЁЭХВ in
/-- **Symmetric BCH (Lie bracket form)**: The Strang splitting has cubic error,
with the `тБЕa/2, bтБЖ` term cancelling. -/
theorem norm_symmetric_bch_sub_add_lie_le (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < 1 / 4) :
    тАЦbch (ЁЭХВ := ЁЭХВ) (bch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) - (a + b)тАЦ тЙд
      300 * (тАЦaтАЦ + тАЦbтАЦ) ^ 3 :=
  norm_symmetric_bch_sub_add_le (ЁЭХВ := ЁЭХВ) a b hab

include ЁЭХВ in
/-- The BCH quadratic bound in Lie bracket notation:
`тАЦbch(a,b) - (a+b)тАЦ тЙд 3s┬▓/(2-e╦в)`, i.e., the leading error is `┬╜тБЕa,bтБЖ`. -/
theorem norm_bch_sub_add_le' (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b)тАЦ тЙд
      3 * (тАЦaтАЦ + тАЦbтАЦ) ^ 2 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) :=
  norm_bch_sub_add_le (ЁЭХВ := ЁЭХВ) a b hab

/-! ### Suzuki infrastructure: Cubic coefficient and quintic remainder

For the fourth-order Suzuki formula, we need the cubic coefficient EтВГ of the
symmetric BCH expansion, with the property that EтВГ(c┬╖a, c┬╖b) = c┬│┬╖EтВГ(a,b).
The Suzuki condition 4p┬│+(1-4p)┬│=0 then kills this term. -/

/-- The degree-3 BCH term: `(1/12)([a,[a,b]] + [b,[b,a]])`.

This is the leading cubic correction in the BCH expansion:
`bch(a,b) = a + b + ┬╜[a,b] + bch_cubic_term a b + O(sтБ┤)`. -/
noncomputable def bch_cubic_term (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) : ЁЭФ╕ :=
  (12 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a) +
  (12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Homogeneity of bch_cubic_term**: EтВГ(c┬╖a, c┬╖b) = c┬│┬╖EтВГ(a,b).
This is the key property enabling Suzuki's cubic cancellation. -/
theorem bch_cubic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_cubic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 3 тАв bch_cubic_term ЁЭХВ a b := by
  -- Helper: triple product homogeneity
  have triple : тИА x y z : ЁЭФ╕,
      (c тАв x) * ((c тАв y) * (c тАв z)) = c ^ 3 тАв (x * (y * z)) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  have triple' : тИА x y z : ЁЭФ╕,
      ((c тАв x) * (c тАв y)) * (c тАв z) = c ^ 3 тАв (x * y * z) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  unfold bch_cubic_term
  simp only [mul_sub, sub_mul, triple, triple', тЖР smul_sub, smul_comm (c ^ 3) ((12 : ЁЭХВ)тБ╗┬╣),
    тЖР smul_add]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- Norm bound for bch_cubic_term. -/
theorem norm_bch_cubic_term_le (a b : ЁЭФ╕) :
    тАЦbch_cubic_term ЁЭХВ a bтАЦ тЙд (тАЦaтАЦ + тАЦbтАЦ) ^ 3 := by
  unfold bch_cubic_term
  set s := тАЦaтАЦ + тАЦbтАЦ
  -- Bound тАЦ(12:ЁЭХВ)тБ╗┬╣тАЦ тЙд 1
  have h12 : тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ тЙд 1 := by
    rw [norm_inv, RCLike.norm_ofNat]
    norm_num
  -- Bound each double commutator
  have hab_comm : тАЦa * b - b * aтАЦ тЙд 2 * тАЦaтАЦ * тАЦbтАЦ := by
    calc тАЦa * b - b * aтАЦ тЙд тАЦa * bтАЦ + тАЦb * aтАЦ := norm_sub_le _ _
      _ тЙд тАЦaтАЦ * тАЦbтАЦ + тАЦbтАЦ * тАЦaтАЦ := by gcongr <;> exact norm_mul_le _ _
      _ = 2 * тАЦaтАЦ * тАЦbтАЦ := by ring
  have hba_comm : тАЦb * a - a * bтАЦ тЙд 2 * тАЦaтАЦ * тАЦbтАЦ := by
    calc тАЦb * a - a * bтАЦ тЙд тАЦb * aтАЦ + тАЦa * bтАЦ := norm_sub_le _ _
      _ тЙд тАЦbтАЦ * тАЦaтАЦ + тАЦaтАЦ * тАЦbтАЦ := by gcongr <;> exact norm_mul_le _ _
      _ = 2 * тАЦaтАЦ * тАЦbтАЦ := by ring
  -- First double commutator: a*[a,b] - [a,b]*a, norm тЙд 4тАЦaтАЦ┬▓тАЦbтАЦ
  have h1 : тАЦa * (a * b - b * a) - (a * b - b * a) * aтАЦ тЙд 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ := by
    calc тАЦa * (a * b - b * a) - (a * b - b * a) * aтАЦ
        тЙд тАЦa * (a * b - b * a)тАЦ + тАЦ(a * b - b * a) * aтАЦ := norm_sub_le _ _
      _ тЙд тАЦaтАЦ * тАЦa * b - b * aтАЦ + тАЦa * b - b * aтАЦ * тАЦaтАЦ := by
          gcongr <;> exact norm_mul_le _ _
      _ тЙд тАЦaтАЦ * (2 * тАЦaтАЦ * тАЦbтАЦ) + (2 * тАЦaтАЦ * тАЦbтАЦ) * тАЦaтАЦ := by
          gcongr
      _ = 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ := by ring
  -- Second double commutator: b*[b,a] - [b,a]*b, norm тЙд 4тАЦaтАЦтАЦbтАЦ┬▓
  have h2 : тАЦb * (b * a - a * b) - (b * a - a * b) * bтАЦ тЙд 4 * тАЦaтАЦ * тАЦbтАЦ ^ 2 := by
    calc тАЦb * (b * a - a * b) - (b * a - a * b) * bтАЦ
        тЙд тАЦb * (b * a - a * b)тАЦ + тАЦ(b * a - a * b) * bтАЦ := norm_sub_le _ _
      _ тЙд тАЦbтАЦ * тАЦb * a - a * bтАЦ + тАЦb * a - a * bтАЦ * тАЦbтАЦ := by
          gcongr <;> exact norm_mul_le _ _
      _ тЙд тАЦbтАЦ * (2 * тАЦaтАЦ * тАЦbтАЦ) + (2 * тАЦaтАЦ * тАЦbтАЦ) * тАЦbтАЦ := by
          gcongr
      _ = 4 * тАЦaтАЦ * тАЦbтАЦ ^ 2 := by ring
  -- Bound the smul'd terms
  have hs1 : тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a)тАЦ
      тЙд 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ := by
    calc _ тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa * (a * b - b * a) - (a * b - b * a) * aтАЦ :=
            norm_smul_le _ _
      _ тЙд 1 * (4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ) := by gcongr
      _ = 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ := by ring
  have hs2 : тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)тАЦ
      тЙд 4 * тАЦaтАЦ * тАЦbтАЦ ^ 2 := by
    calc _ тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦb * (b * a - a * b) - (b * a - a * b) * bтАЦ :=
            norm_smul_le _ _
      _ тЙд 1 * (4 * тАЦaтАЦ * тАЦbтАЦ ^ 2) := by gcongr
      _ = 4 * тАЦaтАЦ * тАЦbтАЦ ^ 2 := by ring
  -- Combine
  have ha := norm_nonneg a
  have hb := norm_nonneg b
  calc тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)тАЦ
      тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a)тАЦ +
        тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)тАЦ :=
        norm_add_le _ _
    _ тЙд 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ + 4 * тАЦaтАЦ * тАЦbтАЦ ^ 2 := by gcongr
    _ тЙд s ^ 3 := by nlinarith [sq_nonneg (тАЦaтАЦ - тАЦbтАЦ)]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Lipschitz-style bound for `bch_cubic_term` in its first argument**:
`тАЦCтВГ(z, y) - CтВГ(x, y)тАЦ тЙд (тАЦzтАЦ+тАЦxтАЦ+тАЦyтАЦ)┬▓ ┬╖ тАЦz - xтАЦ`.

The diff telescopes into 12 summands (counting multiplicities; 9 distinct
patterns), each of the form `[product] ┬╖ (z-x) ┬╖ [product]` with the products
totaling 2 letters from `{z, x, y}`. Each summand has norm тЙд M┬▓┬╖тАЦz-xтАЦ
(M = тАЦzтАЦ+тАЦxтАЦ+тАЦyтАЦ), giving 12┬╖M┬▓┬╖тАЦz-xтАЦ in total; the (1/12)┬╖smul scaling
trims this to exactly M┬▓┬╖тАЦz-xтАЦ.

Use case (T2-F7e parent discharge model): when `z = (a'+b) + W` with
`тАЦWтАЦ = O(s┬▓)` and `тАЦa'+bтАЦ, тАЦyтАЦ = O(s)`, gives `тАЦCтВГ(z, y) - CтВГ(a'+b, y)тАЦ
тЙд K ┬╖ s┬▓ ┬╖ s┬▓ = K ┬╖ sтБ┤`. The analog for `bch_quintic_term` and
`bch_sextic_term` (gives O(sтБ╢) and O(sтБ╖) bounds respectively) provides the
key residual estimates for the parent T2-F7e discharge. -/
theorem norm_bch_cubic_term_diff_le (z x y : ЁЭФ╕) :
    тАЦbch_cubic_term ЁЭХВ z y - bch_cubic_term ЁЭХВ x yтАЦ тЙд
      (тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ) ^ 2 * тАЦz - xтАЦ := by
  -- Step 1: Telescoping algebraic identity. Each (z-x) factor is exposed.
  have htel : bch_cubic_term ЁЭХВ z y - bch_cubic_term ЁЭХВ x y =
      (12 : ЁЭХВ)тБ╗┬╣ тАв (
          z * (z - x) * y + (z - x) * x * y
        - z * y * (z - x) - z * y * (z - x)
        - (z - x) * y * x - (z - x) * y * x
        + y * z * (z - x) + y * (z - x) * x
        + y * y * (z - x)
        - y * (z - x) * y - y * (z - x) * y
        + (z - x) * y * y) := by
    unfold bch_cubic_term
    simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm,
      smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
    match_scalars <;> ring
  rw [htel]
  -- Step 2: Setup
  set M := тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ with hM_def
  set d := тАЦz - xтАЦ with hd_def
  have hd_nn : 0 тЙд d := norm_nonneg _
  have hz_le : тАЦzтАЦ тЙд M := by
    show тАЦzтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg x, norm_nonneg y]
  have hx_le : тАЦxтАЦ тЙд M := by
    show тАЦxтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg y]
  have hy_le : тАЦyтАЦ тЙд M := by
    show тАЦyтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg x]
  -- Helper: triple product norm bound
  have htriple : тИА A B C : ЁЭФ╕, тАЦA * B * CтАЦ тЙд тАЦAтАЦ * тАЦBтАЦ * тАЦCтАЦ := fun A B C => by
    calc тАЦA * B * CтАЦ тЙд тАЦA * BтАЦ * тАЦCтАЦ := norm_mul_le _ _
      _ тЙд тАЦAтАЦ * тАЦBтАЦ * тАЦCтАЦ := by gcongr; exact norm_mul_le _ _
  -- Step 3: Each summand тЙд M┬▓┬╖d
  have h1 : тАЦz * (z - x) * yтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦzтАЦ * тАЦz - xтАЦ * тАЦyтАЦ := htriple _ _ _
      _ тЙд M * d * M := by gcongr
      _ = M ^ 2 * d := by ring
  have h2 : тАЦ(z - x) * x * yтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦxтАЦ * тАЦyтАЦ := htriple _ _ _
      _ тЙд d * M * M := by gcongr
      _ = M ^ 2 * d := by ring
  have h3 : тАЦz * y * (z - x)тАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦzтАЦ * тАЦyтАЦ * тАЦz - xтАЦ := htriple _ _ _
      _ тЙд M * M * d := by gcongr
      _ = M ^ 2 * d := by ring
  have h4 : тАЦ(z - x) * y * xтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦyтАЦ * тАЦxтАЦ := htriple _ _ _
      _ тЙд d * M * M := by gcongr
      _ = M ^ 2 * d := by ring
  have h5 : тАЦy * z * (z - x)тАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦzтАЦ * тАЦz - xтАЦ := htriple _ _ _
      _ тЙд M * M * d := by gcongr
      _ = M ^ 2 * d := by ring
  have h6 : тАЦy * (z - x) * xтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦz - xтАЦ * тАЦxтАЦ := htriple _ _ _
      _ тЙд M * d * M := by gcongr
      _ = M ^ 2 * d := by ring
  have h7 : тАЦy * y * (z - x)тАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦyтАЦ * тАЦz - xтАЦ := htriple _ _ _
      _ тЙд M * M * d := by gcongr
      _ = M ^ 2 * d := by ring
  have h8 : тАЦy * (z - x) * yтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦz - xтАЦ * тАЦyтАЦ := htriple _ _ _
      _ тЙд M * d * M := by gcongr
      _ = M ^ 2 * d := by ring
  have h9 : тАЦ(z - x) * y * yтАЦ тЙд M ^ 2 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦyтАЦ * тАЦyтАЦ := htriple _ _ _
      _ тЙд d * M * M := by gcongr
      _ = M ^ 2 * d := by ring
  -- Step 4: Triangle inequality on the 12-term sum
  set S : ЁЭФ╕ :=
        z * (z - x) * y + (z - x) * x * y
      - z * y * (z - x) - z * y * (z - x)
      - (z - x) * y * x - (z - x) * y * x
      + y * z * (z - x) + y * (z - x) * x
      + y * y * (z - x)
      - y * (z - x) * y - y * (z - x) * y
      + (z - x) * y * y with hS_def
  -- Rewrite S as a sum of 12 explicit terms (each with sign), bound by 12┬╖M┬▓┬╖d
  have hS_eq : S = z * (z - x) * y + (z - x) * x * y +
        -(z * y * (z - x)) + -(z * y * (z - x)) +
        -((z - x) * y * x) + -((z - x) * y * x) +
        y * z * (z - x) + y * (z - x) * x +
        y * y * (z - x) +
        -(y * (z - x) * y) + -(y * (z - x) * y) +
        (z - x) * y * y := by rw [hS_def]; abel
  have hS_le : тАЦSтАЦ тЙд 12 * (M ^ 2 * d) := by
    rw [hS_eq]
    -- Set abbreviations for the 12 summands to keep linarith hypotheses small.
    set s1 : ЁЭФ╕ := z * (z - x) * y with hs1
    set s2 : ЁЭФ╕ := (z - x) * x * y with hs2
    set s3 : ЁЭФ╕ := -(z * y * (z - x)) with hs3
    set s4 : ЁЭФ╕ := -(z * y * (z - x)) with hs4
    set s5 : ЁЭФ╕ := -((z - x) * y * x) with hs5
    set s6 : ЁЭФ╕ := -((z - x) * y * x) with hs6
    set s7 : ЁЭФ╕ := y * z * (z - x) with hs7
    set s8 : ЁЭФ╕ := y * (z - x) * x with hs8
    set s9 : ЁЭФ╕ := y * y * (z - x) with hs9
    set s10 : ЁЭФ╕ := -(y * (z - x) * y) with hs10
    set s11 : ЁЭФ╕ := -(y * (z - x) * y) with hs11
    set s12 : ЁЭФ╕ := (z - x) * y * y with hs12
    have a11 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11) s12
    have a10 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10) s11
    have a9 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9) s10
    have a8 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8) s9
    have a7 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7) s8
    have a6 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6) s7
    have a5 := norm_add_le (s1 + s2 + s3 + s4 + s5) s6
    have a4 := norm_add_le (s1 + s2 + s3 + s4) s5
    have a3 := norm_add_le (s1 + s2 + s3) s4
    have a2 := norm_add_le (s1 + s2) s3
    have a1 := norm_add_le s1 s2
    -- Norms of the negated summands equal norms of unnegated; bound each by M┬▓┬╖d.
    have hs1_le : тАЦs1тАЦ тЙд M ^ 2 * d := h1
    have hs2_le : тАЦs2тАЦ тЙд M ^ 2 * d := h2
    have hs3_le : тАЦs3тАЦ тЙд M ^ 2 * d := by rw [hs3, norm_neg]; exact h3
    have hs4_le : тАЦs4тАЦ тЙд M ^ 2 * d := by rw [hs4, norm_neg]; exact h3
    have hs5_le : тАЦs5тАЦ тЙд M ^ 2 * d := by rw [hs5, norm_neg]; exact h4
    have hs6_le : тАЦs6тАЦ тЙд M ^ 2 * d := by rw [hs6, norm_neg]; exact h4
    have hs7_le : тАЦs7тАЦ тЙд M ^ 2 * d := h5
    have hs8_le : тАЦs8тАЦ тЙд M ^ 2 * d := h6
    have hs9_le : тАЦs9тАЦ тЙд M ^ 2 * d := h7
    have hs10_le : тАЦs10тАЦ тЙд M ^ 2 * d := by rw [hs10, norm_neg]; exact h8
    have hs11_le : тАЦs11тАЦ тЙд M ^ 2 * d := by rw [hs11, norm_neg]; exact h8
    have hs12_le : тАЦs12тАЦ тЙд M ^ 2 * d := h9
    linarith
  -- Step 5: Combine smul bound + sum bound
  have h12_inv : тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ = (12 : тДЭ)тБ╗┬╣ := by
    rw [norm_inv, RCLike.norm_ofNat]
  calc тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв SтАЦ тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦSтАЦ := norm_smul_le _ _
    _ = (12 : тДЭ)тБ╗┬╣ * тАЦSтАЦ := by rw [h12_inv]
    _ тЙд (12 : тДЭ)тБ╗┬╣ * (12 * (M ^ 2 * d)) := by
        apply mul_le_mul_of_nonneg_left hS_le (by norm_num)
    _ = M ^ 2 * d := by ring

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **CтВГ LQ decomposition** (T2-F7e Phase E.2 helper):
    `CтВГ(x+W, y) тИТ CтВГ(x, y) = (1/12) ┬╖ L_C3(x, W, y) + (1/12) ┬╖ Q_C3(W, y)`
where `L_C3` is linear in W and `Q_C3` is quadratic in W.

This is a more granular form of the telescoping identity in
`norm_bch_cubic_term_diff_le`: separating linear-in-W from quadratic-in-W
contributions of the difference. Used to extract the deg-5 (linear-in-W
when W=O(s┬▓)) and deg-6+ (quadratic) parts of the cubic term difference
for the parent T2-F7e discharge.

The L_C3 shape matches the cubic template's `L_W` (in Basic.lean's
`norm_symmetric_bch_cubic_sub_poly_le`) with `x тЙб a'+b`, `y тЙб a'`,
giving `L_W = L_C3(a'+b, W, a')`. -/
theorem bch_cubic_term_LQ_decomp (x W y : ЁЭФ╕) :
    bch_cubic_term ЁЭХВ (x + W) y - bch_cubic_term ЁЭХВ x y =
      (12 : ЁЭХВ)тБ╗┬╣ тАв (
        -- Linear in W (9 distinct terms; "- X - X" written as -2┬╖X equivalent).
        x * W * y + W * x * y - x * y * W - x * y * W - W * y * x - W * y * x +
        y * x * W + y * W * x + y * y * W - y * W * y - y * W * y + W * y * y) +
      (12 : ЁЭХВ)тБ╗┬╣ тАв (
        -- Quadratic in W (3 distinct terms).
        W * W * y - W * y * W - W * y * W + y * W * W) := by
  unfold bch_cubic_term
  simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm,
    smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
  match_scalars <;> ring

/-- The degree-4 BCH term: `-(1/24)тБЕb,тБЕa,тБЕa,bтБЖтБЖтБЖ`.

This is the quartic correction in the BCH expansion:
`bch(a,b) = a + b + ┬╜[a,b] + bch_cubic_term a b + bch_quartic_term a b + O(sтБ╡)`.

The 4th BCH coefficient ZтВД = -(1/24)[b,[a,[a,b]]], verified by direct computation:
the degree-4 part of y-y┬▓/2+y┬│/3-yтБ┤/4 (where y=exp(a)exp(b)-1) equals this expression.

Note: in the free Lie algebra, [b,[a,[a,b]]]+[a,[b,[b,a]]] = 0 (identity in any associative
algebra), so ZтВД = -(1/24)[b,[a,[a,b]]] = (1/24)[a,[b,[b,a]]]. -/
noncomputable def bch_quartic_term (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) : ЁЭФ╕ :=
  -((24 : ЁЭХВ)тБ╗┬╣ тАв (b * (a * (a * b - b * a) - (a * b - b * a) * a) -
    (a * (a * b - b * a) - (a * b - b * a) * a) * b))

