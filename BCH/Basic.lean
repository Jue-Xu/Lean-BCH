      _ ‚â§ ‚Äñz‚Äñ ^ 2 * ‚ÄñP - T‚ÇÇ‚Äñ := by gcongr; exact norm_pow_le z 2
      _ ‚â§ s ^ 2 * (5 * s ^ 3) := mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
          hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have h3 : ‚Äñz * (P - T‚ÇÇ) * z‚Äñ ‚â§ s * (5 * s ^ 3) * s :=
    calc _ ‚â§ ‚Äñz * (P - T‚ÇÇ)‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñz‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ) * ‚Äñz‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s * (5 * s ^ 3)) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul hzn hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have h4 : ‚ÄñP * z * P‚Äñ ‚â§ s ^ 2 * s * s ^ 2 :=
    calc _ ‚â§ ‚ÄñP * z‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 2 * s) * s ^ 2 := by
          apply mul_le_mul _ hP (norm_nonneg _) (by positivity)
          exact mul_le_mul hP hzn (norm_nonneg _) (by positivity)
  have h5 : ‚ÄñP ^ 2 * z‚Äñ ‚â§ (s ^ 2) ^ 2 * s :=
    calc _ ‚â§ ‚ÄñP ^ 2‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ ^ 2 * ‚Äñz‚Äñ := by gcongr; exact norm_pow_le P 2
      _ ‚â§ (s ^ 2) ^ 2 * s := mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 2)
