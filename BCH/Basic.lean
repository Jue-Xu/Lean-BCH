      c ^ 7 ‚Ä¢ (x‚ÇÅ * x‚ÇÇ * x‚ÇÉ * x‚ÇÑ * x‚ÇÖ * x‚ÇÜ * x‚Çá) := by
  simp only [smul_mul_assoc, mul_smul_comm, smul_smul, ‚Üê mul_assoc]
