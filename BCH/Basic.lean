  have hCтВЖ : тАЦbch_sextic_term ЁЭХВ a bтАЦ тЙд s ^ 6 := norm_bch_sextic_term_le a b
  -- Algebraic split: LHS_septic = LHS_sextic - bch_sextic_term
  have hLHS_eq : bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b =
      (bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
       bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
       bch_quintic_term ЁЭХВ a b) - bch_sextic_term ЁЭХВ a b := by abel
  -- тАЦLHS_septicтАЦ тЙд 100000┬╖sтБ╢/(2-exp(s)) + sтБ╢ тЙд 100001┬╖sтБ╢/(2-exp(s))
  have hLHS_100001 : тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a bтАЦ тЙд
      100001 * s ^ 6 / (2 - Real.exp s) := by
    rw [hLHS_eq]
    calc _ тЙд тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
          bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
          bch_quintic_term ЁЭХВ a bтАЦ + тАЦbch_sextic_term ЁЭХВ a bтАЦ := norm_sub_le _ _
      _ тЙд 100000 * s ^ 6 / (2 - Real.exp s) + s ^ 6 := by linarith
      _ тЙд 100000 * s ^ 6 / (2 - Real.exp s) + s ^ 6 / (2 - Real.exp s) := by
          gcongr; rw [le_div_iffтВА hdenom]
          nlinarith [pow_nonneg hs_nn 6]
      _ = 100001 * s ^ 6 / (2 - Real.exp s) := by ring
  -- Bound 100001┬╖sтБ╢ тЙд 1000010┬╖sтБ╖ via 100001 тЙд 1000010┬╖s (using s тЙе 1/10)
  have h_le : 100001 * s ^ 6 тЙд 1000010 * s ^ 7 := by
    have h100001 : (100001 : тДЭ) тЙд 1000010 * s := by linarith
    nlinarith [pow_nonneg hs_nn 6]
  calc _ тЙд 100001 * s ^ 6 / (2 - Real.exp s) := hLHS_100001
    _ тЙд 1000010 * s ^ 7 / (2 - Real.exp s) :=
        div_le_div_of_nonneg_right h_le hdenom.le

include ЁЭХВ in
/-- **Eighth-order BCH remainder, large-s case** (private helper for the future
`norm_bch_octic_remainder_le`).

Crude bound for `тАЦaтАЦ+тАЦbтАЦ тЙе 1/10`: combines `norm_bch_septic_remainder_large_s_le`
with `тАЦbch_septic_termтАЦ тЙд sтБ╖` to give

  `тАЦLHS_octicтАЦ тЙд 1000011┬╖sтБ╖/(2-exp(s)) тЙд 10000110┬╖sтБ╕/(2-exp(s))`

(since `1000011 тЙд 10000110┬╖s` when `s тЙе 1/10`).

This is the crude case of the full octic remainder theorem. The full
theorem requires the small-s analytic case (`s < 1/10`), which will use
`octic_pure_identity` for the deg-7 cancellation (analog of the septic
remainder pattern).

Foundation for stepping stone 1 (`symmetric_bch_septic_sub_poly_axiom`)
discharge тАФ the deg-9 analog of T2-F7e Phase A. -/
private theorem norm_bch_octic_remainder_large_s_le (a b : ЁЭФ╕)
    (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) (hs_large : 1 / 10 тЙд тАЦaтАЦ + тАЦbтАЦ) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b -
      bch_septic_term ЁЭХВ a bтАЦ тЙд
      10000110 * (тАЦaтАЦ + тАЦbтАЦ) ^ 8 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  have hs_nn : 0 тЙд s := by positivity
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hdenom_le1 : 2 - Real.exp s тЙд 1 := by linarith [Real.add_one_le_exp s]
  have hRтВЖ := norm_bch_septic_remainder_large_s_le (ЁЭХВ := ЁЭХВ) a b hab hs_large
  have hZтВЗ : тАЦbch_septic_term ЁЭХВ a bтАЦ тЙд s ^ 7 := norm_bch_septic_term_le a b
  -- Algebraic split: LHS_octic = LHS_septic - bch_septic_term
  have hLHS_eq : bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b -
      bch_septic_term ЁЭХВ a b =
      (bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
       bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
       bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b) -
      bch_septic_term ЁЭХВ a b := by abel
  -- тАЦLHS_octicтАЦ тЙд 1000010┬╖sтБ╖/(2-exp(s)) + sтБ╖ тЙд 1000011┬╖sтБ╖/(2-exp(s))
  have hLHS_1000011 : тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b -
      bch_septic_term ЁЭХВ a bтАЦ тЙд
      1000011 * s ^ 7 / (2 - Real.exp s) := by
    rw [hLHS_eq]
    calc _ тЙд тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
          bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
          bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a bтАЦ +
          тАЦbch_septic_term ЁЭХВ a bтАЦ := norm_sub_le _ _
      _ тЙд 1000010 * s ^ 7 / (2 - Real.exp s) + s ^ 7 := by linarith
      _ тЙд 1000010 * s ^ 7 / (2 - Real.exp s) + s ^ 7 / (2 - Real.exp s) := by
          gcongr; rw [le_div_iffтВА hdenom]
          nlinarith [pow_nonneg hs_nn 7]
      _ = 1000011 * s ^ 7 / (2 - Real.exp s) := by ring
  -- Bound 1000011┬╖sтБ╖ тЙд 10000110┬╖sтБ╕ via 1000011 тЙд 10000110┬╖s (using s тЙе 1/10)
  have h_le : 1000011 * s ^ 7 тЙд 10000110 * s ^ 8 := by
    have h1000011 : (1000011 : тДЭ) тЙд 10000110 * s := by linarith
    nlinarith [pow_nonneg hs_nn 7]
  calc _ тЙд 1000011 * s ^ 7 / (2 - Real.exp s) := hLHS_1000011
    _ тЙд 10000110 * s ^ 8 / (2 - Real.exp s) :=
