/-- **Homogeneity of bch_quartic_term**: CтВД(c┬╖a, c┬╖b) = cтБ┤┬╖CтВД(a,b).
This is the key property for extracting the quartic term from the BCH expansion. -/
theorem bch_quartic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_quartic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 4 тАв bch_quartic_term ЁЭХВ a b := by
  unfold bch_quartic_term
  simp only [smul_mul_assoc, mul_smul_comm, smul_sub, mul_sub, sub_mul, smul_smul,
    smul_neg, neg_inj]
  congr 1; congr 1
  all_goals (try (congr 1; ring)); try ring

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- Norm bound for bch_quartic_term: `тАЦCтВД(a,b)тАЦ тЙд sтБ┤`.
The new definition CтВД = -(1/24)[b,[a,[a,b]]] is a single triple commutator,
so the bound is тАЦ(1/24)┬╖2╬▓┬╖4╬▒┬▓╬▓тАЦ = (1/3)╬▒┬▓╬▓┬▓ тЙд sтБ┤. -/
theorem norm_bch_quartic_term_le (a b : ЁЭФ╕) :
    тАЦbch_quartic_term ЁЭХВ a bтАЦ тЙд (тАЦaтАЦ + тАЦbтАЦ) ^ 4 := by
  set s := тАЦaтАЦ + тАЦbтАЦ
  have ha := norm_nonneg a
  have hb := norm_nonneg b
  have h24 : тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ тЙд 1 := by
    rw [norm_inv, RCLike.norm_ofNat]; norm_num
  -- Double commutator bound: тАЦ[a,[a,b]]тАЦ тЙд 4╬▒┬▓╬▓
  have hab_comm : тАЦa * b - b * aтАЦ тЙд 2 * тАЦaтАЦ * тАЦbтАЦ := by
    calc _ тЙд тАЦa * bтАЦ + тАЦb * aтАЦ := norm_sub_le _ _
      _ тЙд тАЦaтАЦ * тАЦbтАЦ + тАЦbтАЦ * тАЦaтАЦ := by gcongr <;> exact norm_mul_le _ _
      _ = _ := by ring
  have hA_dc : тАЦa * (a * b - b * a) - (a * b - b * a) * aтАЦ тЙд 4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ := by
    calc _ тЙд тАЦa * (a * b - b * a)тАЦ + тАЦ(a * b - b * a) * aтАЦ := norm_sub_le _ _
      _ тЙд тАЦaтАЦ * (2 * тАЦaтАЦ * тАЦbтАЦ) + (2 * тАЦaтАЦ * тАЦbтАЦ) * тАЦaтАЦ := by
          gcongr
          ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_left hab_comm ha)
          ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hab_comm ha)
      _ = _ := by ring
  -- Triple commutator: тАЦ[b,[a,[a,b]]]тАЦ = тАЦb┬╖DC_a-DC_a┬╖bтАЦ тЙд 8╬▒┬▓╬▓┬▓
  show тАЦbch_quartic_term ЁЭХВ a bтАЦ тЙд s ^ 4
  unfold bch_quartic_term
  set DC_a := a * (a * b - b * a) - (a * b - b * a) * a
  have hB_tc : тАЦb * DC_a - DC_a * bтАЦ тЙд 8 * тАЦaтАЦ ^ 2 * тАЦbтАЦ ^ 2 := by
    calc _ тЙд тАЦb * DC_aтАЦ + тАЦDC_a * bтАЦ := norm_sub_le _ _
      _ тЙд тАЦbтАЦ * тАЦDC_aтАЦ + тАЦDC_aтАЦ * тАЦbтАЦ := by gcongr <;> exact norm_mul_le _ _
      _ тЙд тАЦbтАЦ * (4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ) + (4 * тАЦaтАЦ ^ 2 * тАЦbтАЦ) * тАЦbтАЦ := by gcongr
      _ = _ := by ring
  calc тАЦ-((24 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b))тАЦ
      = тАЦ(24 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b)тАЦ := norm_neg _
    _ тЙд тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦb * DC_a - DC_a * bтАЦ := norm_smul_le _ _
    _ тЙд 1 * (8 * тАЦaтАЦ ^ 2 * тАЦbтАЦ ^ 2) := by gcongr
    _ = 8 * тАЦaтАЦ ^ 2 * тАЦbтАЦ ^ 2 := one_mul _
    _ тЙд s ^ 4 := by
        -- 8╬▒┬▓╬▓┬▓ тЙд (╬▒+╬▓)тБ┤ since ╬▒╬▓ тЙд (╬▒+╬▓)┬▓/4 тЖТ ╬▒┬▓╬▓┬▓ тЙд sтБ┤/16 тЖТ 8╬▒┬▓╬▓┬▓ тЙд sтБ┤/2
        have hab : тАЦaтАЦ * тАЦbтАЦ тЙд s ^ 2 / 4 := by nlinarith [sq_nonneg (тАЦaтАЦ - тАЦbтАЦ)]
        have hab2 : тАЦaтАЦ ^ 2 * тАЦbтАЦ ^ 2 тЙд s ^ 4 / 16 := by
          have h1 : (тАЦaтАЦ * тАЦbтАЦ) ^ 2 тЙд (s ^ 2 / 4) ^ 2 :=
            sq_le_sq' (by nlinarith) hab
          nlinarith [h1]
        nlinarith

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **CтВД LQ decomposition** (T2-F7e Phase E.2 step 3 helper):
    `CтВД(x+W, y) тИТ CтВД(x, y) = (1/24) ┬╖ L_C4(x, W, y) + (1/24) ┬╖ Q_C4(W, y)`
where L_C4 is linear in W and Q_C4 is quadratic in W.

Analog of `bch_cubic_term_LQ_decomp` for the deg-4 BCH term. Used to
extract the deg-4 (linear-in-W with W=VтВВ) and deg-6 (linear-in-W with
W=VтВГ + quadratic-in-W with W=VтВВ) leading parts of TтВЖ for the Phase E.2
discharge of R_T6_sept.

Recall `CтВД(z, y) = (1/24)┬╖(zzyy - 2┬╖zyzy + 2┬╖yzyz - yyzz)`. After the
substitution `z := x + W` and subtracting `CтВД(x, y)`, the result has
linear-in-W (8 sub-terms) and quadratic-in-W (4 sub-terms) pieces. -/
theorem bch_quartic_term_LQ_decomp (x W y : ЁЭФ╕) :
    bch_quartic_term ЁЭХВ (x + W) y - bch_quartic_term ЁЭХВ x y =
      (24 : ЁЭХВ)тБ╗┬╣ тАв (
        -- Linear in W (12 sub-terms with multiplicities; coefficients ┬▒1, ┬▒2).
        x * W * y * y + W * x * y * y - x * y * W * y - x * y * W * y -
        W * y * x * y - W * y * x * y +
        y * W * y * x + y * W * y * x + y * x * y * W + y * x * y * W -
        y * y * x * W - y * y * W * x) +
      (24 : ЁЭХВ)тБ╗┬╣ тАв (
        -- Quadratic in W (6 sub-terms with multiplicities).
        W * W * y * y - W * y * W * y - W * y * W * y +
        y * W * y * W + y * W * y * W - y * y * W * W) := by
  unfold bch_quartic_term
  simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm,
    smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, neg_neg, neg_mul, mul_neg,
    sub_neg_eq_add, тЖР mul_assoc]
  match_scalars <;> ring

/-! ### Fifth-order BCH term (ZтВЕ) -/

/-- **Sign-1 group** of `bch_quintic_term`: the four 5-letter words with
  absolute coefficient 1 (the "almost-pure" pattern AAAAB / ABBBB / BAAAA /
  BBBBA). Each appears with coefficient -1/720 in ZтВЕ.

  Factored separately to keep the proofs of `bch_quintic_term_smul` and
  `norm_bch_quintic_term_le` tractable. -/
noncomputable def bch_quintic_group_1 {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕]
    (a b : ЁЭФ╕) : ЁЭФ╕ :=
  a * a * a * a * b + a * b * b * b * b + b * a * a * a * a + b * b * b * b * a

/-- **Sign-4 group** of `bch_quintic_term`: the ten 5-letter words with
  absolute coefficient 4. Each appears with coefficient +4/720 = 1/180. -/
noncomputable def bch_quintic_group_4 {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕]
    (a b : ЁЭФ╕) : ЁЭФ╕ :=
  a * a * a * b * a + a * a * a * b * b + a * a * b * b * b +
  a * b * a * a * a + a * b * b * b * a + b * a * a * a * b +
  b * a * b * b * b + b * b * a * a * a + b * b * b * a * a +
  b * b * b * a * b

/-- **Sign-6 group** of `bch_quintic_term`: the fourteen 5-letter words
  with absolute coefficient 6. Each appears with coefficient -6/720 = -1/120. -/
noncomputable def bch_quintic_group_6 {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕]
    (a b : ЁЭФ╕) : ЁЭФ╕ :=
  a * a * b * a * a + a * a * b * a * b + a * a * b * b * a +
  a * b * a * a * b + a * b * a * b * b + a * b * b * a * a +
  a * b * b * a * b + b * a * a * b * a + b * a * a * b * b +
  b * a * b * a * a + b * a * b * b * a + b * b * a * a * b +
  b * b * a * b * a + b * b * a * b * b

/-- **Sign-24 group** of `bch_quintic_term`: the two 5-letter palindromic
  words with absolute coefficient 24. Each appears with coefficient
  +24/720 = 1/30. -/
noncomputable def bch_quintic_group_24 {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕]
    (a b : ЁЭФ╕) : ЁЭФ╕ :=
  a * b * a * b * a + b * a * b * a * b

/-- The degree-5 BCH term: ╧ДтБ╡ coefficient of `bch(a,b) = log(exp(a)┬╖exp(b))`.

Extracted symbolically by `Lean-Trotter/scripts/extract_bch_z5.py` from the
truncated NC-polynomial expansion of `log(1 + (exp(a)┬╖exp(b) - 1))` to
degree 5. Has 30 non-zero 5-letter words on `{a, b}`; the only words that
do NOT appear are the pure `aaaaa` and `bbbbb` (since `bch(a, 0) = a` and
`bch(0, b) = b` have no quintic correction). LCM of denominators is 720.

Decomposed into four `bch_quintic_group_n` pieces grouped by absolute
coefficient (n тИИ {1, 4, 6, 24}) for clean smul and norm bookkeeping.

This is the next term in the expansion:
`bch(a,b) = a + b + ┬╜[a,b] + bch_cubic_term + bch_quartic_term +
  bch_quintic_term + O(sтБ╢)`. -/
noncomputable def bch_quintic_term (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) : ЁЭФ╕ :=
  (720 : ЁЭХВ)тБ╗┬╣ тАв (
    -bch_quintic_group_1 a b
    + (4 : ЁЭХВ) тАв bch_quintic_group_4 a b
    - (6 : ЁЭХВ) тАв bch_quintic_group_6 a b
    + (24 : ЁЭХВ) тАв bch_quintic_group_24 a b
  )

