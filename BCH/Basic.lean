  have ha1 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ) + T‚ÇÉ * z * T‚ÇÉ + T‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ) +
    (P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÇ + (P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÉ) ((P - T‚ÇÇ - T‚ÇÉ) * z * (P - T‚ÇÇ - T‚ÇÉ))
  have ha2 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ) + T‚ÇÉ * z * T‚ÇÉ + T‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ) +
    (P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÇ) ((P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÉ)
  have ha3 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ) + T‚ÇÉ * z * T‚ÇÉ + T‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ))
    ((P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÇ)
  have ha4 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ) + T‚ÇÉ * z * T‚ÇÉ) (T‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ))
  have ha5 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ)) (T‚ÇÉ * z * T‚ÇÉ)
  -- Sum of bounds: 5s‚Å∑ + s‚Å∑ + 5s‚Å∏ + 5s‚Å∑ + 5s‚Å∏ + 25s‚Åπ = 11s‚Å∑ + 10s‚Å∏ + 25s‚Åπ.
  -- For s ‚â§ 1/10: ‚â§ 11s‚Å∑ + 1¬∑s‚Å∑ + 0.25¬∑s‚Å∑ = 12.25¬∑s‚Å∑ ‚â§ 13¬∑s‚Å∑.
  nlinarith [pow_nonneg hs_nn 7, pow_nonneg hs_nn 8, pow_nonneg hs_nn 9,
    mul_nonneg (pow_nonneg hs_nn 7) hs_nn,
    mul_nonneg (pow_nonneg hs_nn 7) (sq_nonneg s)]

set_option maxHeartbeats 4000000 in
/-- **Combined tricky bound** for the I1 septic residual.
The sum of the three "tricky" pieces `(z¬∑R+R¬∑z) + T22 + T_extra`
where T22 = T‚ÇÇ¬≤ - P¬≤ + T‚ÇÇT‚ÇÉ + T‚ÇÉT‚ÇÇ and T_extra = z¬∑T‚ÇÖ + T‚ÇÇT‚ÇÑ + T‚ÇÉ¬≤ + T‚ÇÑT‚ÇÇ + T‚ÇÖz.
Individually, each piece is deg-6, NOT deg-7 ‚Äî but the SUM is deg-7+ via:
- `R‚ÇÖ = -T‚ÇÖ` (deg-5 cancellation): combining z¬∑R+R¬∑z with z¬∑T‚ÇÖ+T‚ÇÖz gives
  z¬∑(R+T‚ÇÖ) + (R+T‚ÇÖ)¬∑z, which is deg-7+ via `‚ÄñR+T‚ÇÖ‚Äñ ‚â§ 6¬∑s‚Å∂`.
- Algebraic identity `P¬≤ = T‚ÇÇ¬≤ + (T‚ÇÇT‚ÇÉ+T‚ÇÉT‚ÇÇ) + (T‚ÇÇT‚ÇÑ+T‚ÇÉ¬≤+T‚ÇÑT‚ÇÇ) + P¬≤_deg‚â•7`:
  the deg-‚â§6 contributions of T22 + T_extra cancel with the deg-‚â§6 of P¬≤,
  leaving -P¬≤_deg‚â•7 which is deg-7+ via D‚ÇÖ := P-T‚ÇÇ-T‚ÇÉ-T‚ÇÑ.

Bound: ‚Äñcombined‚Äñ ‚â§ 12¬∑s‚Å∑ (z¬∑(R+T‚ÇÖ) part) + ~16¬∑s‚Å∑ (P¬≤_deg‚â•7) ‚â§ 28¬∑s‚Å∑
for `s ‚â§ 1/10`. -/
private theorem norm_combined_tricky_le (z P R T‚ÇÇ T‚ÇÉ T‚ÇÑ T‚ÇÖ : ùî∏) {s : ‚Ñù}
    (hs_nn : 0 ‚â§ s) (hs_small : s ‚â§ 1 / 10)
    (hz : ‚Äñz‚Äñ ‚â§ s) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2) (hT‚ÇÉ : ‚ÄñT‚ÇÉ‚Äñ ‚â§ s ^ 3)
    (hT‚ÇÑ : ‚ÄñT‚ÇÑ‚Äñ ‚â§ s ^ 4)
    (hRT5 : ‚ÄñR + T‚ÇÖ‚Äñ ‚â§ 6 * s ^ 6)
    (hD5 : ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ‚Äñ ‚â§ 6 * s ^ 5) :
    ‚Äñz * R + R * z + (T‚ÇÇ ^ 2 - P ^ 2 + T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ) +
      (z * T‚ÇÖ + T‚ÇÇ * T‚ÇÑ + T‚ÇÉ * T‚ÇÉ + T‚ÇÑ * T‚ÇÇ + T‚ÇÖ * z)‚Äñ ‚â§ 28 * s ^ 7 := by
  -- Algebraic identity: combined = z¬∑(R+T‚ÇÖ) + (R+T‚ÇÖ)¬∑z - P¬≤_deg‚â•7,
  -- where P¬≤_deg‚â•7 unfolds via D‚ÇÖ = P-T‚ÇÇ-T‚ÇÉ-T‚ÇÑ.
  have heq : z * R + R * z + (T‚ÇÇ ^ 2 - P ^ 2 + T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ) +
      (z * T‚ÇÖ + T‚ÇÇ * T‚ÇÑ + T‚ÇÉ * T‚ÇÉ + T‚ÇÑ * T‚ÇÇ + T‚ÇÖ * z) =
      z * (R + T‚ÇÖ) + (R + T‚ÇÖ) * z -
      (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
        (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 +
        T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ +
        T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÑ +
        (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) ^ 2) := by
    noncomm_ring
  rw [heq]
  -- z¬∑(R+T‚ÇÖ) and (R+T‚ÇÖ)¬∑z bounds (each ‚â§ 6¬∑s‚Å∑).
  have h_zRT5 : ‚Äñz * (R + T‚ÇÖ)‚Äñ ‚â§ s * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hz hRT5 (norm_nonneg _) hs_nn)
  have h_RT5z : ‚Äñ(R + T‚ÇÖ) * z‚Äñ ‚â§ (6 * s ^ 6) * s :=
    (norm_mul_le _ _).trans (mul_le_mul hRT5 hz (norm_nonneg _) (by positivity))
  -- 10 components of P¬≤_deg‚â•7
  have h_T3T4 : ‚ÄñT‚ÇÉ * T‚ÇÑ‚Äñ ‚â§ s ^ 3 * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÉ hT‚ÇÑ (norm_nonneg _) (by positivity))
  have h_T4T3 : ‚ÄñT‚ÇÑ * T‚ÇÉ‚Äñ ‚â§ s ^ 4 * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÑ hT‚ÇÉ (norm_nonneg _) (by positivity))
  have h_T2D5 : ‚ÄñT‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ)‚Äñ ‚â§ s ^ 2 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÇ hD5 (norm_nonneg _) (by positivity))
  have h_D5T2 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ‚Äñ ‚â§ (6 * s ^ 5) * s ^ 2 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hT‚ÇÇ (norm_nonneg _) (by positivity))
  have h_T4_2 : ‚ÄñT‚ÇÑ ^ 2‚Äñ ‚â§ s ^ 4 * s ^ 4 :=
    calc _ ‚â§ ‚ÄñT‚ÇÑ‚Äñ ^ 2 := norm_pow_le _ _
      _ ‚â§ (s ^ 4) ^ 2 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hT‚ÇÑ 2
      _ = s ^ 4 * s ^ 4 := by ring
  have h_T3D5 : ‚ÄñT‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ)‚Äñ ‚â§ s ^ 3 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÉ hD5 (norm_nonneg _) (by positivity))
  have h_D5T3 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ‚Äñ ‚â§ (6 * s ^ 5) * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hT‚ÇÉ (norm_nonneg _) (by positivity))
  have h_T4D5 : ‚ÄñT‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ)‚Äñ ‚â§ s ^ 4 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÑ hD5 (norm_nonneg _) (by positivity))
  have h_D5T4 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÑ‚Äñ ‚â§ (6 * s ^ 5) * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hT‚ÇÑ (norm_nonneg _) (by positivity))
  have h_D5_2 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) ^ 2‚Äñ ‚â§ (6 * s ^ 5) ^ 2 :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ‚Äñ ^ 2 := norm_pow_le _ _
      _ ‚â§ (6 * s ^ 5) ^ 2 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hD5 2
  -- Triangle inequality: ‚ÄñA - B‚Äñ ‚â§ ‚ÄñA‚Äñ + ‚ÄñB‚Äñ.
  have h_main := norm_sub_le (z * (R + T‚ÇÖ) + (R + T‚ÇÖ) * z)
    (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 +
     T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ +
     T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÑ + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) ^ 2)
  -- A = z¬∑(R+T‚ÇÖ) + (R+T‚ÇÖ)¬∑z ‚â§ 12¬∑s‚Å∑
  have hA := norm_add_le (z * (R + T‚ÇÖ)) ((R + T‚ÇÖ) * z)
  -- B = sum of 10 terms ‚â§ ~16¬∑s‚Å∑ for s ‚â§ 1/10
  have hB1 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 + T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ + T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÑ) ((P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) ^ 2)
  have hB2 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 + T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ + T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
    ((P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÑ)
  have hB3 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 + T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ) (T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
  have hB4 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2 + T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
    ((P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÉ)
  have hB5 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ + T‚ÇÑ ^ 2) (T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
  have hB6 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ) (T‚ÇÑ ^ 2)
  have hB7 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
    ((P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * T‚ÇÇ)
  have hB8 := norm_add_le (T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ) (T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ))
  have hB9 := norm_add_le (T‚ÇÉ * T‚ÇÑ) (T‚ÇÑ * T‚ÇÉ)
  -- s‚Å∏ ‚â§ s‚Å∑/10, s‚Åπ ‚â§ s‚Å∑/100, s¬π‚Å∞ ‚â§ s‚Å∑/1000
  have hs8 : s ^ 8 ‚â§ s ^ 7 / 10 := by
    have h_eq : s ^ 8 = s ^ 7 * s := by ring
    rw [h_eq]; nlinarith [pow_nonneg hs_nn 7]
  have hs9 : s ^ 9 ‚â§ s ^ 7 / 100 := by
    have h_eq : s ^ 9 = s ^ 7 * (s * s) := by ring
    rw [h_eq]
    have hs2 : s * s ‚â§ 1 / 100 := by nlinarith
    nlinarith [pow_nonneg hs_nn 7]
  have hs10 : s ^ 10 ‚â§ s ^ 7 / 1000 := by
    have h_eq : s ^ 10 = s ^ 7 * (s * s * s) := by ring
    rw [h_eq]
    have hs3 : s * s * s ‚â§ 1 / 1000 := by nlinarith
    nlinarith [pow_nonneg hs_nn 7, mul_nonneg hs_nn hs_nn,
      mul_nonneg (mul_nonneg hs_nn hs_nn) hs_nn]
  -- Combined sum:
  -- A: 6¬∑s‚Å∑ + 6¬∑s‚Å∑ = 12¬∑s‚Å∑
  -- B: s‚Å∑ + s‚Å∑ + 6¬∑s‚Å∑ + 6¬∑s‚Å∑ + s‚Å∏ + 6¬∑s‚Å∏ + 6¬∑s‚Å∏ + 6¬∑s‚Åπ + 6¬∑s‚Åπ + 36¬∑s¬π‚Å∞
  --   = 14¬∑s‚Å∑ + 13¬∑s‚Å∏ + 12¬∑s‚Åπ + 36¬∑s¬π‚Å∞
  --   ‚â§ 14¬∑s‚Å∑ + 1.3¬∑s‚Å∑ + 0.12¬∑s‚Å∑ + 0.036¬∑s‚Å∑ ‚âà 15.5¬∑s‚Å∑ for s ‚â§ 1/10
  -- Total: ‚â§ 27.5 ‚Üí 28¬∑s‚Å∑
  nlinarith [pow_nonneg hs_nn 7]

set_option maxHeartbeats 4000000 in
/-- **Combined tricky bound (octic)** for the I1 octic residual.
The sum of the four "tricky" pieces `(z¬∑R+R¬∑z) + T22 + T_extra + T_extra2`
where
  - T22 = T‚ÇÇ¬≤ - P¬≤ + T‚ÇÇT‚ÇÉ + T‚ÇÉT‚ÇÇ
  - T_extra = z¬∑T‚ÇÖ + T‚ÇÇT‚ÇÑ + T‚ÇÉ¬≤ + T‚ÇÑT‚ÇÇ + T‚ÇÖz
  - T_extra2 = z¬∑T‚ÇÜ + T‚ÇÇT‚ÇÖ + T‚ÇÉT‚ÇÑ + T‚ÇÑT‚ÇÉ + T‚ÇÖT‚ÇÇ + T‚ÇÜz
Individually, each piece is deg-6 or deg-7, NOT deg-8 ‚Äî but the SUM is deg-8+ via:
- `R + T‚ÇÖ + T‚ÇÜ` is deg-7+ (`R_plus_T5_plus_T6_eq_neg_deg7_residual`): combining
  z¬∑R+R¬∑z with z¬∑T‚ÇÖ+T‚ÇÖz and z¬∑T‚ÇÜ+T‚ÇÜz gives z¬∑(R+T‚ÇÖ+T‚ÇÜ) + (R+T‚ÇÖ+T‚ÇÜ)¬∑z,
  which is deg-8+ via `‚ÄñR+T‚ÇÖ+T‚ÇÜ‚Äñ ‚â§ 7¬∑s‚Å∑`.
- Algebraic identity
  `P¬≤ = T‚ÇÇ¬≤ + (T‚ÇÇT‚ÇÉ+T‚ÇÉT‚ÇÇ) + (T‚ÇÇT‚ÇÑ+T‚ÇÉ¬≤+T‚ÇÑT‚ÇÇ) + (T‚ÇÇT‚ÇÖ+T‚ÇÉT‚ÇÑ+T‚ÇÑT‚ÇÉ+T‚ÇÖT‚ÇÇ) + P¬≤_deg‚â•8`:
  the deg-‚â§7 contributions of T22 + T_extra + T_extra2 cancel with the deg-‚â§7
  of P¬≤, leaving -P¬≤_deg‚â•8 (15 terms) which is deg-8+ via D‚ÇÜ := P-T‚ÇÇ-T‚ÇÉ-T‚ÇÑ-T‚ÇÖ.

Bound: ‚Äñcombined‚Äñ ‚â§ 14¬∑s‚Å∏ (z¬∑(R+T‚ÇÖ+T‚ÇÜ) part) + ~17¬∑s‚Å∏ (P¬≤_deg‚â•8) ‚â§ 35¬∑s‚Å∏
for `s ‚â§ 1/10`. Analog of `norm_combined_tricky_le` at one degree higher. -/
private theorem norm_combined_tricky_octic_le (z P R T‚ÇÇ T‚ÇÉ T‚ÇÑ T‚ÇÖ T‚ÇÜ : ùî∏) {s : ‚Ñù}
    (hs_nn : 0 ‚â§ s) (hs_small : s ‚â§ 1 / 10)
    (hz : ‚Äñz‚Äñ ‚â§ s) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2) (hT‚ÇÉ : ‚ÄñT‚ÇÉ‚Äñ ‚â§ s ^ 3)
    (hT‚ÇÑ : ‚ÄñT‚ÇÑ‚Äñ ‚â§ s ^ 4) (hT‚ÇÖ : ‚ÄñT‚ÇÖ‚Äñ ‚â§ s ^ 5)
    (hRT5T6 : ‚ÄñR + T‚ÇÖ + T‚ÇÜ‚Äñ ‚â§ 7 * s ^ 7)
    (hD6 : ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ ‚â§ 6 * s ^ 6) :
    ‚Äñz * R + R * z + (T‚ÇÇ ^ 2 - P ^ 2 + T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ) +
      (z * T‚ÇÖ + T‚ÇÇ * T‚ÇÑ + T‚ÇÉ * T‚ÇÉ + T‚ÇÑ * T‚ÇÇ + T‚ÇÖ * z) +
      (z * T‚ÇÜ + T‚ÇÇ * T‚ÇÖ + T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÖ * T‚ÇÇ + T‚ÇÜ * z)‚Äñ ‚â§ 35 * s ^ 8 := by
  -- Algebraic identity: combined = z¬∑(R+T‚ÇÖ+T‚ÇÜ) + (R+T‚ÇÖ+T‚ÇÜ)¬∑z - P¬≤_deg‚â•8,
  -- where P¬≤_deg‚â•8 unfolds via D‚ÇÜ = P-T‚ÇÇ-T‚ÇÉ-T‚ÇÑ-T‚ÇÖ (15 terms).
  have heq : z * R + R * z + (T‚ÇÇ ^ 2 - P ^ 2 + T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ) +
      (z * T‚ÇÖ + T‚ÇÇ * T‚ÇÑ + T‚ÇÉ * T‚ÇÉ + T‚ÇÑ * T‚ÇÇ + T‚ÇÖ * z) +
      (z * T‚ÇÜ + T‚ÇÇ * T‚ÇÖ + T‚ÇÉ * T‚ÇÑ + T‚ÇÑ * T‚ÇÉ + T‚ÇÖ * T‚ÇÇ + T‚ÇÜ * z) =
      z * (R + T‚ÇÖ + T‚ÇÜ) + (R + T‚ÇÖ + T‚ÇÜ) * z -
      (T‚ÇÉ * T‚ÇÖ + T‚ÇÖ * T‚ÇÉ + T‚ÇÑ ^ 2 +
        T‚ÇÑ * T‚ÇÖ + T‚ÇÖ * T‚ÇÑ + T‚ÇÖ ^ 2 +
        T‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * T‚ÇÇ +
        T‚ÇÉ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * T‚ÇÉ +
        T‚ÇÑ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * T‚ÇÑ +
        T‚ÇÖ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) + (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * T‚ÇÖ +
        (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) ^ 2) := by
    noncomm_ring
  rw [heq]
  -- z¬∑(R+T‚ÇÖ+T‚ÇÜ) and (R+T‚ÇÖ+T‚ÇÜ)¬∑z bounds (each ‚â§ 7¬∑s‚Å∏).
  have h_zRT5T6 : ‚Äñz * (R + T‚ÇÖ + T‚ÇÜ)‚Äñ ‚â§ s * (7 * s ^ 7) :=
    (norm_mul_le _ _).trans (mul_le_mul hz hRT5T6 (norm_nonneg _) hs_nn)
  have h_RT5T6z : ‚Äñ(R + T‚ÇÖ + T‚ÇÜ) * z‚Äñ ‚â§ (7 * s ^ 7) * s :=
    (norm_mul_le _ _).trans (mul_le_mul hRT5T6 hz (norm_nonneg _) (by positivity))
  -- 15 components of P¬≤_deg‚â•8
  have h_T3T5 : ‚ÄñT‚ÇÉ * T‚ÇÖ‚Äñ ‚â§ s ^ 3 * s ^ 5 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÉ hT‚ÇÖ (norm_nonneg _) (by positivity))
  have h_T5T3 : ‚ÄñT‚ÇÖ * T‚ÇÉ‚Äñ ‚â§ s ^ 5 * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÖ hT‚ÇÉ (norm_nonneg _) (by positivity))
  have h_T4_2 : ‚ÄñT‚ÇÑ ^ 2‚Äñ ‚â§ s ^ 4 * s ^ 4 :=
    calc _ ‚â§ ‚ÄñT‚ÇÑ‚Äñ ^ 2 := norm_pow_le _ _
      _ ‚â§ (s ^ 4) ^ 2 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hT‚ÇÑ 2
      _ = s ^ 4 * s ^ 4 := by ring
  have h_T4T5 : ‚ÄñT‚ÇÑ * T‚ÇÖ‚Äñ ‚â§ s ^ 4 * s ^ 5 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÑ hT‚ÇÖ (norm_nonneg _) (by positivity))
  have h_T5T4 : ‚ÄñT‚ÇÖ * T‚ÇÑ‚Äñ ‚â§ s ^ 5 * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÖ hT‚ÇÑ (norm_nonneg _) (by positivity))
  have h_T5_2 : ‚ÄñT‚ÇÖ ^ 2‚Äñ ‚â§ s ^ 5 * s ^ 5 :=
    calc _ ‚â§ ‚ÄñT‚ÇÖ‚Äñ ^ 2 := norm_pow_le _ _
      _ ‚â§ (s ^ 5) ^ 2 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hT‚ÇÖ 2
      _ = s ^ 5 * s ^ 5 := by ring
  have h_T2D6 : ‚ÄñT‚ÇÇ * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ)‚Äñ ‚â§ s ^ 2 * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hT‚ÇÇ hD6 (norm_nonneg _) (by positivity))
