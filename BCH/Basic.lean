    calc тАЦsymmetric_bch_cubic ЁЭХВ (c' тАв a) (c' тАв b) -
          c' ^ 3 тАв symmetric_bch_cubic ЁЭХВ a bтАЦ
        = тАЦ_ + _тАЦ := by rw [hD_decomp]
      _ тЙд тАЦsymmetric_bch_cubic ЁЭХВ (c' тАв a) (c' тАв b) -
            symmetric_bch_cubic_poly ЁЭХВ (c' тАв a) (c' тАв b)тАЦ +
          тАЦc' ^ 3 тАв (symmetric_bch_cubic_poly ЁЭХВ a b - symmetric_bch_cubic ЁЭХВ a b)тАЦ :=
            norm_add_le _ _
      _ тЙд 10000000 * (|c| * s) ^ 5 + |c| ^ 3 * (10000000 * s ^ 5) := by linarith
      _ тЙд 20000000 * |c| ^ 3 * s ^ 5 := by
          -- 10тБ╖┬╖|c|тБ╡┬╖sтБ╡ + 10тБ╖┬╖|c|┬│┬╖sтБ╡ тЙд 10тБ╖┬╖|c|┬│┬╖sтБ╡ + 10тБ╖┬╖|c|┬│┬╖sтБ╡ = 2┬╖10тБ╖┬╖|c|┬│┬╖sтБ╡
          have hc5_le_c3 : |c| ^ 5 тЙд |c| ^ 3 := by
            have h_c2 : |c| ^ 2 тЙд 1 := by
              calc |c| ^ 2 тЙд 1 ^ 2 := by gcongr
                _ = 1 := one_pow _
            calc |c| ^ 5 = |c| ^ 3 * |c| ^ 2 := by ring
              _ тЙд |c| ^ 3 * 1 := by
                  apply mul_le_mul_of_nonneg_left h_c2 (pow_nonneg hc_nn 3)
              _ = |c| ^ 3 := mul_one _
          have hcs5 : (|c| * s) ^ 5 = |c| ^ 5 * s ^ 5 := by ring
          calc 10000000 * (|c| * s) ^ 5 + |c| ^ 3 * (10000000 * s ^ 5)
              = 10000000 * |c| ^ 5 * s ^ 5 + 10000000 * |c| ^ 3 * s ^ 5 := by rw [hcs5]; ring
            _ тЙд 10000000 * |c| ^ 3 * s ^ 5 + 10000000 * |c| ^ 3 * s ^ 5 := by
                gcongr
            _ = 20000000 * |c| ^ 3 * s ^ 5 := by ring

end

end BCH
