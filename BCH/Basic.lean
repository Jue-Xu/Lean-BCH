  have hs‚ÇÇ_lt_log2 : ‚Äñz‚Äñ + ‚Äña'‚Äñ < Real.log 2 := by
    calc ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ (s‚ÇÅ + 3 / 11) + ‚Äña'‚Äñ := by linarith [hz_le, hquad_bound]
      _ ‚â§ s + 3 / 11 := by linarith [ha'_le_s]
