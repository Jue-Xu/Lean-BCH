/-- **6-fold smul-product identity**: `(cтАвxтВБ)┬╖...┬╖(cтАвxтВЖ) = cтБ╢ тАв (xтВБ┬╖...┬╖xтВЖ)`. -/
private lemma six_fold_smul_mul (c : ЁЭХВ) (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ : ЁЭФ╕) :
    (c тАв xтВБ) * (c тАв xтВВ) * (c тАв xтВГ) * (c тАв xтВД) * (c тАв xтВЕ) * (c тАв xтВЖ) =
      c ^ 6 тАв (xтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ) := by
  simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
  congr 1; ring

