theorem norm_bch_quartic_remainder_le (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a bтАЦ тЙд
      200 * (тАЦaтАЦ + тАЦbтАЦ) ^ 4 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  -- SETUP: same as H1
  set y := exp a * exp b - 1 with hy_def
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  set ╬▒ := тАЦaтАЦ; set ╬▓ := тАЦbтАЦ
  have hs_nn : 0 тЙд s := by positivity
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have h╬▒_le : ╬▒ тЙд s := le_add_of_nonneg_right h╬▓_nn
  have h╬▓_le : ╬▓ тЙд s := le_add_of_nonneg_left h╬▒_nn
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hy_lt : тАЦyтАЦ < 1 := norm_exp_mul_exp_sub_one_lt_one (ЁЭХВ := ЁЭХВ) a b hab
  have hy_le : тАЦyтАЦ тЙд Real.exp s - 1 := by
    have : y = (exp a - 1) * exp b + (exp b - 1) := by rw [hy_def, sub_mul, one_mul]; abel
    calc тАЦyтАЦ = тАЦ(exp a - 1) * exp b + (exp b - 1)тАЦ := by rw [this]
      _ тЙд тАЦexp a - 1тАЦ * тАЦexp bтАЦ + тАЦexp b - 1тАЦ := by
          calc _ тЙд тАЦ(exp a - 1) * exp bтАЦ + _ := norm_add_le _ _
            _ тЙд _ := by gcongr; exact norm_mul_le _ _
      _ тЙд (Real.exp ╬▒ - 1) * Real.exp ╬▓ + (Real.exp ╬▓ - 1) := by
          apply add_le_add
          ┬╖ exact mul_le_mul (norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) a) (norm_exp_le (ЁЭХВ := ЁЭХВ) b)
              (norm_nonneg _) (by linarith [Real.add_one_le_exp ╬▒])
