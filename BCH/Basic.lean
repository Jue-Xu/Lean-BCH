/-- **6-fold smul-product identity**: `(c•x₁)·...·(c•x₆) = c⁶ • (x₁·...·x₆)`. -/
private lemma six_fold_smul_mul (c : 𝕂) (x₁ x₂ x₃ x₄ x₅ x₆ : 𝔸) :
    (c • x₁) * (c • x₂) * (c • x₃) * (c • x₄) * (c • x₅) * (c • x₆) =
      c ^ 6 • (x₁ * x₂ * x₃ * x₄ * x₅ * x₆) := by
  simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
  congr 1; ring

