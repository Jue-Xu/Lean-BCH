    nlinarith [hdтВБ, hdтВВ, hdтВГ, hdтВД, hdтВЕ, hdтВЖ, hdтВЗ, hdтВИ, hN7_nn]
  have hwd2 : тАЦxтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ*xтВИ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗ*yтВИтАЦ тЙд 8 * N^7 * D := le_trans hwd hwd_bound
  have h_pos : 0 тЙд 8 * N^7 * D := by positivity
  calc тАЦc тАв (xтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ*xтВИ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗ*yтВИ)тАЦ
