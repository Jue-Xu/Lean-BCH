  have ha6s : Œ± ^ 6 ‚â§ s ^ 6 := pow_le_pow_left‚ÇÄ hŒ±_nn hŒ±_le 6
  have hb6s : Œ≤ ^ 6 ‚â§ s ^ 6 := pow_le_pow_left‚ÇÄ hŒ≤_nn hŒ≤_le 6
  have ha5bs : Œ± ^ 5 * Œ≤ ‚â§ s ^ 6 := by
    calc Œ± ^ 5 * Œ≤ ‚â§ s ^ 5 * s := mul_le_mul (pow_le_pow_left‚ÇÄ hŒ±_nn hŒ±_le 5) hŒ≤_le
          hŒ≤_nn (by positivity)
