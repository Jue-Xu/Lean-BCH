  have ht1 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - T‚ÇÇ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - T‚ÇÇ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - T‚ÇÇ) * z ^ 2 +
    (y ^ 2 - z ^ 2) * P * z ^ 3 + z ^ 2 * (P - T‚ÇÇ) * z ^ 3 +
