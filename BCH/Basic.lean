set_option maxHeartbeats 400000 in
omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
/-- Word #2 (a¬∑a¬∑a¬∑b¬∑a¬∑b, 4 a-positions). -/
private lemma bch_sextic_word02_diff_le (z x y : ùî∏) :
    ‚Äñz * z * z * y * z * y - x * x * x * y * x * y‚Äñ ‚â§
      4 * (‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ) ^ 5 * ‚Äñz - x‚Äñ := by
  have htel : z * z * z * y * z * y - x * x * x * y * x * y =
      (z - x) * z * z * y * z * y + x * (z - x) * z * y * z * y +
      x * x * (z - x) * y * z * y + x * x * x * y * (z - x) * y := by
    noncomm_ring
  rw [htel]
  set M := ‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ
  have hz_le : ‚Äñz‚Äñ ‚â§ M := by
    show ‚Äñz‚Äñ ‚â§ ‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ; linarith [norm_nonneg x, norm_nonneg y]
  have hx_le : ‚Äñx‚Äñ ‚â§ M := by
    show ‚Äñx‚Äñ ‚â§ ‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ; linarith [norm_nonneg z, norm_nonneg y]
  have hy_le : ‚Äñy‚Äñ ‚â§ M := by
    show ‚Äñy‚Äñ ‚â§ ‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ; linarith [norm_nonneg z, norm_nonneg x]
  have h1 := norm_6prod_pos1_le z x y z z y z y hz_le hz_le hy_le hz_le hy_le
  have h2 := norm_6prod_pos2_le z x y x z y z y hx_le hz_le hy_le hz_le hy_le
  have h3 := norm_6prod_pos3_le z x y x x y z y hx_le hx_le hy_le hz_le hy_le
  have h5 := norm_6prod_pos5_le z x y x x x y y hx_le hx_le hx_le hy_le hy_le
  set s1 : ùî∏ := (z - x) * z * z * y * z * y
  set s2 : ùî∏ := x * (z - x) * z * y * z * y
  set s3 : ùî∏ := x * x * (z - x) * y * z * y
  set s4 : ùî∏ := x * x * x * y * (z - x) * y
  have a3 := norm_add_le (s1 + s2 + s3) s4
  have a2 := norm_add_le (s1 + s2) s3
  have a1 := norm_add_le s1 s2
  linarith

