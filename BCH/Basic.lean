        rw [hS_eq]
        have hEтВБ_s3 : тАЦEтВБтАЦ тЙд ╬▒ ^ 3 := le_trans hEтВБ_le hEa3
        have hEтВВ_s3 : тАЦEтВВтАЦ тЙд ╬▓ ^ 3 := le_trans hEтВВ_le hEb3
        have haDтВВ : тАЦa * DтВВтАЦ тЙд ╬▒ * ╬▓ ^ 2 :=
