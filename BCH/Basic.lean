/-- Norm bound `‚ÄñT‚Çá‚Äñ ‚â§ s‚Å∑` where
`T‚Çá = (1/5040)¬∑a‚Å∑ + (1/720)¬∑a‚Å∂b + (1/240)¬∑a‚Åµb¬≤ + (1/144)¬∑a‚Å¥b¬≥ +
      (1/144)¬∑a¬≥b‚Å¥ + (1/240)¬∑a¬≤b‚Åµ + (1/720)¬∑ab‚Å∂ + (1/5040)¬∑b‚Å∑`
is the deg-7 contribution of `exp(a)¬∑exp(b)-1`. Sum of |coefficients| =
(1+7+21+35+35+21+7+1)/5040 = 128/5040 ‚âà 0.0254, so `‚ÄñT‚Çá‚Äñ ‚â§ s‚Å∑`. -/
private theorem norm_T7_le (a b : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hŒ±_le : ‚Äña‚Äñ ‚â§ s) (hŒ≤_le : ‚Äñb‚Äñ ‚â§ s) :
    ‚Äñ(5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
      (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2) + (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3) +
      (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4) + (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 5) +
      (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 6) + (5040 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 7‚Äñ ‚â§ s ^ 7 := by
  set Œ± := ‚Äña‚Äñ
  set Œ≤ := ‚Äñb‚Äñ
  have hŒ±_nn : (0 : ‚Ñù) ‚â§ Œ± := norm_nonneg a
  have hŒ≤_nn : (0 : ‚Ñù) ‚â§ Œ≤ := norm_nonneg b
  have h144eq : ‚Äñ(144 : ùïÇ)‚Åª¬π‚Äñ = (144 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h240eq : ‚Äñ(240 : ùïÇ)‚Åª¬π‚Äñ = (240 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h720eq : ‚Äñ(720 : ùïÇ)‚Åª¬π‚Äñ = (720 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h5040eq : ‚Äñ(5040 : ùïÇ)‚Åª¬π‚Äñ = (5040 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  -- Per-coefficient bounds.
  have hT1 : ‚Äñ(5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7‚Äñ ‚â§ Œ± ^ 7 / 5040 :=
    calc _ ‚â§ ‚Äñ(5040 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 7‚Äñ := norm_smul_le _ _
      _ ‚â§ (5040 : ‚Ñù)‚Åª¬π * Œ± ^ 7 := by
          rw [h5040eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = Œ± ^ 7 / 5040 := by ring
  have hT2 : ‚Äñ(720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b)‚Äñ ‚â§ Œ± ^ 6 * Œ≤ / 720 :=
    calc _ ‚â§ ‚Äñ(720 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 6 * b‚Äñ := norm_smul_le _ _
      _ ‚â§ (720 : ‚Ñù)‚Åª¬π * (Œ± ^ 6 * Œ≤) := by
          rw [h720eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) le_rfl hŒ≤_nn
              (by positivity))) (by norm_num)
      _ = Œ± ^ 6 * Œ≤ / 720 := by ring
  have hT3 : ‚Äñ(240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2)‚Äñ ‚â§ Œ± ^ 5 * Œ≤ ^ 2 / 240 :=
    calc _ ‚â§ ‚Äñ(240 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 5 * b ^ 2‚Äñ := norm_smul_le _ _
      _ ‚â§ (240 : ‚Ñù)‚Åª¬π * (Œ± ^ 5 * Œ≤ ^ 2) := by
          rw [h240eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = Œ± ^ 5 * Œ≤ ^ 2 / 240 := by ring
  have hT4 : ‚Äñ(144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3)‚Äñ ‚â§ Œ± ^ 4 * Œ≤ ^ 3 / 144 :=
    calc _ ‚â§ ‚Äñ(144 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 4 * b ^ 3‚Äñ := norm_smul_le _ _
      _ ‚â§ (144 : ‚Ñù)‚Åª¬π * (Œ± ^ 4 * Œ≤ ^ 3) := by
          rw [h144eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = Œ± ^ 4 * Œ≤ ^ 3 / 144 := by ring
  have hT5 : ‚Äñ(144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4)‚Äñ ‚â§ Œ± ^ 3 * Œ≤ ^ 4 / 144 :=
    calc _ ‚â§ ‚Äñ(144 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 3 * b ^ 4‚Äñ := norm_smul_le _ _
      _ ‚â§ (144 : ‚Ñù)‚Åª¬π * (Œ± ^ 3 * Œ≤ ^ 4) := by
          rw [h144eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = Œ± ^ 3 * Œ≤ ^ 4 / 144 := by ring
  have hT6 : ‚Äñ(240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 5)‚Äñ ‚â§ Œ± ^ 2 * Œ≤ ^ 5 / 240 :=
    calc _ ‚â§ ‚Äñ(240 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 2 * b ^ 5‚Äñ := norm_smul_le _ _
      _ ‚â§ (240 : ‚Ñù)‚Åª¬π * (Œ± ^ 2 * Œ≤ ^ 5) := by
          rw [h240eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul (norm_pow_le _ _) (norm_pow_le _ _)
              (norm_nonneg _) (by positivity))) (by norm_num)
      _ = Œ± ^ 2 * Œ≤ ^ 5 / 240 := by ring
  have hT7 : ‚Äñ(720 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 6)‚Äñ ‚â§ Œ± * Œ≤ ^ 6 / 720 :=
    calc _ ‚â§ ‚Äñ(720 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña * b ^ 6‚Äñ := norm_smul_le _ _
      _ ‚â§ (720 : ‚Ñù)‚Åª¬π * (Œ± * Œ≤ ^ 6) := by
          rw [h720eq]
          exact mul_le_mul_of_nonneg_left
            ((norm_mul_le _ _).trans (mul_le_mul le_rfl (norm_pow_le _ _)
              (by positivity) hŒ±_nn)) (by norm_num)
      _ = Œ± * Œ≤ ^ 6 / 720 := by ring
  have hT8 : ‚Äñ(5040 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 7‚Äñ ‚â§ Œ≤ ^ 7 / 5040 :=
    calc _ ‚â§ ‚Äñ(5040 : ùïÇ)‚Åª¬π‚Äñ * ‚Äñb ^ 7‚Äñ := norm_smul_le _ _
      _ ‚â§ (5040 : ‚Ñù)‚Åª¬π * Œ≤ ^ 7 := by
          rw [h5040eq]; exact mul_le_mul_of_nonneg_left (norm_pow_le _ _) (by norm_num)
      _ = Œ≤ ^ 7 / 5040 := by ring
  -- Triangle inequality (7 norm_add_le applications).
  have ha1 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
    (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2) + (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3) +
    (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4) + (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 5) +
    (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 6)) ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 7)
  have ha2 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
    (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2) + (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3) +
    (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4) + (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 5))
    ((720 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 6))
  have ha3 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
    (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2) + (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3) +
    (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4)) ((240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 5))
  have ha4 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
    (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2) + (144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3))
    ((144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 4))
  have ha5 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
    (240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2)) ((144 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 3))
  have ha6 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b))
    ((240 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b ^ 2))
  have ha7 := norm_add_le ((5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7) ((720 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b))
  -- Œ±^k¬∑Œ≤^(7-k) ‚â§ s^7.
