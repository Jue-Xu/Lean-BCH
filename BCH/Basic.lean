  have hb7s : Œ≤ ^ 7 ‚â§ s ^ 7 := pow_le_pow_left‚ÇÄ hŒ≤_nn hŒ≤_le 7
  have ha6bs : Œ± ^ 6 * Œ≤ ‚â§ s ^ 7 := by
    calc Œ± ^ 6 * Œ≤ ‚â§ s ^ 6 * s := mul_le_mul (pow_le_pow_left‚ÇÄ hŒ±_nn hŒ±_le 6) hŒ≤_le
