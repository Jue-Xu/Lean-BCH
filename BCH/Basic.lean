  have hF‚ÇÇ_le : ‚ÄñF‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ùïÇ := ùïÇ) b
  have hG‚ÇÅ_le : ‚ÄñG‚ÇÅ‚Äñ ‚â§ Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ùïÇ := ùïÇ) a
  have hG‚ÇÇ_le : ‚ÄñG‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 - Œ≤ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ùïÇ := ùïÇ) b
  -- Real bound transitions
  have hEa3 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 ‚â§ Œ± ^ 3 :=
    real_exp_third_order_le_cube hŒ±_nn (lt_of_le_of_lt hŒ±_le hs56)
  have hEb3 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 ‚â§ Œ≤ ^ 3 :=
    real_exp_third_order_le_cube hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs56)
  have hFa4 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 ‚â§ Œ± ^ 4 :=
    real_exp_fourth_order_le_quartic hŒ±_nn (lt_of_le_of_lt hŒ±_le hs34)
  have hFb4 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 ‚â§ Œ≤ ^ 4 :=
    real_exp_fourth_order_le_quartic hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs34)
  have hGa5 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 ‚â§ Œ± ^ 5 :=
    real_exp_fifth_order_le_quintic hŒ±_nn (lt_of_le_of_lt hŒ±_le hs34)
  have hGb5 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 - Œ≤ ^ 4 / 24 ‚â§ Œ≤ ^ 5 :=
    real_exp_fifth_order_le_quintic hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs34)
  -- Component bounds (each of the 7 RHS pieces ‚â§ s‚Åµ or s‚Å∂)
  have hG‚ÇÅs : ‚ÄñG‚ÇÅ‚Äñ ‚â§ s ^ 5 := le_trans (le_trans hG‚ÇÅ_le hGa5)
    (pow_le_pow_left‚ÇÄ hŒ±_nn hŒ±_le 5)
  have hG‚ÇÇs : ‚ÄñG‚ÇÇ‚Äñ ‚â§ s ^ 5 := le_trans (le_trans hG‚ÇÇ_le hGb5)
    (pow_le_pow_left‚ÇÄ hŒ≤_nn hŒ≤_le 5)
  have h_aF‚ÇÇ : ‚Äña * F‚ÇÇ‚Äñ ‚â§ s ^ 5 :=
    calc _ ‚â§ ‚Äña‚Äñ * ‚ÄñF‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ Œ± * Œ≤ ^ 4 := mul_le_mul_of_nonneg_left
