      _ ‚â§ s * (K_P2' * s ^ 7) := mul_le_mul hz hP2'_le (norm_nonneg _) (by positivity)
  have h6 : ‚Äñ(P ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
              T‚ÇÇ * T‚ÇÑ - T‚ÇÉ * T‚ÇÉ - T‚ÇÑ * T‚ÇÇ) * z‚Äñ ‚â§ (K_P2' * s ^ 7) * s :=
    calc _ ‚â§ ‚ÄñP ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
