/-! ### Lie bracket formulation of BCH results -/

/-- The Lie bracket `‚ÅÖa, b‚ÅÜ` in an associative ring equals the ring commutator `a*b - b*a`.
This is `LieRing.of_associative_ring_bracket` from Mathlib, restated here for convenience. -/
theorem lie_eq_commutator (a b : ùî∏) : ‚ÅÖa, b‚ÅÜ = a * b - b * a :=
  LieRing.of_associative_ring_bracket a b

include ùïÇ in
/-- **BCH commutator extraction (Lie bracket form)**:
`bch(a,b) = a + b + ¬Ω‚ÅÖa,b‚ÅÜ + O(s¬≥)`. -/
theorem norm_bch_sub_add_sub_lie_le (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) :
    ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ ‚ÅÖa, b‚ÅÜ‚Äñ ‚â§
      10 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 3 / (2 - Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)) := by
  rw [lie_eq_commutator]
  exact norm_bch_sub_add_sub_bracket_le (ùïÇ := ùïÇ) a b hab

include ùïÇ in
/-- **Symmetric BCH (Lie bracket form)**: The Strang splitting has cubic error,
with the `‚ÅÖa/2, b‚ÅÜ` term cancelling. -/
theorem norm_symmetric_bch_sub_add_lie_le (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < 1 / 4) :
    ‚Äñbch (ùïÇ := ùïÇ) (bch (ùïÇ := ùïÇ) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) - (a + b)‚Äñ ‚â§
      300 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 3 :=
  norm_symmetric_bch_sub_add_le (ùïÇ := ùïÇ) a b hab

include ùïÇ in
/-- The BCH quadratic bound in Lie bracket notation:
`‚Äñbch(a,b) - (a+b)‚Äñ ‚â§ 3s¬≤/(2-eÀ¢)`, i.e., the leading error is `¬Ω‚ÅÖa,b‚ÅÜ`. -/
theorem norm_bch_sub_add_le' (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) :
    ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b)‚Äñ ‚â§
      3 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 2 / (2 - Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)) :=
  norm_bch_sub_add_le (ùïÇ := ùïÇ) a b hab

/-! ### Suzuki infrastructure: Cubic coefficient and quintic remainder

For the fourth-order Suzuki formula, we need the cubic coefficient E‚ÇÉ of the
symmetric BCH expansion, with the property that E‚ÇÉ(c¬∑a, c¬∑b) = c¬≥¬∑E‚ÇÉ(a,b).
The Suzuki condition 4p¬≥+(1-4p)¬≥=0 then kills this term. -/

/-- The degree-3 BCH term: `(1/12)([a,[a,b]] + [b,[b,a]])`.

This is the leading cubic correction in the BCH expansion:
`bch(a,b) = a + b + ¬Ω[a,b] + bch_cubic_term a b + O(s‚Å¥)`. -/
noncomputable def bch_cubic_term (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (a b : ùî∏) : ùî∏ :=
  (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a * (a * b - b * a) - (a * b - b * a) * a) +
  (12 : ùïÇ)‚Åª¬π ‚Ä¢ (b * (b * a - a * b) - (b * a - a * b) * b)

omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
/-- **Homogeneity of bch_cubic_term**: E‚ÇÉ(c¬∑a, c¬∑b) = c¬≥¬∑E‚ÇÉ(a,b).
This is the key property enabling Suzuki's cubic cancellation. -/
theorem bch_cubic_term_smul (a b : ùî∏) (c : ùïÇ) :
    bch_cubic_term ùïÇ (c ‚Ä¢ a) (c ‚Ä¢ b) = c ^ 3 ‚Ä¢ bch_cubic_term ùïÇ a b := by
  -- Helper: triple product homogeneity
  have triple : ‚àÄ x y z : ùî∏,
      (c ‚Ä¢ x) * ((c ‚Ä¢ y) * (c ‚Ä¢ z)) = c ^ 3 ‚Ä¢ (x * (y * z)) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  have triple' : ‚àÄ x y z : ùî∏,
      ((c ‚Ä¢ x) * (c ‚Ä¢ y)) * (c ‚Ä¢ z) = c ^ 3 ‚Ä¢ (x * y * z) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  unfold bch_cubic_term
  simp only [mul_sub, sub_mul, triple, triple', ‚Üê smul_sub, smul_comm (c ^ 3) ((12 : ùïÇ)‚Åª¬π),
    ‚Üê smul_add]

