      -- H1 identity: y-z-┬╜[a,b]-┬╜y┬▓ = ┬╜W
      have hH1 : y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 =
