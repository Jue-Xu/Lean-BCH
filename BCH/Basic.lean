/-- Norm bound for `‚ÄñP¬≤ - T‚ÇÇ¬≤‚Äñ ‚â§ 10¬∑s‚Åµ` via `P¬≤ - T‚ÇÇ¬≤ = (P-T‚ÇÇ)P + T‚ÇÇ(P-T‚ÇÇ)`. -/
private theorem norm_P2_sub_T22_le (P T‚ÇÇ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2) (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) :
    ‚ÄñP ^ 2 - T‚ÇÇ ^ 2‚Äñ ‚â§ 10 * s ^ 5 := by
  have heq : P ^ 2 - T‚ÇÇ ^ 2 = (P - T‚ÇÇ) * P + T‚ÇÇ * (P - T‚ÇÇ) := by noncomm_ring
  rw [heq]
  have ht1 : ‚Äñ(P - T‚ÇÇ) * P‚Äñ ‚â§ (5 * s ^ 3) * s ^ 2 :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ (5 * s ^ 3) * s ^ 2 := mul_le_mul hPmT‚ÇÇ hP (norm_nonneg _) (by positivity)
  have ht2 : ‚ÄñT‚ÇÇ * (P - T‚ÇÇ)‚Äñ ‚â§ s ^ 2 * (5 * s ^ 3) :=
    calc _ ‚â§ ‚ÄñT‚ÇÇ‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ s ^ 2 * (5 * s ^ 3) := mul_le_mul hT‚ÇÇ hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have hadd := norm_add_le ((P - T‚ÇÇ) * P) (T‚ÇÇ * (P - T‚ÇÇ))
  nlinarith [pow_nonneg hs_nn 5]

/-- Norm bound for `‚ÄñP¬≥ - T‚ÇÇ¬≥‚Äñ ‚â§ 15¬∑s‚Å∑` via the 3-fold telescoping
`P¬≥ - T‚ÇÇ¬≥ = (P-T‚ÇÇ)¬∑P¬≤ + T‚ÇÇ¬∑(P-T‚ÇÇ)¬∑P + T‚ÇÇ¬≤¬∑(P-T‚ÇÇ)`. Each term ‚â§ 5¬∑s¬≥¬∑s‚Å¥ = 5¬∑s‚Å∑
(or symmetric). Used in the I2 septic residual bound. -/
private theorem norm_P3_sub_T23_le (P T‚ÇÇ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2) (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) :
    ‚ÄñP ^ 3 - T‚ÇÇ ^ 3‚Äñ ‚â§ 15 * s ^ 7 := by
  have heq : P ^ 3 - T‚ÇÇ ^ 3 =
      (P - T‚ÇÇ) * P ^ 2 + T‚ÇÇ * (P - T‚ÇÇ) * P + T‚ÇÇ ^ 2 * (P - T‚ÇÇ) := by noncomm_ring
  rw [heq]
  have ht1 : ‚Äñ(P - T‚ÇÇ) * P ^ 2‚Äñ ‚â§ (5 * s ^ 3) * (s ^ 2) ^ 2 :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚ÄñP ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚ÄñP‚Äñ ^ 2 := by gcongr; exact norm_pow_le P 2
      _ ‚â§ (5 * s ^ 3) * (s ^ 2) ^ 2 := mul_le_mul hPmT‚ÇÇ
          (pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 2) (by positivity) (by positivity)
  have ht2 : ‚ÄñT‚ÇÇ * (P - T‚ÇÇ) * P‚Äñ ‚â§ s ^ 2 * (5 * s ^ 3) * s ^ 2 :=
    calc _ ‚â§ ‚ÄñT‚ÇÇ * (P - T‚ÇÇ)‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñT‚ÇÇ‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ) * ‚ÄñP‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 2 * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ hP (norm_nonneg _) (by positivity)
          exact mul_le_mul hT‚ÇÇ hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have ht3 : ‚ÄñT‚ÇÇ ^ 2 * (P - T‚ÇÇ)‚Äñ ‚â§ (s ^ 2) ^ 2 * (5 * s ^ 3) :=
    calc _ ‚â§ ‚ÄñT‚ÇÇ ^ 2‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñT‚ÇÇ‚Äñ ^ 2 * ‚ÄñP - T‚ÇÇ‚Äñ := by gcongr; exact norm_pow_le T‚ÇÇ 2
      _ ‚â§ (s ^ 2) ^ 2 * (5 * s ^ 3) := mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hT‚ÇÇ 2)
          hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have hadd1 := norm_add_le ((P - T‚ÇÇ) * P ^ 2 + T‚ÇÇ * (P - T‚ÇÇ) * P) (T‚ÇÇ ^ 2 * (P - T‚ÇÇ))
  have hadd2 := norm_add_le ((P - T‚ÇÇ) * P ^ 2) (T‚ÇÇ * (P - T‚ÇÇ) * P)
  nlinarith [pow_nonneg hs_nn 7]

