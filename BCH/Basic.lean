/-- Helper: any 5-letter word on `{a, b}` has norm ‚â§ s‚Åµ where s = ‚Äña‚Äñ+‚Äñb‚Äñ. -/
private lemma norm_word5_le {ùî∏ : Type*} [NormedRing ùî∏] (a b : ùî∏)
    (x‚ÇÅ x‚ÇÇ x‚ÇÉ x‚ÇÑ x‚ÇÖ : ùî∏)
    (h‚ÇÅ : x‚ÇÅ = a ‚à® x‚ÇÅ = b) (h‚ÇÇ : x‚ÇÇ = a ‚à® x‚ÇÇ = b) (h‚ÇÉ : x‚ÇÉ = a ‚à® x‚ÇÉ = b)
    (h‚ÇÑ : x‚ÇÑ = a ‚à® x‚ÇÑ = b) (h‚ÇÖ : x‚ÇÖ = a ‚à® x‚ÇÖ = b) :
    ‚Äñx‚ÇÅ * x‚ÇÇ * x‚ÇÉ * x‚ÇÑ * x‚ÇÖ‚Äñ ‚â§ (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 5 := by
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ
  have ha := norm_nonneg a
  have hb := norm_nonneg b
  have hxs : ‚àÄ x : ùî∏, x = a ‚à® x = b ‚Üí ‚Äñx‚Äñ ‚â§ s := by
    intro x hx
    cases hx with
    | inl h => rw [h]; linarith
    | inr h => rw [h]; linarith
  calc ‚Äñx‚ÇÅ * x‚ÇÇ * x‚ÇÉ * x‚ÇÑ * x‚ÇÖ‚Äñ
      ‚â§ ‚Äñx‚ÇÅ * x‚ÇÇ * x‚ÇÉ * x‚ÇÑ‚Äñ * ‚Äñx‚ÇÖ‚Äñ := norm_mul_le _ _
    _ ‚â§ ‚Äñx‚ÇÅ * x‚ÇÇ * x‚ÇÉ‚Äñ * ‚Äñx‚ÇÑ‚Äñ * ‚Äñx‚ÇÖ‚Äñ := by gcongr; exact norm_mul_le _ _
    _ ‚â§ ‚Äñx‚ÇÅ * x‚ÇÇ‚Äñ * ‚Äñx‚ÇÉ‚Äñ * ‚Äñx‚ÇÑ‚Äñ * ‚Äñx‚ÇÖ‚Äñ := by gcongr; exact norm_mul_le _ _
    _ ‚â§ ‚Äñx‚ÇÅ‚Äñ * ‚Äñx‚ÇÇ‚Äñ * ‚Äñx‚ÇÉ‚Äñ * ‚Äñx‚ÇÑ‚Äñ * ‚Äñx‚ÇÖ‚Äñ := by gcongr; exact norm_mul_le _ _
    _ ‚â§ s * s * s * s * s := by
        gcongr <;> [exact hxs _ h‚ÇÅ; exact hxs _ h‚ÇÇ; exact hxs _ h‚ÇÉ;
                    exact hxs _ h‚ÇÑ; exact hxs _ h‚ÇÖ]
    _ = s ^ 5 := by ring

