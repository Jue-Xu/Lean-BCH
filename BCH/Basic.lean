  unfold bch_quintic_group_1
  have quint : ‚àÄ x‚ÇÅ x‚ÇÇ x‚ÇÉ x‚ÇÑ x‚ÇÖ : ùî∏,
      (c ‚Ä¢ x‚ÇÅ) * (c ‚Ä¢ x‚ÇÇ) * (c ‚Ä¢ x‚ÇÉ) * (c ‚Ä¢ x‚ÇÑ) * (c ‚Ä¢ x‚ÇÖ) =
        c ^ 5 ‚Ä¢ (x‚ÇÅ * x‚ÇÇ * x‚ÇÉ * x‚ÇÑ * x‚ÇÖ) := by
    intros; simp only [smul_mul_assoc, mul_smul_comm, smul_smul]; congr 1; ring
  simp only [quint, ‚Üê smul_add]

