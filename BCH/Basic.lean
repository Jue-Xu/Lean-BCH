/-- **Homogeneity of `symmetric_bch_cubic_poly`**: `sym_EтВГ(c┬╖a, c┬╖b) = c┬│┬╖sym_EтВГ(a, b)`.

Used to close the small-s case of `norm_symmetric_bch_cubic_sub_smul_le`: the
c┬│-scaling mismatch between `symmetric_bch_cubic` and `c┬│┬╖symmetric_bch_cubic` is
absorbed into the quintic remainder after subtracting this homogeneous polynomial. -/
theorem symmetric_bch_cubic_poly_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    symmetric_bch_cubic_poly ЁЭХВ (c тАв a) (c тАв b) =
      c ^ 3 тАв symmetric_bch_cubic_poly ЁЭХВ a b := by
  -- Helper: triple-product homogeneity (same as in bch_cubic_term_smul)
  have triple : тИА x y z : ЁЭФ╕,
      (c тАв x) * ((c тАв y) * (c тАв z)) = c ^ 3 тАв (x * (y * z)) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  have triple' : тИА x y z : ЁЭФ╕,
      ((c тАв x) * (c тАв y)) * (c тАв z) = c ^ 3 тАв (x * y * z) := by
    intro x y z
    simp only [smul_mul_assoc, mul_smul_comm, smul_smul]
    congr 1; ring
  unfold symmetric_bch_cubic_poly
  simp only [mul_sub, sub_mul, triple, triple', тЖР smul_sub,
    smul_comm ((24 : ЁЭХВ)тБ╗┬╣) (c ^ 3), smul_comm ((12 : ЁЭХВ)тБ╗┬╣) (c ^ 3),
    тЖР smul_add, тЖР smul_neg]

