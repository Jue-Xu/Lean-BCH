          rw [sub_eq_add_neg]
          exact (norm_add_le _ _).trans (by rw [norm_neg])
      _ тЙд ╬▒ * (2 * ╬▒ * ╬▓) + (2 * ╬▒ * ╬▓) * ╬▒ := by
          gcongr
