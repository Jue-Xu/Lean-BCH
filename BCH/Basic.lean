    calc ‚Äñz‚Äñ ‚â§ s‚ÇÅ + 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) := hz_le
      _ ‚â§ s + 12 * s / 11 := by linarith
      _ = 23/11 * s := by ring
  have hs‚ÇÇ_mult : ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ 57/22 * s := by
    calc ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ 23/11 * s + s/2 := by linarith [hz_mult, ha'_s]
