/-- **Algebraic decomposition of `pieceB'''` for the septic remainder small-s case.**

Extends `pieceB_sextic_decomp` to one degree higher. States that pieceB'''
(= pieceB'' - тЕЩyтБ╢ - CтВЖ) decomposes as:

```
pieceB''' = (IтВБ - corrтВБ - corrтВБ_5 - corrтВБ_6) + (IтВВ - corrтВВ - corrтВВ_5 - corrтВВ_6)
           - ┬╝(yтБ┤ - zтБ┤ - y4_5 - y4_6) + тЕХ(yтБ╡ - zтБ╡ - y5_6) - тЕЩ(yтБ╢ - zтБ╢)
```

where (in addition to the sextic case):
- `corrтВБ_6 = ┬╜┬╖W6` (the deg-6 contribution to IтВБ from septic_pure_identity)
- `corrтВВ_6 = тЕУ┬╖y3_6` (the deg-6 contribution to тЕУ(y┬│-z┬│) from septic_pure_identity)
- `y4_6 = z┬▓TтВГ + zTтВГz + TтВГz┬▓ + TтВГz┬│ + z┬▓TтВВ┬▓ + zTтВВzTтВВ + zTтВВ┬▓z + TтВВz┬▓TтВВ + TтВВzTтВВz + TтВВ┬▓z┬▓`
   (10 terms тАФ the deg-6 contribution to yтБ┤ via (1,1,1,3) + (1,1,2,2) perms)
- `y5_6 = zтБ┤TтВВ + z┬│TтВВz + z┬▓TтВВz┬▓ + zTтВВz┬│ + TтВВzтБ┤` (5 terms тАФ (1,1,1,1,2) perms)
- `W6 = 2┬╖y_d6 - (y┬▓)_d6` per septic_pure_identity definition

Each piece on the RHS is deg-7+. Proof: `pieceB''' - RHS =
(LHS_QPI deg-4) + (LHS_SPI deg-5) + (LHS_Septic deg-6) = 0+0+0 = 0`. -/
private theorem pieceB_septic_decomp (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) :
    let z : ЁЭФ╕ := a + b
    let TтВВ : ЁЭФ╕ := a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let TтВГ_QPI : ЁЭФ╕ := (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b)
    let TтВГ_SPI : ЁЭФ╕ := (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let TтВД : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    let TтВЕ : ЁЭФ╕ := (120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5
    let W5 : ЁЭФ╕ := (60 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (60 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5 +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) -
        (z * TтВД + TтВД * z) - (TтВВ * TтВГ_SPI + TтВГ_SPI * TтВВ)
    let W6 : ЁЭФ╕ := (360 : ЁЭХВ)тБ╗┬╣ тАв a ^ 6 + (60 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b ^ 2) + (18 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 4) + (60 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 5) +
        (360 : ЁЭХВ)тБ╗┬╣ тАв b ^ 6 -
        (z * TтВЕ + TтВВ * TтВД + TтВГ_SPI * TтВГ_SPI + TтВД * TтВВ + TтВЕ * z)
    let y3_5 : ЁЭФ╕ := z ^ 2 * TтВГ_SPI + z * TтВГ_SPI * z + TтВГ_SPI * z ^ 2 +
        z * TтВВ ^ 2 + TтВВ * z * TтВВ + TтВВ ^ 2 * z
    let y3_6 : ЁЭФ╕ := z ^ 2 * TтВД + z * TтВД * z + TтВД * z ^ 2 +
        z * TтВВ * TтВГ_SPI + z * TтВГ_SPI * TтВВ + TтВВ * z * TтВГ_SPI +
        TтВВ * TтВГ_SPI * z + TтВГ_SPI * z * TтВВ + TтВГ_SPI * TтВВ * z + TтВВ ^ 3
    let y4_5 : ЁЭФ╕ := z ^ 3 * TтВВ + z ^ 2 * TтВВ * z + z * TтВВ * z ^ 2 + TтВВ * z ^ 3
    let y4_6 : ЁЭФ╕ := z ^ 3 * TтВГ_SPI + z ^ 2 * TтВГ_SPI * z + z * TтВГ_SPI * z ^ 2 + TтВГ_SPI * z ^ 3 +
        z ^ 2 * TтВВ ^ 2 + z * TтВВ * z * TтВВ + z * TтВВ ^ 2 * z +
        TтВВ * z ^ 2 * TтВВ + TтВВ * z * TтВВ * z + TтВВ ^ 2 * z ^ 2
    let y5_6 : ЁЭФ╕ := z ^ 4 * TтВВ + z ^ 3 * TтВВ * z + z ^ 2 * TтВВ * z ^ 2 +
        z * TтВВ * z ^ 3 + TтВВ * z ^ 4
    let y : ЁЭФ╕ := exp a * exp b - 1
    let corrтВБ : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) -
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВГ_QPI + TтВГ_QPI * z) - (2 : ЁЭХВ)тБ╗┬╣ тАв TтВВ ^ 2
    let corrтВВ : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2)
    let corrтВБ_5 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W5
    let corrтВВ_5 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_5
    let corrтВБ_6 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W6
    let corrтВВ_6 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_6
    -- pieceB''' (extends pieceB'' by -тЕЩyтБ╢ - CтВЖ)
    y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
      (3 : ЁЭХВ)тБ╗┬╣ тАв y ^ 3 - (4 : ЁЭХВ)тБ╗┬╣ тАв y ^ 4 + (5 : ЁЭХВ)тБ╗┬╣ тАв y ^ 5 -
      (6 : ЁЭХВ)тБ╗┬╣ тАв y ^ 6 -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b - bch_sextic_term ЁЭХВ a b =
    -- RHS: 5 pieces
    ((y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
        (3 : ЁЭХВ)тБ╗┬╣ тАв z ^ 3 - bch_cubic_term ЁЭХВ a b) - corrтВБ - corrтВБ_5 - corrтВБ_6) +
    ((3 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 3 - z ^ 3) - corrтВВ - corrтВВ_5 - corrтВВ_6) -
    (4 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 4 - z ^ 4 - y4_5 - y4_6) +
    (5 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 5 - z ^ 5 - y5_6) -
    (6 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 6 - z ^ 6) := by
  intro z TтВВ TтВГ_QPI TтВГ_SPI TтВД TтВЕ W5 W6 y3_5 y3_6 y4_5 y4_6 y5_6 y
    corrтВБ corrтВВ corrтВБ_5 corrтВВ_5 corrтВБ_6 corrтВВ_6
  -- Use QPI + SPI + Septic
  have hQPI := quintic_pure_identity ЁЭХВ a b
  have hSPI := sextic_pure_identity ЁЭХВ a b
  have hSeptic := septic_pure_identity ЁЭХВ a b
  linear_combination (norm := module) hQPI + hSPI + hSeptic

