  -- a'+a' = a
  have ha'_add : a' + a' = a := by
    rw [ha'_def, тЖР add_smul, show (2 : ЁЭХВ)тБ╗┬╣ + (2 : ЁЭХВ)тБ╗┬╣ = 1 from by
