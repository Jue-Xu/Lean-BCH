include ùïÇ in
/-- **Quintic remainder for symmetric BCH**: `E‚ÇÉ(c¬∑a, c¬∑b) - c¬≥¬∑E‚ÇÉ(a,b)` is `O(|c|¬≥¬∑s‚Åµ)`.

The `|c|¬≥¬∑s‚Åµ` bound suffices for Suzuki's cancellation: when `Œ£·µ¢ c·µ¢¬≥ = 0`, the sum
`Œ£·µ¢ E‚ÇÉ(c·µ¢¬∑a, c·µ¢¬∑b) = Œ£·µ¢ (E‚ÇÉ(c·µ¢¬∑a,c·µ¢¬∑b) - c·µ¢¬≥¬∑E‚ÇÉ(a,b))` is `O(s‚Åµ)`.

The proof requires establishing that the symmetric BCH is an *odd function* of `(a,b)`:
`bch(bch(-a/2,-b),-a/2) = -bch(bch(a/2,b),a/2)`. This follows from the triple product
identity `exp(a/2)exp(b)exp(a/2) ¬∑ exp(-a/2)exp(-b)exp(-a/2) = 1`, combined with
commutativity of `logOnePlus(y)` and `logOnePlus((1+y)‚Åª¬π-1)` (both are power series
in `y`) and a chain-of-neighborhoods argument similar to `logOnePlus_exp_sub_one`.
The oddness kills all even-degree Taylor coefficients, so extracting the cubic term
`bch_cubic_term` (degree-3 homogeneous) leaves a quintic+ remainder. -/
theorem norm_symmetric_bch_cubic_sub_smul_le (a b : ùî∏) (c : ‚Ñù)
    (hc : |c| ‚â§ 1) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < 1 / 4) :
    ‚Äñsymmetric_bch_cubic ùïÇ ((‚Üëc : ùïÇ) ‚Ä¢ a) ((‚Üëc : ùïÇ) ‚Ä¢ b) -
      (‚Üëc : ùïÇ) ^ 3 ‚Ä¢ symmetric_bch_cubic ùïÇ a b‚Äñ ‚â§
      20000000 * |c| ^ 3 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 5 := by
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ with hs_def
  have hs_nn : 0 ‚â§ s := by positivity
  have hs14 : s < 1 / 4 := hab
  -- Key fact: ‚Äñc ‚Ä¢ a‚Äñ + ‚Äñc ‚Ä¢ b‚Äñ = |c| ¬∑ s ‚â§ s < 1/4
  have hnorm_scale : ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ a)‚Äñ + ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ b)‚Äñ ‚â§ |c| * s := by
    have hc_norm : ‚Äñ(‚Üëc : ùïÇ)‚Äñ = |c| := by
      rw [RCLike.norm_ofReal]
    calc ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ a)‚Äñ + ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ b)‚Äñ
        ‚â§ ‚Äñ(‚Üëc : ùïÇ)‚Äñ * ‚Äña‚Äñ + ‚Äñ(‚Üëc : ùïÇ)‚Äñ * ‚Äñb‚Äñ := by
          gcongr <;> exact norm_smul_le _ _
      _ = |c| * s := by rw [hc_norm]; ring
  have hc_nn : 0 ‚â§ |c| := abs_nonneg c
  have hcs_lt : |c| * s < 1 / 4 := by
    calc |c| * s ‚â§ 1 * s := by gcongr
      _ = s := one_mul s
      _ < 1 / 4 := hs14
  have hcs_14 : ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ a)‚Äñ + ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ b)‚Äñ < 1 / 4 :=
    lt_of_le_of_lt hnorm_scale hcs_lt
  -- H2 bound on E‚ÇÉ(ca,cb) and on E‚ÇÉ(a,b)
  have h_E3_ca : ‚Äñsymmetric_bch_cubic ùïÇ ((‚Üëc : ùïÇ) ‚Ä¢ a) ((‚Üëc : ùïÇ) ‚Ä¢ b)‚Äñ ‚â§
      300 * (|c| * s) ^ 3 := by
    calc _ ‚â§ 300 * (‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ a)‚Äñ + ‚Äñ((‚Üëc : ùïÇ) ‚Ä¢ b)‚Äñ) ^ 3 :=
          norm_symmetric_bch_cubic_le (ùïÇ := ùïÇ) _ _ hcs_14
      _ ‚â§ 300 * (|c| * s) ^ 3 := by gcongr
  have h_E3_ab : ‚Äñsymmetric_bch_cubic ùïÇ a b‚Äñ ‚â§ 300 * s ^ 3 :=
    norm_symmetric_bch_cubic_le (ùïÇ := ùïÇ) a b hab
  -- Crude bound: ‚ÄñD(c)‚Äñ ‚â§ 600 |c|¬≥ s¬≥
  have h_crude : ‚Äñsymmetric_bch_cubic ùïÇ ((‚Üëc : ùïÇ) ‚Ä¢ a) ((‚Üëc : ùïÇ) ‚Ä¢ b) -
      (‚Üëc : ùïÇ) ^ 3 ‚Ä¢ symmetric_bch_cubic ùïÇ a b‚Äñ ‚â§ 600 * |c| ^ 3 * s ^ 3 := by
    have hsmul_norm : ‚Äñ(‚Üëc : ùïÇ) ^ 3 ‚Ä¢ symmetric_bch_cubic ùïÇ a b‚Äñ ‚â§
        |c| ^ 3 * (300 * s ^ 3) := by
      have : ‚Äñ((‚Üëc : ùïÇ) ^ 3)‚Äñ = |c| ^ 3 := by
        rw [norm_pow, RCLike.norm_ofReal]
      calc _ ‚â§ ‚Äñ((‚Üëc : ùïÇ) ^ 3)‚Äñ * ‚Äñsymmetric_bch_cubic ùïÇ a b‚Äñ := norm_smul_le _ _
        _ ‚â§ |c| ^ 3 * (300 * s ^ 3) := by rw [this]; gcongr
    calc ‚Äñ_‚Äñ ‚â§ _ + _ := norm_sub_le _ _
      _ ‚â§ 300 * (|c| * s) ^ 3 + |c| ^ 3 * (300 * s ^ 3) := by linarith
      _ = 600 * |c| ^ 3 * s ^ 3 := by ring
  -- Case split on s¬≤ vs 6/100
  by_cases hs_large : 6 / 100 ‚â§ s ^ 2
  ¬∑ -- Large s case: crude bound 600¬∑|c|¬≥¬∑s¬≥ ‚â§ 20¬∑10‚Å∂¬∑|c|¬≥¬∑s‚Åµ when s¬≤ ‚â• 0.06
    have h600 : 600 * |c| ^ 3 * s ^ 3 ‚â§ 20000000 * |c| ^ 3 * s ^ 5 := by
      have hc3_nn : 0 ‚â§ |c| ^ 3 := pow_nonneg hc_nn 3
      have hs3_nn : 0 ‚â§ s ^ 3 := pow_nonneg hs_nn 3
      have h1 : 600 * s ^ 3 ‚â§ 20000000 * s ^ 5 := by
        -- s¬≤ ‚â• 0.06 ‚áí 20000000¬∑s¬≤ ‚â• 1200000 ‚â• 600
        have hdiff : 20000000 * s ^ 5 - 600 * s ^ 3 = s ^ 3 * (20000000 * s ^ 2 - 600) := by ring
        have h2 : 0 ‚â§ 20000000 * s ^ 2 - 600 := by linarith
        nlinarith [mul_nonneg hs3_nn h2]
      nlinarith [h1, hc3_nn]
    linarith
  ¬∑ -- Small s case: s¬≤ < 0.06. Use the symmetric quintic remainder bound.
    push_neg at hs_large
    -- Decomposition:
    --   D(c) = [sym_bch_cubic(ca,cb) - sym_E‚ÇÉ(ca,cb)]
    --        + [sym_E‚ÇÉ(ca,cb) - c¬≥¬∑sym_E‚ÇÉ(a,b)]            -- ZERO by homogeneity
    --        + c¬≥¬∑[sym_E‚ÇÉ(a,b) - sym_bch_cubic(a,b)]
    -- Bounds:  ‚â§ 10‚Å∑¬∑(|c|s)‚Åµ + 0 + |c|¬≥¬∑10‚Å∑¬∑s‚Åµ ‚â§ 2¬∑10‚Å∑¬∑|c|¬≥¬∑s‚Åµ.
    -- Set c' = (‚Üëc : ùïÇ)
    set c' : ùïÇ := (‚Üëc : ùïÇ) with hc'_def
    have hc'_norm : ‚Äñc'‚Äñ = |c| := by rw [hc'_def, RCLike.norm_ofReal]
    -- Term 1: ‚Äñsym_bch_cubic(c'‚Ä¢a, c'‚Ä¢b) - sym_E‚ÇÉ(c'‚Ä¢a, c'‚Ä¢b)‚Äñ ‚â§ 10‚Å∑¬∑(|c|s)‚Åµ
    have hT1 : ‚Äñsymmetric_bch_cubic ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) -
        symmetric_bch_cubic_poly ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b)‚Äñ ‚â§ 10000000 * (|c| * s) ^ 5 := by
      calc _ ‚â§ 10000000 * (‚Äñc' ‚Ä¢ a‚Äñ + ‚Äñc' ‚Ä¢ b‚Äñ) ^ 5 :=
            norm_symmetric_bch_cubic_sub_poly_le (ùïÇ := ùïÇ) _ _ hcs_14
        _ ‚â§ 10000000 * (|c| * s) ^ 5 := by gcongr
    -- Homogeneity: sym_E‚ÇÉ(c'‚Ä¢a, c'‚Ä¢b) = c'¬≥ ‚Ä¢ sym_E‚ÇÉ(a, b)
    have hhom : symmetric_bch_cubic_poly ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) =
        c' ^ 3 ‚Ä¢ symmetric_bch_cubic_poly ùïÇ a b :=
      symmetric_bch_cubic_poly_smul a b c'
    -- Term 2: ‚Äñc'¬≥ ‚Ä¢ (sym_E‚ÇÉ(a,b) - sym_bch_cubic(a,b))‚Äñ ‚â§ |c|¬≥¬∑10‚Å∑¬∑s‚Åµ
    have hT2 : ‚Äñc' ^ 3 ‚Ä¢ (symmetric_bch_cubic_poly ùïÇ a b - symmetric_bch_cubic ùïÇ a b)‚Äñ ‚â§
        |c| ^ 3 * (10000000 * s ^ 5) := by
      have hc3_norm : ‚Äñc' ^ 3‚Äñ = |c| ^ 3 := by rw [norm_pow, hc'_norm]
      have hbound : ‚Äñsymmetric_bch_cubic_poly ùïÇ a b - symmetric_bch_cubic ùïÇ a b‚Äñ ‚â§
          10000000 * s ^ 5 := by
        rw [show symmetric_bch_cubic_poly ùïÇ a b - symmetric_bch_cubic ùïÇ a b =
            -(symmetric_bch_cubic ùïÇ a b - symmetric_bch_cubic_poly ùïÇ a b) from by abel]
        rw [norm_neg]
        exact norm_symmetric_bch_cubic_sub_poly_le (ùïÇ := ùïÇ) a b hab
      calc _ ‚â§ ‚Äñc' ^ 3‚Äñ * ‚Äñ_‚Äñ := norm_smul_le _ _
        _ ‚â§ |c| ^ 3 * (10000000 * s ^ 5) := by rw [hc3_norm]; gcongr
    -- Combine: D(c) = (sym_bch_cubic(ca,cb) - sym_E‚ÇÉ(ca,cb)) + c'¬≥ ‚Ä¢ (sym_E‚ÇÉ(a,b) - sym_bch_cubic(a,b))
    have hD_decomp : symmetric_bch_cubic ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) -
        c' ^ 3 ‚Ä¢ symmetric_bch_cubic ùïÇ a b =
        (symmetric_bch_cubic ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) -
          symmetric_bch_cubic_poly ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b)) +
        c' ^ 3 ‚Ä¢ (symmetric_bch_cubic_poly ùïÇ a b - symmetric_bch_cubic ùïÇ a b) := by
      rw [hhom, smul_sub]; abel
    -- Apply triangle inequality
    calc ‚Äñsymmetric_bch_cubic ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) -
          c' ^ 3 ‚Ä¢ symmetric_bch_cubic ùïÇ a b‚Äñ
        = ‚Äñ_ + _‚Äñ := by rw [hD_decomp]
      _ ‚â§ ‚Äñsymmetric_bch_cubic ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b) -
            symmetric_bch_cubic_poly ùïÇ (c' ‚Ä¢ a) (c' ‚Ä¢ b)‚Äñ +
          ‚Äñc' ^ 3 ‚Ä¢ (symmetric_bch_cubic_poly ùïÇ a b - symmetric_bch_cubic ùïÇ a b)‚Äñ :=
            norm_add_le _ _
      _ ‚â§ 10000000 * (|c| * s) ^ 5 + |c| ^ 3 * (10000000 * s ^ 5) := by linarith
      _ ‚â§ 20000000 * |c| ^ 3 * s ^ 5 := by
          -- 10‚Å∑¬∑|c|‚Åµ¬∑s‚Åµ + 10‚Å∑¬∑|c|¬≥¬∑s‚Åµ ‚â§ 10‚Å∑¬∑|c|¬≥¬∑s‚Åµ + 10‚Å∑¬∑|c|¬≥¬∑s‚Åµ = 2¬∑10‚Å∑¬∑|c|¬≥¬∑s‚Åµ
          have hc5_le_c3 : |c| ^ 5 ‚â§ |c| ^ 3 := by
            have h_c2 : |c| ^ 2 ‚â§ 1 := by
              calc |c| ^ 2 ‚â§ 1 ^ 2 := by gcongr
                _ = 1 := one_pow _
            calc |c| ^ 5 = |c| ^ 3 * |c| ^ 2 := by ring
              _ ‚â§ |c| ^ 3 * 1 := by
                  apply mul_le_mul_of_nonneg_left h_c2 (pow_nonneg hc_nn 3)
              _ = |c| ^ 3 := mul_one _
          have hcs5 : (|c| * s) ^ 5 = |c| ^ 5 * s ^ 5 := by ring
          calc 10000000 * (|c| * s) ^ 5 + |c| ^ 3 * (10000000 * s ^ 5)
              = 10000000 * |c| ^ 5 * s ^ 5 + 10000000 * |c| ^ 3 * s ^ 5 := by rw [hcs5]; ring
            _ ‚â§ 10000000 * |c| ^ 3 * s ^ 5 + 10000000 * |c| ^ 3 * s ^ 5 := by
                gcongr
            _ = 20000000 * |c| ^ 3 * s ^ 5 := by ring

end

