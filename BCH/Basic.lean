  `‚ÄñLHS_octic‚Äñ ‚â§ 1000011¬∑s‚Å∑/(2-exp(s)) ‚â§ 10000110¬∑s‚Å∏/(2-exp(s))`

(since `1000011 ‚â§ 10000110¬∑s` when `s ‚â• 1/10`).

This is the crude case of the full octic remainder theorem. The full
theorem requires the small-s analytic case (`s < 1/10`), which will use
`octic_pure_identity` for the deg-7 cancellation (analog of the septic
remainder pattern).

Foundation for stepping stone 1 (`symmetric_bch_septic_sub_poly_axiom`)
discharge ‚Äî the deg-9 analog of T2-F7e Phase A. -/
private theorem norm_bch_octic_remainder_large_s_le (a b : ùî∏)
    (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) (hs_large : 1 / 10 ‚â§ ‚Äña‚Äñ + ‚Äñb‚Äñ) :
    ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
      bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
      bch_quintic_term ùïÇ a b - bch_sextic_term ùïÇ a b -
      bch_septic_term ùïÇ a b‚Äñ ‚â§
      10000110 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 8 / (2 - Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)) := by
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ with hs_def
  have hs_nn : 0 ‚â§ s := by positivity
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hdenom_le1 : 2 - Real.exp s ‚â§ 1 := by linarith [Real.add_one_le_exp s]
  have hR‚ÇÜ := norm_bch_septic_remainder_large_s_le (ùïÇ := ùïÇ) a b hab hs_large
  have hZ‚Çá : ‚Äñbch_septic_term ùïÇ a b‚Äñ ‚â§ s ^ 7 := norm_bch_septic_term_le a b
  -- Algebraic split: LHS_octic = LHS_septic - bch_septic_term
  have hLHS_eq : bch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
      bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
      bch_quintic_term ùïÇ a b - bch_sextic_term ùïÇ a b -
      bch_septic_term ùïÇ a b =
      (bch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
       bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
       bch_quintic_term ùïÇ a b - bch_sextic_term ùïÇ a b) -
      bch_septic_term ùïÇ a b := by abel
  -- ‚ÄñLHS_octic‚Äñ ‚â§ 1000010¬∑s‚Å∑/(2-exp(s)) + s‚Å∑ ‚â§ 1000011¬∑s‚Å∑/(2-exp(s))
  have hLHS_1000011 : ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
      bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
      bch_quintic_term ùïÇ a b - bch_sextic_term ùïÇ a b -
      bch_septic_term ùïÇ a b‚Äñ ‚â§
      1000011 * s ^ 7 / (2 - Real.exp s) := by
    rw [hLHS_eq]
    calc _ ‚â§ ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
          bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
          bch_quintic_term ùïÇ a b - bch_sextic_term ùïÇ a b‚Äñ +
          ‚Äñbch_septic_term ùïÇ a b‚Äñ := norm_sub_le _ _
      _ ‚â§ 1000010 * s ^ 7 / (2 - Real.exp s) + s ^ 7 := by linarith
      _ ‚â§ 1000010 * s ^ 7 / (2 - Real.exp s) + s ^ 7 / (2 - Real.exp s) := by
          gcongr; rw [le_div_iff‚ÇÄ hdenom]
          nlinarith [pow_nonneg hs_nn 7]
      _ = 1000011 * s ^ 7 / (2 - Real.exp s) := by ring
  -- Bound 1000011¬∑s‚Å∑ ‚â§ 10000110¬∑s‚Å∏ via 1000011 ‚â§ 10000110¬∑s (using s ‚â• 1/10)
  have h_le : 1000011 * s ^ 7 ‚â§ 10000110 * s ^ 8 := by
    have h1000011 : (1000011 : ‚Ñù) ‚â§ 10000110 * s := by linarith
    nlinarith [pow_nonneg hs_nn 7]
  calc _ ‚â§ 1000011 * s ^ 7 / (2 - Real.exp s) := hLHS_1000011
    _ ‚â§ 10000110 * s ^ 8 / (2 - Real.exp s) :=
        div_le_div_of_nonneg_right h_le hdenom.le

/-! ### Sextic remainder small-s case helpers

These are building blocks for the (future) `norm_bch_sextic_remainder_small_s_le`
which handles `s < 1/10` via the deg-5 cancellation in `sextic_pure_identity`.

Each helper is a self-contained lemma about non-commutative algebra,
provable by `noncomm_ring` after scalar clearing.
-/

/-- 5-fold non-commutative telescoping: `y‚Åµ - (y - P)‚Åµ` expands as a sum of
five 5-letter words, each with one `P` factor and four `y`/`(y-P)` factors. -/
private theorem pow5_sub_zpow5_telescope (y P : ùî∏) :
    y ^ 5 - (y - P) ^ 5 =
      y ^ 4 * P + y ^ 3 * P * (y - P) + y ^ 2 * P * (y - P) ^ 2 +
        y * P * (y - P) ^ 3 + P * (y - P) ^ 4 := by
  noncomm_ring

/-- 6-fold non-commutative telescoping: `y‚Å∂ - (y - P)‚Å∂` expands as a sum of
six 6-letter words, each with one `P` factor and five `y`/`(y-P)` factors. -/
private theorem pow6_sub_zpow6_telescope (y P : ùî∏) :
    y ^ 6 - (y - P) ^ 6 =
      y ^ 5 * P + y ^ 4 * P * (y - P) + y ^ 3 * P * (y - P) ^ 2 +
        y ^ 2 * P * (y - P) ^ 3 + y * P * (y - P) ^ 4 + P * (y - P) ^ 5 := by
  noncomm_ring

/-- 7-fold non-commutative telescoping: `y‚Å∑ - (y - P)‚Å∑` expands as a sum of
seven 7-letter words, each with one `P` factor and six `y`/`(y-P)` factors. -/
private theorem pow7_sub_zpow7_telescope (y P : ùî∏) :
    y ^ 7 - (y - P) ^ 7 =
      y ^ 6 * P + y ^ 5 * P * (y - P) + y ^ 4 * P * (y - P) ^ 2 +
        y ^ 3 * P * (y - P) ^ 3 + y ^ 2 * P * (y - P) ^ 4 +
        y * P * (y - P) ^ 5 + P * (y - P) ^ 6 := by
  noncomm_ring

/-- 4-fold non-commutative telescoping: `y‚Å¥ - (y - P)‚Å¥` expands as a sum of
four 4-letter words, each with one `P` factor and three `y`/`(y-P)` factors. -/
private theorem pow4_sub_zpow4_telescope (y P : ùî∏) :
    y ^ 4 - (y - P) ^ 4 =
      y ^ 3 * P + y ^ 2 * P * (y - P) + y * P * (y - P) ^ 2 + P * (y - P) ^ 3 := by
  noncomm_ring

/-- 3-fold non-commutative telescoping: `y¬≥ - (y - P)¬≥`. -/
private theorem pow3_sub_zpow3_telescope (y P : ùî∏) :
    y ^ 3 - (y - P) ^ 3 =
      y ^ 2 * P + y * P * (y - P) + P * (y - P) ^ 2 := by
  noncomm_ring

/-- Algebraic decomposition of `y‚Å¥ - z‚Å¥ - y4_5` where `z = y - P` and
`y4_5 = z¬≥T‚ÇÇ + z¬≤T‚ÇÇz + zT‚ÇÇz¬≤ + T‚ÇÇz¬≥` is the deg-5 contribution from
`y‚Å¥ = (z + T‚ÇÇ + ...)‚Å¥`. Expresses the difference as a sum of 7 deg-6+
terms in the BCH context where `‚Äñy‚Äñ ‚â§ 2s`, `‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñz‚Äñ ‚â§ s`,
`‚ÄñP-T‚ÇÇ‚Äñ ‚â§ 5s¬≥`. -/
private theorem y4_sub_z4_sub_y4_5_decomp (y P T‚ÇÇ : ùî∏) :
    y ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * T‚ÇÇ + (y - P) ^ 2 * T‚ÇÇ * (y - P) +
        (y - P) * T‚ÇÇ * (y - P) ^ 2 + T‚ÇÇ * (y - P) ^ 3) =
      (y - P) ^ 3 * (P - T‚ÇÇ) + (y - P) ^ 2 * (P - T‚ÇÇ) * (y - P) +
        (y - P) * (P - T‚ÇÇ) * (y - P) ^ 2 + (P - T‚ÇÇ) * (y - P) ^ 3 +
      (y ^ 3 - (y - P) ^ 3) * P + (y ^ 2 - (y - P) ^ 2) * P * (y - P) +
      P * P * (y - P) ^ 2 := by
  noncomm_ring

/-- Norm bound for the 5-fold telescoping: given `‚Äñy‚Äñ ‚â§ 2s`, `‚Äñz‚Äñ ‚â§ s`,
`‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñy‚Åµ - z‚Åµ‚Äñ ‚â§ 31¬∑s‚Å∂`. Used in the small-s case of the sextic
remainder bound. -/
private theorem norm_pow5_sub_zpow5_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 5 - (y - P) ^ 5‚Äñ ‚â§ 31 * s ^ 6 := by
  rw [pow5_sub_zpow5_telescope]
  -- 5 terms: y‚Å¥P + y¬≥P(y-P) + y¬≤P(y-P)¬≤ + yP(y-P)¬≥ + P(y-P)‚Å¥
  -- Bounds: 16s‚Å∂ + 8s‚Å∂ + 4s‚Å∂ + 2s‚Å∂ + s‚Å∂ = 31s‚Å∂
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  have h_y4P : ‚Äñy ^ 4 * P‚Äñ ‚â§ (2 * s) ^ 4 * s ^ 2 :=
    calc ‚Äñy ^ 4 * P‚Äñ ‚â§ ‚Äñy ^ 4‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñy‚Äñ ^ 4 * ‚ÄñP‚Äñ := by gcongr; exact norm_pow_le y 4
      _ ‚â§ (2 * s) ^ 4 * s ^ 2 :=
          mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 4) hP (by positivity) (by positivity)
  have h_y3Pz : ‚Äñy ^ 3 * P * z‚Äñ ‚â§ (2 * s) ^ 3 * s ^ 2 * s :=
    calc ‚Äñy ^ 3 * P * z‚Äñ ‚â§ ‚Äñy ^ 3 * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 3 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by
          gcongr
          calc _ ‚â§ ‚Äñy ^ 3‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
            _ ‚â§ _ := by gcongr; exact norm_pow_le y 3
      _ ‚â§ ((2 * s) ^ 3 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz2 : ‚Äñy ^ 2 * P * z ^ 2‚Äñ ‚â§ (2 * s) ^ 2 * s ^ 2 * s ^ 2 :=
    calc ‚Äñy ^ 2 * P * z ^ 2‚Äñ ‚â§ ‚Äñy ^ 2 * P‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 2 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 2‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 2
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ ((2 * s) ^ 2 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz3 : ‚Äñy * P * z ^ 3‚Äñ ‚â§ 2 * s * s ^ 2 * s ^ 3 :=
    calc ‚Äñy * P * z ^ 3‚Äñ ‚â§ ‚Äñy * P‚Äñ * ‚Äñz ^ 3‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 3 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 3
      _ ‚â§ (2 * s * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz4 : ‚ÄñP * z ^ 4‚Äñ ‚â§ s ^ 2 * s ^ 4 :=
    calc ‚ÄñP * z ^ 4‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñz ^ 4‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ * ‚Äñz‚Äñ ^ 4 := by gcongr; exact norm_pow_le z 4
      _ ‚â§ s ^ 2 * s ^ 4 := mul_le_mul hP (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 4)
          (by positivity) (by positivity)
  -- Sum via triangle inequality
  have ht1 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z + y ^ 2 * P * z ^ 2 + y * P * z ^ 3)
    (P * z ^ 4)
  have ht2 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z + y ^ 2 * P * z ^ 2) (y * P * z ^ 3)
  have ht3 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z) (y ^ 2 * P * z ^ 2)
  have ht4 := norm_add_le (y ^ 4 * P) (y ^ 3 * P * z)
  nlinarith [pow_nonneg hs_nn 6]

/-- Norm bound for the 6-fold telescoping: given `‚Äñy‚Äñ ‚â§ 2s`, `‚Äñz‚Äñ ‚â§ s`,
`‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñy‚Å∂ - z‚Å∂‚Äñ ‚â§ 63¬∑s‚Å∑`. Used in the small-s case of the septic
remainder bound (analog of `norm_pow5_sub_zpow5_le` at one degree higher).

Per-term bounds: `(2s)‚Åµ¬∑s¬≤ + (2s)‚Å¥¬∑s¬≤¬∑s + (2s)¬≥¬∑s¬≤¬∑s¬≤ + (2s)¬≤¬∑s¬≤¬∑s¬≥ +
                 (2s)¬∑s¬≤¬∑s‚Å¥ + s¬≤¬∑s‚Åµ
                = 32s‚Å∑ + 16s‚Å∑ + 8s‚Å∑ + 4s‚Å∑ + 2s‚Å∑ + s‚Å∑ = 63s‚Å∑`. -/
private theorem norm_pow6_sub_zpow6_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 6 - (y - P) ^ 6‚Äñ ‚â§ 63 * s ^ 7 := by
  rw [pow6_sub_zpow6_telescope]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  -- Six terms, bounded individually.
  have h_y5P : ‚Äñy ^ 5 * P‚Äñ ‚â§ (2 * s) ^ 5 * s ^ 2 :=
    calc ‚Äñy ^ 5 * P‚Äñ ‚â§ ‚Äñy ^ 5‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñy‚Äñ ^ 5 * ‚ÄñP‚Äñ := by gcongr; exact norm_pow_le y 5
      _ ‚â§ (2 * s) ^ 5 * s ^ 2 :=
          mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 5) hP (by positivity) (by positivity)
  have h_y4Pz : ‚Äñy ^ 4 * P * z‚Äñ ‚â§ (2 * s) ^ 4 * s ^ 2 * s :=
    calc ‚Äñy ^ 4 * P * z‚Äñ ‚â§ ‚Äñy ^ 4 * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 4 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by
          gcongr
          calc _ ‚â§ ‚Äñy ^ 4‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
            _ ‚â§ _ := by gcongr; exact norm_pow_le y 4
      _ ‚â§ ((2 * s) ^ 4 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 4) hP
            (norm_nonneg _) (by positivity)
  have h_y3Pz2 : ‚Äñy ^ 3 * P * z ^ 2‚Äñ ‚â§ (2 * s) ^ 3 * s ^ 2 * s ^ 2 :=
    calc ‚Äñy ^ 3 * P * z ^ 2‚Äñ ‚â§ ‚Äñy ^ 3 * P‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 3 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 3‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 3
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ ((2 * s) ^ 3 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz3 : ‚Äñy ^ 2 * P * z ^ 3‚Äñ ‚â§ (2 * s) ^ 2 * s ^ 2 * s ^ 3 :=
    calc ‚Äñy ^ 2 * P * z ^ 3‚Äñ ‚â§ ‚Äñy ^ 2 * P‚Äñ * ‚Äñz ^ 3‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 2 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 3 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 2‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 2
          ¬∑ exact norm_pow_le z 3
      _ ‚â§ ((2 * s) ^ 2 * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz4 : ‚Äñy * P * z ^ 4‚Äñ ‚â§ 2 * s * s ^ 2 * s ^ 4 :=
    calc ‚Äñy * P * z ^ 4‚Äñ ‚â§ ‚Äñy * P‚Äñ * ‚Äñz ^ 4‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 4 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 4
      _ ‚â§ (2 * s * s ^ 2) * s ^ 4 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 4)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz5 : ‚ÄñP * z ^ 5‚Äñ ‚â§ s ^ 2 * s ^ 5 :=
    calc ‚ÄñP * z ^ 5‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñz ^ 5‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ * ‚Äñz‚Äñ ^ 5 := by gcongr; exact norm_pow_le z 5
      _ ‚â§ s ^ 2 * s ^ 5 := mul_le_mul hP (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 5)
