          _ = s ^ 5 := by ring
      -- Step 6a: Set up the IтВБ/IтВВ decomposition (same as quartic proof)
      have h2ne : (2 : ЁЭХВ) тЙа 0 := two_ne_zero
      set Q := a * DтВВ + DтВБ * b + DтВБ * DтВВ with hQ_def
      set W_H1 := (2 : ЁЭХВ) тАв (EтВБ + EтВВ + a * DтВВ + DтВБ * b + DтВБ * DтВВ) -
