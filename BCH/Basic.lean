private theorem R_eq_neg_deg5_residual (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (ea eb a b : ùî∏) :
    let D‚ÇÅ : ùî∏ := ea - 1 - a
