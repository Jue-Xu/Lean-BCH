    calc _ ‚â§ ‚Äñz ^ 2‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñz‚Äñ ^ 2 * ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ := by gcongr; exact norm_pow_le z 2
      _ ‚â§ s ^ 2 * (K_PmT5 * s ^ 6) :=
