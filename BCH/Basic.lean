/-- **Lipschitz bound for `bch_quintic_group_24` in its first argument**:
`тАЦgroup_24(z, y) тИТ group_24(x, y)тАЦ тЙд 5 ┬╖ (тАЦzтАЦ+тАЦxтАЦ+тАЦyтАЦ)тБ┤ ┬╖ тАЦz тИТ xтАЦ`.

`bch_quintic_group_24 = a┬╖b┬╖a┬╖b┬╖a + b┬╖a┬╖b┬╖a┬╖b` has 2 words with a-position
counts `{3, 2}`, summing to 5 telescoping summands. -/
theorem norm_bch_quintic_group_24_diff_le (z x y : ЁЭФ╕) :
    тАЦbch_quintic_group_24 z y - bch_quintic_group_24 x yтАЦ тЙд
      5 * (тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ) ^ 4 * тАЦz - xтАЦ := by
  have htel : bch_quintic_group_24 z y - bch_quintic_group_24 x y =
      -- word 1: z┬╖y┬╖z┬╖y┬╖z (3 summands)
      (z - x) * y * z * y * z + x * y * (z - x) * y * z + x * y * x * y * (z - x) +
      -- word 2: y┬╖z┬╖y┬╖z┬╖y (2 summands)
      y * (z - x) * y * z * y + y * x * y * (z - x) * y := by
    unfold bch_quintic_group_24
    noncomm_ring
  rw [htel]
  set M := тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ with hM_def
  set d := тАЦz - xтАЦ with hd_def
  have hd_nn : 0 тЙд d := norm_nonneg _
  have hz_le : тАЦzтАЦ тЙд M := by
    show тАЦzтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg x, norm_nonneg y]
  have hx_le : тАЦxтАЦ тЙд M := by
    show тАЦxтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg y]
  have hy_le : тАЦyтАЦ тЙд M := by
    show тАЦyтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg x]
  have h1 : тАЦ(z - x) * y * z * y * zтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦyтАЦ * тАЦzтАЦ * тАЦyтАЦ * тАЦzтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд d * M * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h2 : тАЦx * y * (z - x) * y * zтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦyтАЦ * тАЦz - xтАЦ * тАЦyтАЦ * тАЦzтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h3 : тАЦx * y * x * y * (z - x)тАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦyтАЦ * тАЦxтАЦ * тАЦyтАЦ * тАЦz - xтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * M * M * d := by gcongr
      _ = M ^ 4 * d := by ring
  have h4 : тАЦy * (z - x) * y * z * yтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦz - xтАЦ * тАЦyтАЦ * тАЦzтАЦ * тАЦyтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * d * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h5 : тАЦy * x * y * (z - x) * yтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦxтАЦ * тАЦyтАЦ * тАЦz - xтАЦ * тАЦyтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * M * d * M := by gcongr
      _ = M ^ 4 * d := by ring
  set s1 : ЁЭФ╕ := (z - x) * y * z * y * z
  set s2 : ЁЭФ╕ := x * y * (z - x) * y * z
  set s3 : ЁЭФ╕ := x * y * x * y * (z - x)
  set s4 : ЁЭФ╕ := y * (z - x) * y * z * y
  set s5 : ЁЭФ╕ := y * x * y * (z - x) * y
  have a4 := norm_add_le (s1 + s2 + s3 + s4) s5
  have a3 := norm_add_le (s1 + s2 + s3) s4
  have a2 := norm_add_le (s1 + s2) s3
  have a1 := norm_add_le s1 s2
  linarith

