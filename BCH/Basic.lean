/-- **Lipschitz bound for `bch_quintic_group_4` in its first argument**:
`тАЦgroup_4(z, y) тИТ group_4(x, y)тАЦ тЙд 25 ┬╖ (тАЦzтАЦ+тАЦxтАЦ+тАЦyтАЦ)тБ┤ ┬╖ тАЦz тИТ xтАЦ`.

`bch_quintic_group_4` has 10 words; the a-position counts are
`{4, 3, 2, 4, 2, 3, 1, 3, 2, 1}`, summing to 25 telescoping summands.
Proof structure mirrors `norm_bch_quintic_group_1_diff_le`: telescoping
identity (`noncomm_ring`) + per-summand 5-product norm bound + 24-step
triangle inequality. -/
theorem norm_bch_quintic_group_4_diff_le (z x y : ЁЭФ╕) :
    тАЦbch_quintic_group_4 z y - bch_quintic_group_4 x yтАЦ тЙд
      25 * (тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ) ^ 4 * тАЦz - xтАЦ := by
  have htel : bch_quintic_group_4 z y - bch_quintic_group_4 x y =
      -- word 1: z┬╖z┬╖z┬╖y┬╖z (4 summands)
      (z - x) * z * z * y * z + x * (z - x) * z * y * z +
      x * x * (z - x) * y * z + x * x * x * y * (z - x) +
      -- word 2: z┬╖z┬╖z┬╖y┬╖y (3 summands)
      (z - x) * z * z * y * y + x * (z - x) * z * y * y +
      x * x * (z - x) * y * y +
      -- word 3: z┬╖z┬╖y┬╖y┬╖y (2 summands)
      (z - x) * z * y * y * y + x * (z - x) * y * y * y +
      -- word 4: z┬╖y┬╖z┬╖z┬╖z (4 summands)
      (z - x) * y * z * z * z + x * y * (z - x) * z * z +
      x * y * x * (z - x) * z + x * y * x * x * (z - x) +
      -- word 5: z┬╖y┬╖y┬╖y┬╖z (2 summands)
      (z - x) * y * y * y * z + x * y * y * y * (z - x) +
      -- word 6: y┬╖z┬╖z┬╖z┬╖y (3 summands)
      y * (z - x) * z * z * y + y * x * (z - x) * z * y +
      y * x * x * (z - x) * y +
      -- word 7: y┬╖z┬╖y┬╖y┬╖y (1 summand)
      y * (z - x) * y * y * y +
      -- word 8: y┬╖y┬╖z┬╖z┬╖z (3 summands)
      y * y * (z - x) * z * z + y * y * x * (z - x) * z +
      y * y * x * x * (z - x) +
      -- word 9: y┬╖y┬╖y┬╖z┬╖z (2 summands)
      y * y * y * (z - x) * z + y * y * y * x * (z - x) +
      -- word 10: y┬╖y┬╖y┬╖z┬╖y (1 summand)
      y * y * y * (z - x) * y := by
    unfold bch_quintic_group_4
    noncomm_ring
  rw [htel]
  set M := тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ with hM_def
  set d := тАЦz - xтАЦ with hd_def
  have hd_nn : 0 тЙд d := norm_nonneg _
  have hz_le : тАЦzтАЦ тЙд M := by
    show тАЦzтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg x, norm_nonneg y]
  have hx_le : тАЦxтАЦ тЙд M := by
    show тАЦxтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg y]
  have hy_le : тАЦyтАЦ тЙд M := by
    show тАЦyтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg x]
  -- Per-summand bounds. Each is MтБ┤┬╖d via norm_5prod_le.
  -- We inline a single helper macro-ish pattern.
  have hM4d : тИА (aтВБ aтВВ aтВГ aтВД aтВЕ : ЁЭФ╕),
      тАЦaтВБтАЦ тЙд M тЖТ тАЦaтВВтАЦ тЙд M тЖТ тАЦaтВГтАЦ тЙд M тЖТ тАЦaтВДтАЦ тЙд M тЖТ тАЦaтВЕтАЦ тЙд M тЖТ
      тАЦaтВБ * aтВВ * aтВГ * aтВД * aтВЕтАЦ тЙд M ^ 5 := fun aтВБ aтВВ aтВГ aтВД aтВЕ hтВБ hтВВ hтВГ hтВД hтВЕ => by
    calc _ тЙд тАЦaтВБтАЦ * тАЦaтВВтАЦ * тАЦaтВГтАЦ * тАЦaтВДтАЦ * тАЦaтВЕтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * M * M * M := by gcongr
      _ = M ^ 5 := by ring
  -- Key lemma: any 5-product with one (z-x) and four тЙдM factors is тЙд MтБ┤┬╖d.
  -- Cases: (z-x) at position 1, 2, 3, 4, or 5.
  have hL1 : тИА a b c d' : ЁЭФ╕, тАЦaтАЦ тЙд M тЖТ тАЦbтАЦ тЙд M тЖТ тАЦcтАЦ тЙд M тЖТ тАЦd'тАЦ тЙд M тЖТ
      тАЦ(z - x) * a * b * c * d'тАЦ тЙд M ^ 4 * d := fun a b c d' ha hb hc hd' => by
    calc _ тЙд тАЦz - xтАЦ * тАЦaтАЦ * тАЦbтАЦ * тАЦcтАЦ * тАЦd'тАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд d * M * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have hL2 : тИА a b c d' : ЁЭФ╕, тАЦaтАЦ тЙд M тЖТ тАЦbтАЦ тЙд M тЖТ тАЦcтАЦ тЙд M тЖТ тАЦd'тАЦ тЙд M тЖТ
      тАЦa * (z - x) * b * c * d'тАЦ тЙд M ^ 4 * d := fun a b c d' ha hb hc hd' => by
    calc _ тЙд тАЦaтАЦ * тАЦz - xтАЦ * тАЦbтАЦ * тАЦcтАЦ * тАЦd'тАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * d * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have hL3 : тИА a b c d' : ЁЭФ╕, тАЦaтАЦ тЙд M тЖТ тАЦbтАЦ тЙд M тЖТ тАЦcтАЦ тЙд M тЖТ тАЦd'тАЦ тЙд M тЖТ
      тАЦa * b * (z - x) * c * d'тАЦ тЙд M ^ 4 * d := fun a b c d' ha hb hc hd' => by
    calc _ тЙд тАЦaтАЦ * тАЦbтАЦ * тАЦz - xтАЦ * тАЦcтАЦ * тАЦd'тАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have hL4 : тИА a b c d' : ЁЭФ╕, тАЦaтАЦ тЙд M тЖТ тАЦbтАЦ тЙд M тЖТ тАЦcтАЦ тЙд M тЖТ тАЦd'тАЦ тЙд M тЖТ
      тАЦa * b * c * (z - x) * d'тАЦ тЙд M ^ 4 * d := fun a b c d' ha hb hc hd' => by
    calc _ тЙд тАЦaтАЦ * тАЦbтАЦ * тАЦcтАЦ * тАЦz - xтАЦ * тАЦd'тАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * M * d * M := by gcongr
      _ = M ^ 4 * d := by ring
  have hL5 : тИА a b c d' : ЁЭФ╕, тАЦaтАЦ тЙд M тЖТ тАЦbтАЦ тЙд M тЖТ тАЦcтАЦ тЙд M тЖТ тАЦd'тАЦ тЙд M тЖТ
      тАЦa * b * c * d' * (z - x)тАЦ тЙд M ^ 4 * d := fun a b c d' ha hb hc hd' => by
    calc _ тЙд тАЦaтАЦ * тАЦbтАЦ * тАЦcтАЦ * тАЦd'тАЦ * тАЦz - xтАЦ := norm_5prod_le _ _ _ _ _
      _ тЙд M * M * M * M * d := by gcongr
      _ = M ^ 4 * d := by ring
  -- Apply per-summand bounds. 25 summands.
  have h1  := hL1 z z y z hz_le hz_le hy_le hz_le
  have h2  := hL2 x z y z hx_le hz_le hy_le hz_le
  have h3  := hL3 x x y z hx_le hx_le hy_le hz_le
  have h4  := hL5 x x x y hx_le hx_le hx_le hy_le
  have h5  := hL1 z z y y hz_le hz_le hy_le hy_le
  have h6  := hL2 x z y y hx_le hz_le hy_le hy_le
  have h7  := hL3 x x y y hx_le hx_le hy_le hy_le
  have h8  := hL1 z y y y hz_le hy_le hy_le hy_le
  have h9  := hL2 x y y y hx_le hy_le hy_le hy_le
  have h10 := hL1 y z z z hy_le hz_le hz_le hz_le
  have h11 := hL3 x y z z hx_le hy_le hz_le hz_le
  have h12 := hL4 x y x z hx_le hy_le hx_le hz_le
  have h13 := hL5 x y x x hx_le hy_le hx_le hx_le
  have h14 := hL1 y y y z hy_le hy_le hy_le hz_le
  have h15 := hL5 x y y y hx_le hy_le hy_le hy_le
  have h16 := hL2 y z z y hy_le hz_le hz_le hy_le
  have h17 := hL3 y x z y hy_le hx_le hz_le hy_le
  have h18 := hL4 y x x y hy_le hx_le hx_le hy_le
  have h19 := hL2 y y y y hy_le hy_le hy_le hy_le
