      calc _ тЙд тАЦ(a' + b) * (W * a' - a' * W)тАЦ + тАЦ(W * a' - a' * W) * (a' + b)тАЦ := by
            rw [sub_eq_add_neg]; exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд тАЦa' + bтАЦ * (2 * тАЦWтАЦ * тАЦa'тАЦ) + (2 * тАЦWтАЦ * тАЦa'тАЦ) * тАЦa' + bтАЦ := by
            gcongr
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_left hcomm_Wa' hp_nn)
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hcomm_Wa' hp_nn)
        _ = 4 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ := by ring
    have h2 : тАЦW * ((a' + b) * a' - a' * (a' + b)) -
        ((a' + b) * a' - a' * (a' + b)) * WтАЦ тЙд 4 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ := by
      calc _ тЙд тАЦW * ((a' + b) * a' - a' * (a' + b))тАЦ +
             тАЦ((a' + b) * a' - a' * (a' + b)) * WтАЦ := by
            rw [sub_eq_add_neg]; exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд тАЦWтАЦ * (2 * тАЦa' + bтАЦ * тАЦa'тАЦ) + (2 * тАЦa' + bтАЦ * тАЦa'тАЦ) * тАЦWтАЦ := by
            gcongr
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_left hcomm_pa' hW_nn)
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hcomm_pa' hW_nn)
        _ = 4 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ := by ring
    have h3 : тАЦW * (W * a' - a' * W) - (W * a' - a' * W) * WтАЦ тЙд 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
      calc _ тЙд тАЦW * (W * a' - a' * W)тАЦ + тАЦ(W * a' - a' * W) * WтАЦ := by
            rw [sub_eq_add_neg]; exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд тАЦWтАЦ * (2 * тАЦWтАЦ * тАЦa'тАЦ) + (2 * тАЦWтАЦ * тАЦa'тАЦ) * тАЦWтАЦ := by
            gcongr
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_left hcomm_Wa' hW_nn)
            ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hcomm_Wa' hW_nn)
        _ = 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
    calc тАЦS6тАЦ тЙд тАЦ((a' + b) * (W * a' - a' * W) - (W * a' - a' * W) * (a' + b)) +
                 (W * ((a' + b) * a' - a' * (a' + b)) -
                  ((a' + b) * a' - a' * (a' + b)) * W)тАЦ +
                тАЦW * (W * a' - a' * W) - (W * a' - a' * W) * WтАЦ := norm_add_le _ _
      _ тЙд тАЦ(a' + b) * (W * a' - a' * W) - (W * a' - a' * W) * (a' + b)тАЦ +
          тАЦW * ((a' + b) * a' - a' * (a' + b)) -
           ((a' + b) * a' - a' * (a' + b)) * WтАЦ +
          тАЦW * (W * a' - a' * W) - (W * a' - a' * W) * WтАЦ := by
            linarith [norm_add_le
              ((a' + b) * (W * a' - a' * W) - (W * a' - a' * W) * (a' + b))
              (W * ((a' + b) * a' - a' * (a' + b)) -
               ((a' + b) * a' - a' * (a' + b)) * W)]
      _ тЙд 4 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ + 4 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ +
          4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by linarith
      _ = 8 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ + 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
  -- TERM 6 norm bound: тАЦCтВД(z,a') - CтВД(a'+b,a')тАЦ тЙд 2┬╖sтБ╡
  have hT6 : тАЦbch_quartic_term ЁЭХВ z a' - bch_quartic_term ЁЭХВ (a' + b) a'тАЦ тЙд 2 * s ^ 5 := by
    rw [hT6_id]
    have h24_inv : тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ = (24 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
    have hcomm_S6 : тАЦa' * S6 - S6 * a'тАЦ тЙд 2 * тАЦa'тАЦ * тАЦS6тАЦ := by
      calc _ тЙд тАЦa' * S6тАЦ + тАЦS6 * a'тАЦ := by
            rw [sub_eq_add_neg]; exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд тАЦa'тАЦ * тАЦS6тАЦ + тАЦS6тАЦ * тАЦa'тАЦ := by gcongr <;> exact norm_mul_le _ _
        _ = 2 * тАЦa'тАЦ * тАЦS6тАЦ := by ring
    have hS6_nn : (0 : тДЭ) тЙд тАЦS6тАЦ := norm_nonneg _
    have ha'_nn : (0 : тДЭ) тЙд тАЦa'тАЦ := norm_nonneg _
    have hS6_explicit : тАЦS6тАЦ тЙд 8 * (3/2 * s) * (48/11 * s^2) * (s/2) +
        4 * (48/11 * s^2) ^ 2 * (s/2) := by
      calc тАЦS6тАЦ тЙд 8 * тАЦa' + bтАЦ * тАЦWтАЦ * тАЦa'тАЦ + 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := hS6_bound
        _ тЙд 8 * (3/2 * s) * (48/11 * s^2) * (s/2) + 4 * (48/11 * s^2) ^ 2 * (s/2) := by
            gcongr
    calc тАЦ-((24 : ЁЭХВ)тБ╗┬╣ тАв (a' * S6 - S6 * a'))тАЦ
        = тАЦ(24 : ЁЭХВ)тБ╗┬╣ тАв (a' * S6 - S6 * a')тАЦ := norm_neg _
      _ тЙд тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa' * S6 - S6 * a'тАЦ := norm_smul_le _ _
      _ = (1 / 24) * тАЦa' * S6 - S6 * a'тАЦ := by rw [h24_inv]; ring
      _ тЙд (1 / 24) * (2 * тАЦa'тАЦ * тАЦS6тАЦ) := by
          apply mul_le_mul_of_nonneg_left hcomm_S6 (by norm_num)
      _ тЙд (1 / 24) * (2 * (s / 2) *
            (8 * (3/2 * s) * (48/11 * s^2) * (s/2) + 4 * (48/11 * s^2) ^ 2 * (s/2))) := by
          apply mul_le_mul_of_nonneg_left _ (by norm_num)
          apply mul_le_mul _ hS6_explicit hS6_nn (by positivity)
          apply mul_le_mul_of_nonneg_left ha'_s (by norm_num)
      _ тЙд 2 * s ^ 5 := by nlinarith [pow_nonneg hs_nn 5, hs_lt, sq_nonneg s]
  -- TERM 5: CтВГ(z, a') - CтВГ(a'+b, a') + (96)тБ╗┬╣┬╖[b, DC_a] via cancellation
  set WтВВ : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') with hWтВВ_def
  set W_rest : ЁЭФ╕ := W - WтВВ with hWrest_def
  -- Explicit linear-in-╬╛ and quadratic-in-╬╛ polynomials (with p = a'+b)
  -- L(╬╛) := ((a'+b)╬╛ + ╬╛(a'+b))a' - 2((a'+b)a'╬╛ + ╬╛a'(a'+b)) + a'((a'+b)╬╛ + ╬╛(a'+b))
  --       + a'a'╬╛ - 2(a'╬╛a') + ╬╛a'a'
  -- Q(╬╛) := ╬╛╬╛a' - 2(╬╛a'╬╛) + a'╬╛╬╛
  set L_W : ЁЭФ╕ :=
    ((a' + b) * W + W * (a' + b)) * a' -
    ((a' + b) * a' * W + W * a' * (a' + b)) -
    ((a' + b) * a' * W + W * a' * (a' + b)) +
    a' * ((a' + b) * W + W * (a' + b)) +
    a' * a' * W - a' * W * a' - a' * W * a' + W * a' * a' with hL_W_def
  set L_Wrest : ЁЭФ╕ :=
    ((a' + b) * W_rest + W_rest * (a' + b)) * a' -
    ((a' + b) * a' * W_rest + W_rest * a' * (a' + b)) -
    ((a' + b) * a' * W_rest + W_rest * a' * (a' + b)) +
    a' * ((a' + b) * W_rest + W_rest * (a' + b)) +
    a' * a' * W_rest - a' * W_rest * a' - a' * W_rest * a' + W_rest * a' * a'
    with hL_Wrest_def
  set L_W2 : ЁЭФ╕ :=
    ((a' + b) * WтВВ + WтВВ * (a' + b)) * a' -
    ((a' + b) * a' * WтВВ + WтВВ * a' * (a' + b)) -
    ((a' + b) * a' * WтВВ + WтВВ * a' * (a' + b)) +
    a' * ((a' + b) * WтВВ + WтВВ * (a' + b)) +
    a' * a' * WтВВ - a' * WтВВ * a' - a' * WтВВ * a' + WтВВ * a' * a' with hL_W2_def
  set Q_W : ЁЭФ╕ := W * W * a' - W * a' * W - W * a' * W + a' * W * W with hQ_W_def
  -- Identity 1: bch_cubic_term diff = (12)тБ╗┬╣тАвL_W + (12)тБ╗┬╣тАвQ_W
  have hId1 : bch_cubic_term ЁЭХВ z a' - bch_cubic_term ЁЭХВ (a' + b) a' =
      (12 : ЁЭХВ)тБ╗┬╣ тАв L_W + (12 : ЁЭХВ)тБ╗┬╣ тАв Q_W := by
    rw [hz_eq, hL_W_def, hQ_W_def]
    unfold bch_cubic_term
    simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm,
      smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
    match_scalars <;> ring
  -- Identity 3: L_W = L_Wrest + L_W2 (linearity in ╬╛)
  have hId3 : L_W = L_Wrest + L_W2 := by
    rw [hL_W_def, hL_Wrest_def, hL_W2_def, hWrest_def]
    noncomm_ring
  -- Identity 2 (cancellation): (12)тБ╗┬╣тАвL_W2 + (96)тБ╗┬╣тАв(b┬╖DC_a - DC_a┬╖b) = 0
  have hId2 : (12 : ЁЭХВ)тБ╗┬╣ тАв L_W2 + (96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b) = 0 := by
    rw [hL_W2_def, hWтВВ_def, hDC_a_def, ha'_def]
    simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm,
      smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
    match_scalars <;> ring
  -- Combine: Term5 = (12)тБ╗┬╣тАвL_Wrest + (12)тБ╗┬╣тАвQ_W
  have hT5_id : bch_cubic_term ЁЭХВ z a' - bch_cubic_term ЁЭХВ (a' + b) a' -
        -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b)) =
      (12 : ЁЭХВ)тБ╗┬╣ тАв L_Wrest + (12 : ЁЭХВ)тБ╗┬╣ тАв Q_W := by
    rw [sub_neg_eq_add, hId1, hId3, smul_add]
    have h := hId2
    have rearr :
        (12 : ЁЭХВ)тБ╗┬╣ тАв L_Wrest + (12 : ЁЭХВ)тБ╗┬╣ тАв L_W2 + (12 : ЁЭХВ)тБ╗┬╣ тАв Q_W +
          (96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b) =
        (12 : ЁЭХВ)тБ╗┬╣ тАв L_Wrest + (12 : ЁЭХВ)тБ╗┬╣ тАв Q_W +
          ((12 : ЁЭХВ)тБ╗┬╣ тАв L_W2 + (96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b)) := by abel
    rw [rearr, h, add_zero]
  -- Norm bound on W_rest: W_rest = RтВБ + CтВГ(a',b) + CтВД(a',b)
  have hWrest_eq : W_rest = RтВБ + bch_cubic_term ЁЭХВ a' b + bch_quartic_term ЁЭХВ a' b := by
    rw [hRтВБ_def]; abel
  have hCтВГ_ab_le : тАЦbch_cubic_term ЁЭХВ a' bтАЦ тЙд s ^ 3 := by
    calc _ тЙд (тАЦa'тАЦ + тАЦbтАЦ) ^ 3 := norm_bch_cubic_term_le a' b
      _ = sтВБ ^ 3 := by rw [тЖР hsтВБ_def]
      _ тЙд s ^ 3 := pow_le_pow_leftтВА hsтВБ_nn hsтВБ_le 3
  have hWrest_le : тАЦW_restтАЦ тЙд 5000 * s ^ 5 + s ^ 3 + s ^ 4 := by
    rw [hWrest_eq]
    calc _ тЙд тАЦRтВБ + bch_cubic_term ЁЭХВ a' bтАЦ + тАЦbch_quartic_term ЁЭХВ a' bтАЦ :=
          norm_add_le _ _
      _ тЙд тАЦRтВБтАЦ + тАЦbch_cubic_term ЁЭХВ a' bтАЦ + тАЦbch_quartic_term ЁЭХВ a' bтАЦ := by
          linarith [norm_add_le RтВБ (bch_cubic_term ЁЭХВ a' b)]
      _ тЙд 5000 * s ^ 5 + s ^ 3 + s ^ 4 := by linarith [hRтВБ_s5, hCтВГ_ab_le, hCтВД_s4]
  -- Norm bound on L_Wrest: тЙд 8┬╖тАЦa'+bтАЦ┬╖тАЦa'тАЦ┬╖тАЦW_restтАЦ + 4┬╖тАЦa'тАЦ┬▓┬╖тАЦW_restтАЦ
  have hL_Wrest_bound : тАЦL_WrestтАЦ тЙд
      8 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ + 4 * тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by
    rw [hL_Wrest_def]
    -- L_Wrest = A + a'*(...) + a'a'W_rest - a'W_rest a' - a'W_rest a' + W_rest a' a'
    -- where A = ((a'+b)*W_rest + W_rest*(a'+b))*a' - 2((a'+b)a'W_rest + W_rest a'(a'+b))
    -- We'll use a series of norm_add_le triangulations.
    have ha'_nn : (0 : тДЭ) тЙд тАЦa'тАЦ := norm_nonneg _
    have hWrest_nn : (0 : тДЭ) тЙд тАЦW_restтАЦ := norm_nonneg _
    -- Key mini-bounds:
    have e1 : тАЦ((a' + b) * W_rest + W_rest * (a' + b)) * a'тАЦ тЙд
        2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ := by
      calc _ тЙд тАЦ(a' + b) * W_rest + W_rest * (a' + b)тАЦ * тАЦa'тАЦ := norm_mul_le _ _
        _ тЙд (тАЦ(a' + b) * W_restтАЦ + тАЦW_rest * (a' + b)тАЦ) * тАЦa'тАЦ := by
            gcongr; exact norm_add_le _ _
        _ тЙд (тАЦa' + bтАЦ * тАЦW_restтАЦ + тАЦW_restтАЦ * тАЦa' + bтАЦ) * тАЦa'тАЦ := by
            gcongr <;> exact norm_mul_le _ _
        _ = 2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ := by ring
    have e2 : тАЦ(a' + b) * a' * W_rest + W_rest * a' * (a' + b)тАЦ тЙд
        2 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ := by
      calc _ тЙд тАЦ(a' + b) * a' * W_restтАЦ + тАЦW_rest * a' * (a' + b)тАЦ := norm_add_le _ _
        _ тЙд тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ + тАЦW_restтАЦ * тАЦa'тАЦ * тАЦa' + bтАЦ := by
            gcongr
            ┬╖ exact (norm_mul_le _ _).trans
                (mul_le_mul_of_nonneg_right (norm_mul_le _ _) hWrest_nn)
            ┬╖ exact (norm_mul_le _ _).trans
                (mul_le_mul_of_nonneg_right (norm_mul_le _ _) hp_nn)
        _ = 2 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ := by ring
    have e3 : тАЦa' * ((a' + b) * W_rest + W_rest * (a' + b))тАЦ тЙд
        2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ := by
      calc _ тЙд тАЦa'тАЦ * тАЦ(a' + b) * W_rest + W_rest * (a' + b)тАЦ := norm_mul_le _ _
        _ тЙд тАЦa'тАЦ * (тАЦ(a' + b) * W_restтАЦ + тАЦW_rest * (a' + b)тАЦ) := by
            gcongr; exact norm_add_le _ _
        _ тЙд тАЦa'тАЦ * (тАЦa' + bтАЦ * тАЦW_restтАЦ + тАЦW_restтАЦ * тАЦa' + bтАЦ) := by
            gcongr <;> exact norm_mul_le _ _
        _ = 2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ := by ring
    have e4 : тАЦa' * a' * W_restтАЦ тЙд тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by
      calc _ тЙд тАЦa' * a'тАЦ * тАЦW_restтАЦ := norm_mul_le _ _
        _ тЙд (тАЦa'тАЦ * тАЦa'тАЦ) * тАЦW_restтАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by ring
    have e5 : тАЦa' * W_rest * a'тАЦ тЙд тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by
      calc _ тЙд тАЦa' * W_restтАЦ * тАЦa'тАЦ := norm_mul_le _ _
        _ тЙд тАЦa'тАЦ * тАЦW_restтАЦ * тАЦa'тАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by ring
    have e6 : тАЦW_rest * a' * a'тАЦ тЙд тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by
      calc _ тЙд тАЦW_rest * a'тАЦ * тАЦa'тАЦ := norm_mul_le _ _
        _ тЙд (тАЦW_restтАЦ * тАЦa'тАЦ) * тАЦa'тАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by ring
    -- Rewrite the L_Wrest expression as a pure sum (replace - with +(-))
    set X1 : ЁЭФ╕ := ((a' + b) * W_rest + W_rest * (a' + b)) * a' with hX1
    set X2 : ЁЭФ╕ := (a' + b) * a' * W_rest + W_rest * a' * (a' + b) with hX2
    set X3 : ЁЭФ╕ := a' * ((a' + b) * W_rest + W_rest * (a' + b)) with hX3
    set X4 : ЁЭФ╕ := a' * a' * W_rest with hX4
    set X5 : ЁЭФ╕ := a' * W_rest * a' with hX5
    set X6 : ЁЭФ╕ := W_rest * a' * a' with hX6
    have hsum_eq : X1 - X2 - X2 + X3 + X4 - X5 - X5 + X6 =
        X1 + -X2 + -X2 + X3 + X4 + -X5 + -X5 + X6 := by abel
    calc тАЦX1 - X2 - X2 + X3 + X4 - X5 - X5 + X6тАЦ
        = тАЦX1 + -X2 + -X2 + X3 + X4 + -X5 + -X5 + X6тАЦ := by rw [hsum_eq]
      _ тЙд тАЦX1тАЦ + тАЦX2тАЦ + тАЦX2тАЦ + тАЦX3тАЦ + тАЦX4тАЦ + тАЦX5тАЦ + тАЦX5тАЦ + тАЦX6тАЦ := by
          have a7 := norm_add_le (X1 + -X2 + -X2 + X3 + X4 + -X5 + -X5) X6
          have a6 := norm_add_le (X1 + -X2 + -X2 + X3 + X4 + -X5) (-X5)
          have a5 := norm_add_le (X1 + -X2 + -X2 + X3 + X4) (-X5)
          have a4 := norm_add_le (X1 + -X2 + -X2 + X3) X4
          have a3 := norm_add_le (X1 + -X2 + -X2) X3
          have a2 := norm_add_le (X1 + -X2) (-X2)
          have a1 := norm_add_le X1 (-X2)
          simp only [norm_neg] at a1 a2 a5 a6
          linarith
      _ тЙд 2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ +
          2 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ +
          2 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ +
          2 * тАЦa' + bтАЦ * тАЦW_restтАЦ * тАЦa'тАЦ +
          тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ + тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ + тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ +
          тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by linarith [e1, e2, e3, e4, e5, e6]
      _ = 8 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ + 4 * тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ := by ring
  -- Norm bound on Q_W: тЙд 4┬╖тАЦWтАЦ┬▓┬╖тАЦa'тАЦ
  have hQ_W_bound : тАЦQ_WтАЦ тЙд 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
    rw [hQ_W_def]
    have q1 : тАЦW * W * a'тАЦ тЙд тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
      calc _ тЙд тАЦW * WтАЦ * тАЦa'тАЦ := norm_mul_le _ _
        _ тЙд (тАЦWтАЦ * тАЦWтАЦ) * тАЦa'тАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
    have q2 : тАЦW * a' * WтАЦ тЙд тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
      calc _ тЙд тАЦW * a'тАЦ * тАЦWтАЦ := norm_mul_le _ _
        _ тЙд (тАЦWтАЦ * тАЦa'тАЦ) * тАЦWтАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
    have q3 : тАЦa' * W * WтАЦ тЙд тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
      calc _ тЙд тАЦa' * WтАЦ * тАЦWтАЦ := norm_mul_le _ _
        _ тЙд (тАЦa'тАЦ * тАЦWтАЦ) * тАЦWтАЦ := by gcongr; exact norm_mul_le _ _
        _ = тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
    calc тАЦW * W * a' - W * a' * W - W * a' * W + a' * W * WтАЦ
        тЙд тАЦW * W * a'тАЦ + тАЦW * a' * WтАЦ + тАЦW * a' * WтАЦ + тАЦa' * W * WтАЦ := by
          have h : W * W * a' - W * a' * W - W * a' * W + a' * W * W =
              W * W * a' + -(W * a' * W) + -(W * a' * W) + a' * W * W := by abel
          rw [h]
          have a3 := norm_add_le (W * W * a' + -(W * a' * W) + -(W * a' * W)) (a' * W * W)
          have a2 := norm_add_le (W * W * a' + -(W * a' * W)) (-(W * a' * W))
          have a1 := norm_add_le (W * W * a') (-(W * a' * W))
          simp only [norm_neg] at a1 a2
          linarith
      _ тЙд тАЦWтАЦ ^ 2 * тАЦa'тАЦ + тАЦWтАЦ ^ 2 * тАЦa'тАЦ + тАЦWтАЦ ^ 2 * тАЦa'тАЦ + тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by
          linarith
      _ = 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := by ring
  -- TERM 5 total bound: тЙд 500┬╖sтБ╡
  have hT5 : тАЦbch_cubic_term ЁЭХВ z a' - bch_cubic_term ЁЭХВ (a' + b) a' -
      -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b))тАЦ тЙд 500 * s ^ 5 := by
    rw [hT5_id]
    have h12_inv : тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ = (12 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
    -- тАЦ(12)тБ╗┬╣ тАв L_WrestтАЦ тЙд (1/12) ┬╖ (8┬╖(3s/2)┬╖(s/2)┬╖тАЦW_restтАЦ + 4┬╖(s/2)┬▓┬╖тАЦW_restтАЦ)
    -- тЙд (1/12) ┬╖ (6s┬▓┬╖тАЦW_restтАЦ + s┬▓┬╖тАЦW_restтАЦ) = (7/12)┬╖s┬▓┬╖тАЦW_restтАЦ
    -- With тАЦW_restтАЦ тЙд 5000┬╖sтБ╡ + s┬│ + sтБ┤:
    -- (7/12)┬╖s┬▓┬╖(5000┬╖sтБ╡ + s┬│ + sтБ┤) = (7/12)┬╖(5000┬╖sтБ╖ + sтБ╡ + sтБ╢)
    -- For s тЙд 1/4: sтБ╖ тЙд sтБ╡/16, sтБ╢ тЙд sтБ╡/4
    -- = (7/12) ┬╖ (5000/16 + 1 + 1/4) ┬╖ sтБ╡ = (7/12) ┬╖ (312.5 + 1.25) ┬╖ sтБ╡ тЙИ 183┬╖sтБ╡
    have hL_Wrest_s : тАЦL_WrestтАЦ тЙд 7 * s ^ 2 * тАЦW_restтАЦ := by
      have hWrest_nn : (0 : тДЭ) тЙд тАЦW_restтАЦ := norm_nonneg _
      calc тАЦL_WrestтАЦ тЙд 8 * тАЦa' + bтАЦ * тАЦa'тАЦ * тАЦW_restтАЦ + 4 * тАЦa'тАЦ ^ 2 * тАЦW_restтАЦ :=
            hL_Wrest_bound
        _ тЙд 8 * (3 / 2 * s) * (s / 2) * тАЦW_restтАЦ + 4 * (s / 2) ^ 2 * тАЦW_restтАЦ := by
            gcongr
        _ = 6 * s ^ 2 * тАЦW_restтАЦ + s ^ 2 * тАЦW_restтАЦ := by ring
        _ = 7 * s ^ 2 * тАЦW_restтАЦ := by ring
    have hL_Wrest_final : (12 : тДЭ)тБ╗┬╣ * тАЦL_WrestтАЦ тЙд 250 * s ^ 5 := by
      calc (12 : тДЭ)тБ╗┬╣ * тАЦL_WrestтАЦ
          тЙд (12 : тДЭ)тБ╗┬╣ * (7 * s ^ 2 * тАЦW_restтАЦ) := by
            apply mul_le_mul_of_nonneg_left hL_Wrest_s (by norm_num)
        _ тЙд (12 : тДЭ)тБ╗┬╣ * (7 * s ^ 2 * (5000 * s ^ 5 + s ^ 3 + s ^ 4)) := by
            apply mul_le_mul_of_nonneg_left _ (by norm_num)
            apply mul_le_mul_of_nonneg_left hWrest_le (by positivity)
        _ тЙд 250 * s ^ 5 := by
            have h5 : (0:тДЭ) тЙд s ^ 5 := pow_nonneg hs_nn 5
            have hle : s тЙд 1/4 := by linarith
            have s7_le : s^7 тЙд s^5 * (1/16) := by
              have hrew : s^7 = s^2 * s^5 := by ring
              rw [hrew]
              have hs2 : s^2 тЙд 1/16 := by nlinarith [hle, hs_nn]
              nlinarith [hs2, h5]
            have s6_le : s^6 тЙд s^5 * (1/4) := by
              have hrew : s^6 = s * s^5 := by ring
              rw [hrew]
              nlinarith [hle, h5, hs_nn]
            have expand : (12:тДЭ)тБ╗┬╣ * (7 * s^2 * (5000 * s^5 + s^3 + s^4)) =
                         (35000/12) * s^7 + (7/12) * s^5 + (7/12) * s^6 := by ring
            rw [expand]
            nlinarith [s7_le, s6_le, h5]
    have hQ_W_s : тАЦQ_WтАЦ тЙд 4 * (48 / 11 * s ^ 2) ^ 2 * (s / 2) := by
      have hW2_nn : (0 : тДЭ) тЙд тАЦWтАЦ ^ 2 := sq_nonneg _
      calc тАЦQ_WтАЦ тЙд 4 * тАЦWтАЦ ^ 2 * тАЦa'тАЦ := hQ_W_bound
        _ тЙд 4 * (48 / 11 * s ^ 2) ^ 2 * (s / 2) := by
            gcongr
    have hQ_W_final : (12 : тДЭ)тБ╗┬╣ * тАЦQ_WтАЦ тЙд 250 * s ^ 5 := by
      calc (12 : тДЭ)тБ╗┬╣ * тАЦQ_WтАЦ
          тЙд (12 : тДЭ)тБ╗┬╣ * (4 * (48 / 11 * s ^ 2) ^ 2 * (s / 2)) := by
            apply mul_le_mul_of_nonneg_left hQ_W_s (by norm_num)
        _ тЙд 250 * s ^ 5 := by nlinarith [pow_nonneg hs_nn 5, hs_lt]
    calc тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв L_Wrest + (12 : ЁЭХВ)тБ╗┬╣ тАв Q_WтАЦ
        тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв L_WrestтАЦ + тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв Q_WтАЦ := norm_add_le _ _
      _ тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦL_WrestтАЦ + тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦQ_WтАЦ := by
          gcongr <;> exact norm_smul_le _ _
      _ = (12 : тДЭ)тБ╗┬╣ * тАЦL_WrestтАЦ + (12 : тДЭ)тБ╗┬╣ * тАЦQ_WтАЦ := by rw [h12_inv]
      _ тЙд 250 * s ^ 5 + 250 * s ^ 5 := by linarith
      _ = 500 * s ^ 5 := by ring
  -- TRIANGLE INEQUALITY: sum the 6 bounds
  set TтВБ := RтВБ with hTтВБ
  set TтВВ := RтВВ with hTтВВ
  set TтВГ := (2 : ЁЭХВ)тБ╗┬╣ тАв (RтВБ * a' - a' * RтВБ) with hTтВГ
  set TтВД := (2 : ЁЭХВ)тБ╗┬╣ тАв (bch_quartic_term ЁЭХВ a' b * a' - a' * bch_quartic_term ЁЭХВ a' b)
    with hTтВД
  set TтВЕ := bch_cubic_term ЁЭХВ z a' - bch_cubic_term ЁЭХВ (a' + b) a' -
        -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b)) with hTтВЕ
  set TтВЖ := bch_quartic_term ЁЭХВ z a' - bch_quartic_term ЁЭХВ (a' + b) a' with hTтВЖ
  have hsum_le : тАЦTтВБ + TтВВ + TтВГ + TтВД + TтВЕ + TтВЖтАЦ тЙд
      тАЦTтВБтАЦ + тАЦTтВВтАЦ + тАЦTтВГтАЦ + тАЦTтВДтАЦ + тАЦTтВЕтАЦ + тАЦTтВЖтАЦ := by
    have a5 := norm_add_le (TтВБ + TтВВ + TтВГ + TтВД + TтВЕ) TтВЖ
    have a4 := norm_add_le (TтВБ + TтВВ + TтВГ + TтВД) TтВЕ
    have a3 := norm_add_le (TтВБ + TтВВ + TтВГ) TтВД
    have a2 := norm_add_le (TтВБ + TтВВ) TтВГ
    have a1 := norm_add_le TтВБ TтВВ
    linarith
  calc тАЦTтВБ + TтВВ + TтВГ + TтВД + TтВЕ + TтВЖтАЦ
      тЙд тАЦTтВБтАЦ + тАЦTтВВтАЦ + тАЦTтВГтАЦ + тАЦTтВДтАЦ + тАЦTтВЕтАЦ + тАЦTтВЖтАЦ := hsum_le
    _ тЙд 5000 * s ^ 5 + 5000000 * s ^ 5 + 1000 * s ^ 5 + s ^ 5 + 500 * s ^ 5 +
        2 * s ^ 5 := by linarith [hRтВБ_s5, hRтВВ_s5, hT3, hT4, hT5, hT6]
    _ = 5006503 * s ^ 5 := by ring
    _ тЙд 10000000 * s ^ 5 := by nlinarith [pow_nonneg hs_nn 5]


/-! ### Phase A scaffolding for the ╧ДтБ╡ symmetric-BCH discharge (T2-F7e)

The two private lemmas below mirror the cubic template's RтВБ/RтВВ setup at one
degree higher, packaging `norm_bch_septic_remainder_le` together with the
