      (тЖСc : ЁЭХВ) ^ 3 тАв symmetric_bch_cubic ЁЭХВ a bтАЦ тЙд 600 * |c| ^ 3 * s ^ 3 := by
    have hsmul_norm : тАЦ(тЖСc : ЁЭХВ) ^ 3 тАв symmetric_bch_cubic ЁЭХВ a bтАЦ тЙд
        |c| ^ 3 * (300 * s ^ 3) := by
      have : тАЦ((тЖСc : ЁЭХВ) ^ 3)тАЦ = |c| ^ 3 := by
        rw [norm_pow, RCLike.norm_ofReal]
      calc _ тЙд тАЦ((тЖСc : ЁЭХВ) ^ 3)тАЦ * тАЦsymmetric_bch_cubic ЁЭХВ a bтАЦ := norm_smul_le _ _
