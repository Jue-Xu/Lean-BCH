/-- The symmetric BCH cubic coefficient is an odd function:
`EтВГ(-a,-b) = -EтВГ(a,b)`. -/
theorem symmetric_bch_cubic_neg (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < 1 / 4) :
    symmetric_bch_cubic ЁЭХВ (-a) (-b) = -(symmetric_bch_cubic ЁЭХВ a b) := by
  unfold symmetric_bch_cubic
  have h := symmetric_bch_add_neg (ЁЭХВ := ЁЭХВ) a b hab
  have hZ_neg : bch (ЁЭХВ := ЁЭХВ) (bch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв (-a)) (-b)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (-a)) =
      -(bch (ЁЭХВ := ЁЭХВ) (bch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a)) :=
    eq_neg_of_add_eq_zero_right h
  rw [hZ_neg]; abel

/-- The cubic-polynomial part of the symmetric BCH deviation `Z(a,b) - (a+b)`.

Computed explicitly as `-(1/24)┬╖[a,[a,b]] + (1/12)┬╖[b,[b,a]]`, the classical
third-order Strang splitting coefficient. Homogeneous of degree 3 in `(a, b)`.
Derived from `bch_cubic_term(┬╜a, b) + (1/16)┬╖[[a,b],a] + bch_cubic_term(┬╜a+b, ┬╜a)`,
which is the degree-3 part of the expansion of `bch(bch(┬╜a, b), ┬╜a) - (a+b)`. -/
noncomputable def symmetric_bch_cubic_poly (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) : ЁЭФ╕ :=
  -((24 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a)) +
  (12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)

