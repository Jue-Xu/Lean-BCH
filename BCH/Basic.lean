private theorem norm_bch_octic_pieceA_le (a b : ЁЭФ╕)
    (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) (hs_small : тАЦaтАЦ + тАЦbтАЦ < 1 / 10) :
    тАЦlogOnePlus (ЁЭХВ := ЁЭХВ) (exp a * exp b - 1) - (exp a * exp b - 1) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 2 -
      (3 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 3 +
      (4 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 4 -
      (5 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 5 +
      (6 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 6 -
      (7 : ЁЭХВ)тБ╗┬╣ тАв (exp a * exp b - 1) ^ 7тАЦ тЙд
      3 * (тАЦaтАЦ + тАЦbтАЦ) ^ 8 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  set y := exp a * exp b - 1 with hy_def
  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have hs_nn : 0 тЙд s := by positivity
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have hs_small_le : s тЙд 1 / 10 := hs_small.le
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hy_lt : тАЦyтАЦ < 1 := norm_exp_mul_exp_sub_one_lt_one (ЁЭХВ := ЁЭХВ) a b hab
  have hy_le : тАЦyтАЦ тЙд Real.exp s - 1 := by
    have hy_eq : y = (exp a - 1) * exp b + (exp b - 1) := by
      rw [hy_def, sub_mul, one_mul]; abel
    calc тАЦyтАЦ = тАЦ(exp a - 1) * exp b + (exp b - 1)тАЦ := by rw [hy_eq]
      _ тЙд тАЦexp a - 1тАЦ * тАЦexp bтАЦ + тАЦexp b - 1тАЦ := by
          calc _ тЙд тАЦ(exp a - 1) * exp bтАЦ + _ := norm_add_le _ _
            _ тЙд _ := by gcongr; exact norm_mul_le _ _
      _ тЙд (Real.exp ╬▒ - 1) * Real.exp ╬▓ + (Real.exp ╬▓ - 1) := by
          apply add_le_add
          ┬╖ exact mul_le_mul (norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) a) (norm_exp_le (ЁЭХВ := ЁЭХВ) b)
              (norm_nonneg _) (by linarith [Real.add_one_le_exp ╬▒])
          ┬╖ exact norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) b
      _ = Real.exp s - 1 := by rw [hs_def, Real.exp_add]; ring
  have hE1_nn : 0 тЙд Real.exp s - 1 := by linarith [Real.add_one_le_exp s]
  have hexp8_le : (Real.exp s - 1) ^ 8 тЙд 3 * s ^ 8 :=
    real_exp_sub_one_pow8_le_small hs_nn hs_small_le
  calc _ тЙд тАЦyтАЦ ^ 8 / (1 - тАЦyтАЦ) :=
          norm_logOnePlus_sub_sub_sub_sub_sub_sub_sub_le (ЁЭХВ := ЁЭХВ) y hy_lt
    _ тЙд (Real.exp s - 1) ^ 8 / (2 - Real.exp s) :=
        div_le_divтВА (pow_nonneg hE1_nn 8)
          (pow_le_pow_leftтВА (norm_nonneg _) hy_le 8) hdenom (by linarith)
    _ тЙд 3 * s ^ 8 / (2 - Real.exp s) := by
        apply div_le_div_of_nonneg_right _ hdenom.le
        linarith

