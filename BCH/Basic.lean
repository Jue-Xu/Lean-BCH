- `┬╜┬╖GтВБ┬╖b┬▓ тЖТ ┬╜┬╖HтВБ┬╖b┬▓` (cancels `aтБ╡┬╖b┬▓/240`).
- `тЕЩ┬╖a┬│┬╖FтВВ тЖТ тЕЩ┬╖a┬│┬╖GтВВ` (cancels `a┬│┬╖bтБ┤/144`).
- `тЕЩ┬╖FтВБ┬╖b┬│ тЖТ тЕЩ┬╖GтВБ┬╖b┬│` (cancels `aтБ┤┬╖b┬│/144`).
- `FтВБ┬╖FтВВ` unchanged (deg-8+ leading already).

Plus the non-monomial part of W7 (`z┬╖TтВЖ + TтВВ┬╖TтВЕ + TтВГ┬╖TтВД + TтВД┬╖TтВГ + TтВЕ┬╖TтВВ + TтВЖ┬╖z`)
gets added back as a NEW cluster `┬╜┬╖(z┬╖TтВЖ + TтВВ┬╖TтВЕ + TтВГ┬╖TтВД + TтВД┬╖TтВГ + TтВЕ┬╖TтВВ + TтВЖ┬╖z)`,
alongside the existing septic-level cluster `┬╜┬╖(z┬╖TтВЕ + TтВВ┬╖TтВД + TтВГ┬▓ + TтВД┬╖TтВВ + TтВЕ┬╖z)`.

The three "tricky" clusters `┬╜┬╖(z┬╖R+R┬╖z) + ┬╜┬╖(TтВВ┬▓тИТP┬▓+TтВВTтВГ+TтВГTтВВ) +
┬╜┬╖(z┬╖TтВЕ+TтВВ┬╖TтВД+TтВГ┬▓+TтВД┬╖TтВВ+TтВЕ┬╖z) + ┬╜┬╖(z┬╖TтВЖ+TтВВ┬╖TтВЕ+TтВГ┬╖TтВД+TтВД┬╖TтВГ+TтВЕ┬╖TтВВ+TтВЖ┬╖z)`
have individual deg-6 or deg-7 leading parts, but combine to deg-8+ via the
R+TтВЕ+TтВЖ identity (`R_plus_T5_plus_T6_eq_neg_deg7_residual`), to be
exploited in the future `norm_combined_tricky_octic_le`.

Proof: `match_scalars <;> ring` (mirrors I1_septic_residual_decomp_eq's pattern). -/
private theorem I1_octic_residual_decomp_eq (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (ea eb a b : ЁЭФ╕) :
    let DтВБ : ЁЭФ╕ := ea - 1 - a
    let DтВВ : ЁЭФ╕ := eb - 1 - b
    let EтВБ : ЁЭФ╕ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2
    let EтВВ : ЁЭФ╕ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let FтВБ : ЁЭФ╕ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3
    let FтВВ : ЁЭФ╕ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let GтВБ : ЁЭФ╕ := FтВБ - (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4
    let GтВВ : ЁЭФ╕ := FтВВ - (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    let HтВБ : ЁЭФ╕ := GтВБ - (120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5
    let HтВВ : ЁЭФ╕ := GтВВ - (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5
    let I_a : ЁЭФ╕ := HтВБ - (720 : ЁЭХВ)тБ╗┬╣ тАв a ^ 6
    let I_b : ЁЭФ╕ := HтВВ - (720 : ЁЭХВ)тБ╗┬╣ тАв b ^ 6
    let J_a : ЁЭФ╕ := I_a - (5040 : ЁЭХВ)тБ╗┬╣ тАв a ^ 7
    let J_b : ЁЭФ╕ := I_b - (5040 : ЁЭХВ)тБ╗┬╣ тАв b ^ 7
    let P : ЁЭФ╕ := ea * eb - 1 - (a + b)
    let z : ЁЭФ╕ := a + b
    let Q : ЁЭФ╕ := a * DтВВ + DтВБ * b + DтВБ * DтВВ
    let TтВВ : ЁЭФ╕ := a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let TтВГ : ЁЭФ╕ := (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let TтВД : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    let TтВЕ : ЁЭФ╕ := (120 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5
    let TтВЖ : ЁЭФ╕ := (720 : ЁЭХВ)тБ╗┬╣ тАв a ^ 6 + (120 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b) +
        (48 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b ^ 2) + (36 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 3) +
        (48 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 5) +
        (720 : ЁЭХВ)тБ╗┬╣ тАв b ^ 6
    let W5 : ЁЭФ╕ := (60 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (60 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5 +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) -
        (z * TтВД + TтВД * z) - (TтВВ * TтВГ + TтВГ * TтВВ)
    let W6 : ЁЭФ╕ := (360 : ЁЭХВ)тБ╗┬╣ тАв a ^ 6 + (60 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b ^ 2) + (18 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 4) + (60 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 5) +
        (360 : ЁЭХВ)тБ╗┬╣ тАв b ^ 6 -
        (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z)
    let W7 : ЁЭФ╕ := (2520 : ЁЭХВ)тБ╗┬╣ тАв a ^ 7 + (360 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 6 * b) +
        (120 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 5 * b ^ 2) + (72 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b ^ 3) +
        (72 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 4) + (120 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 5) +
        (360 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 6) + (2520 : ЁЭХВ)тБ╗┬╣ тАв b ^ 7 -
        (z * TтВЖ + TтВВ * TтВЕ + TтВГ * TтВД + TтВД * TтВГ + TтВЕ * TтВВ + TтВЖ * z)
    let R : ЁЭФ╕ := TтВГ - EтВБ - EтВВ - Q + TтВД
    -- LHS: IтВБ (quartic_identity form) - corrтВБ - corrтВБ_5 - corrтВБ_6 - corrтВБ_7
    (FтВБ + FтВВ + a * EтВВ + EтВБ * b + DтВБ * DтВВ -
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * (EтВБ + EтВВ + Q) + (EтВБ + EтВВ + Q) * z) -
        (2 : ЁЭХВ)тБ╗┬╣ тАв P ^ 2) -
      ((24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) -
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВГ + TтВГ * z) - (2 : ЁЭХВ)тБ╗┬╣ тАв TтВВ ^ 2) -
      (2 : ЁЭХВ)тБ╗┬╣ тАв W5 -
      (2 : ЁЭХВ)тБ╗┬╣ тАв W6 -
      (2 : ЁЭХВ)тБ╗┬╣ тАв W7 =
    -- RHS: 13 deg-8+ terms (combined into 10 cluster expressions)
    J_a + J_b + a * I_b + I_a * b +
    ((6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * GтВВ) + (6 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 3) + FтВБ * FтВВ) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * HтВВ) + (2 : ЁЭХВ)тБ╗┬╣ тАв (HтВБ * b ^ 2) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (z * R + R * z) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВЖ + TтВВ * TтВЕ + TтВГ * TтВД + TтВД * TтВГ + TтВЕ * TтВВ + TтВЖ * z) := by
  dsimp only
  simp only [pow_succ, pow_zero, one_mul, smul_sub, smul_add, smul_neg, smul_smul,
    mul_smul_comm, smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
  match_scalars <;> ring

/-- Norm bound `тАЦIтВБ residual (RHS form)тАЦ тЙд 20┬╖sтБ╢` from precomputed component bounds.
This is the IтВБ residual bound from precomputed individual norm bounds.
Combined with I1_residual_decomp_eq (commit 2fccfa8), gives
`тАЦIтВБ - corrтВБ - corrтВБ_5тАЦ тЙд 20┬╖sтБ╢` where `s тЙд 1/10`.

The decomp RHS: HтВБ+HтВВ+a┬╖GтВВ+GтВБ┬╖b+(EтВБEтВВ+┬╜a┬▓FтВВ+┬╜FтВБb┬▓)+┬╜(z┬╖R+R┬╖z)+┬╜(TтВВ┬▓-P┬▓+TтВВTтВГ+TтВГTтВВ).
Per-term: 1+1+1+1+1+┬╜+┬╜+6+7.5 = 19.5 тЙд 20. -/
private theorem norm_I1_residual_RHS_le (a b z HтВБ HтВВ GтВБ GтВВ FтВБ FтВВ EтВБ EтВВ R T22 : ЁЭФ╕)
    {s : тДЭ} (hs_nn : 0 тЙд s)
    (hHтВБ_le : тАЦHтВБтАЦ тЙд s ^ 6) (hHтВВ_le : тАЦHтВВтАЦ тЙд s ^ 6)
    (h_aGтВВ_le : тАЦa * GтВВтАЦ тЙд s ^ 6) (h_GтВБb_le : тАЦGтВБ * bтАЦ тЙд s ^ 6)
    (h_EтВБEтВВ_le : тАЦEтВБ * EтВВтАЦ тЙд s ^ 6)
    (h_a2FтВВ_le : тАЦa ^ 2 * FтВВтАЦ тЙд s ^ 6) (h_FтВБb2_le : тАЦFтВБ * b ^ 2тАЦ тЙд s ^ 6)
    (h_zRpRz_le : тАЦz * R + R * zтАЦ тЙд 12 * s ^ 6)
    (h_T22_le : тАЦT22тАЦ тЙд 15 * s ^ 6) :
    тАЦHтВБ + HтВВ + a * GтВВ + GтВБ * b +
      (EтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) + (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (z * R + R * z) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв T22тАЦ тЙд 20 * s ^ 6 := by
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h_a2F2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * FтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2FтВВ_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_F1b2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦFтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_FтВБb2_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_zRpRz_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (z * R + R * z)тАЦ тЙд 6 * s ^ 6 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦz * R + R * zтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * (12 * s ^ 6) := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_zRpRz_le (by norm_num)
      _ = 6 * s ^ 6 := by ring
  have h_T22_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв T22тАЦ тЙд 15 * s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦT22тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * (15 * s ^ 6) := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_T22_le (by norm_num)
      _ = 15 * s ^ 6 / 2 := by ring
  -- Triangle inequality on the 9-term sum
  -- Outer: (HтВБ+HтВВ+a*GтВВ+GтВБ*b) + inner_3 + ┬╜(zR+Rz) + ┬╜T22
  -- Inner_3 = EтВБ*EтВВ + ┬╜(a┬▓*FтВВ) + ┬╜(FтВБ*b┬▓)
  have h_inner3 : тАЦEтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)тАЦ тЙд s ^ 6 + s ^ 6 / 2 + s ^ 6 / 2 := by
    have hi1 := norm_add_le (EтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ))
      ((2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2))
    have hi2 := norm_add_le (EтВБ * EтВВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ))
    linarith
  -- Outer chain: 4 + inner + 2 = 7 norm_add_le applications
  have ha1 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b +
    (EтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) + (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)) +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (z * R + R * z)) ((2 : ЁЭХВ)тБ╗┬╣ тАв T22)
  have ha2 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b +
    (EтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) + (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)))
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (z * R + R * z))
  have ha3 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b)
    (EтВБ * EтВВ + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ) + (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2))
  have ha4 := norm_add_le (HтВБ + HтВВ + a * GтВВ) (GтВБ * b)
  have ha5 := norm_add_le (HтВБ + HтВВ) (a * GтВВ)
  have ha6 := norm_add_le HтВБ HтВВ
  -- Sum: 1+1+1+1 + (1+┬╜+┬╜) + 6 + 7.5 = 19.5 тЙд 20
  linarith [pow_nonneg hs_nn 6]

