            _ тЙд _ := mul_le_mul (le_trans hDтВБ_le hDa2) le_rfl h╬▓_nn (by positivity)
        have hDD : тАЦDтВБ * DтВВтАЦ тЙд ╬▒ ^ 2 * ╬▓ ^ 2 :=
          calc _ тЙд тАЦDтВБтАЦ * тАЦDтВВтАЦ := norm_mul_le _ _
            _ тЙд _ := mul_le_mul (le_trans hDтВБ_le hDa2) (le_trans hDтВВ_le hDb2)
