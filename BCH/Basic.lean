/-- **I‚ÇÅ residual decomposition** (pure algebraic identity in (ea, eb, a, b)):
expresses `(I‚ÇÅ in quartic_id form) - corr‚ÇÅ - corr‚ÇÅ_5` as a sum of 7 deg-6+ terms.

Proof: √ó720 scalar clearing + dsimp (unfold let-bindings) + simp distribution
+ noncomm_ring. Mirrors the pattern of `quartic_identity` and
`sextic_pure_identity`. -/
private theorem I1_residual_decomp_eq (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (ea eb a b : ùî∏) :
    let D‚ÇÅ : ùî∏ := ea - 1 - a
    let D‚ÇÇ : ùî∏ := eb - 1 - b
    let E‚ÇÅ : ùî∏ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2
    let E‚ÇÇ : ùî∏ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2
    let F‚ÇÅ : ùî∏ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3
    let F‚ÇÇ : ùî∏ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3
    let G‚ÇÅ : ùî∏ := F‚ÇÅ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4
    let G‚ÇÇ : ùî∏ := F‚ÇÇ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4
    let H‚ÇÅ : ùî∏ := G‚ÇÅ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5
    let H‚ÇÇ : ùî∏ := G‚ÇÇ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5
    let P : ùî∏ := ea * eb - 1 - (a + b)
    let z : ùî∏ := a + b
    let Q : ùî∏ := a * D‚ÇÇ + D‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ
    let T‚ÇÇ : ùî∏ := a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2
    let T‚ÇÉ : ùî∏ := (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3
    let T‚ÇÑ : ùî∏ := (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4
    let W5 : ùî∏ := (60 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5 + (60 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5 +
        (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 4) + (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b) +
        (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 3) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 2) -
        (z * T‚ÇÑ + T‚ÇÑ * z) - (T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ)
    let R : ùî∏ := T‚ÇÉ - E‚ÇÅ - E‚ÇÇ - Q + T‚ÇÑ
    -- LHS: I‚ÇÅ (quartic_identity form) - corr‚ÇÅ - corr‚ÇÅ_5
    (F‚ÇÅ + F‚ÇÇ + a * E‚ÇÇ + E‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ -
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * (E‚ÇÅ + E‚ÇÇ + Q) + (E‚ÇÅ + E‚ÇÇ + Q) * z) -
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ P ^ 2) -
      ((24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4 +
        (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) -
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * T‚ÇÉ + T‚ÇÉ * z) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ T‚ÇÇ ^ 2) -
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ W5 =
    -- RHS: 7 deg-6+ terms
    H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b +
    (E‚ÇÅ * E‚ÇÇ + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)) +
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * R + R * z) +
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (T‚ÇÇ ^ 2 - P ^ 2 + T‚ÇÇ * T‚ÇÉ + T‚ÇÉ * T‚ÇÇ) := by
  -- KEY: dsimp only unfolds the let-bindings (transparent reduction)
  dsimp only
  simp only [pow_succ, pow_zero, one_mul, smul_sub, smul_add, smul_neg, smul_smul,
    mul_smul_comm, smul_mul_assoc, mul_add, add_mul, mul_sub, sub_mul, ‚Üê mul_assoc]
  match_scalars <;> ring

