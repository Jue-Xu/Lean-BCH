            rw [sub_eq_add_neg]
            exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд ╬▒ * ╬▓ + ╬▓ * ╬▒ := by gcongr <;> exact norm_mul_le _ _
