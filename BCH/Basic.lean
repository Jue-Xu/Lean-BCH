        тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (t тАв a)тАЦ + тАЦt тАв bтАЦ тЙд s := by
      intro t ht; linarith [hnorm_triple t ht, norm_nonneg ((2 : ЁЭХВ)тБ╗┬╣ тАв (t тАв a))]
    -- Helper: тАЦexp f * exp g - 1тАЦ тЙд exp(тАЦfтАЦ+тАЦgтАЦ)-1
    have hprod_le : тИА (f g : ЁЭФ╕), тАЦexp f * exp g - 1тАЦ тЙд Real.exp (тАЦfтАЦ + тАЦgтАЦ) - 1 := by
