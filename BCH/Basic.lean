    norm_exp_sub_one_sub_sub_le (ùïÇ := ùïÇ) b
  have hEa3 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 ‚â§ Œ± ^ 3 :=
    real_exp_third_order_le_cube hŒ±_nn (lt_of_le_of_lt hŒ±_le hs56)
  have hEb3 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 ‚â§ Œ≤ ^ 3 :=
    real_exp_third_order_le_cube hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs56)
  have hF‚ÇÅ_le : ‚ÄñF‚ÇÅ‚Äñ ‚â§ Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ùïÇ := ùïÇ) a
  have hF‚ÇÇ_le : ‚ÄñF‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ùïÇ := ùïÇ) b
  have hFa4 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 ‚â§ Œ± ^ 4 :=
    real_exp_fourth_order_le_quartic hŒ±_nn (lt_of_le_of_lt hŒ±_le hs34)
  have hFb4 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 ‚â§ Œ≤ ^ 4 :=
    real_exp_fourth_order_le_quartic hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs34)
