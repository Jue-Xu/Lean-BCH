  -- Triangle inequality (7 norm_add_le applications).
  have ha1 := norm_add_le ((5040 : ЁЭХВ)тБ╗┬╣ тАв a ^ 7 + (720 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 6 * b) +
