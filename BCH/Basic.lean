  have heq : P ^ 3 - TтВВ ^ 3 =
      (P - TтВВ) * P ^ 2 + TтВВ * (P - TтВВ) * P + TтВВ ^ 2 * (P - TтВВ) := by noncomm_ring
  rw [heq]
  have ht1 : тАЦ(P - TтВВ) * P ^ 2тАЦ тЙд (5 * s ^ 3) * (s ^ 2) ^ 2 :=
    calc _ тЙд тАЦP - TтВВтАЦ * тАЦP ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВтАЦ * тАЦPтАЦ ^ 2 := by gcongr; exact norm_pow_le P 2
      _ тЙд (5 * s ^ 3) * (s ^ 2) ^ 2 := mul_le_mul hPmTтВВ
          (pow_le_pow_leftтВА (norm_nonneg _) hP 2) (by positivity) (by positivity)
  have ht2 : тАЦTтВВ * (P - TтВВ) * PтАЦ тЙд s ^ 2 * (5 * s ^ 3) * s ^ 2 :=
    calc _ тЙд тАЦTтВВ * (P - TтВВ)тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВВтАЦ * тАЦP - TтВВтАЦ) * тАЦPтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 2 * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ hP (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hPmTтВВ (norm_nonneg _) (by positivity)
  have ht3 : тАЦTтВВ ^ 2 * (P - TтВВ)тАЦ тЙд (s ^ 2) ^ 2 * (5 * s ^ 3) :=
    calc _ тЙд тАЦTтВВ ^ 2тАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд тАЦTтВВтАЦ ^ 2 * тАЦP - TтВВтАЦ := by gcongr; exact norm_pow_le TтВВ 2
      _ тЙд (s ^ 2) ^ 2 * (5 * s ^ 3) := mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hTтВВ 2)
          hPmTтВВ (norm_nonneg _) (by positivity)
  have hadd1 := norm_add_le ((P - TтВВ) * P ^ 2 + TтВВ * (P - TтВВ) * P) (TтВВ ^ 2 * (P - TтВВ))
  have hadd2 := norm_add_le ((P - TтВВ) * P ^ 2) (TтВВ * (P - TтВВ) * P)
  nlinarith [pow_nonneg hs_nn 7]

