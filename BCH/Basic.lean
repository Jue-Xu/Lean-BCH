  have hdenom‚ÇÇ_pos : 0 < 2 - Real.exp (‚Äñz‚Äñ + ‚Äña'‚Äñ) := by
    have hexp2_lt : Real.exp (‚Äñz‚Äñ + ‚Äña'‚Äñ) < 2 := by
