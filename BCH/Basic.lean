      _ = (2 : ℝ)⁻¹ * ‖bch_quartic_term 𝕂 a' b * a' - a' * bch_quartic_term 𝕂 a' b‖ := by
          rw [h2_inv]
      _ ≤ (2 : ℝ)⁻¹ * (2 * ‖bch_quartic_term 𝕂 a' b‖ * ‖a'‖) :=
