    let H‚ÇÅ : ùî∏ := G‚ÇÅ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5
    let H‚ÇÇ : ùî∏ := G‚ÇÇ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5
    let I_a : ùî∏ := H‚ÇÅ - (720 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 6
    let I_b : ùî∏ := H‚ÇÇ - (720 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 6
    let J_a : ùî∏ := I_a - (5040 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7
    let J_b : ùî∏ := I_b - (5040 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 7
