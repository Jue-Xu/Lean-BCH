  have ha3 := norm_add_le (z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) +
    z * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * z +
    (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * z ^ 2 +
