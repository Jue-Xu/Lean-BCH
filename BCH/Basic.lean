/-- **8-fold smul-product identity** (local copy for use in `bch_octic_term_smul`). -/
private lemma bch_octic_term_eight_fold_smul_mul
    (c : ЁЭХВ) (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ xтВЗ xтВИ : ЁЭФ╕) :
    (c тАв xтВБ) * (c тАв xтВВ) * (c тАв xтВГ) * (c тАв xтВД) * (c тАв xтВЕ) * (c тАв xтВЖ) * (c тАв xтВЗ) * (c тАв xтВИ) =
      c ^ 8 тАв (xтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ * xтВИ) := by
  simp only [smul_mul_assoc, mul_smul_comm, smul_smul, тЖР mul_assoc]
  ring_nf

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Homogeneity of `bch_octic_term`**: `ZтВИ(cтАвa, cтАвb) = cтБ╕ тАв ZтВИ(a, b)`. -/
theorem bch_octic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_octic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 8 тАв bch_octic_term ЁЭХВ a b := by
  unfold bch_octic_term
  simp only [bch_octic_term_eight_fold_smul_mul c, smul_comm _ (c ^ 8 : ЁЭХВ), тЖР smul_add]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Helper (deg-8, local copy)**: `тАЦc тАв (lтВБ┬╖тАж┬╖l8)тАЦ тЙд cb ┬╖ s^8` if `тАЦcтАЦ тЙд cb`
and each `тАЦlс╡втАЦ тЙд s`. -/
private lemma deg8_smul_word_le_basic
    (c : ЁЭХВ) (cb : тДЭ) (hc : тАЦcтАЦ тЙд cb)
    (l1 l2 l3 l4 l5 l6 l7 l8 : ЁЭФ╕) (s : тДЭ)
    (h1 : тАЦl1тАЦ тЙд s) (h2 : тАЦl2тАЦ тЙд s) (h3 : тАЦl3тАЦ тЙд s) (h4 : тАЦl4тАЦ тЙд s)
    (h5 : тАЦl5тАЦ тЙд s) (h6 : тАЦl6тАЦ тЙд s) (h7 : тАЦl7тАЦ тЙд s) (h8 : тАЦl8тАЦ тЙд s)
    (hcb : 0 тЙд cb) (hs : 0 тЙд s) :
    тАЦc тАв (l1 * l2 * l3 * l4 * l5 * l6 * l7 * l8)тАЦ тЙд cb * s ^ 8 := by
  calc тАЦc тАв (l1 * l2 * l3 * l4 * l5 * l6 * l7 * l8)тАЦ
      тЙд тАЦcтАЦ * тАЦl1 * l2 * l3 * l4 * l5 * l6 * l7 * l8тАЦ := norm_smul_le _ _
    _ тЙд cb * тАЦl1 * l2 * l3 * l4 * l5 * l6 * l7 * l8тАЦ :=
        mul_le_mul_of_nonneg_right hc (norm_nonneg _)
    _ тЙд cb * (тАЦl1тАЦ * тАЦl2тАЦ * тАЦl3тАЦ * тАЦl4тАЦ * тАЦl5тАЦ * тАЦl6тАЦ * тАЦl7тАЦ * тАЦl8тАЦ) :=
        mul_le_mul_of_nonneg_left (norm_8prod_le _ _ _ _ _ _ _ _) hcb
    _ тЙд cb * (s * s * s * s * s * s * s * s) := by
        refine mul_le_mul_of_nonneg_left ?_ hcb; gcongr
    _ = cb * s ^ 8 := by ring

