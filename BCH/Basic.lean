/-- **Norm bound for `bch_sextic_term`**: `тАЦZтВЖ(a,b)тАЦ тЙд (тАЦaтАЦ+тАЦbтАЦ)тБ╢`.

Sum of |numerators| over the 28 terms = 164. So `тАЦZтВЖтАЦ тЙд 164/1440┬╖sтБ╢ тЙИ 0.114┬╖sтБ╢`. -/
theorem norm_bch_sextic_term_le (a b : ЁЭФ╕) :
    тАЦbch_sextic_term ЁЭХВ a bтАЦ тЙд (тАЦaтАЦ + тАЦbтАЦ) ^ 6 := by
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  have hs_nn : 0 тЙд s := by positivity
  have hs6_nn : (0 : тДЭ) тЙд s ^ 6 := pow_nonneg hs_nn 6
  have ha_le : тАЦaтАЦ тЙд s := by linarith [norm_nonneg b]
  have hb_le : тАЦbтАЦ тЙд s := by linarith [norm_nonneg a]
  have hw : тИА (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ : ЁЭФ╕), тАЦxтВБтАЦ тЙд s тЖТ тАЦxтВВтАЦ тЙд s тЖТ тАЦxтВГтАЦ тЙд s тЖТ
      тАЦxтВДтАЦ тЙд s тЖТ тАЦxтВЕтАЦ тЙд s тЖТ тАЦxтВЖтАЦ тЙд s тЖТ тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖтАЦ тЙд s ^ 6 :=
    fun xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ hтВБ hтВВ hтВГ hтВД hтВЕ hтВЖ => by
      have := norm_six_word_le (ЁЭФ╕ := ЁЭФ╕) a b xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ
        (by rw [hs_def] at hтВБ; exact hтВБ) (by rw [hs_def] at hтВВ; exact hтВВ)
        (by rw [hs_def] at hтВГ; exact hтВГ) (by rw [hs_def] at hтВД; exact hтВД)
        (by rw [hs_def] at hтВЕ; exact hтВЕ) (by rw [hs_def] at hтВЖ; exact hтВЖ)
      rw [hs_def]; exact this
  -- 28 word-norm bounds (one per word in bch_sextic_term)
  have w01 := hw a a a a b b ha_le ha_le ha_le ha_le hb_le hb_le
  have w02 := hw a a a b a b ha_le ha_le ha_le hb_le ha_le hb_le
