  -- Group E: (P¬≤-T‚ÇÇ¬≤)¬∑z¬≥
  have hE : ‚Äñ(P ^ 2 - T‚ÇÇ ^ 2) * z ^ 3‚Äñ ‚â§ (10 * s ^ 5) * s ^ 3 :=
