    ‚Äñexp a * exp b - 1 - (a + b) -
      (a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2) -
      ((6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3) -
      ((24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4)‚Äñ ‚â§ 6 * s ^ 5 := by
  set Œ± := ‚Äña‚Äñ
  set Œ≤ := ‚Äñb‚Äñ
  have hŒ±_nn : (0 : ‚Ñù) ‚â§ Œ± := norm_nonneg a
  have hŒ≤_nn : (0 : ‚Ñù) ‚â§ Œ≤ := norm_nonneg b
  have hs56 : s < 5 / 6 := by linarith
  -- Set up D, E, F, G variables
  set D‚ÇÅ := exp a - 1 - a with hD‚ÇÅ_def
  set D‚ÇÇ := exp b - 1 - b with hD‚ÇÇ_def
  set E‚ÇÅ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 with hE‚ÇÅ_def
  set E‚ÇÇ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2 with hE‚ÇÇ_def
  set F‚ÇÅ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 with hF‚ÇÅ_def
  set F‚ÇÇ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3 with hF‚ÇÇ_def
  set G‚ÇÅ := F‚ÇÅ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 with hG‚ÇÅ_def
  set G‚ÇÇ := F‚ÇÇ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4 with hG‚ÇÇ_def
  -- Algebraic identity:
  -- P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ = G‚ÇÅ + G‚ÇÇ + a¬∑F‚ÇÇ + F‚ÇÅ¬∑b + E‚ÇÅ¬∑E‚ÇÇ + (1/2)¬∑E‚ÇÅ¬∑b¬≤ + (1/2)¬∑a¬≤¬∑E‚ÇÇ
  have h_alg : exp a * exp b - 1 - (a + b) -
      (a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2) -
      ((6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3) -
      ((24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4) =
      G‚ÇÅ + G‚ÇÇ + a * F‚ÇÇ + F‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (E‚ÇÅ * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * E‚ÇÇ) := by
    have h := P_sub_T2_sub_T3_sub_T4_decomp_eq ùïÇ (exp a) (exp b) a b
    simp only [hG‚ÇÅ_def, hG‚ÇÇ_def, hF‚ÇÅ_def, hF‚ÇÇ_def, hE‚ÇÅ_def, hE‚ÇÇ_def,
