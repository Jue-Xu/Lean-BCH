/-- Norm bound `‚ÄñI‚ÇÅ residual (RHS form)‚Äñ ‚â§ 20¬∑s‚Å∂` from precomputed component bounds.
This is the I‚ÇÅ residual bound from precomputed individual norm bounds.
Combined with I1_residual_decomp_eq (commit 2fccfa8), gives
`‚ÄñI‚ÇÅ - corr‚ÇÅ - corr‚ÇÅ_5‚Äñ ‚â§ 20¬∑s‚Å∂` where `s ‚â§ 1/10`.

The decomp RHS: H‚ÇÅ+H‚ÇÇ+a¬∑G‚ÇÇ+G‚ÇÅ¬∑b+(E‚ÇÅE‚ÇÇ+¬Ωa¬≤F‚ÇÇ+¬ΩF‚ÇÅb¬≤)+¬Ω(z¬∑R+R¬∑z)+¬Ω(T‚ÇÇ¬≤-P¬≤+T‚ÇÇT‚ÇÉ+T‚ÇÉT‚ÇÇ).
Per-term: 1+1+1+1+1+¬Ω+¬Ω+6+7.5 = 19.5 ‚â§ 20. -/
private theorem norm_I1_residual_RHS_le (a b z H‚ÇÅ H‚ÇÇ G‚ÇÅ G‚ÇÇ F‚ÇÅ F‚ÇÇ E‚ÇÅ E‚ÇÇ R T22 : ùî∏)
    {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hH‚ÇÅ_le : ‚ÄñH‚ÇÅ‚Äñ ‚â§ s ^ 6) (hH‚ÇÇ_le : ‚ÄñH‚ÇÇ‚Äñ ‚â§ s ^ 6)
    (h_aG‚ÇÇ_le : ‚Äña * G‚ÇÇ‚Äñ ‚â§ s ^ 6) (h_G‚ÇÅb_le : ‚ÄñG‚ÇÅ * b‚Äñ ‚â§ s ^ 6)
    (h_E‚ÇÅE‚ÇÇ_le : ‚ÄñE‚ÇÅ * E‚ÇÇ‚Äñ ‚â§ s ^ 6)
    (h_a2F‚ÇÇ_le : ‚Äña ^ 2 * F‚ÇÇ‚Äñ ‚â§ s ^ 6) (h_F‚ÇÅb2_le : ‚ÄñF‚ÇÅ * b ^ 2‚Äñ ‚â§ s ^ 6)
    (h_zRpRz_le : ‚Äñz * R + R * z‚Äñ ‚â§ 12 * s ^ 6)
    (h_T22_le : ‚ÄñT22‚Äñ ‚â§ 15 * s ^ 6) :
    ‚ÄñH‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b +
      (E‚ÇÅ * E‚ÇÇ + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)) +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * R + R * z) +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ T22‚Äñ ‚â§ 20 * s ^ 6 := by
  have h2eq : ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ = (2 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h_a2F2_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ)‚Äñ ‚â§ s ^ 6 / 2 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 2 * F‚ÇÇ‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2F‚ÇÇ_le (by norm_num)
