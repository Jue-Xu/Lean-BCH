  have h_D5zT3 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * z * T‚ÇÉ‚Äñ ‚â§ (6 * s ^ 5) * s * s ^ 3 :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * z‚Äñ * ‚ÄñT‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((6 * s ^ 5) * s) * s ^ 3 := by
