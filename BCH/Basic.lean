private lemma word_7_diff_le_basic
    (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ xтВЗ yтВБ yтВВ yтВГ yтВД yтВЕ yтВЖ yтВЗ : ЁЭФ╕) (N : тДЭ)
    (hxтВБ : тАЦxтВБтАЦ тЙд N) (hxтВВ : тАЦxтВВтАЦ тЙд N) (hxтВГ : тАЦxтВГтАЦ тЙд N) (hxтВД : тАЦxтВДтАЦ тЙд N)
    (hxтВЕ : тАЦxтВЕтАЦ тЙд N) (hxтВЖ : тАЦxтВЖтАЦ тЙд N) (hxтВЗ : тАЦxтВЗтАЦ тЙд N)
    (hyтВБ : тАЦyтВБтАЦ тЙд N) (hyтВВ : тАЦyтВВтАЦ тЙд N) (hyтВГ : тАЦyтВГтАЦ тЙд N) (hyтВД : тАЦyтВДтАЦ тЙд N)
    (hyтВЕ : тАЦyтВЕтАЦ тЙд N) (hyтВЖ : тАЦyтВЖтАЦ тЙд N) (hyтВЗ : тАЦyтВЗтАЦ тЙд N) (hN_nn : 0 тЙд N) :
    тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ - yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * yтВЗтАЦ тЙд
      N ^ 6 * (тАЦxтВБ - yтВБтАЦ + тАЦxтВВ - yтВВтАЦ + тАЦxтВГ - yтВГтАЦ + тАЦxтВД - yтВДтАЦ + тАЦxтВЕ - yтВЕтАЦ + тАЦxтВЖ - yтВЖтАЦ + тАЦxтВЗ - yтВЗтАЦ) := by
  have hid : xтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ - yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * yтВЗ =
      (xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ +
      yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ +
      yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ +
      yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ +
      yтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗ +
      yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗ +
      yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ) := by noncomm_ring
  rw [hid]
  have hN_pow_nn : (0 : тДЭ) тЙд N ^ 6 := pow_nonneg hN_nn 6
  have htтВБ : тАЦ(xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВБ - yтВБтАЦ := by
    calc тАЦ(xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ
        тЙд тАЦxтВБ - yтВБтАЦ * тАЦxтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ * тАЦxтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд тАЦxтВБ - yтВБтАЦ * N * N * N * N * N * N := by gcongr
      _ = N ^ 6 * тАЦxтВБ - yтВБтАЦ := by ring
  have htтВВ : тАЦyтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВВ - yтВВтАЦ := by
    calc тАЦyтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ
        тЙд тАЦyтВБтАЦ * тАЦxтВВ - yтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ * тАЦxтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд N * тАЦxтВВ - yтВВтАЦ * N * N * N * N * N := by gcongr
      _ = N ^ 6 * тАЦxтВВ - yтВВтАЦ := by ring
  have htтВГ : тАЦyтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВГ - yтВГтАЦ := by
    calc тАЦyтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ
        тЙд тАЦyтВБтАЦ * тАЦyтВВтАЦ * тАЦxтВГ - yтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ * тАЦxтВЖтАЦ * тАЦxтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд N * N * тАЦxтВГ - yтВГтАЦ * N * N * N * N := by gcongr
      _ = N ^ 6 * тАЦxтВГ - yтВГтАЦ := by ring
  have htтВД : тАЦyтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВД - yтВДтАЦ := by
    calc тАЦyтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗтАЦ
