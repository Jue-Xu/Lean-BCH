  set Y : ùî∏ := b * (b * a - a * b) - (b * a - a * b) * b
  calc ‚Äñ-((24 : ùïÇ)‚Åª¬π ‚Ä¢ X) + (12 : ùïÇ)‚Åª¬π ‚Ä¢ Y‚Äñ
      ‚â§ ‚Äñ-((24 : ùïÇ)‚Åª¬π ‚Ä¢ X)‚Äñ + ‚Äñ(12 : ùïÇ)‚Åª¬π ‚Ä¢ Y‚Äñ := norm_add_le _ _
    _ = ‚Äñ(24 : ùïÇ)‚Åª¬π ‚Ä¢ X‚Äñ + ‚Äñ(12 : ùïÇ)‚Åª¬π ‚Ä¢ Y‚Äñ := by rw [norm_neg]
    _ ‚â§ Œ± ^ 2 * Œ≤ + Œ± * Œ≤ ^ 2 := by linarith
    _ ‚â§ (Œ± + Œ≤) ^ 3 := by nlinarith [sq_nonneg (Œ± - Œ≤), hŒ±_nn, hŒ≤_nn, sq_nonneg Œ±, sq_nonneg Œ≤]

omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
/-- **sym_E‚ÇÉ alt-form identity**: the closed-form `symmetric_bch_cubic_poly` equals
the alt form `C‚ÇÉ(¬Ωa,b) + C‚ÇÉ(¬Ωa+b,¬Ωa) - (1/16)¬∑DC_a`, where `DC_a = a¬∑[a,b] - [a,b]¬∑a`.

This is the key step relating the explicit polynomial definition to the form that
arises from applying `norm_bch_quintic_remainder_le` twice through the symmetric
composition. Verified by multiplying both sides by 48, clearing scalars, and
`noncomm_ring`. -/
theorem symmetric_bch_cubic_poly_alt_form (a b : ùî∏) :
    symmetric_bch_cubic_poly ùïÇ a b =
      bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b +
      bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a + b) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) -
      (16 : ùïÇ)‚Åª¬π ‚Ä¢ (a * (a * b - b * a) - (a * b - b * a) * a) := by
  unfold symmetric_bch_cubic_poly bch_cubic_term
  simp only [smul_sub, smul_add, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul]
  match_scalars <;> ring

omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
/-- **Key quartic cancellation for symmetric BCH**: the four degree-4 contributions to
`sym_bch_cubic - sym_E‚ÇÉ` sum to zero as a ring identity.

Specifically, writing `a' = ¬Ωa`, the four contributions are:
- A := ¬Ω[C‚ÇÉ(a',b), a']  (from the half-commutator ¬Ω[w, a'] expansion, w = z-(a'+b))
- B := C‚ÇÑ(a',b)         (the inner BCH quartic)
- C := -(1/96)¬∑[b, DC_a]  (the linear-in-w‚ÇÇ part of [C‚ÇÉ(z,a') - C‚ÇÉ(a'+b,a')],
                           where w‚ÇÇ = ¬Ω(a'b-ba'); equals (1/12)¬∑([(a'+b),[w‚ÇÇ,a']] +
                           [w‚ÇÇ,[(a'+b),a']] + [a',[a',w‚ÇÇ]]) ‚Äî verified algebraically)
- D := C‚ÇÑ(a'+b, a')     (the constant part of C‚ÇÑ(z, a'))

The identity `A + B + C + D = 0` holds because, after expansion:
- A + D contributes `(1/48)¬∑[DC_b, a]` (the [DC_a,a] terms cancel between A and D).
- B + C contributes `-(1/48)¬∑[b, DC_a]`.
- And `[DC_b, a] = [b, DC_a]` is itself an associative-algebra identity (both expand
  to `b¬≤a¬≤ - 2baba + 2abab - a¬≤b¬≤`). -/
theorem symmetric_bch_quartic_identity (a b : ùî∏) :
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b * ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) -
                  ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) * bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b) +
      bch_quartic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b +
      -((96 : ùïÇ)‚Åª¬π ‚Ä¢ (b * (a * (a * b - b * a) - (a * b - b * a) * a) -
                       (a * (a * b - b * a) - (a * b - b * a) * a) * b)) +
      bch_quartic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a + b) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) = 0 := by
  unfold bch_cubic_term bch_quartic_term
  simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul, ‚Üê mul_assoc]
  match_scalars <;> ring

set_option maxHeartbeats 16000000 in
include ùïÇ in
/-- **Symmetric BCH quintic remainder bound**: the symmetric BCH deviation equals the
cubic polynomial `symmetric_bch_cubic_poly` up to `O(s‚Åµ)` error. This is the symmetric
analog of `norm_bch_quintic_remainder_le`, obtained by applying the quintic BCH theorem
twice through the composition `bch(bch(¬Ωa, b), ¬Ωa)` and collecting cubic contributions.

The constant `10‚Å∑` is loose: the dominant contribution comes from the outer-BCH
quintic remainder R‚ÇÇ at norm `s‚ÇÇ = ‚Äñz‚Äñ+‚Äña'‚Äñ ‚â§ 57s/22`, giving R‚ÇÇ ‚â§ ~4¬∑10‚Å∂¬∑s‚Åµ.
A tighter form `K¬∑s‚Åµ/(2-exp(2s))` would reduce it (analogous to
`norm_bch_quintic_remainder_le`), but the simpler `K¬∑s‚Åµ` form suffices for
the Suzuki use case. -/
theorem norm_symmetric_bch_cubic_sub_poly_le (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < 1 / 4) :
    ‚Äñsymmetric_bch_cubic ùïÇ a b - symmetric_bch_cubic_poly ùïÇ a b‚Äñ ‚â§
      10000000 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 5 := by
  -- SETUP: a' = ¬Ωa, s = ‚Äña‚Äñ+‚Äñb‚Äñ, s‚ÇÅ = ‚Äña'‚Äñ+‚Äñb‚Äñ ‚â§ s, z = bch(a', b)
  set a' : ùî∏ := (2 : ùïÇ)‚Åª¬π ‚Ä¢ a with ha'_def
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ with hs_def
  set s‚ÇÅ := ‚Äña'‚Äñ + ‚Äñb‚Äñ with hs‚ÇÅ_def
  have h_half_norm : ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ = (2 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have ha'_le : ‚Äña'‚Äñ ‚â§ ‚Äña‚Äñ / 2 := by
    calc ‚Äña'‚Äñ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña‚Äñ := norm_smul_le _ _
      _ = ‚Äña‚Äñ / 2 := by rw [h_half_norm]; ring
  have ha'_le_s : ‚Äña'‚Äñ ‚â§ s := by
    calc ‚Äña'‚Äñ ‚â§ ‚Äña‚Äñ / 2 := ha'_le
      _ ‚â§ ‚Äña‚Äñ := by linarith [norm_nonneg a]
      _ ‚â§ s := le_add_of_nonneg_right (norm_nonneg b)
  have hs_nn : 0 ‚â§ s := by positivity
  have hs_lt : s < 1 / 4 := hab
  have hs1 : s < 1 := by linarith
  have hs‚ÇÅ_le : s‚ÇÅ ‚â§ s := by
    show ‚Äña'‚Äñ + ‚Äñb‚Äñ ‚â§ ‚Äña‚Äñ + ‚Äñb‚Äñ; linarith [ha'_le, norm_nonneg a]
  have hs‚ÇÅ_nn : 0 ‚â§ s‚ÇÅ := by positivity
  have hln2 : (1 : ‚Ñù) / 4 < Real.log 2 := by
    rw [Real.lt_log_iff_exp_lt (by norm_num : (0:‚Ñù) < 2)]
    linarith [real_exp_third_order_le_cube (by norm_num : (0:‚Ñù) ‚â§ 1/4)
      (by norm_num : (1:‚Ñù)/4 < 5/6)]
  have hs‚ÇÅ_lt_log2 : s‚ÇÅ < Real.log 2 := by linarith
  -- Inner BCH: z = bch(a', b)
  set z := bch (ùïÇ := ùïÇ) a' b with hz_def
  -- Quintic remainder of inner BCH: R‚ÇÅ = z - (a'+b) - ¬Ω(a'b-ba') - C‚ÇÉ(a',b) - C‚ÇÑ(a',b)
  set R‚ÇÅ := z - (a' + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a' * b - b * a') -
      bch_cubic_term ùïÇ a' b - bch_quartic_term ùïÇ a' b with hR‚ÇÅ_def
  -- Bound: ‚ÄñR‚ÇÅ‚Äñ ‚â§ 3000¬∑s‚ÇÅ‚Åµ/(2-exp(s‚ÇÅ))
  have hR‚ÇÅ_le : ‚ÄñR‚ÇÅ‚Äñ ‚â§ 3000 * s‚ÇÅ ^ 5 / (2 - Real.exp s‚ÇÅ) := by
    rw [hR‚ÇÅ_def]
    exact norm_bch_quintic_remainder_le (ùïÇ := ùïÇ) a' b hs‚ÇÅ_lt_log2
  -- Quadratic bound: ‚Äñz - (a'+b)‚Äñ ‚â§ 3¬∑s‚ÇÅ¬≤/(2-exp(s‚ÇÅ))
  have hexp_s‚ÇÅ_lt : Real.exp s‚ÇÅ < 2 := by
    calc _ < Real.exp (Real.log 2) := Real.exp_strictMono hs‚ÇÅ_lt_log2
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom‚ÇÅ : 0 < 2 - Real.exp s‚ÇÅ := by linarith
  set W := z - (a' + b) with hW_def
  have hW_le : ‚ÄñW‚Äñ ‚â§ 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) := by
    rw [hW_def]; exact norm_bch_sub_add_le (ùïÇ := ùïÇ) a' b hs‚ÇÅ_lt_log2
  -- s‚ÇÇ = ‚Äñz‚Äñ + ‚Äña'‚Äñ < log 2 (for the second quintic application)
  have hexp_le : Real.exp s‚ÇÅ ‚â§ 1 + s‚ÇÅ + s‚ÇÅ ^ 2 := by
    nlinarith [real_exp_third_order_le_cube hs‚ÇÅ_nn (by linarith : s‚ÇÅ < 5/6)]
  have hdenom_lb : (11 : ‚Ñù) / 16 ‚â§ 2 - Real.exp s‚ÇÅ := by nlinarith
  have hquad_bound : 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) ‚â§ 3 / 11 := by
    rw [div_le_div_iff‚ÇÄ hdenom‚ÇÅ (by norm_num : (0:‚Ñù) < 11)]
    nlinarith [sq_nonneg s‚ÇÅ, sq_nonneg (1/4 - s‚ÇÅ)]
  have hz_le : ‚Äñz‚Äñ ‚â§ s‚ÇÅ + 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) := by
    calc ‚Äñz‚Äñ = ‚Äñ(z - (a' + b)) + (a' + b)‚Äñ := by congr 1; abel
      _ ‚â§ ‚Äñz - (a' + b)‚Äñ + ‚Äña' + b‚Äñ := norm_add_le _ _
      _ ‚â§ 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) + s‚ÇÅ := by
          have hsum : ‚Äña' + b‚Äñ ‚â§ s‚ÇÅ := norm_add_le _ _
          linarith [hW_le, hW_def]
      _ = s‚ÇÅ + 3 * s‚ÇÅ ^ 2 / (2 - Real.exp s‚ÇÅ) := by ring
  have hln2_611 : (6 : ‚Ñù) / 11 < Real.log 2 := by
    rw [Real.lt_log_iff_exp_lt (by norm_num : (0:‚Ñù) < 2)]
    linarith [real_exp_third_order_le_cube (by norm_num : (0:‚Ñù) ‚â§ 6/11)
      (by norm_num : (6:‚Ñù)/11 < 5/6)]
  have hs‚ÇÇ_lt_log2 : ‚Äñz‚Äñ + ‚Äña'‚Äñ < Real.log 2 := by
    calc ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ (s‚ÇÅ + 3 / 11) + ‚Äña'‚Äñ := by linarith [hz_le, hquad_bound]
      _ ‚â§ s + 3 / 11 := by linarith [ha'_le_s]
      _ < 1/4 + 3 / 11 := by linarith
      _ = 23 / 44 := by norm_num
      _ < 6 / 11 := by norm_num
      _ < Real.log 2 := hln2_611
  -- Outer quintic remainder: R‚ÇÇ = bch(z,a') - (z+a') - ¬Ω(z¬∑a'-a'¬∑z) - C‚ÇÉ(z,a') - C‚ÇÑ(z,a')
  set R‚ÇÇ := bch (ùïÇ := ùïÇ) z a' - (z + a') - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * a' - a' * z) -
      bch_cubic_term ùïÇ z a' - bch_quartic_term ùïÇ z a' with hR‚ÇÇ_def
  have hR‚ÇÇ_le : ‚ÄñR‚ÇÇ‚Äñ ‚â§ 3000 * (‚Äñz‚Äñ + ‚Äña'‚Äñ) ^ 5 / (2 - Real.exp (‚Äñz‚Äñ + ‚Äña'‚Äñ)) := by
    rw [hR‚ÇÇ_def]
    exact norm_bch_quintic_remainder_le (ùïÇ := ùïÇ) z a' hs‚ÇÇ_lt_log2
  -- Key commutator helper: ¬º[(a'b - ba'), a'] = -(1/16)¬∑DC_a
  set DC_a : ùî∏ := a * (a * b - b * a) - (a * b - b * a) * a with hDC_a_def
  -- KEY DECOMPOSITION: sym_bch_cubic - sym_E‚ÇÉ as a sum of 6 terms.
  -- 1. R‚ÇÅ + R‚ÇÇ  (each O(s‚Åµ) by quintic BCH)
  -- 2. ¬Ω[R‚ÇÅ, a']     (O(s¬∑s‚Åµ) = O(s‚Å∂) ‚â§ O(s‚Åµ))
  -- 3. ¬Ω[C‚ÇÑ(a',b), a']     (O(s‚Å¥¬∑s) = O(s‚Åµ))
  -- 4. quartic_identity_sum = 0 (by symmetric_bch_quartic_identity)
  -- 5. C‚ÇÉ(z,a') - C‚ÇÉ(a'+b, a') - C_d4  (O(s‚Åµ) residual after subtracting
  --    the degree-4 part; the degree-4 part is C_d4 = -(1/96)¬∑[b, DC_a])
  -- 6. C‚ÇÑ(z,a') - C‚ÇÑ(a'+b, a')  (O(s‚Åµ) residual after degree-4)
  --
  -- The algebraic decomposition (provable by `abel` after unfolding R‚ÇÅ, R‚ÇÇ and
  -- the sym_E‚ÇÉ ‚Üí alt form rewrite, plus the quartic identity for degree-4 cancel):
  have hdecomp : symmetric_bch_cubic ùïÇ a b - symmetric_bch_cubic_poly ùïÇ a b =
      R‚ÇÅ + R‚ÇÇ +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (R‚ÇÅ * a' - a' * R‚ÇÅ) +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (bch_quartic_term ùïÇ a' b * a' - a' * bch_quartic_term ùïÇ a' b) +
      (bch_cubic_term ùïÇ z a' - bch_cubic_term ùïÇ (a' + b) a' -
        -((96 : ùïÇ)‚Åª¬π ‚Ä¢ (b * DC_a - DC_a * b))) +
      (bch_quartic_term ùïÇ z a' - bch_quartic_term ùïÇ (a' + b) a') := by
    rw [symmetric_bch_cubic_poly_alt_form (ùïÇ := ùïÇ)]
    have hbch_z_a' : bch (ùïÇ := ùïÇ) z a' = (z + a') + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * a' - a' * z) +
        bch_cubic_term ùïÇ z a' + bch_quartic_term ùïÇ z a' + R‚ÇÇ := by
      rw [hR‚ÇÇ_def]; abel
    have hzcom : z * a' - a' * z = (a' + b) * a' - a' * (a' + b) +
        ((z - (a' + b)) * a' - a' * (z - (a' + b))) := by noncomm_ring
    have hW_eq : z - (a' + b) =
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a' * b - b * a') + bch_cubic_term ùïÇ a' b +
          bch_quartic_term ùïÇ a' b + R‚ÇÅ := by
      rw [hR‚ÇÅ_def, hW_def]; abel
    have hz_eq : z = a' + b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a' * b - b * a') + bch_cubic_term ùïÇ a' b +
        bch_quartic_term ùïÇ a' b + R‚ÇÅ := by
      rw [show z = (z - (a' + b)) + (a' + b) from by abel, hW_eq]; abel
    have hQI := symmetric_bch_quartic_identity (ùïÇ := ùïÇ) a b
    show bch (ùïÇ := ùïÇ) (bch (ùïÇ := ùïÇ) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) - (a + b) -
        (bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b +
         bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a + b) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) -
         (16 : ùïÇ)‚Åª¬π ‚Ä¢ (a * (a * b - b * a) - (a * b - b * a) * a)) = _
    have hbch_inner : bch (ùïÇ := ùïÇ) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b = z := by rw [hz_def, ha'_def]
    rw [hbch_inner, hbch_z_a', hzcom, hW_eq]
    have hQI_rearr : bch_quartic_term ùïÇ (a' + b) a' =
        -((2 : ùïÇ)‚Åª¬π ‚Ä¢ (bch_cubic_term ùïÇ a' b * a' - a' * bch_cubic_term ùïÇ a' b)) -
        bch_quartic_term ùïÇ a' b +
        (96 : ùïÇ)‚Åª¬π ‚Ä¢ (b * DC_a - DC_a * b) := by
      have h := hQI
      have h' : ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (bch_cubic_term ùïÇ a' b * a' - a' * bch_cubic_term ùïÇ a' b) +
                  bch_quartic_term ùïÇ a' b +
                  -((96 : ùïÇ)‚Åª¬π ‚Ä¢ (b * DC_a - DC_a * b))) +
                 bch_quartic_term ùïÇ (a' + b) a' = 0 := by
        simp only [ha'_def, hDC_a_def]
        convert h using 2
      have hW := eq_neg_of_add_eq_zero_right h'
      rw [hW]; abel
    rw [hQI_rearr]
    simp only [smul_sub, smul_add, smul_mul_assoc, mul_smul_comm, add_mul, mul_add,
      sub_mul, mul_sub, ha'_def, hDC_a_def, smul_smul,
      show ((2 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = (4 : ùïÇ)‚Åª¬π from by norm_num,
      show ((2 : ùïÇ)‚Åª¬π * ((2 : ùïÇ)‚Åª¬π * (4 : ùïÇ)‚Åª¬π)) = (16 : ùïÇ)‚Åª¬π from by norm_num,
      show ((2 : ùïÇ)‚Åª¬π * ((4 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π)) = (16 : ùïÇ)‚Åª¬π from by norm_num,
      show ((2 : ùïÇ)‚Åª¬π * (4 : ùïÇ)‚Åª¬π) = (8 : ùïÇ)‚Åª¬π from by norm_num,
      show ((4 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = (8 : ùïÇ)‚Åª¬π from by norm_num,
      show ((2 : ùïÇ)‚Åª¬π * (8 : ùïÇ)‚Åª¬π) = (16 : ùïÇ)‚Åª¬π from by norm_num,
      show ((8 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = (16 : ùïÇ)‚Åª¬π from by norm_num]
    nth_rewrite 1 [hz_eq]
    simp only [ha'_def, smul_sub, smul_add, smul_mul_assoc, mul_smul_comm, smul_smul,
      show ((2 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = (4 : ùïÇ)‚Åª¬π from by norm_num,
      one_smul, mul_one]
    -- The remaining mismatch: two separate `(2:ùïÇ)‚Åª¬π ‚Ä¢ a` terms on LHS sum to `a` on RHS.
    -- Combine them: 2‚Åª¬π‚Ä¢a + 2‚Åª¬π‚Ä¢a = (2‚Åª¬π+2‚Åª¬π)‚Ä¢a = 1‚Ä¢a = a.
    have h_half_sum : (2 : ùïÇ)‚Åª¬π ‚Ä¢ a + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a = a := by
      rw [‚Üê add_smul, show ((2 : ùïÇ)‚Åª¬π + (2 : ùïÇ)‚Åª¬π) = (1 : ùïÇ) from by ring, one_smul]
    -- abel will collect the 2‚Åª¬π‚Ä¢a terms; combined with h_half_sum, equality holds.
    linear_combination (norm := abel) (h_half_sum : (2 : ùïÇ)‚Åª¬π ‚Ä¢ a + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a = a)
  rw [hdecomp]
