/-- **Algebraic decomposition of `pieceB''` for the sextic remainder small-s case.**

States that pieceB'' (the algebraic part of the sextic remainder, with H1
NOT applied ‚Äî keeping the `y - z - ¬Ω[a,b] - ¬Ωy¬≤` form) decomposes as:

```
pieceB'' = (I‚ÇÅ - corr‚ÇÅ - corr‚ÇÅ_5) + (I‚ÇÇ - corr‚ÇÇ - corr‚ÇÇ_5)
           - ¬º(y‚Å¥ - z‚Å¥ - y4_5) + ‚Öï(y‚Åµ - z‚Åµ)
```

where:
- `I‚ÇÅ = y - z - ¬Ω[a,b] - ¬Ωy¬≤ + ‚Öìz¬≥ - C‚ÇÉ` (== ¬ΩW + ‚Öìz¬≥ - C‚ÇÉ via H1)
- `I‚ÇÇ = ‚Öì(y¬≥ - z¬≥)`
- `corr‚ÇÅ`, `corr‚ÇÇ` from `quintic_pure_identity` (deg-4 corrections)
- `corr‚ÇÅ_5 = ¬Ω¬∑W5`, `corr‚ÇÇ_5 = ‚Öì¬∑y3_5` from `sextic_pure_identity` (deg-5)

Proof: `pieceB'' - RHS = (LHS_QPI) + (LHS_SPI) = 0 + 0 = 0` via QPI + SPI. -/
private theorem pieceB_sextic_decomp (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (a b : ùî∏) :
    let z : ùî∏ := a + b
    let T‚ÇÇ : ùî∏ := a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2
    let T‚ÇÉ_QPI : ùî∏ := (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3 +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b)
    let T‚ÇÉ_SPI : ùî∏ := (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3
    let T‚ÇÑ : ùî∏ := (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4
    let W5 : ùî∏ := (60 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5 + (60 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5 +
        (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 4) + (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b) +
        (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 3) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 2) -
        (z * T‚ÇÑ + T‚ÇÑ * z) - (T‚ÇÇ * T‚ÇÉ_SPI + T‚ÇÉ_SPI * T‚ÇÇ)
    let y3_5 : ùî∏ := z ^ 2 * T‚ÇÉ_SPI + z * T‚ÇÉ_SPI * z + T‚ÇÉ_SPI * z ^ 2 +
        z * T‚ÇÇ ^ 2 + T‚ÇÇ * z * T‚ÇÇ + T‚ÇÇ ^ 2 * z
    let y4_5 : ùî∏ := z ^ 3 * T‚ÇÇ + z ^ 2 * T‚ÇÇ * z + z * T‚ÇÇ * z ^ 2 + T‚ÇÇ * z ^ 3
    let y : ùî∏ := exp a * exp b - 1
    let corr‚ÇÅ : ùî∏ := (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4 +
        (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) -
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * T‚ÇÉ_QPI + T‚ÇÉ_QPI * z) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ T‚ÇÇ ^ 2
    let corr‚ÇÇ : ùî∏ := (3 : ùïÇ)‚Åª¬π ‚Ä¢ (z ^ 2 * T‚ÇÇ + z * T‚ÇÇ * z + T‚ÇÇ * z ^ 2)
    let corr‚ÇÅ_5 : ùî∏ := (2 : ùïÇ)‚Åª¬π ‚Ä¢ W5
    let corr‚ÇÇ_5 : ùî∏ := (3 : ùïÇ)‚Åª¬π ‚Ä¢ y3_5
    -- pieceB''
    y - z - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ y ^ 2 +
      (3 : ùïÇ)‚Åª¬π ‚Ä¢ y ^ 3 - (4 : ùïÇ)‚Åª¬π ‚Ä¢ y ^ 4 + (5 : ùïÇ)‚Åª¬π ‚Ä¢ y ^ 5 -
      bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
      bch_quintic_term ùïÇ a b =
    -- RHS
    ((y - z - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ y ^ 2 +
        (3 : ùïÇ)‚Åª¬π ‚Ä¢ z ^ 3 - bch_cubic_term ùïÇ a b) - corr‚ÇÅ - corr‚ÇÅ_5) +
    ((3 : ùïÇ)‚Åª¬π ‚Ä¢ (y ^ 3 - z ^ 3) - corr‚ÇÇ - corr‚ÇÇ_5) -
    (4 : ùïÇ)‚Åª¬π ‚Ä¢ (y ^ 4 - z ^ 4 - y4_5) +
    (5 : ùïÇ)‚Åª¬π ‚Ä¢ (y ^ 5 - z ^ 5) := by
  intro z T‚ÇÇ T‚ÇÉ_QPI T‚ÇÉ_SPI T‚ÇÑ W5 y3_5 y4_5 y corr‚ÇÅ corr‚ÇÇ corr‚ÇÅ_5 corr‚ÇÇ_5
  -- Use QPI + SPI
  have hQPI := quintic_pure_identity ùïÇ a b
  have hSPI := sextic_pure_identity ùïÇ a b
  -- Try linear_combination with module as norm
  linear_combination (norm := module) hQPI + hSPI

