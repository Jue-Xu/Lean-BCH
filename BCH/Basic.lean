/-! ### Quartic algebraic identity for BCH -/

set_option maxHeartbeats 64000000 in
/-- The quartic algebraic identity: `¬ΩW_H1 + ‚Öì(a+b)¬≥ - bch_cubic_term` equals
a specific combination of quartic+ terms (F‚ÇÅ, F‚ÇÇ, E¬∑b, a¬∑E, D‚ÇÅD‚ÇÇ, cross, P¬≤).

Proof: clear all scalar denominators by multiplying by 12 (via the injectivity trick
from H1), then verify with `noncomm_ring`. -/
private theorem quartic_identity (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (ea eb a b : ùî∏) :
    let D‚ÇÅ := ea - 1 - a
    let D‚ÇÇ := eb - 1 - b
    let P := ea * eb - 1 - (a + b)
    let E‚ÇÅ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2
    let E‚ÇÇ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2
    let Q := a * D‚ÇÇ + D‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ
    let F‚ÇÅ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3
    let F‚ÇÇ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3
    -- LHS: ¬ΩW_H1 + ‚Öì(a+b)¬≥ - bch_cubic_term
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ ((2 : ùïÇ) ‚Ä¢ (E‚ÇÅ + E‚ÇÇ + a * D‚ÇÇ + D‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ) -
          (a + b) * P - P * (a + b) - P ^ 2) +
        (3 : ùïÇ)‚Åª¬π ‚Ä¢ (a + b) ^ 3 - bch_cubic_term ùïÇ a b =
    -- RHS: quartic+ terms
    F‚ÇÅ + F‚ÇÇ + a * E‚ÇÇ + E‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ -
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ ((a + b) * (E‚ÇÅ + E‚ÇÇ + Q) + (E‚ÇÅ + E‚ÇÇ + Q) * (a + b)) -
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ P ^ 2 := by
  -- DECOMPOSITION: reduce to a pure identity in (a,b) that noncomm_ring can handle.
  --
  -- Step 1: ¬ΩW = E‚ÇÅ+E‚ÇÇ+aD‚ÇÇ+D‚ÇÅb+D‚ÇÅD‚ÇÇ - ¬Ω((a+b)P+P(a+b)+P¬≤)
  -- Step 2: Substitute E=F+‚Öôx¬≥, aD‚ÇÇ=aE‚ÇÇ+¬Ωab¬≤, D‚ÇÅb=E‚ÇÅb+¬Ωa¬≤b
  -- Step 3: Split (a+b)P using P=ab+D‚ÇÅ+D‚ÇÇ+Q and D=E+¬Ωx¬≤
  -- Step 4: After cancellation, a pure identity in a,b remains, provable by noncomm_ring.
  --
  -- The pure identity (verified by hand, all 8 noncomm monomials cancel):
  -- ‚Öôa¬≥+‚Öôb¬≥+¬Ωab¬≤+¬Ωa¬≤b - ¬Ω((a+b)¬∑ab+ab¬∑(a+b))
  --   - ¬º((a+b)(a¬≤+b¬≤)+(a¬≤+b¬≤)(a+b)) + ‚Öì(a+b)¬≥ - bch_cubic_term = 0
  have h2ne : (2 : ùïÇ) ‚âÝ 0 := two_ne_zero
  -- Sub-identity 1: the pure cubic identity (no ea,eb ‚Äî just a,b)
  -- After multiplying by 12 to clear denominators:
  -- 2a¬≥+2b¬≥+6ab¬≤+6a¬≤b - 6((a+b)ab+ab(a+b)) - 3((a+b)(a¬≤+b¬≤)+(a¬≤+b¬≤)(a+b))
  --   + 4(a+b)¬≥ - [a,[a,b]] - [b,[b,a]] = 0
  have hpure : (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3 +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) -
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ ((a + b) * (a * b) + a * b * (a + b)) -
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (2 : ùïÇ)‚Åª¬π ‚Ä¢ ((a + b) * (a ^ 2 + b ^ 2) + (a ^ 2 + b ^ 2) * (a + b)) +
      (3 : ùïÇ)‚Åª¬π ‚Ä¢ (a + b) ^ 3 - bch_cubic_term ùïÇ a b = 0 := by
    -- Multiply by 12
    have h12ne : (12 : ùïÇ) ‚âÝ 0 := by exact_mod_cast (show (12 : ‚Ñï) ‚âÝ 0 by norm_num)
    have hinj : Function.Injective ((12 : ùïÇ) ‚Ä¢ ¬∑ : ùî∏ ‚Üí ùî∏) := by
      intro x‚ÇÄ y‚ÇÄ hxy
      have := congrArg ((12 : ùïÇ)‚Åª¬π ‚Ä¢ ¬∑) hxy
      simp only [smul_smul, inv_mul_cancel‚ÇÄ h12ne, one_smul] at this; exact this
    apply hinj; simp only [smul_zero]
    unfold bch_cubic_term
    simp only [smul_sub, smul_add, smul_smul]
    -- Clear scalar products: 12¬∑(6‚Åª¬π)=2, 12¬∑(2‚Åª¬π)=6, 12¬∑(3‚Åª¬π)=4, 12¬∑(12‚Åª¬π)=1,
    -- 12¬∑(2‚Åª¬π¬∑2‚Åª¬π)=3
    have h12_6 : (12 : ùïÇ) * (6 : ùïÇ)‚Åª¬π = 2 := by push_cast; norm_num
    have h12_2 : (12 : ùïÇ) * (2 : ùïÇ)‚Åª¬π = 6 := by push_cast; norm_num
    have h12_3 : (12 : ùïÇ) * (3 : ùïÇ)‚Åª¬π = 4 := by push_cast; norm_num
    have h12_12 : (12 : ùïÇ) * (12 : ùïÇ)‚Åª¬π = 1 := mul_inv_cancel‚ÇÄ h12ne
    have h12_22 : (12 : ùïÇ) * ((2 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = 3 := by push_cast; norm_num
    simp only [h12_6, h12_2, h12_3, h12_12, h12_22, one_smul, mul_one]
    -- Now expand n‚Ä¢x to sums
    simp only [two_smul ùïÇ, show ‚àÄ x : ùî∏, (3 : ùïÇ) ‚Ä¢ x = x + x + x from by
        intro x; rw [show (3:ùïÇ) = 2+1 from by push_cast; norm_num, add_smul, two_smul, one_smul],
      show ‚àÄ x : ùî∏, (4 : ùïÇ) ‚Ä¢ x = x + x + x + x from by
        intro x; rw [show (4:ùïÇ) = 2+2 from by push_cast; norm_num, add_smul, two_smul]; abel,
      show ‚àÄ x : ùî∏, (6 : ùïÇ) ‚Ä¢ x = x + x + x + x + x + x from by
        intro x; rw [show (6:ùïÇ) = 2+2+2 from by push_cast; norm_num,
          add_smul, add_smul, two_smul]; abel]
    noncomm_ring
  -- Connection: multiply by 24, clear scalar denominators, convert to ‚Ñï-smul, noncomm_ring.
  dsimp only
  unfold bch_cubic_term
  rw [‚Üê sub_eq_zero]
  -- Multiply by 24 to clear all denominators (deepest scalar nesting: 2‚Åª¬π¬∑2‚Åª¬π¬∑2‚Åª¬π = 8‚Åª¬π)
  have h24ne : (24 : ùïÇ) ‚âÝ 0 := by exact_mod_cast (show (24 : ‚Ñï) ‚âÝ 0 by norm_num)
  have hinj : Function.Injective ((24 : ùïÇ) ‚Ä¢ ¬∑ : ùî∏ ‚Üí ùî∏) := by
    intro x‚ÇÄ y‚ÇÄ hxy; have := congrArg ((24 : ùïÇ)‚Åª¬π ‚Ä¢ ¬∑) hxy
    simp only [smul_smul, inv_mul_cancel‚ÇÄ h24ne, one_smul] at this; exact this
  apply hinj; simp only [smul_zero]
  -- Pull all smul out of products and merge nested smuls
  simp only [smul_sub, smul_add, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul]
  -- Clear scalar products: use mul_assoc to right-associate, then cancel n*n‚Åª¬π and n‚Åª¬π*n.
  -- The h24_* lemmas handle direct products 24*c‚Åª¬π; mul_assoc + cancel handle deeper nesting.
  simp only [mul_assoc,
    -- n * n‚Åª¬π = 1 and n‚Åª¬π * n = 1
    mul_inv_cancel‚ÇÄ h2ne, inv_mul_cancel‚ÇÄ h2ne,
    -- 24 * c‚Åª¬π products (after right-association by mul_assoc)
    show (24 : ùïÇ) * (2 : ùïÇ)‚Åª¬π = 12 from by norm_num,
    show (24 : ùïÇ) * (3 : ùïÇ)‚Åª¬π = 8 from by norm_num,
    show (24 : ùïÇ) * (6 : ùïÇ)‚Åª¬π = 4 from by norm_num,
    show (24 : ùïÇ) * (12 : ùïÇ)‚Åª¬π = 2 from by norm_num,
    -- 24 * 2‚Åª¬π * 2‚Åª¬π (two-level nesting)
    show (24 : ùïÇ) * ((2 : ùïÇ)‚Åª¬π * (2 : ùïÇ)‚Åª¬π) = 6 from by norm_num,
    -- Cleanup
    one_smul, mul_one]
  -- Convert (n : ùïÇ) ‚Ä¢ x to (n : ‚Ñï) ‚Ä¢ x so noncomm_ring (which uses abel) can close.
  simp only [ofNat_smul_eq_nsmul (R := ùïÇ)]
  noncomm_ring

/-! ### Fourth-order BCH expansion -/

-- Fourth-order exp remainder: ‚Äñexp(x)-1-x-¬Ωx¬≤-‚Öôx¬≥‚Äñ ‚â§ exp(‚Äñx‚Äñ)-1-‚Äñx‚Äñ-‚Äñx‚Äñ¬≤/2-‚Äñx‚Äñ¬≥/6
include ùïÇ in
private theorem norm_exp_sub_one_sub_sub_sub_le (x : ùî∏) :
    ‚Äñexp x - 1 - x - (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2 - (6 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 3‚Äñ ‚â§
      Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ - ‚Äñx‚Äñ ^ 2 / 2 - ‚Äñx‚Äñ ^ 3 / 6 := by
  set f : ‚Ñï ‚Üí ùî∏ := fun n => (n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ùïÇ := ùïÇ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have hf2 : f 2 = (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    ring
  have hf3 : f 3 = (6 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 3 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    norm_num
  have h_sub : exp x - 1 - x - (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2 - (6 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 3 = ‚àë' n, f (n + 4) := by
    rw [congr_fun (exp_eq_tsum ùïÇ (ùî∏ := ùî∏)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    have h4 := ((summable_nat_add_iff 3).mpr hf_summ).tsum_eq_zero_add
    simp only [hf3] at h4
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left,
        h4, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp ‚Äñx‚Äñ
  have h_summ4 : Summable (fun n => ((n + 4) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 4)) :=
    (summable_nat_add_iff 4).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 4) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 4))
      (Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ - ‚Äñx‚Äñ ^ 2 / 2 - ‚Äñx‚Äñ ^ 3 / 6) := by
    rw [h_summ4.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ùïÇ := ùïÇ) x (n + 4))

-- For 0 ‚â§ s with s < 3/4, the fourth-order Taylor remainder satisfies
-- exp(s)-1-s-s¬≤/2-s¬≥/6 ‚â§ s‚Å¥.
private lemma real_exp_fourth_order_le_quartic {s : ‚Ñù} (hs : 0 ‚â§ s) (hs1 : s < 3 / 4) :
    Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 ‚â§ s ^ 4 := by
  have hs_lt1 : s < 1 := by linarith
  -- exp(s)-1-s-s¬≤/2 ‚â§ s¬≥/(6(1-s)) from real_exp_third_order_le_div
  -- So exp(s)-1-s-s¬≤/2-s¬≥/6 = (exp(s)-1-s-s¬≤/2) - s¬≥/6
  -- The n‚â•4 tail: Œ£_{n‚â•0} s^(n+4)/(n+4)!
  have h_rexp := hasSum_real_exp s
  have h_summ4 : Summable (fun n => ((n + 4) !‚Åª¬π : ‚Ñù) * s ^ (n + 4)) :=
    (summable_nat_add_iff 4).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 4) !‚Åª¬π : ‚Ñù) * s ^ (n + 4))
      (Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6) := by
    rw [h_summ4.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4
    linarith
  -- Comparison: (n+4)!‚Åª¬π * s^(n+4) ‚â§ (24)‚Åª¬π * s^(n+4) since (n+4)! ‚â• 4! = 24
  -- So tail ‚â§ s‚Å¥/(24(1-s)) ‚â§ s‚Å¥ for s < 23/24
  have h_geom_summ : Summable (fun n => s ^ (n + 4) / 24) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 4) |>.congr fun n => by ring
  have hterm : ‚àÄ n, ((n + 4) !‚Åª¬π : ‚Ñù) * s ^ (n + 4) ‚â§ s ^ (n + 4) * (24 : ‚Ñù)‚Åª¬π := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_inv‚ÇÄ (by positivity : (0 : ‚Ñù) < (n + 4)!) (by positivity : (0 : ‚Ñù) < 24)]
    have : (4 : ‚Ñï)! ‚â§ (n + 4)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  have h_geom : HasSum (fun n => s ^ (n + 4) * (24 : ‚Ñù)‚Åª¬π) (s ^ 4 * (1 - s)‚Åª¬π * (24 : ‚Ñù)‚Åª¬π) := by
    have hg := (hasSum_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 4)
    have h_eq : (fun n => s ^ 4 * s ^ n) = (fun n => s ^ (n + 4)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (24 : ‚Ñù)‚Åª¬π
  calc Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6
      = ‚àë' n, ((n + 4) !‚Åª¬π : ‚Ñù) * s ^ (n + 4) := h_val.tsum_eq.symm
    _ ‚â§ ‚àë' n, (s ^ (n + 4) * (24 : ‚Ñù)‚Åª¬π) :=
        h_summ4.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 4 * (1 - s)‚Åª¬π * (24 : ‚Ñù)‚Åª¬π := h_geom.tsum_eq
    _ = s ^ 4 / (24 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring
