    _ ≤ ‖x₁ * x₂ * x₃ * x₄‖ * ‖x₅‖ * ‖x₆‖ := by
        gcongr; exact norm_mul_le _ _
    _ ≤ ‖x₁ * x₂ * x₃‖ * ‖x₄‖ * ‖x₅‖ * ‖x₆‖ := by
        gcongr; exact norm_mul_le _ _
    _ ≤ ‖x₁ * x₂‖ * ‖x₃‖ * ‖x₄‖ * ‖x₅‖ * ‖x₆‖ := by
