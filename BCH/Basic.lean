      _ тЙд ((тАЦTтВВтАЦ * тАЦzтАЦ ^ 2) * тАЦP - TтВВтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦTтВВ * z ^ 2тАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
            _ тЙд _ := by
                gcongr
                calc _ тЙд тАЦTтВВтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
                  _ тЙд _ := by gcongr; exact norm_pow_le z 2
      _ тЙд ((s ^ 2 * s ^ 2) * (5 * s ^ 3)) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
  -- Group D: (y┬▓-z┬▓-y2_3)┬╖P┬╖z┬▓ + 2 perms y2_3┬╖(P-TтВВ)┬╖z┬▓.
  have hD_compound : тАЦ(y ^ 2 - z ^ 2 - (z * TтВВ + TтВВ * z)) * P * z ^ 2тАЦ тЙд
      11 * s ^ 4 * s ^ 2 * s ^ 2 :=
    calc _ тЙд тАЦ(y ^ 2 - z ^ 2 - (z * TтВВ + TтВВ * z)) * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦy ^ 2 - z ^ 2 - (z * TтВВ + TтВВ * z)тАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд (11 * s ^ 4 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hy2_323 hP (norm_nonneg _) (by positivity)
  have hD1 : тАЦz * TтВВ * (P - TтВВ) * z ^ 2тАЦ тЙд s * s ^ 2 * (5 * s ^ 3) * s ^ 2 :=
    calc _ тЙд тАЦz * TтВВ * (P - TтВВ)тАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд ((тАЦzтАЦ * тАЦTтВВтАЦ) * тАЦP - TтВВтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ calc _ тЙд тАЦz * TтВВтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд ((s * s ^ 2) * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hzn hTтВВ (norm_nonneg _) (by positivity)
  have hD2 : тАЦTтВВ * z * (P - TтВВ) * z ^ 2тАЦ тЙд s ^ 2 * s * (5 * s ^ 3) * s ^ 2 :=
    calc _ тЙд тАЦTтВВ * z * (P - TтВВ)тАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд ((тАЦTтВВтАЦ * тАЦzтАЦ) * тАЦP - TтВВтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ calc _ тЙд тАЦTтВВ * zтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд ((s ^ 2 * s) * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hzn (norm_nonneg _) (by positivity)
  -- Group E: (P┬▓-TтВВ┬▓)┬╖z┬│
  have hE : тАЦ(P ^ 2 - TтВВ ^ 2) * z ^ 3тАЦ тЙд (10 * s ^ 5) * s ^ 3 :=
    calc _ тЙд тАЦP ^ 2 - TтВВ ^ 2тАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд тАЦP ^ 2 - TтВВ ^ 2тАЦ * тАЦzтАЦ ^ 3 := by gcongr; exact norm_pow_le z 3
      _ тЙд (10 * s ^ 5) * s ^ 3 := mul_le_mul hP2T22
          (pow_le_pow_leftтВА (norm_nonneg _) hzn 3) (by positivity) (by positivity)
  -- Triangle inequality (17 norm_add_le applications, 18 terms).
  set u1 : ЁЭФ╕ := z ^ 4 * (P - TтВВ - TтВГ)
  set u2 : ЁЭФ╕ := z ^ 3 * (P - TтВВ - TтВГ) * z
  set u3 : ЁЭФ╕ := z ^ 2 * (P - TтВВ - TтВГ) * z ^ 2
  set u4 : ЁЭФ╕ := z * (P - TтВВ - TтВГ) * z ^ 3
  set u5 : ЁЭФ╕ := (P - TтВВ - TтВГ) * z ^ 4
  set u6 : ЁЭФ╕ := (y ^ 4 - z ^ 4 -
      (z ^ 3 * TтВВ + z ^ 2 * TтВВ * z + z * TтВВ * z ^ 2 + TтВВ * z ^ 3)) * P
  set u7 : ЁЭФ╕ := z ^ 3 * TтВВ * (P - TтВВ)
  set u8 : ЁЭФ╕ := z ^ 2 * TтВВ * z * (P - TтВВ)
  set u9 : ЁЭФ╕ := z * TтВВ * z ^ 2 * (P - TтВВ)
  set u10 : ЁЭФ╕ := TтВВ * z ^ 3 * (P - TтВВ)
  set u11 : ЁЭФ╕ := (y ^ 3 - z ^ 3 -
      (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2)) * P * z
  set u12 : ЁЭФ╕ := z ^ 2 * TтВВ * (P - TтВВ) * z
  set u13 : ЁЭФ╕ := z * TтВВ * z * (P - TтВВ) * z
  set u14 : ЁЭФ╕ := TтВВ * z ^ 2 * (P - TтВВ) * z
  set u15 : ЁЭФ╕ := (y ^ 2 - z ^ 2 - (z * TтВВ + TтВВ * z)) * P * z ^ 2
  set u16 : ЁЭФ╕ := z * TтВВ * (P - TтВВ) * z ^ 2
  set u17 : ЁЭФ╕ := TтВВ * z * (P - TтВВ) * z ^ 2
  set u18 : ЁЭФ╕ := (P ^ 2 - TтВВ ^ 2) * z ^ 3
  have ht_17 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12 + u13 + u14 + u15 + u16 + u17) u18
  have ht_16 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12 + u13 + u14 + u15 + u16) u17
  have ht_15 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12 + u13 + u14 + u15) u16
  have ht_14 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12 + u13 + u14) u15
  have ht_13 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12 + u13) u14
  have ht_12 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11 + u12) u13
  have ht_11 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10
    + u11) u12
  have ht_10 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9 + u10) u11
  have ht_9 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8 + u9) u10
  have ht_8 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8) u9
  have ht_7 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6 + u7) u8
  have ht_6 := norm_add_le (u1 + u2 + u3 + u4 + u5 + u6) u7
  have ht_5 := norm_add_le (u1 + u2 + u3 + u4 + u5) u6
  have ht_4 := norm_add_le (u1 + u2 + u3 + u4) u5
  have ht_3 := norm_add_le (u1 + u2 + u3) u4
  have ht_2 := norm_add_le (u1 + u2) u3
  have ht_1 := norm_add_le u1 u2
  nlinarith [pow_nonneg hs_nn 8, pow_nonneg hs_nn 7, pow_nonneg hs_nn 6,
    pow_nonneg hs_nn 5, pow_nonneg hs_nn 4, pow_nonneg hs_nn 3,
    pow_nonneg hs_nn 2, hs_le_one, sq_nonneg s]

/-- Norm bound for `IтВВ residual` (post `(3:ЁЭХВ)тБ╗┬╣` scalar factor):
inner sum тЙд 50┬╖sтБ╢ for `s < 1/10`. -/
private theorem norm_I2_residual_inner_le (z P TтВВ TтВГ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_small : s тЙд 1 / 10)
    (hz : тАЦzтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3) (hPmTтВВmTтВГ : тАЦP - TтВВ - TтВГтАЦ тЙд 5 * s ^ 4) :
    тАЦz ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z + (P - TтВВ - TтВГ) * z ^ 2 +
     z * (P ^ 2 - TтВВ ^ 2) + (P * z * P - TтВВ * z * TтВВ) +
     (P ^ 2 - TтВВ ^ 2) * z + P ^ 3тАЦ тЙд 50 * s ^ 6 := by
  -- Helper bounds
  have hP2T22 := norm_P2_sub_T22_le P TтВВ hs_nn hP hTтВВ hPmTтВВ
  have hPzP := norm_PzP_sub_T2zT2_le z P TтВВ hs_nn hs_small hz hTтВВ hPmTтВВ
  -- Term 1: z┬▓ ┬╖ (P-TтВВ-TтВГ) тЙд s┬▓┬╖5sтБ┤ = 5sтБ╢
  have h1 : тАЦz ^ 2 * (P - TтВВ - TтВГ)тАЦ тЙд s ^ 2 * (5 * s ^ 4) :=
    calc _ тЙд тАЦz ^ 2тАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд тАЦzтАЦ ^ 2 * тАЦP - TтВВ - TтВГтАЦ := by gcongr; exact norm_pow_le z 2
      _ тЙд s ^ 2 * (5 * s ^ 4) := mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hz 2)
          hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
  -- Term 2: z ┬╖ (P-TтВВ-TтВГ) ┬╖ z тЙд s┬╖5sтБ┤┬╖s = 5sтБ╢
  have h2 : тАЦz * (P - TтВВ - TтВГ) * zтАЦ тЙд s * (5 * s ^ 4) * s :=
    calc _ тЙд тАЦz * (P - TтВВ - TтВГ)тАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦzтАЦ * тАЦP - TтВВ - TтВГтАЦ) * тАЦzтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s * (5 * s ^ 4)) * s := by
          apply mul_le_mul _ hz (norm_nonneg _) (by positivity)
          exact mul_le_mul hz hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
  -- Term 3: (P-TтВВ-TтВГ) ┬╖ z┬▓ тЙд 5sтБ┤┬╖s┬▓ = 5sтБ╢
  have h3 : тАЦ(P - TтВВ - TтВГ) * z ^ 2тАЦ тЙд (5 * s ^ 4) * s ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВ - TтВГтАЦ * тАЦzтАЦ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ тЙд (5 * s ^ 4) * s ^ 2 := mul_le_mul hPmTтВВmTтВГ
          (pow_le_pow_leftтВА (norm_nonneg _) hz 2) (by positivity) (by positivity)
  -- Term 4: z ┬╖ (P┬▓-TтВВ┬▓) тЙд s┬╖10sтБ╡ = 10sтБ╢
  have h4 : тАЦz * (P ^ 2 - TтВВ ^ 2)тАЦ тЙд s * (10 * s ^ 5) :=
    calc _ тЙд тАЦzтАЦ * тАЦP ^ 2 - TтВВ ^ 2тАЦ := norm_mul_le _ _
      _ тЙд s * (10 * s ^ 5) := mul_le_mul hz hP2T22 (norm_nonneg _) hs_nn
  -- Term 5: PzP - TтВВzTтВВ тЙд 13sтБ╢
  -- (already have hPzP)
  -- Term 6: (P┬▓-TтВВ┬▓) ┬╖ z тЙд 10sтБ╡┬╖s = 10sтБ╢
  have h6 : тАЦ(P ^ 2 - TтВВ ^ 2) * zтАЦ тЙд (10 * s ^ 5) * s :=
    calc _ тЙд тАЦP ^ 2 - TтВВ ^ 2тАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (10 * s ^ 5) * s := mul_le_mul hP2T22 hz (norm_nonneg _) (by positivity)
  -- Term 7: P┬│ тЙд sтБ╢
  have h7 : тАЦP ^ 3тАЦ тЙд (s ^ 2) ^ 3 :=
    calc _ тЙд тАЦPтАЦ ^ 3 := norm_pow_le P 3
      _ тЙд (s ^ 2) ^ 3 := pow_le_pow_leftтВА (norm_nonneg _) hP 3
  -- Sum 7 terms via norm_add_le chain
  have ha1 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z +
    (P - TтВВ - TтВГ) * z ^ 2 + z * (P ^ 2 - TтВВ ^ 2) + (P * z * P - TтВВ * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2) * z) (P ^ 3)
  have ha2 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z +
    (P - TтВВ - TтВГ) * z ^ 2 + z * (P ^ 2 - TтВВ ^ 2) + (P * z * P - TтВВ * z * TтВВ))
    ((P ^ 2 - TтВВ ^ 2) * z)
  have ha3 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z +
    (P - TтВВ - TтВГ) * z ^ 2 + z * (P ^ 2 - TтВВ ^ 2)) (P * z * P - TтВВ * z * TтВВ)
  have ha4 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z +
    (P - TтВВ - TтВГ) * z ^ 2) (z * (P ^ 2 - TтВВ ^ 2))
  have ha5 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z)
    ((P - TтВВ - TтВГ) * z ^ 2)
  have ha6 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ)) (z * (P - TтВВ - TтВГ) * z)
  -- Sum: 5+5+5+10+13+10+1 = 49 тЙд 50
  nlinarith [pow_nonneg hs_nn 6]

set_option maxHeartbeats 1024000000 in
omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Algebraic decomposition of `pieceB''` for the sextic remainder small-s case.**

States that pieceB'' (the algebraic part of the sextic remainder, with H1
NOT applied тАФ keeping the `y - z - ┬╜[a,b] - ┬╜y┬▓` form) decomposes as:

```
pieceB'' = (IтВБ - corrтВБ - corrтВБ_5) + (IтВВ - corrтВВ - corrтВВ_5)
           - ┬╝(yтБ┤ - zтБ┤ - y4_5) + тЕХ(yтБ╡ - zтБ╡)
```

where:
- `IтВБ = y - z - ┬╜[a,b] - ┬╜y┬▓ + тЕУz┬│ - CтВГ` (== ┬╜W + тЕУz┬│ - CтВГ via H1)
- `IтВВ = тЕУ(y┬│ - z┬│)`
- `corrтВБ`, `corrтВВ` from `quintic_pure_identity` (deg-4 corrections)
- `corrтВБ_5 = ┬╜┬╖W5`, `corrтВВ_5 = тЕУ┬╖y3_5` from `sextic_pure_identity` (deg-5)

Proof: `pieceB'' - RHS = (LHS_QPI) + (LHS_SPI) = 0 + 0 = 0` via QPI + SPI. -/
private theorem pieceB_sextic_decomp (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (a b : ЁЭФ╕) :
    let z : ЁЭФ╕ := a + b
    let TтВВ : ЁЭФ╕ := a * b + (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2 + (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let TтВГ_QPI : ЁЭФ╕ := (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b)
    let TтВГ_SPI : ЁЭФ╕ := (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) +
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    let TтВД : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) +
        (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4
    let W5 : ЁЭФ╕ := (60 : ЁЭХВ)тБ╗┬╣ тАв a ^ 5 + (60 : ЁЭХВ)тБ╗┬╣ тАв b ^ 5 +
        (12 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 4) + (12 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 4 * b) +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b ^ 2) -
        (z * TтВД + TтВД * z) - (TтВВ * TтВГ_SPI + TтВГ_SPI * TтВВ)
    let y3_5 : ЁЭФ╕ := z ^ 2 * TтВГ_SPI + z * TтВГ_SPI * z + TтВГ_SPI * z ^ 2 +
        z * TтВВ ^ 2 + TтВВ * z * TтВВ + TтВВ ^ 2 * z
    let y4_5 : ЁЭФ╕ := z ^ 3 * TтВВ + z ^ 2 * TтВВ * z + z * TтВВ * z ^ 2 + TтВВ * z ^ 3
    let y : ЁЭФ╕ := exp a * exp b - 1
    let corrтВБ : ЁЭФ╕ := (24 : ЁЭХВ)тБ╗┬╣ тАв a ^ 4 + (24 : ЁЭХВ)тБ╗┬╣ тАв b ^ 4 +
        (6 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 3) + (6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * b) +
        (4 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b ^ 2) -
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * TтВГ_QPI + TтВГ_QPI * z) - (2 : ЁЭХВ)тБ╗┬╣ тАв TтВВ ^ 2
    let corrтВВ : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2)
    let corrтВБ_5 : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв W5
    let corrтВВ_5 : ЁЭФ╕ := (3 : ЁЭХВ)тБ╗┬╣ тАв y3_5
    -- pieceB''
    y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
      (3 : ЁЭХВ)тБ╗┬╣ тАв y ^ 3 - (4 : ЁЭХВ)тБ╗┬╣ тАв y ^ 4 + (5 : ЁЭХВ)тБ╗┬╣ тАв y ^ 5 -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a b =
    -- RHS
    ((y - z - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) - (2 : ЁЭХВ)тБ╗┬╣ тАв y ^ 2 +
        (3 : ЁЭХВ)тБ╗┬╣ тАв z ^ 3 - bch_cubic_term ЁЭХВ a b) - corrтВБ - corrтВБ_5) +
    ((3 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 3 - z ^ 3) - corrтВВ - corrтВВ_5) -
    (4 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 4 - z ^ 4 - y4_5) +
    (5 : ЁЭХВ)тБ╗┬╣ тАв (y ^ 5 - z ^ 5) := by
  intro z TтВВ TтВГ_QPI TтВГ_SPI TтВД W5 y3_5 y4_5 y corrтВБ corrтВВ corrтВБ_5 corrтВВ_5
  -- Use QPI + SPI
  have hQPI := quintic_pure_identity ЁЭХВ a b
  have hSPI := sextic_pure_identity ЁЭХВ a b
  -- Try linear_combination with module as norm
  linear_combination (norm := module) hQPI + hSPI

