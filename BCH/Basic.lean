        _ = 2 * ‖bch_quartic_term 𝕂 a' b‖ * ‖a'‖ := by ring
    calc ‖(2 : 𝕂)⁻¹ • (bch_quartic_term 𝕂 a' b * a' - a' * bch_quartic_term 𝕂 a' b)‖
        ≤ ‖(2 : 𝕂)⁻¹‖ * ‖bch_quartic_term 𝕂 a' b * a' - a' * bch_quartic_term 𝕂 a' b‖ :=
