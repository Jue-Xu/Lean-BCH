  -- y¬≤ - z¬≤ - y2_3 = z¬∑(P-T‚ÇÇ) + (P-T‚ÇÇ)¬∑z + P¬≤
  have heq : y ^ 2 - (y - P) ^ 2 - ((y - P) * T‚ÇÇ + T‚ÇÇ * (y - P)) =
      (y - P) * (P - T‚ÇÇ) + (P - T‚ÇÇ) * (y - P) + P ^ 2 := by noncomm_ring
  rw [heq]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  have h1 : ‚Äñz * (P - T‚ÇÇ)‚Äñ ‚â§ s * (5 * s ^ 3) :=
