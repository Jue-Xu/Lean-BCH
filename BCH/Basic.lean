/-- **Homogeneity of `bch_septic_term`**: `ZтВЗ(cтАвa, cтАвb) = cтБ╖ тАв ZтВЗ(a, b)`. -/
theorem bch_septic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_septic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 7 тАв bch_septic_term ЁЭХВ a b := by
  unfold bch_septic_term
  simp only [bch_septic_term_seven_fold_smul_mul c, smul_comm _ (c ^ 7 : ЁЭХВ), тЖР smul_add]

