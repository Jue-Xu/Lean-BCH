set_option maxRecDepth 2000 in
private theorem bch_septic_term_eq_sum (a b : ЁЭФ╕) :
    bch_septic_term ЁЭХВ a b = тИС i : Fin 126, bchSepticTerm (ЁЭХВ := ЁЭХВ) a b i := by
