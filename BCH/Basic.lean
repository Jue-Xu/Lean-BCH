    ((6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * GтВВ) + (6 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 3) + FтВБ * FтВВ))
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * HтВВ))
  have ha3 := norm_add_le (J_a + J_b + a * I_b + I_a * b)
    ((6 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 3 * GтВВ) + (6 : ЁЭХВ)тБ╗┬╣ тАв (GтВБ * b ^ 3) + FтВБ * FтВВ)
  have ha4 := norm_add_le (J_a + J_b + a * I_b) (I_a * b)
  have ha5 := norm_add_le (J_a + J_b) (a * I_b)
  have ha6 := norm_add_le J_a J_b
  -- Sum: 4┬╖sтБ╕ + 4/3┬╖sтБ╕ + 1┬╖sтБ╕ + C/2┬╖sтБ╕ = 19/3┬╖sтБ╕ + C/2┬╖sтБ╕ тЙд 7┬╖sтБ╕ + C/2┬╖sтБ╕.
  nlinarith [pow_nonneg hs_nn 8]

/-- Norm bound for the RHS of `I2_septic_residual_decomp_eq`.

Given precomputed bounds for the 4 input pieces (with parameterized constants
K_PmT4, K_P2, K_PzP, K_P3), bounds the RHS by `(3┬╖K_PmT4 + 2┬╖K_P2 + K_PzP + K_P3)┬╖sтБ╖`.

Per-term contributions:
- 3 weight-1 (P-TтВВ-TтВГ-TтВД) middle terms: each тЙд K_PmT4┬╖sтБ╖.
- 2 compound `z┬╖(P┬▓-TтВВ┬▓-TтВВTтВГ-TтВГTтВВ)`-style terms: each тЙд K_P2┬╖sтБ╖.
- 1 sandwich `PzP-TтВВzTтВВ-TтВВzTтВГ-TтВГzTтВВ` term: тЙд K_PzP┬╖sтБ╖.
- 1 (P┬│ - TтВВ┬│) term: тЙд K_P3┬╖sтБ╖.

The user supplies the parameterized bounds; this wrapper combines via
triangle inequality. -/
private theorem norm_I2_septic_residual_RHS_le (z P TтВВ TтВГ TтВД : ЁЭФ╕)
    {s K_PmT4 K_P2 K_PzP K_P3 : тДЭ} (hs_nn : 0 тЙд s)
    (hK_PmT4_nn : 0 тЙд K_PmT4) (hK_P2_nn : 0 тЙд K_P2)
    (hK_PzP_nn : 0 тЙд K_PzP) (hK_P3_nn : 0 тЙд K_P3)
    (hz : тАЦzтАЦ тЙд s)
    (hPmT4_le : тАЦP - TтВВ - TтВГ - TтВДтАЦ тЙд K_PmT4 * s ^ 5)
    (hP2_etc_le : тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВтАЦ тЙд K_P2 * s ^ 6)
    (hPzP_etc_le :
        тАЦP * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВтАЦ тЙд K_PzP * s ^ 7)
    (hP3_le : тАЦP ^ 3 - TтВВ ^ 3тАЦ тЙд K_P3 * s ^ 7) :
    тАЦz ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
      (P - TтВВ - TтВГ - TтВД) * z ^ 2 +
      z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) +
      (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ) +
      (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * z +
      (P ^ 3 - TтВВ ^ 3)тАЦ тЙд
      (3 * K_PmT4 + 2 * K_P2 + K_PzP + K_P3) * s ^ 7 := by
  -- Bound each of the 7 outer terms.
  have h1 : тАЦz ^ 2 * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 2 * (K_PmT4 * s ^ 5) :=
    calc _ тЙд тАЦz ^ 2тАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ := norm_mul_le _ _
      _ тЙд тАЦzтАЦ ^ 2 * тАЦP - TтВВ - TтВГ - TтВДтАЦ := by gcongr; exact norm_pow_le z 2
      _ тЙд s ^ 2 * (K_PmT4 * s ^ 5) := mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hz 2)
          hPmT4_le (norm_nonneg _) (by positivity)
  have h2 : тАЦz * (P - TтВВ - TтВГ - TтВД) * zтАЦ тЙд s * (K_PmT4 * s ^ 5) * s :=
    calc _ тЙд тАЦz * (P - TтВВ - TтВГ - TтВД)тАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦzтАЦ * тАЦP - TтВВ - TтВГ - TтВДтАЦ) * тАЦzтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s * (K_PmT4 * s ^ 5)) * s := by
          apply mul_le_mul _ hz (norm_nonneg _) (by positivity)
          exact mul_le_mul hz hPmT4_le (norm_nonneg _) (by positivity)
  have h3 : тАЦ(P - TтВВ - TтВГ - TтВД) * z ^ 2тАЦ тЙд (K_PmT4 * s ^ 5) * s ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВ - TтВГ - TтВДтАЦ * тАЦzтАЦ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ тЙд (K_PmT4 * s ^ 5) * s ^ 2 := mul_le_mul hPmT4_le
          (pow_le_pow_leftтВА (norm_nonneg _) hz 2) (by positivity) (by positivity)
  have h4 : тАЦz * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ)тАЦ тЙд s * (K_P2 * s ^ 6) :=
    calc _ тЙд тАЦzтАЦ * тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВтАЦ := norm_mul_le _ _
      _ тЙд s * (K_P2 * s ^ 6) := mul_le_mul hz hP2_etc_le (norm_nonneg _) (by positivity)
  have h6 : тАЦ(P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * zтАЦ тЙд (K_P2 * s ^ 6) * s :=
    calc _ тЙд тАЦP ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (K_P2 * s ^ 6) * s := mul_le_mul hP2_etc_le hz (norm_nonneg _) (by positivity)
  -- Sum 7 terms via triangle inequality (6 norm_add_le).
  have ha1 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
    (P - TтВВ - TтВГ - TтВД) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * z) (P ^ 3 - TтВВ ^ 3)
  have ha2 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
    (P - TтВВ - TтВГ - TтВД) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ))
    ((P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * z)
  have ha3 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
    (P - TтВВ - TтВГ - TтВД) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ))
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ)
  have ha4 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
    (P - TтВВ - TтВГ - TтВД) * z ^ 2) (z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ))
  have ha5 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z)
    ((P - TтВВ - TтВГ - TтВД) * z ^ 2)
  have ha6 := norm_add_le (z ^ 2 * (P - TтВВ - TтВГ - TтВД)) (z * (P - TтВВ - TтВГ - TтВД) * z)
  -- Sum: 3┬╖K_PmT4 + 2┬╖K_P2 + K_PzP + K_P3 (in units of sтБ╖).
  nlinarith [pow_nonneg hs_nn 7]

/-- Norm bound `тАЦTтВВ┬▓ - P┬▓ + TтВВTтВГ + TтВГTтВВтАЦ тЙд 15┬╖sтБ╢`. Decomposition uses
`P┬▓ - TтВВ┬▓ - TтВВTтВГ - TтВГTтВВ = (P-TтВВ-TтВГ)┬╖P + TтВВ┬╖(P-TтВВ-TтВГ) + TтВГ┬╖(P-TтВВ)`. -/
private theorem norm_T22_sub_P2_etc_le (P TтВВ TтВГ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hP : тАЦPтАЦ тЙд s ^ 2) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3)
    (hPmTтВВmTтВГ : тАЦP - TтВВ - TтВГтАЦ тЙд 5 * s ^ 4) :
    тАЦTтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВтАЦ тЙд 15 * s ^ 6 := by
  have heq : TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ =
      -((P - TтВВ - TтВГ) * P + TтВВ * (P - TтВВ - TтВГ) + TтВГ * (P - TтВВ)) := by noncomm_ring
  rw [heq, norm_neg]
  have h1 : тАЦ(P - TтВВ - TтВГ) * PтАЦ тЙд (5 * s ^ 4) * s ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГтАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд (5 * s ^ 4) * s ^ 2 := mul_le_mul hPmTтВВmTтВГ hP (norm_nonneg _) (by positivity)
  have h2 : тАЦTтВВ * (P - TтВВ - TтВГ)тАЦ тЙд s ^ 2 * (5 * s ^ 4) :=
    calc _ тЙд тАЦTтВВтАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд s ^ 2 * (5 * s ^ 4) := mul_le_mul hTтВВ hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
  have h3 : тАЦTтВГ * (P - TтВВ)тАЦ тЙд s ^ 3 * (5 * s ^ 3) :=
    calc _ тЙд тАЦTтВГтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд s ^ 3 * (5 * s ^ 3) := mul_le_mul hTтВГ hPmTтВВ (norm_nonneg _) (by positivity)
  have ha1 := norm_add_le ((P - TтВВ - TтВГ) * P + TтВВ * (P - TтВВ - TтВГ)) (TтВГ * (P - TтВВ))
  have ha2 := norm_add_le ((P - TтВВ - TтВГ) * P) (TтВВ * (P - TтВВ - TтВГ))
  linarith [pow_nonneg hs_nn 6]

/-- Norm bound `тАЦR-residual sumтАЦ тЙд 6┬╖sтБ╡` from precomputed component bounds.
The 7 terms come from R_eq_neg_deg5_residual: GтВБ+GтВВ+a┬╖FтВВ+FтВБ┬╖b+EтВБ┬╖EтВВ+┬╜EтВБb┬▓+┬╜a┬▓EтВВ. -/
private theorem norm_R_residual_sum_le (GтВБ GтВВ FтВБ FтВВ EтВБ EтВВ a b : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hGтВБ_le : тАЦGтВБтАЦ тЙд s ^ 5) (hGтВВ_le : тАЦGтВВтАЦ тЙд s ^ 5)
    (h_aFтВВ_le : тАЦa * FтВВтАЦ тЙд s ^ 5) (h_FтВБb_le : тАЦFтВБ * bтАЦ тЙд s ^ 5)
    (h_EтВБEтВВ_le : тАЦEтВБ * EтВВтАЦ тЙд s ^ 6)
    (h_EтВБb2_le : тАЦEтВБ * b ^ 2тАЦ тЙд s ^ 5)
    (h_a2EтВВ_le : тАЦa ^ 2 * EтВВтАЦ тЙд s ^ 5) :
    тАЦGтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ)тАЦ тЙд 6 * s ^ 5 := by
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h_smul1 : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2)тАЦ тЙд s ^ 5 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦEтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 5 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_EтВБb2_le (by norm_num)
      _ = s ^ 5 / 2 := by ring
  have h_smul2 : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ)тАЦ тЙд s ^ 5 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * EтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 5 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2EтВВ_le (by norm_num)
      _ = s ^ 5 / 2 := by ring
  have hs6 : s ^ 6 тЙд s ^ 5 / 10 := by
    have h_eq : s ^ 6 = s ^ 5 * s := by ring
    rw [h_eq]
    have : s ^ 5 * s тЙд s ^ 5 * (1 / 10) := by
      apply mul_le_mul_of_nonneg_left hs_small (pow_nonneg hs_nn 5)
    linarith
  have ha1 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * EтВВ))
  have ha2 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b + EтВБ * EтВВ)
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (EтВБ * b ^ 2))
  have ha3 := norm_add_le (GтВБ + GтВВ + a * FтВВ + FтВБ * b) (EтВБ * EтВВ)
  have ha4 := norm_add_le (GтВБ + GтВВ + a * FтВВ) (FтВБ * b)
  have ha5 := norm_add_le (GтВБ + GтВВ) (a * FтВВ)
  have ha6 := norm_add_le GтВБ GтВВ
  linarith [pow_nonneg hs_nn 5, pow_nonneg hs_nn 6]

/-- Norm bound `тАЦR+TтВЕ residual sumтАЦ тЙд 6┬╖sтБ╢` from precomputed component bounds.
The 7 terms come from `R_plus_T5_eq_neg_deg6_residual`:
HтВБ+HтВВ+a┬╖GтВВ+GтВБ┬╖b+EтВБ┬╖EтВВ+┬╜┬╖FтВБ┬╖b┬▓+┬╜┬╖a┬▓┬╖FтВВ. Analog of `norm_R_residual_sum_le`
at one degree higher; all inputs are already deg-6, so no `s тЙд 1/10`
constraint is needed. -/
private theorem norm_R_plus_T5_residual_sum_le (HтВБ HтВВ GтВБ GтВВ FтВБ FтВВ EтВБ EтВВ a b : ЁЭФ╕)
    {s : тДЭ} (hs_nn : 0 тЙд s)
    (hHтВБ_le : тАЦHтВБтАЦ тЙд s ^ 6) (hHтВВ_le : тАЦHтВВтАЦ тЙд s ^ 6)
    (h_aGтВВ_le : тАЦa * GтВВтАЦ тЙд s ^ 6) (h_GтВБb_le : тАЦGтВБ * bтАЦ тЙд s ^ 6)
    (h_EтВБEтВВ_le : тАЦEтВБ * EтВВтАЦ тЙд s ^ 6)
    (h_FтВБb2_le : тАЦFтВБ * b ^ 2тАЦ тЙд s ^ 6)
    (h_a2FтВВ_le : тАЦa ^ 2 * FтВВтАЦ тЙд s ^ 6) :
    тАЦHтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ)тАЦ тЙд 6 * s ^ 6 := by
  have h2eq : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h_F1b2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦFтВБ * b ^ 2тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_FтВБb2_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_a2F2_smul : тАЦ(2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ)тАЦ тЙд s ^ 6 / 2 := by
    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦa ^ 2 * FтВВтАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2FтВВ_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have ha1 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ +
    (2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2)) ((2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * FтВВ))
  have ha2 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b + EтВБ * EтВВ)
    ((2 : ЁЭХВ)тБ╗┬╣ тАв (FтВБ * b ^ 2))
  have ha3 := norm_add_le (HтВБ + HтВВ + a * GтВВ + GтВБ * b) (EтВБ * EтВВ)
  have ha4 := norm_add_le (HтВБ + HтВВ + a * GтВВ) (GтВБ * b)
  have ha5 := norm_add_le (HтВБ + HтВВ) (a * GтВВ)
  have ha6 := norm_add_le HтВБ HтВВ
  -- Total: 5┬╖sтБ╢ + sтБ╢/2 + sтБ╢/2 = 6┬╖sтБ╢
  linarith [pow_nonneg hs_nn 6]

/-- Norm bound for `тАЦPzP - TтВВzTтВВтАЦ тЙд 13┬╖sтБ╢` for small s (`s < 1/10`).
Splits via `P = TтВВ + (P-TтВВ)` into 3 terms each bounded by CsтБ╢. -/
private theorem norm_PzP_sub_T2zT2_le (z P TтВВ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_small : s тЙд 1 / 10) (hz : тАЦzтАЦ тЙд s) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3) :
    тАЦP * z * P - TтВВ * z * TтВВтАЦ тЙд 13 * s ^ 6 := by
  have heq : P * z * P - TтВВ * z * TтВВ =
      TтВВ * z * (P - TтВВ) + (P - TтВВ) * z * TтВВ + (P - TтВВ) * z * (P - TтВВ) := by
    have hP : P = TтВВ + (P - TтВВ) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  have ht1 : тАЦTтВВ * z * (P - TтВВ)тАЦ тЙд s ^ 2 * s * (5 * s ^ 3) :=
    calc _ тЙд тАЦTтВВ * zтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВВтАЦ * тАЦzтАЦ) * тАЦP - TтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 2 * s) * (5 * s ^ 3) := by
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hz (norm_nonneg _) (by positivity)
  have ht2 : тАЦ(P - TтВВ) * z * TтВВтАЦ тЙд (5 * s ^ 3) * s * s ^ 2 :=
    calc _ тЙд тАЦ(P - TтВВ) * zтАЦ * тАЦTтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВтАЦ * тАЦzтАЦ) * тАЦTтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 3) * s) * s ^ 2 := by
          apply mul_le_mul _ hTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВ hz (norm_nonneg _) (by positivity)
  have ht3 : тАЦ(P - TтВВ) * z * (P - TтВВ)тАЦ тЙд (5 * s ^ 3) * s * (5 * s ^ 3) :=
    calc _ тЙд тАЦ(P - TтВВ) * zтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВтАЦ * тАЦzтАЦ) * тАЦP - TтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 3) * s) * (5 * s ^ 3) := by
          apply mul_le_mul _ hPmTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВ hz (norm_nonneg _) (by positivity)
  have hadd1 := norm_add_le (TтВВ * z * (P - TтВВ) + (P - TтВВ) * z * TтВВ)
    ((P - TтВВ) * z * (P - TтВВ))
  have hadd2 := norm_add_le (TтВВ * z * (P - TтВВ)) ((P - TтВВ) * z * TтВВ)
  -- Total: 5sтБ╢ + 5sтБ╢ + 25sтБ╖ тЙд 5 + 5 + 25┬╖(1/10)┬╖sтБ╢ = 12.5sтБ╢ тЙд 13sтБ╢
  nlinarith [pow_nonneg hs_nn 6, pow_nonneg hs_nn 7]

/-- Norm bound for `тАЦPzP - TтВВzTтВВ - TтВВzTтВГ - TтВГzTтВВтАЦ тЙд 13┬╖sтБ╖` for small s
(`s тЙд 1/10`). Decomposes via `P = TтВВ + TтВГ + (P-TтВВ-TтВГ)` into 6 terms.
The "I2 sandwich" piece for the septic residual; provides K_PzP = 13. -/
private theorem norm_PzP_sub_T2zT2_etc_le (z P TтВВ TтВГ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_small : s тЙд 1 / 10) (hz : тАЦzтАЦ тЙд s) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2)
    (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3)
    (hPmTтВВmTтВГ : тАЦP - TтВВ - TтВГтАЦ тЙд 5 * s ^ 4) :
    тАЦP * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВтАЦ тЙд 13 * s ^ 7 := by
  have heq : P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ =
      TтВВ * z * (P - TтВВ - TтВГ) + TтВГ * z * TтВГ + TтВГ * z * (P - TтВВ - TтВГ) +
      (P - TтВВ - TтВГ) * z * TтВВ + (P - TтВВ - TтВГ) * z * TтВГ +
      (P - TтВВ - TтВГ) * z * (P - TтВВ - TтВГ) := by
    have hP : P = TтВВ + TтВГ + (P - TтВВ - TтВГ) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  have h1 : тАЦTтВВ * z * (P - TтВВ - TтВГ)тАЦ тЙд s ^ 2 * s * (5 * s ^ 4) :=
    calc _ тЙд тАЦTтВВ * zтАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВВтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 2 * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВВ hz (norm_nonneg _) (by positivity)
  have h2 : тАЦTтВГ * z * TтВГтАЦ тЙд s ^ 3 * s * s ^ 3 :=
    calc _ тЙд тАЦTтВГ * zтАЦ * тАЦTтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВГтАЦ * тАЦzтАЦ) * тАЦTтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 3 * s) * s ^ 3 := by
          apply mul_le_mul _ hTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВГ hz (norm_nonneg _) (by positivity)
  have h3 : тАЦTтВГ * z * (P - TтВВ - TтВГ)тАЦ тЙд s ^ 3 * s * (5 * s ^ 4) :=
    calc _ тЙд тАЦTтВГ * zтАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦTтВГтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (s ^ 3 * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hTтВГ hz (norm_nonneg _) (by positivity)
  have h4 : тАЦ(P - TтВВ - TтВГ) * z * TтВВтАЦ тЙд (5 * s ^ 4) * s * s ^ 2 :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ) * zтАЦ * тАЦTтВВтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГтАЦ * тАЦzтАЦ) * тАЦTтВВтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 4) * s) * s ^ 2 := by
          apply mul_le_mul _ hTтВВ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВmTтВГ hz (norm_nonneg _) (by positivity)
  have h5 : тАЦ(P - TтВВ - TтВГ) * z * TтВГтАЦ тЙд (5 * s ^ 4) * s * s ^ 3 :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ) * zтАЦ * тАЦTтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГтАЦ * тАЦzтАЦ) * тАЦTтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 4) * s) * s ^ 3 := by
          apply mul_le_mul _ hTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВmTтВГ hz (norm_nonneg _) (by positivity)
  have h6 : тАЦ(P - TтВВ - TтВГ) * z * (P - TтВВ - TтВГ)тАЦ тЙд (5 * s ^ 4) * s * (5 * s ^ 4) :=
    calc _ тЙд тАЦ(P - TтВВ - TтВГ) * zтАЦ * тАЦP - TтВВ - TтВГтАЦ := norm_mul_le _ _
      _ тЙд (тАЦP - TтВВ - TтВГтАЦ * тАЦzтАЦ) * тАЦP - TтВВ - TтВГтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((5 * s ^ 4) * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmTтВВmTтВГ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmTтВВmTтВГ hz (norm_nonneg _) (by positivity)
  -- Triangle inequality (5 norm_add_le's chained left-to-right)
  have ha1 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ) + TтВГ * z * TтВГ + TтВГ * z * (P - TтВВ - TтВГ) +
    (P - TтВВ - TтВГ) * z * TтВВ + (P - TтВВ - TтВГ) * z * TтВГ) ((P - TтВВ - TтВГ) * z * (P - TтВВ - TтВГ))
  have ha2 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ) + TтВГ * z * TтВГ + TтВГ * z * (P - TтВВ - TтВГ) +
    (P - TтВВ - TтВГ) * z * TтВВ) ((P - TтВВ - TтВГ) * z * TтВГ)
  have ha3 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ) + TтВГ * z * TтВГ + TтВГ * z * (P - TтВВ - TтВГ))
    ((P - TтВВ - TтВГ) * z * TтВВ)
  have ha4 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ) + TтВГ * z * TтВГ) (TтВГ * z * (P - TтВВ - TтВГ))
  have ha5 := norm_add_le (TтВВ * z * (P - TтВВ - TтВГ)) (TтВГ * z * TтВГ)
  -- Sum of bounds: 5sтБ╖ + sтБ╖ + 5sтБ╕ + 5sтБ╖ + 5sтБ╕ + 25sтБ╣ = 11sтБ╖ + 10sтБ╕ + 25sтБ╣.
  -- For s тЙд 1/10: тЙд 11sтБ╖ + 1┬╖sтБ╖ + 0.25┬╖sтБ╖ = 12.25┬╖sтБ╖ тЙд 13┬╖sтБ╖.
  nlinarith [pow_nonneg hs_nn 7, pow_nonneg hs_nn 8, pow_nonneg hs_nn 9,
    mul_nonneg (pow_nonneg hs_nn 7) hs_nn,
    mul_nonneg (pow_nonneg hs_nn 7) (sq_nonneg s)]

set_option maxHeartbeats 4000000 in
/-- **Combined tricky bound** for the I1 septic residual.
The sum of the three "tricky" pieces `(z┬╖R+R┬╖z) + T22 + T_extra`
where T22 = TтВВ┬▓ - P┬▓ + TтВВTтВГ + TтВГTтВВ and T_extra = z┬╖TтВЕ + TтВВTтВД + TтВГ┬▓ + TтВДTтВВ + TтВЕz.
Individually, each piece is deg-6, NOT deg-7 тАФ but the SUM is deg-7+ via:
- `RтВЕ = -TтВЕ` (deg-5 cancellation): combining z┬╖R+R┬╖z with z┬╖TтВЕ+TтВЕz gives
  z┬╖(R+TтВЕ) + (R+TтВЕ)┬╖z, which is deg-7+ via `тАЦR+TтВЕтАЦ тЙд 6┬╖sтБ╢`.
- Algebraic identity `P┬▓ = TтВВ┬▓ + (TтВВTтВГ+TтВГTтВВ) + (TтВВTтВД+TтВГ┬▓+TтВДTтВВ) + P┬▓_degтЙе7`:
  the deg-тЙд6 contributions of T22 + T_extra cancel with the deg-тЙд6 of P┬▓,
  leaving -P┬▓_degтЙе7 which is deg-7+ via DтВЕ := P-TтВВ-TтВГ-TтВД.

Bound: тАЦcombinedтАЦ тЙд 12┬╖sтБ╖ (z┬╖(R+TтВЕ) part) + ~16┬╖sтБ╖ (P┬▓_degтЙе7) тЙд 28┬╖sтБ╖
for `s тЙд 1/10`. -/
private theorem norm_combined_tricky_le (z P R TтВВ TтВГ TтВД TтВЕ : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hz : тАЦzтАЦ тЙд s) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3)
    (hTтВД : тАЦTтВДтАЦ тЙд s ^ 4)
    (hRT5 : тАЦR + TтВЕтАЦ тЙд 6 * s ^ 6)
    (hD5 : тАЦP - TтВВ - TтВГ - TтВДтАЦ тЙд 6 * s ^ 5) :
    тАЦz * R + R * z + (TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ) +
      (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z)тАЦ тЙд 28 * s ^ 7 := by
  -- Algebraic identity: combined = z┬╖(R+TтВЕ) + (R+TтВЕ)┬╖z - P┬▓_degтЙе7,
  -- where P┬▓_degтЙе7 unfolds via DтВЕ = P-TтВВ-TтВГ-TтВД.
  have heq : z * R + R * z + (TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ) +
      (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z) =
      z * (R + TтВЕ) + (R + TтВЕ) * z -
      (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
        (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 +
        TтВГ * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВГ +
        TтВД * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВД +
        (P - TтВВ - TтВГ - TтВД) ^ 2) := by
    noncomm_ring
  rw [heq]
  -- z┬╖(R+TтВЕ) and (R+TтВЕ)┬╖z bounds (each тЙд 6┬╖sтБ╖).
  have h_zRT5 : тАЦz * (R + TтВЕ)тАЦ тЙд s * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hz hRT5 (norm_nonneg _) hs_nn)
  have h_RT5z : тАЦ(R + TтВЕ) * zтАЦ тЙд (6 * s ^ 6) * s :=
    (norm_mul_le _ _).trans (mul_le_mul hRT5 hz (norm_nonneg _) (by positivity))
  -- 10 components of P┬▓_degтЙе7
  have h_T3T4 : тАЦTтВГ * TтВДтАЦ тЙд s ^ 3 * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hTтВД (norm_nonneg _) (by positivity))
  have h_T4T3 : тАЦTтВД * TтВГтАЦ тЙд s ^ 4 * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hTтВГ (norm_nonneg _) (by positivity))
  have h_T2D5 : тАЦTтВВ * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 2 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВВ hD5 (norm_nonneg _) (by positivity))
  have h_D5T2 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВВтАЦ тЙд (6 * s ^ 5) * s ^ 2 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВВ (norm_nonneg _) (by positivity))
  have h_T4_2 : тАЦTтВД ^ 2тАЦ тЙд s ^ 4 * s ^ 4 :=
    calc _ тЙд тАЦTтВДтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (s ^ 4) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hTтВД 2
      _ = s ^ 4 * s ^ 4 := by ring
  have h_T3D5 : тАЦTтВГ * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 3 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hD5 (norm_nonneg _) (by positivity))
  have h_D5T3 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВГтАЦ тЙд (6 * s ^ 5) * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВГ (norm_nonneg _) (by positivity))
  have h_T4D5 : тАЦTтВД * (P - TтВВ - TтВГ - TтВД)тАЦ тЙд s ^ 4 * (6 * s ^ 5) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hD5 (norm_nonneg _) (by positivity))
  have h_D5T4 : тАЦ(P - TтВВ - TтВГ - TтВД) * TтВДтАЦ тЙд (6 * s ^ 5) * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hD5 hTтВД (norm_nonneg _) (by positivity))
  have h_D5_2 : тАЦ(P - TтВВ - TтВГ - TтВД) ^ 2тАЦ тЙд (6 * s ^ 5) ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГ - TтВДтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (6 * s ^ 5) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hD5 2
  -- Triangle inequality: тАЦA - BтАЦ тЙд тАЦAтАЦ + тАЦBтАЦ.
  have h_main := norm_sub_le (z * (R + TтВЕ) + (R + TтВЕ) * z)
    (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 +
     TтВГ * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВГ +
     TтВД * (P - TтВВ - TтВГ - TтВД) + (P - TтВВ - TтВГ - TтВД) * TтВД + (P - TтВВ - TтВГ - TтВД) ^ 2)
  -- A = z┬╖(R+TтВЕ) + (R+TтВЕ)┬╖z тЙд 12┬╖sтБ╖
  have hA := norm_add_le (z * (R + TтВЕ)) ((R + TтВЕ) * z)
  -- B = sum of 10 terms тЙд ~16┬╖sтБ╖ for s тЙд 1/10
  have hB1 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ + TтВД * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВД) ((P - TтВВ - TтВГ - TтВД) ^ 2)
  have hB2 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ + TтВД * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВД)
  have hB3 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВГ) (TтВД * (P - TтВВ - TтВГ - TтВД))
  have hB4 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2 + TтВГ * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВГ)
  have hB5 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ + TтВД ^ 2) (TтВГ * (P - TтВВ - TтВГ - TтВД))
  have hB6 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД) +
    (P - TтВВ - TтВГ - TтВД) * TтВВ) (TтВД ^ 2)
  have hB7 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ + TтВВ * (P - TтВВ - TтВГ - TтВД))
    ((P - TтВВ - TтВГ - TтВД) * TтВВ)
  have hB8 := norm_add_le (TтВГ * TтВД + TтВД * TтВГ) (TтВВ * (P - TтВВ - TтВГ - TтВД))
  have hB9 := norm_add_le (TтВГ * TтВД) (TтВД * TтВГ)
  -- sтБ╕ тЙд sтБ╖/10, sтБ╣ тЙд sтБ╖/100, s┬╣тБ░ тЙд sтБ╖/1000
  have hs8 : s ^ 8 тЙд s ^ 7 / 10 := by
    have h_eq : s ^ 8 = s ^ 7 * s := by ring
    rw [h_eq]; nlinarith [pow_nonneg hs_nn 7]
  have hs9 : s ^ 9 тЙд s ^ 7 / 100 := by
    have h_eq : s ^ 9 = s ^ 7 * (s * s) := by ring
    rw [h_eq]
    have hs2 : s * s тЙд 1 / 100 := by nlinarith
    nlinarith [pow_nonneg hs_nn 7]
  have hs10 : s ^ 10 тЙд s ^ 7 / 1000 := by
    have h_eq : s ^ 10 = s ^ 7 * (s * s * s) := by ring
    rw [h_eq]
    have hs3 : s * s * s тЙд 1 / 1000 := by nlinarith
    nlinarith [pow_nonneg hs_nn 7, mul_nonneg hs_nn hs_nn,
      mul_nonneg (mul_nonneg hs_nn hs_nn) hs_nn]
  -- Combined sum:
  -- A: 6┬╖sтБ╖ + 6┬╖sтБ╖ = 12┬╖sтБ╖
  -- B: sтБ╖ + sтБ╖ + 6┬╖sтБ╖ + 6┬╖sтБ╖ + sтБ╕ + 6┬╖sтБ╕ + 6┬╖sтБ╕ + 6┬╖sтБ╣ + 6┬╖sтБ╣ + 36┬╖s┬╣тБ░
  --   = 14┬╖sтБ╖ + 13┬╖sтБ╕ + 12┬╖sтБ╣ + 36┬╖s┬╣тБ░
  --   тЙд 14┬╖sтБ╖ + 1.3┬╖sтБ╖ + 0.12┬╖sтБ╖ + 0.036┬╖sтБ╖ тЙИ 15.5┬╖sтБ╖ for s тЙд 1/10
  -- Total: тЙд 27.5 тЖТ 28┬╖sтБ╖
  nlinarith [pow_nonneg hs_nn 7]

set_option maxHeartbeats 4000000 in
/-- **Combined tricky bound (octic)** for the I1 octic residual.
The sum of the four "tricky" pieces `(z┬╖R+R┬╖z) + T22 + T_extra + T_extra2`
where
  - T22 = TтВВ┬▓ - P┬▓ + TтВВTтВГ + TтВГTтВВ
  - T_extra = z┬╖TтВЕ + TтВВTтВД + TтВГ┬▓ + TтВДTтВВ + TтВЕz
  - T_extra2 = z┬╖TтВЖ + TтВВTтВЕ + TтВГTтВД + TтВДTтВГ + TтВЕTтВВ + TтВЖz
Individually, each piece is deg-6 or deg-7, NOT deg-8 тАФ but the SUM is deg-8+ via:
- `R + TтВЕ + TтВЖ` is deg-7+ (`R_plus_T5_plus_T6_eq_neg_deg7_residual`): combining
  z┬╖R+R┬╖z with z┬╖TтВЕ+TтВЕz and z┬╖TтВЖ+TтВЖz gives z┬╖(R+TтВЕ+TтВЖ) + (R+TтВЕ+TтВЖ)┬╖z,
  which is deg-8+ via `тАЦR+TтВЕ+TтВЖтАЦ тЙд 7┬╖sтБ╖`.
- Algebraic identity
  `P┬▓ = TтВВ┬▓ + (TтВВTтВГ+TтВГTтВВ) + (TтВВTтВД+TтВГ┬▓+TтВДTтВВ) + (TтВВTтВЕ+TтВГTтВД+TтВДTтВГ+TтВЕTтВВ) + P┬▓_degтЙе8`:
  the deg-тЙд7 contributions of T22 + T_extra + T_extra2 cancel with the deg-тЙд7
  of P┬▓, leaving -P┬▓_degтЙе8 (15 terms) which is deg-8+ via DтВЖ := P-TтВВ-TтВГ-TтВД-TтВЕ.

Bound: тАЦcombinedтАЦ тЙд 14┬╖sтБ╕ (z┬╖(R+TтВЕ+TтВЖ) part) + ~17┬╖sтБ╕ (P┬▓_degтЙе8) тЙд 35┬╖sтБ╕
for `s тЙд 1/10`. Analog of `norm_combined_tricky_le` at one degree higher. -/
private theorem norm_combined_tricky_octic_le (z P R TтВВ TтВГ TтВД TтВЕ TтВЖ : ЁЭФ╕) {s : тДЭ}
    (hs_nn : 0 тЙд s) (hs_small : s тЙд 1 / 10)
    (hz : тАЦzтАЦ тЙд s) (hTтВВ : тАЦTтВВтАЦ тЙд s ^ 2) (hTтВГ : тАЦTтВГтАЦ тЙд s ^ 3)
    (hTтВД : тАЦTтВДтАЦ тЙд s ^ 4) (hTтВЕ : тАЦTтВЕтАЦ тЙд s ^ 5)
    (hRT5T6 : тАЦR + TтВЕ + TтВЖтАЦ тЙд 7 * s ^ 7)
    (hD6 : тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ тЙд 6 * s ^ 6) :
    тАЦz * R + R * z + (TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ) +
      (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z) +
      (z * TтВЖ + TтВВ * TтВЕ + TтВГ * TтВД + TтВД * TтВГ + TтВЕ * TтВВ + TтВЖ * z)тАЦ тЙд 35 * s ^ 8 := by
  -- Algebraic identity: combined = z┬╖(R+TтВЕ+TтВЖ) + (R+TтВЕ+TтВЖ)┬╖z - P┬▓_degтЙе8,
  -- where P┬▓_degтЙе8 unfolds via DтВЖ = P-TтВВ-TтВГ-TтВД-TтВЕ (15 terms).
  have heq : z * R + R * z + (TтВВ ^ 2 - P ^ 2 + TтВВ * TтВГ + TтВГ * TтВВ) +
      (z * TтВЕ + TтВВ * TтВД + TтВГ * TтВГ + TтВД * TтВВ + TтВЕ * z) +
      (z * TтВЖ + TтВВ * TтВЕ + TтВГ * TтВД + TтВД * TтВГ + TтВЕ * TтВВ + TтВЖ * z) =
      z * (R + TтВЕ + TтВЖ) + (R + TтВЕ + TтВЖ) * z -
      (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
        TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
        TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
        TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
        TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД +
        TтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВЕ +
        (P - TтВВ - TтВГ - TтВД - TтВЕ) ^ 2) := by
    noncomm_ring
  rw [heq]
  -- z┬╖(R+TтВЕ+TтВЖ) and (R+TтВЕ+TтВЖ)┬╖z bounds (each тЙд 7┬╖sтБ╕).
  have h_zRT5T6 : тАЦz * (R + TтВЕ + TтВЖ)тАЦ тЙд s * (7 * s ^ 7) :=
    (norm_mul_le _ _).trans (mul_le_mul hz hRT5T6 (norm_nonneg _) hs_nn)
  have h_RT5T6z : тАЦ(R + TтВЕ + TтВЖ) * zтАЦ тЙд (7 * s ^ 7) * s :=
    (norm_mul_le _ _).trans (mul_le_mul hRT5T6 hz (norm_nonneg _) (by positivity))
  -- 15 components of P┬▓_degтЙе8
  have h_T3T5 : тАЦTтВГ * TтВЕтАЦ тЙд s ^ 3 * s ^ 5 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hTтВЕ (norm_nonneg _) (by positivity))
  have h_T5T3 : тАЦTтВЕ * TтВГтАЦ тЙд s ^ 5 * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВЕ hTтВГ (norm_nonneg _) (by positivity))
  have h_T4_2 : тАЦTтВД ^ 2тАЦ тЙд s ^ 4 * s ^ 4 :=
    calc _ тЙд тАЦTтВДтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (s ^ 4) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hTтВД 2
      _ = s ^ 4 * s ^ 4 := by ring
  have h_T4T5 : тАЦTтВД * TтВЕтАЦ тЙд s ^ 4 * s ^ 5 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hTтВЕ (norm_nonneg _) (by positivity))
  have h_T5T4 : тАЦTтВЕ * TтВДтАЦ тЙд s ^ 5 * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВЕ hTтВД (norm_nonneg _) (by positivity))
  have h_T5_2 : тАЦTтВЕ ^ 2тАЦ тЙд s ^ 5 * s ^ 5 :=
    calc _ тЙд тАЦTтВЕтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (s ^ 5) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hTтВЕ 2
      _ = s ^ 5 * s ^ 5 := by ring
  have h_T2D6 : тАЦTтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ тЙд s ^ 2 * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВВ hD6 (norm_nonneg _) (by positivity))
  have h_D6T2 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВтАЦ тЙд (6 * s ^ 6) * s ^ 2 :=
    (norm_mul_le _ _).trans (mul_le_mul hD6 hTтВВ (norm_nonneg _) (by positivity))
  have h_T3D6 : тАЦTтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ тЙд s ^ 3 * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВГ hD6 (norm_nonneg _) (by positivity))
  have h_D6T3 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГтАЦ тЙд (6 * s ^ 6) * s ^ 3 :=
    (norm_mul_le _ _).trans (mul_le_mul hD6 hTтВГ (norm_nonneg _) (by positivity))
  have h_T4D6 : тАЦTтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ тЙд s ^ 4 * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВД hD6 (norm_nonneg _) (by positivity))
  have h_D6T4 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВДтАЦ тЙд (6 * s ^ 6) * s ^ 4 :=
    (norm_mul_le _ _).trans (mul_le_mul hD6 hTтВД (norm_nonneg _) (by positivity))
  have h_T5D6 : тАЦTтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ)тАЦ тЙд s ^ 5 * (6 * s ^ 6) :=
    (norm_mul_le _ _).trans (mul_le_mul hTтВЕ hD6 (norm_nonneg _) (by positivity))
  have h_D6T5 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВЕтАЦ тЙд (6 * s ^ 6) * s ^ 5 :=
    (norm_mul_le _ _).trans (mul_le_mul hD6 hTтВЕ (norm_nonneg _) (by positivity))
  have h_D6_2 : тАЦ(P - TтВВ - TтВГ - TтВД - TтВЕ) ^ 2тАЦ тЙд (6 * s ^ 6) ^ 2 :=
    calc _ тЙд тАЦP - TтВВ - TтВГ - TтВД - TтВЕтАЦ ^ 2 := norm_pow_le _ _
      _ тЙд (6 * s ^ 6) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hD6 2
  -- Triangle inequality: тАЦA - BтАЦ тЙд тАЦAтАЦ + тАЦBтАЦ.
  have h_main := norm_sub_le (z * (R + TтВЕ + TтВЖ) + (R + TтВЕ + TтВЖ) * z)
    (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
     TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
     TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
     TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
     TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД +
     TтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВЕ +
     (P - TтВВ - TтВГ - TтВД - TтВЕ) ^ 2)
  -- A = z┬╖(R+TтВЕ+TтВЖ) + (R+TтВЕ+TтВЖ)┬╖z тЙд 14┬╖sтБ╕
  have hA := norm_add_le (z * (R + TтВЕ + TтВЖ)) ((R + TтВЕ + TтВЖ) * z)
  -- B = sum of 15 deg-8+ terms (each successively bounded via norm_add_le)
  have hB1 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
    TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД +
    TтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВЕ)
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) ^ 2)
  have hB2 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
    TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД +
    TтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВЕ)
  have hB3 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
    TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД)
    (TтВЕ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
  have hB4 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ +
    TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ))
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВД)
  have hB5 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ)
    (TтВД * (P - TтВВ - TтВГ - TтВД - TтВЕ))
  have hB6 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ +
    TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВГ)
  have hB7 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ) + (P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ)
    (TтВГ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
  have hB8 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2 +
    TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
    ((P - TтВВ - TтВГ - TтВД - TтВЕ) * TтВВ)
  have hB9 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД + TтВЕ ^ 2) (TтВВ * (P - TтВВ - TтВГ - TтВД - TтВЕ))
  have hB10 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 +
    TтВД * TтВЕ + TтВЕ * TтВД) (TтВЕ ^ 2)
  have hB11 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2 + TтВД * TтВЕ) (TтВЕ * TтВД)
  have hB12 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ + TтВД ^ 2) (TтВД * TтВЕ)
  have hB13 := norm_add_le (TтВГ * TтВЕ + TтВЕ * TтВГ) (TтВД ^ 2)
  have hB14 := norm_add_le (TтВГ * TтВЕ) (TтВЕ * TтВГ)
  -- sтБ╣ тЙд sтБ╕/10, s┬╣тБ░ тЙд sтБ╕/100, s┬╣┬╣ тЙд sтБ╕/1000, s┬╣┬▓ тЙд sтБ╕/10000
  have hs9 : s ^ 9 тЙд s ^ 8 / 10 := by
    have h_eq : s ^ 9 = s ^ 8 * s := by ring
    rw [h_eq]; nlinarith [pow_nonneg hs_nn 8]
  have hs10 : s ^ 10 тЙд s ^ 8 / 100 := by
    have h_eq : s ^ 10 = s ^ 8 * (s * s) := by ring
    rw [h_eq]
    have hs2 : s * s тЙд 1 / 100 := by nlinarith
    nlinarith [pow_nonneg hs_nn 8]
  have hs11 : s ^ 11 тЙд s ^ 8 / 1000 := by
    have h_eq : s ^ 11 = s ^ 8 * (s * s * s) := by ring
    rw [h_eq]
    have hs3 : s * s * s тЙд 1 / 1000 := by nlinarith
    nlinarith [pow_nonneg hs_nn 8, mul_nonneg hs_nn hs_nn,
      mul_nonneg (mul_nonneg hs_nn hs_nn) hs_nn]
  have hs12 : s ^ 12 тЙд s ^ 8 / 10000 := by
    have h_eq : s ^ 12 = s ^ 8 * (s * s) * (s * s) := by ring
    rw [h_eq]
    have hs2 : s * s тЙд 1 / 100 := by nlinarith
