/-! ### Sextic remainder small-s case helpers

These are building blocks for the (future) `norm_bch_sextic_remainder_small_s_le`
which handles `s < 1/10` via the deg-5 cancellation in `sextic_pure_identity`.

Each helper is a self-contained lemma about non-commutative algebra,
provable by `noncomm_ring` after scalar clearing.
-/

/-- 5-fold non-commutative telescoping: `yтБ╡ - (y - P)тБ╡` expands as a sum of
five 5-letter words, each with one `P` factor and four `y`/`(y-P)` factors. -/
private theorem pow5_sub_zpow5_telescope (y P : ЁЭФ╕) :
    y ^ 5 - (y - P) ^ 5 =
      y ^ 4 * P + y ^ 3 * P * (y - P) + y ^ 2 * P * (y - P) ^ 2 +
        y * P * (y - P) ^ 3 + P * (y - P) ^ 4 := by
  noncomm_ring

/-- 6-fold non-commutative telescoping: `yтБ╢ - (y - P)тБ╢` expands as a sum of
six 6-letter words, each with one `P` factor and five `y`/`(y-P)` factors. -/
private theorem pow6_sub_zpow6_telescope (y P : ЁЭФ╕) :
    y ^ 6 - (y - P) ^ 6 =
      y ^ 5 * P + y ^ 4 * P * (y - P) + y ^ 3 * P * (y - P) ^ 2 +
        y ^ 2 * P * (y - P) ^ 3 + y * P * (y - P) ^ 4 + P * (y - P) ^ 5 := by
  noncomm_ring

/-- 7-fold non-commutative telescoping: `yтБ╖ - (y - P)тБ╖` expands as a sum of
seven 7-letter words, each with one `P` factor and six `y`/`(y-P)` factors. -/
private theorem pow7_sub_zpow7_telescope (y P : ЁЭФ╕) :
    y ^ 7 - (y - P) ^ 7 =
      y ^ 6 * P + y ^ 5 * P * (y - P) + y ^ 4 * P * (y - P) ^ 2 +
        y ^ 3 * P * (y - P) ^ 3 + y ^ 2 * P * (y - P) ^ 4 +
        y * P * (y - P) ^ 5 + P * (y - P) ^ 6 := by
  noncomm_ring

/-- 4-fold non-commutative telescoping: `yтБ┤ - (y - P)тБ┤` expands as a sum of
four 4-letter words, each with one `P` factor and three `y`/`(y-P)` factors. -/
private theorem pow4_sub_zpow4_telescope (y P : ЁЭФ╕) :
    y ^ 4 - (y - P) ^ 4 =
      y ^ 3 * P + y ^ 2 * P * (y - P) + y * P * (y - P) ^ 2 + P * (y - P) ^ 3 := by
  noncomm_ring

/-- 3-fold non-commutative telescoping: `y┬│ - (y - P)┬│`. -/
private theorem pow3_sub_zpow3_telescope (y P : ЁЭФ╕) :
    y ^ 3 - (y - P) ^ 3 =
      y ^ 2 * P + y * P * (y - P) + P * (y - P) ^ 2 := by
  noncomm_ring

/-- Algebraic decomposition of `yтБ┤ - zтБ┤ - y4_5` where `z = y - P` and
`y4_5 = z┬│TтВВ + z┬▓TтВВz + zTтВВz┬▓ + TтВВz┬│` is the deg-5 contribution from
`yтБ┤ = (z + TтВВ + ...)тБ┤`. Expresses the difference as a sum of 7 deg-6+
terms in the BCH context where `тАЦyтАЦ тЙд 2s`, `тАЦPтАЦ тЙд s┬▓`, `тАЦzтАЦ тЙд s`,
`тАЦP-TтВВтАЦ тЙд 5s┬│`. -/
private theorem y4_sub_z4_sub_y4_5_decomp (y P TтВВ : ЁЭФ╕) :
    y ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * TтВВ + (y - P) ^ 2 * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) ^ 2 + TтВВ * (y - P) ^ 3) =
      (y - P) ^ 3 * (P - TтВВ) + (y - P) ^ 2 * (P - TтВВ) * (y - P) +
        (y - P) * (P - TтВВ) * (y - P) ^ 2 + (P - TтВВ) * (y - P) ^ 3 +
      (y ^ 3 - (y - P) ^ 3) * P + (y ^ 2 - (y - P) ^ 2) * P * (y - P) +
      P * P * (y - P) ^ 2 := by
  noncomm_ring

/-- Norm bound for the 5-fold telescoping: given `тАЦyтАЦ тЙд 2s`, `тАЦzтАЦ тЙд s`,
`тАЦPтАЦ тЙд s┬▓`, `тАЦyтБ╡ - zтБ╡тАЦ тЙд 31┬╖sтБ╢`. Used in the small-s case of the sextic
remainder bound. -/
private theorem norm_pow5_sub_zpow5_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 5 - (y - P) ^ 5тАЦ тЙд 31 * s ^ 6 := by
  rw [pow5_sub_zpow5_telescope]
  -- 5 terms: yтБ┤P + y┬│P(y-P) + y┬▓P(y-P)┬▓ + yP(y-P)┬│ + P(y-P)тБ┤
  -- Bounds: 16sтБ╢ + 8sтБ╢ + 4sтБ╢ + 2sтБ╢ + sтБ╢ = 31sтБ╢
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  have h_y4P : тАЦy ^ 4 * PтАЦ тЙд (2 * s) ^ 4 * s ^ 2 :=
    calc тАЦy ^ 4 * PтАЦ тЙд тАЦy ^ 4тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд тАЦyтАЦ ^ 4 * тАЦPтАЦ := by gcongr; exact norm_pow_le y 4
      _ тЙд (2 * s) ^ 4 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 4) hP (by positivity) (by positivity)
  have h_y3Pz : тАЦy ^ 3 * P * zтАЦ тЙд (2 * s) ^ 3 * s ^ 2 * s :=
    calc тАЦy ^ 3 * P * zтАЦ тЙд тАЦy ^ 3 * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 3 * тАЦPтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦy ^ 3тАЦ * тАЦPтАЦ := norm_mul_le _ _
            _ тЙд _ := by gcongr; exact norm_pow_le y 3
      _ тЙд ((2 * s) ^ 3 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz2 : тАЦy ^ 2 * P * z ^ 2тАЦ тЙд (2 * s) ^ 2 * s ^ 2 * s ^ 2 :=
    calc тАЦy ^ 2 * P * z ^ 2тАЦ тЙд тАЦy ^ 2 * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 2 * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 2тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 2
          ┬╖ exact norm_pow_le z 2
      _ тЙд ((2 * s) ^ 2 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz3 : тАЦy * P * z ^ 3тАЦ тЙд 2 * s * s ^ 2 * s ^ 3 :=
    calc тАЦy * P * z ^ 3тАЦ тЙд тАЦy * PтАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 3 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 3
      _ тЙд (2 * s * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz4 : тАЦP * z ^ 4тАЦ тЙд s ^ 2 * s ^ 4 :=
    calc тАЦP * z ^ 4тАЦ тЙд тАЦPтАЦ * тАЦz ^ 4тАЦ := norm_mul_le _ _
      _ тЙд тАЦPтАЦ * тАЦzтАЦ ^ 4 := by gcongr; exact norm_pow_le z 4
      _ тЙд s ^ 2 * s ^ 4 := mul_le_mul hP (pow_le_pow_leftтВА (norm_nonneg _) hzn 4)
          (by positivity) (by positivity)
  -- Sum via triangle inequality
  have ht1 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z + y ^ 2 * P * z ^ 2 + y * P * z ^ 3)
    (P * z ^ 4)
  have ht2 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z + y ^ 2 * P * z ^ 2) (y * P * z ^ 3)
  have ht3 := norm_add_le (y ^ 4 * P + y ^ 3 * P * z) (y ^ 2 * P * z ^ 2)
  have ht4 := norm_add_le (y ^ 4 * P) (y ^ 3 * P * z)
  nlinarith [pow_nonneg hs_nn 6]

/-- Norm bound for the 6-fold telescoping: given `тАЦyтАЦ тЙд 2s`, `тАЦzтАЦ тЙд s`,
`тАЦPтАЦ тЙд s┬▓`, `тАЦyтБ╢ - zтБ╢тАЦ тЙд 63┬╖sтБ╖`. Used in the small-s case of the septic
remainder bound (analog of `norm_pow5_sub_zpow5_le` at one degree higher).

Per-term bounds: `(2s)тБ╡┬╖s┬▓ + (2s)тБ┤┬╖s┬▓┬╖s + (2s)┬│┬╖s┬▓┬╖s┬▓ + (2s)┬▓┬╖s┬▓┬╖s┬│ +
                 (2s)┬╖s┬▓┬╖sтБ┤ + s┬▓┬╖sтБ╡
                = 32sтБ╖ + 16sтБ╖ + 8sтБ╖ + 4sтБ╖ + 2sтБ╖ + sтБ╖ = 63sтБ╖`. -/
private theorem norm_pow6_sub_zpow6_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 6 - (y - P) ^ 6тАЦ тЙд 63 * s ^ 7 := by
  rw [pow6_sub_zpow6_telescope]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  -- Six terms, bounded individually.
  have h_y5P : тАЦy ^ 5 * PтАЦ тЙд (2 * s) ^ 5 * s ^ 2 :=
    calc тАЦy ^ 5 * PтАЦ тЙд тАЦy ^ 5тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд тАЦyтАЦ ^ 5 * тАЦPтАЦ := by gcongr; exact norm_pow_le y 5
      _ тЙд (2 * s) ^ 5 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 5) hP (by positivity) (by positivity)
  have h_y4Pz : тАЦy ^ 4 * P * zтАЦ тЙд (2 * s) ^ 4 * s ^ 2 * s :=
    calc тАЦy ^ 4 * P * zтАЦ тЙд тАЦy ^ 4 * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 4 * тАЦPтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦy ^ 4тАЦ * тАЦPтАЦ := norm_mul_le _ _
            _ тЙд _ := by gcongr; exact norm_pow_le y 4
      _ тЙд ((2 * s) ^ 4 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 4) hP
            (norm_nonneg _) (by positivity)
  have h_y3Pz2 : тАЦy ^ 3 * P * z ^ 2тАЦ тЙд (2 * s) ^ 3 * s ^ 2 * s ^ 2 :=
    calc тАЦy ^ 3 * P * z ^ 2тАЦ тЙд тАЦy ^ 3 * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 3 * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 3тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 3
          ┬╖ exact norm_pow_le z 2
      _ тЙд ((2 * s) ^ 3 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz3 : тАЦy ^ 2 * P * z ^ 3тАЦ тЙд (2 * s) ^ 2 * s ^ 2 * s ^ 3 :=
    calc тАЦy ^ 2 * P * z ^ 3тАЦ тЙд тАЦy ^ 2 * PтАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 2 * тАЦPтАЦ) * тАЦzтАЦ ^ 3 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 2тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 2
          ┬╖ exact norm_pow_le z 3
      _ тЙд ((2 * s) ^ 2 * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz4 : тАЦy * P * z ^ 4тАЦ тЙд 2 * s * s ^ 2 * s ^ 4 :=
    calc тАЦy * P * z ^ 4тАЦ тЙд тАЦy * PтАЦ * тАЦz ^ 4тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 4 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 4
      _ тЙд (2 * s * s ^ 2) * s ^ 4 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 4)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz5 : тАЦP * z ^ 5тАЦ тЙд s ^ 2 * s ^ 5 :=
    calc тАЦP * z ^ 5тАЦ тЙд тАЦPтАЦ * тАЦz ^ 5тАЦ := norm_mul_le _ _
      _ тЙд тАЦPтАЦ * тАЦzтАЦ ^ 5 := by gcongr; exact norm_pow_le z 5
      _ тЙд s ^ 2 * s ^ 5 := mul_le_mul hP (pow_le_pow_leftтВА (norm_nonneg _) hzn 5)
          (by positivity) (by positivity)
