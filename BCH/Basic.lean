    _ ‚â§ ‚Äñ(24 : ùïÇ)‚Åª¬π‚Äñ * ‚Äñb * DC_a - DC_a * b‚Äñ := norm_smul_le _ _
    _ ‚â§ 1 * (8 * ‚Äña‚Äñ ^ 2 * ‚Äñb‚Äñ ^ 2) := by gcongr
    _ = 8 * ‚Äña‚Äñ ^ 2 * ‚Äñb‚Äñ ^ 2 := one_mul _
    _ ‚â§ s ^ 4 := by
        -- 8Œ±¬≤Œ≤¬≤ ‚â§ (Œ±+Œ≤)‚Å¥ since Œ±Œ≤ ‚â§ (Œ±+Œ≤)¬≤/4 ‚Üí Œ±¬≤Œ≤¬≤ ‚â§ s‚Å¥/16 ‚Üí 8Œ±¬≤Œ≤¬≤ ‚â§ s‚Å¥/2
        have hab : ‚Äña‚Äñ * ‚Äñb‚Äñ ‚â§ s ^ 2 / 4 := by nlinarith [sq_nonneg (‚Äña‚Äñ - ‚Äñb‚Äñ)]
        have hab2 : ‚Äña‚Äñ ^ 2 * ‚Äñb‚Äñ ^ 2 ‚â§ s ^ 4 / 16 := by
          have h1 : (‚Äña‚Äñ * ‚Äñb‚Äñ) ^ 2 ‚â§ (s ^ 2 / 4) ^ 2 :=
            sq_le_sq' (by nlinarith) hab
          nlinarith [h1]
