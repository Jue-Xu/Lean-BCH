        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4
    let T‚ÇÖ : ùî∏ := (120 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5 + (24 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b) +
        (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 2) + (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 4) + (120 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5
    let T‚ÇÜ : ùî∏ := (720 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 6 + (120 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 5 * b) +
        (48 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b ^ 2) + (36 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 3) +
        (48 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 4) + (120 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 5) +
