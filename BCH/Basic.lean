private theorem norm_bch_quintic_group_4_le (a b : ЁЭФ╕) :
    тАЦbch_quintic_group_4 a bтАЦ тЙд 10 * (тАЦaтАЦ + тАЦbтАЦ) ^ 5 := by
  unfold bch_quintic_group_4
  set s := тАЦaтАЦ + тАЦbтАЦ
  have m1 := norm_word5_le a b a a a b a
    (Or.inl rfl) (Or.inl rfl) (Or.inl rfl) (Or.inr rfl) (Or.inl rfl)
