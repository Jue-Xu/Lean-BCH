private theorem norm_T4_le (a b : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hŒ±_le : ‚Äña‚Äñ ‚â§ s) (hŒ≤_le : ‚Äñb‚Äñ ‚â§ s) :
