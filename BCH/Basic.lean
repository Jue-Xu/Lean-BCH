    Real.exp_monotone hs‚ÇÇ_le_const
  have hdenom‚ÇÇ_lb : (1 : ‚Ñù) / 12 ‚â§ 2 - Real.exp (‚Äñz‚Äñ + ‚Äña'‚Äñ) := by
    linarith [hexp_s‚ÇÇ_le, hexp_57]
