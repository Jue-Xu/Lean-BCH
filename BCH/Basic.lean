private theorem norm_R_plus_T5_plus_T6_residual_sum_le
    (I_a I_b H‚ÇÅ H‚ÇÇ G‚ÇÅ G‚ÇÇ F‚ÇÅ F‚ÇÇ a b : ùî∏) {s : ‚Ñù}
    (hs_nn : 0 ‚â§ s) (hs_le_one : s ‚â§ 1)
    (hI_a_le : ‚ÄñI_a‚Äñ ‚â§ s ^ 7) (hI_b_le : ‚ÄñI_b‚Äñ ‚â§ s ^ 7)
    (h_aH‚ÇÇ_le : ‚Äña * H‚ÇÇ‚Äñ ‚â§ s ^ 7) (h_H‚ÇÅb_le : ‚ÄñH‚ÇÅ * b‚Äñ ‚â§ s ^ 7)
    (h_F‚ÇÅF‚ÇÇ_le : ‚ÄñF‚ÇÅ * F‚ÇÇ‚Äñ ‚â§ s ^ 8)
    (h_F‚ÇÅb3_le : ‚ÄñF‚ÇÅ * b ^ 3‚Äñ ‚â§ s ^ 7)
    (h_a3F‚ÇÇ_le : ‚Äña ^ 3 * F‚ÇÇ‚Äñ ‚â§ s ^ 7)
    (h_G‚ÇÅb2_le : ‚ÄñG‚ÇÅ * b ^ 2‚Äñ ‚â§ s ^ 7)
    (h_a2G‚ÇÇ_le : ‚Äña ^ 2 * G‚ÇÇ‚Äñ ‚â§ s ^ 7) :
    ‚ÄñI_a + I_b + a * H‚ÇÇ + H‚ÇÅ * b + F‚ÇÅ * F‚ÇÇ +
      (6 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 3) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * F‚ÇÇ) +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (G‚ÇÅ * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * G‚ÇÇ)‚Äñ ‚â§ 7 * s ^ 7 := by
  have h2eq : ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ = (2 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h6eq : ‚Äñ(6 : ùïÇ)‚Åª¬π‚Äñ = (6 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have hs7_le_s7 : s ^ 8 ‚â§ s ^ 7 := by
