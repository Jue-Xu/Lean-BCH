              have h1 : тАЦa * (exp b - 1)тАЦ тЙд ╬▒ * (Real.exp ╬▓ - 1) :=
                calc _ тЙд тАЦaтАЦ * тАЦexp b - 1тАЦ := norm_mul_le _ _
                  _ тЙд _ := by gcongr; exact norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) b
