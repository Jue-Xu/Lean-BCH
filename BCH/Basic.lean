  have hGa5 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 ‚â§ Œ± ^ 5 :=
    real_exp_fifth_order_le_quintic hŒ±_nn (lt_of_le_of_lt hŒ±_le hs34)
  have hGb5 : Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 - Œ≤ ^ 4 / 24 ‚â§ Œ≤ ^ 5 :=
    real_exp_fifth_order_le_quintic hŒ≤_nn (lt_of_le_of_lt hŒ≤_le hs34)
  have hHa6 : Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 - Œ± ^ 5 / 120 ‚â§ Œ± ^ 6 :=
    real_exp_sixth_order_le_sextic hŒ±_nn (lt_of_le_of_lt hŒ±_le hs34)
