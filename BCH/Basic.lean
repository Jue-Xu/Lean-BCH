private lemma deg8_smul_word_le_basic
    (c : ùïÇ) (cb : ‚Ñù) (hc : ‚Äñc‚Äñ ‚â§ cb)
    (l1 l2 l3 l4 l5 l6 l7 l8 : ùî∏) (s : ‚Ñù)
    (h1 : ‚Äñl1‚Äñ ‚â§ s) (h2 : ‚Äñl2‚Äñ ‚â§ s) (h3 : ‚Äñl3‚Äñ ‚â§ s) (h4 : ‚Äñl4‚Äñ ‚â§ s)
