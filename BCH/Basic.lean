      _ = M ^ 4 * d := by ring
  have h3 : тАЦx * x * (z - x) * z * yтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦzтАЦ * тАЦyтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h4 : тАЦx * x * x * (z - x) * yтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦyтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * M * d * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h5 : тАЦ(z - x) * y * y * y * yтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦyтАЦ * тАЦyтАЦ * тАЦyтАЦ * тАЦyтАЦ := h5prod _ _ _ _ _
      _ тЙд d * M * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h6 : тАЦy * (z - x) * z * z * zтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦz - xтАЦ * тАЦzтАЦ * тАЦzтАЦ * тАЦzтАЦ := h5prod _ _ _ _ _
      _ тЙд M * d * M * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h7 : тАЦy * x * (z - x) * z * zтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦzтАЦ * тАЦzтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h8 : тАЦy * x * x * (z - x) * zтАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦzтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * M * d * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h9 : тАЦy * x * x * x * (z - x)тАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦxтАЦ * тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * M * M * d := by gcongr
      _ = M ^ 4 * d := by ring
  have h10 : тАЦy * y * y * y * (z - x)тАЦ тЙд M ^ 4 * d := by
    calc _ тЙд тАЦyтАЦ * тАЦyтАЦ * тАЦyтАЦ * тАЦyтАЦ * тАЦz - xтАЦ := h5prod _ _ _ _ _
      _ тЙд M * M * M * M * d := by gcongr
      _ = M ^ 4 * d := by ring
  -- Step 5: 9-step triangle inequality on the 10-term sum (use `set` for clarity)
  set s1 : ЁЭФ╕ := (z - x) * z * z * z * y with hs1
  set s2 : ЁЭФ╕ := x * (z - x) * z * z * y with hs2
  set s3 : ЁЭФ╕ := x * x * (z - x) * z * y with hs3
  set s4 : ЁЭФ╕ := x * x * x * (z - x) * y with hs4
  set s5 : ЁЭФ╕ := (z - x) * y * y * y * y with hs5
  set s6 : ЁЭФ╕ := y * (z - x) * z * z * z with hs6
  set s7 : ЁЭФ╕ := y * x * (z - x) * z * z with hs7
  set s8 : ЁЭФ╕ := y * x * x * (z - x) * z with hs8
  set s9 : ЁЭФ╕ := y * x * x * x * (z - x) with hs9
  set s10 : ЁЭФ╕ := y * y * y * y * (z - x) with hs10
  have a9 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9) s10
  have a8 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8) s9
  have a7 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6 + s7) s8
  have a6 := norm_add_le (s1 + s2 + s3 + s4 + s5 + s6) s7
  have a5 := norm_add_le (s1 + s2 + s3 + s4 + s5) s6
  have a4 := norm_add_le (s1 + s2 + s3 + s4) s5
  have a3 := norm_add_le (s1 + s2 + s3) s4
  have a2 := norm_add_le (s1 + s2) s3
  have a1 := norm_add_le s1 s2
  linarith

