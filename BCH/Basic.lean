      _ = M ^ 4 * d := by ring
  have h2 : ‖x * y * (z - x) * y * z‖ ≤ M ^ 4 * d := by
    calc _ ≤ ‖x‖ * ‖y‖ * ‖z - x‖ * ‖y‖ * ‖z‖ := norm_5prod_le _ _ _ _ _
      _ ≤ M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h3 : ‖x * y * x * y * (z - x)‖ ≤ M ^ 4 * d := by
