/-- Helper: any 5-letter word on `{a, b}` has norm тЙд sтБ╡ where s = тАЦaтАЦ+тАЦbтАЦ. -/
private lemma norm_word5_le {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕] (a b : ЁЭФ╕)
    (xтВБ xтВВ xтВГ xтВД xтВЕ : ЁЭФ╕)
    (hтВБ : xтВБ = a тИи xтВБ = b) (hтВВ : xтВВ = a тИи xтВВ = b) (hтВГ : xтВГ = a тИи xтВГ = b)
    (hтВД : xтВД = a тИи xтВД = b) (hтВЕ : xтВЕ = a тИи xтВЕ = b) :
    тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕтАЦ тЙд (тАЦaтАЦ + тАЦbтАЦ) ^ 5 := by
  set s := тАЦaтАЦ + тАЦbтАЦ
  have ha := norm_nonneg a
  have hb := norm_nonneg b
  have hxs : тИА x : ЁЭФ╕, x = a тИи x = b тЖТ тАЦxтАЦ тЙд s := by
    intro x hx
    cases hx with
    | inl h => rw [h]; linarith
    | inr h => rw [h]; linarith
  calc тАЦxтВБ * xтВВ * xтВГ * xтВД * xтВЕтАЦ
      тЙд тАЦxтВБ * xтВВ * xтВГ * xтВДтАЦ * тАЦxтВЕтАЦ := norm_mul_le _ _
    _ тЙд тАЦxтВБ * xтВВ * xтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ := by gcongr; exact norm_mul_le _ _
    _ тЙд тАЦxтВБ * xтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ := by gcongr; exact norm_mul_le _ _
    _ тЙд тАЦxтВБтАЦ * тАЦxтВВтАЦ * тАЦxтВГтАЦ * тАЦxтВДтАЦ * тАЦxтВЕтАЦ := by gcongr; exact norm_mul_le _ _
    _ тЙд s * s * s * s * s := by
        gcongr <;> [exact hxs _ hтВБ; exact hxs _ hтВВ; exact hxs _ hтВГ;
                    exact hxs _ hтВД; exact hxs _ hтВЕ]
    _ = s ^ 5 := by ring

