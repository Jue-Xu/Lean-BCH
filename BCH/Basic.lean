  set ╬▒ := тАЦaтАЦ
  set ╬▓ := тАЦbтАЦ
  have h╬▒_nn : (0 : тДЭ) тЙд ╬▒ := norm_nonneg a
  have h╬▓_nn : (0 : тДЭ) тЙд ╬▓ := norm_nonneg b
  have h144eq : тАЦ(144 : ЁЭХВ)тБ╗┬╣тАЦ = (144 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h240eq : тАЦ(240 : ЁЭХВ)тБ╗┬╣тАЦ = (240 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have h720eq : тАЦ(720 : ЁЭХВ)тБ╗┬╣тАЦ = (720 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
