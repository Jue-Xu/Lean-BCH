          have hinj : Function.Injective ((2 : ЁЭХВ) тАв ┬╖ : ЁЭФ╕ тЖТ ЁЭФ╕) := by
            intro xтВА yтВА hxy; have := congrArg ((2 : ЁЭХВ)тБ╗┬╣ тАв ┬╖) hxy
