  rw [Fin.sum_univ_eq_sum_range (fun k => bchSepticTermN (ЁЭХВ := ЁЭХВ) a b k)]
  simp only [Finset.sum_range_succ, Finset.sum_range_zero, bchSepticTermN, zero_add]
  try abel

