            _ тЙд Real.exp (5 / 6) := Real.quadratic_le_exp_of_nonneg (by norm_num)
  have hs34 : s < 3 / 4 := lt_of_lt_of_le hab (by
    rw [Real.log_le_iff_le_exp (by norm_num : (0 : тДЭ) < 2)]
    calc (2 : тДЭ) тЙд 1 + 3 / 4 + (3 / 4) ^ 2 / 2 := by norm_num
      _ тЙд Real.exp (3 / 4) := Real.quadratic_le_exp_of_nonneg (by norm_num))
  have hs1 : s < 1 := by linarith
  -- Auxiliary definitions
