      set D₂ := exp b - 1 - b with hD₂_def
      set E₁ := D₁ - (2 : 𝕂)⁻¹ • a ^ 2 with hE₁_def
      set E₂ := D₂ - (2 : 𝕂)⁻¹ • b ^ 2 with hE₂_def
      set F₁ := E₁ - (6 : 𝕂)⁻¹ • a ^ 3 with hF₁_def
      set F₂ := E₂ - (6 : 𝕂)⁻¹ • b ^ 3 with hF₂_def
