    have h_sтВВ_cu : sтВВ ^ 3 тЙд 8 * s ^ 3 :=
      -- sтВВ┬│ = sтВВ┬╖sтВВ┬▓ тЙд 2s┬╖4s┬▓ = 8s┬│
      calc sтВВ ^ 3 = sтВВ * sтВВ ^ 2 := by ring
        _ тЙд (2 * s) * (4 * s ^ 2) := mul_le_mul hsтВВ_le h_sтВВ_sq (sq_nonneg _) (by linarith)
        _ = 8 * s ^ 3 := by ring
