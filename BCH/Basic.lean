              (lt_of_le_of_lt hα_le hs34)
      have hG₂_le : ‖G₂‖ ≤ β ^ 5 := by
        calc ‖G₂‖ ≤ Real.exp β - 1 - β - β ^ 2 / 2 - β ^ 3 / 6 - β ^ 4 / 24 :=
              norm_exp_sub_one_sub_sub_sub_sub_le (𝕂 := 𝕂) b
          _ ≤ β ^ 5 := real_exp_fifth_order_le_quintic (norm_nonneg b)
