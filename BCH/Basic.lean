      _ ‚â§ (s ^ 2) ^ 3 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 3
  have h7 : ‚Äñz * P ^ 2‚Äñ ‚â§ s * (s ^ 2) ^ 2 :=
    calc _ ‚â§ ‚Äñz‚Äñ * ‚ÄñP ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñz‚Äñ * ‚ÄñP‚Äñ ^ 2 := by gcongr; exact norm_pow_le P 2
      _ ‚â§ s * (s ^ 2) ^ 2 := mul_le_mul hzn (pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 2)
