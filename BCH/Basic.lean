/-- **Lipschitz bound for `bch_quintic_term` in its first argument**:
`‚ÄñC‚ÇÖ(z, y) ‚àí C‚ÇÖ(x, y)‚Äñ ‚â§ (‚Äñz‚Äñ+‚Äñx‚Äñ+‚Äñy‚Äñ)‚Å¥ ¬∑ ‚Äñz ‚àí x‚Äñ`.

Combines the 4 per-group Lipschitz bounds with the (720)‚Åª¬π scalar factor:
`(10 + 4¬∑25 + 6¬∑35 + 24¬∑5)/720 = 440/720 = 11/18 < 1`.

This is the analog of `norm_bch_cubic_term_diff_le` at degree 5; both are
key infrastructure for the parent T2-F7e discharge. With `z = (a'+b) + W`
(where ‚ÄñW‚Äñ = O(s¬≤)), this gives `‚ÄñC‚ÇÖ(z, y) ‚àí C‚ÇÖ(a'+b, y)‚Äñ ‚â§ K ¬∑ s¬≤ ¬∑ M‚Å¥ ‚â§
K ¬∑ s‚Å∂`, the deg-6+ residual estimate needed in the extended hdecomp. -/
theorem norm_bch_quintic_term_diff_le (z x y : ùî∏) :
    ‚Äñbch_quintic_term ùïÇ z y - bch_quintic_term ùïÇ x y‚Äñ ‚â§
      (‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ) ^ 4 * ‚Äñz - x‚Äñ := by
  set M := ‚Äñz‚Äñ + ‚Äñx‚Äñ + ‚Äñy‚Äñ with hM_def
  set d := ‚Äñz - x‚Äñ with hd_def
  have hd_nn : 0 ‚â§ d := norm_nonneg _
  have hM_nn : 0 ‚â§ M := by positivity
  have hM4_nn : (0 : ‚Ñù) ‚â§ M ^ 4 := pow_nonneg hM_nn 4
  -- Per-group bounds.
  have hg1 := norm_bch_quintic_group_1_diff_le z x y
  have hg4 := norm_bch_quintic_group_4_diff_le z x y
  have hg6 := norm_bch_quintic_group_6_diff_le z x y
  have hg24 := norm_bch_quintic_group_24_diff_le z x y
  -- Identity: bch_quintic_term diff = (720)‚Åª¬π ‚Ä¢ (per-group diffs combo).
  have htel : bch_quintic_term ùïÇ z y - bch_quintic_term ùïÇ x y =
      (720 : ùïÇ)‚Åª¬π ‚Ä¢ (
        -(bch_quintic_group_1 z y - bch_quintic_group_1 x y)
        + (4 : ùïÇ) ‚Ä¢ (bch_quintic_group_4 z y - bch_quintic_group_4 x y)
        - (6 : ùïÇ) ‚Ä¢ (bch_quintic_group_6 z y - bch_quintic_group_6 x y)
        + (24 : ùïÇ) ‚Ä¢ (bch_quintic_group_24 z y - bch_quintic_group_24 x y)) := by
    unfold bch_quintic_term
    simp only [smul_sub, smul_add, smul_neg]
    abel
  rw [htel]
  -- Norm bound on the smul'd expression.
  set d1 : ùî∏ := bch_quintic_group_1 z y - bch_quintic_group_1 x y
  set d4 : ùî∏ := bch_quintic_group_4 z y - bch_quintic_group_4 x y
  set d6 : ùî∏ := bch_quintic_group_6 z y - bch_quintic_group_6 x y
  set d24 : ùî∏ := bch_quintic_group_24 z y - bch_quintic_group_24 x y
  -- Bounds on the smul'd diffs
  have h_neg_d1 : ‚Äñ-d1‚Äñ ‚â§ 10 * M ^ 4 * d := by
    rw [norm_neg]; exact hg1
  have h_4_d4 : ‚Äñ((4 : ùïÇ)) ‚Ä¢ d4‚Äñ ‚â§ 100 * M ^ 4 * d := by
    calc ‚Äñ((4 : ùïÇ)) ‚Ä¢ d4‚Äñ ‚â§ ‚Äñ((4 : ùïÇ))‚Äñ * ‚Äñd4‚Äñ := norm_smul_le _ _
      _ = 4 * ‚Äñd4‚Äñ := by rw [RCLike.norm_ofNat]
      _ ‚â§ 4 * (25 * M ^ 4 * d) := by gcongr
      _ = 100 * M ^ 4 * d := by ring
  have h_6_d6 : ‚Äñ((6 : ùïÇ)) ‚Ä¢ d6‚Äñ ‚â§ 210 * M ^ 4 * d := by
    calc ‚Äñ((6 : ùïÇ)) ‚Ä¢ d6‚Äñ ‚â§ ‚Äñ((6 : ùïÇ))‚Äñ * ‚Äñd6‚Äñ := norm_smul_le _ _
      _ = 6 * ‚Äñd6‚Äñ := by rw [RCLike.norm_ofNat]
      _ ‚â§ 6 * (35 * M ^ 4 * d) := by gcongr
      _ = 210 * M ^ 4 * d := by ring
  have h_24_d24 : ‚Äñ((24 : ùïÇ)) ‚Ä¢ d24‚Äñ ‚â§ 120 * M ^ 4 * d := by
    calc ‚Äñ((24 : ùïÇ)) ‚Ä¢ d24‚Äñ ‚â§ ‚Äñ((24 : ùïÇ))‚Äñ * ‚Äñd24‚Äñ := norm_smul_le _ _
      _ = 24 * ‚Äñd24‚Äñ := by rw [RCLike.norm_ofNat]
      _ ‚â§ 24 * (5 * M ^ 4 * d) := by gcongr
      _ = 120 * M ^ 4 * d := by ring
  -- Triangle inequality for the 4-term sum
  set S : ùî∏ := -d1 + (4 : ùïÇ) ‚Ä¢ d4 - (6 : ùïÇ) ‚Ä¢ d6 + (24 : ùïÇ) ‚Ä¢ d24 with hS_def
  have hS_eq : S = -d1 + (4 : ùïÇ) ‚Ä¢ d4 + (-((6 : ùïÇ) ‚Ä¢ d6)) + (24 : ùïÇ) ‚Ä¢ d24 := by
    rw [hS_def]; abel
  have hS_le : ‚ÄñS‚Äñ ‚â§ 440 * M ^ 4 * d := by
    rw [hS_eq]
    have a3 := norm_add_le (-d1 + (4 : ùïÇ) ‚Ä¢ d4 + (-((6 : ùïÇ) ‚Ä¢ d6))) ((24 : ùïÇ) ‚Ä¢ d24)
    have a2 := norm_add_le (-d1 + (4 : ùïÇ) ‚Ä¢ d4) (-((6 : ùïÇ) ‚Ä¢ d6))
    have a1 := norm_add_le (-d1) ((4 : ùïÇ) ‚Ä¢ d4)
    have h_neg : ‚Äñ-((6 : ùïÇ) ‚Ä¢ d6)‚Äñ = ‚Äñ((6 : ùïÇ) ‚Ä¢ d6)‚Äñ := norm_neg _
    rw [h_neg] at a2
    linarith
  -- Final smul bound
  have h720 : ‚Äñ((720 : ùïÇ)‚Åª¬π)‚Äñ = 1 / 720 := by
    rw [norm_inv, RCLike.norm_ofNat]; norm_num
  calc ‚Äñ((720 : ùïÇ)‚Åª¬π) ‚Ä¢ S‚Äñ
      ‚â§ ‚Äñ((720 : ùïÇ)‚Åª¬π)‚Äñ * ‚ÄñS‚Äñ := norm_smul_le _ _
    _ = (1 / 720) * ‚ÄñS‚Äñ := by rw [h720]
    _ ‚â§ (1 / 720) * (440 * M ^ 4 * d) := by
        apply mul_le_mul_of_nonneg_left hS_le (by norm_num)
    _ ‚â§ M ^ 4 * d := by nlinarith [hM4_nn, hd_nn]

/-! ### Per-group LQ decompositions for `bch_quintic_group_*`

These are the building blocks for `bch_quintic_term_LQ_decomp` (T2-F7e Phase E.2
step 4 foundation). Each decomposes `group_k(x+W, y) - group_k(x, y)` into
linear-in-W + quadratic-in-W + (cubic-in-W) + (quartic-in-W) parts.

For W = V‚ÇÇ = ¬Ω¬∑[a',b] (degree 2 in (a, b)) and y = a' (degree 1), each piece
is naturally bounded:
- linear-in-W: M‚Å¥¬∑‚ÄñW‚Äñ scaling.
- quadratic-in-W: M¬≥¬∑‚ÄñW‚Äñ¬≤ scaling.
- cubic-in-W: M¬≤¬∑‚ÄñW‚Äñ¬≥ scaling.
- quartic-in-W: M¬∑‚ÄñW‚Äñ‚Å¥ scaling.

When ‚ÄñW‚Äñ ‚â§ s¬≤/2 (V‚ÇÇ bound), each piece is O(s‚Å∑). -/

