/-- Norm bound for the 7-fold telescoping: given `тАЦyтАЦ тЙд 2s`, `тАЦzтАЦ тЙд s`,
`тАЦPтАЦ тЙд s┬▓`, `тАЦyтБ╖ - zтБ╖тАЦ тЙд 127┬╖sтБ╕`. Used in the small-s case of the octic
remainder bound (analog of `norm_pow6_sub_zpow6_le` at one degree higher).

Per-term bounds: `(2s)тБ╢┬╖s┬▓ + (2s)тБ╡┬╖s┬▓┬╖s + (2s)тБ┤┬╖s┬▓┬╖s┬▓ + (2s)┬│┬╖s┬▓┬╖s┬│ +
                 (2s)┬▓┬╖s┬▓┬╖sтБ┤ + (2s)┬╖s┬▓┬╖sтБ╡ + s┬▓┬╖sтБ╢
                = 64sтБ╕ + 32sтБ╕ + 16sтБ╕ + 8sтБ╕ + 4sтБ╕ + 2sтБ╕ + sтБ╕ = 127sтБ╕`. -/
private theorem norm_pow7_sub_zpow7_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 7 - (y - P) ^ 7тАЦ тЙд 127 * s ^ 8 := by
  rw [pow7_sub_zpow7_telescope]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  -- Seven terms, bounded individually.
  have h_y6P : тАЦy ^ 6 * PтАЦ тЙд (2 * s) ^ 6 * s ^ 2 :=
    calc тАЦy ^ 6 * PтАЦ тЙд тАЦy ^ 6тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд тАЦyтАЦ ^ 6 * тАЦPтАЦ := by gcongr; exact norm_pow_le y 6
      _ тЙд (2 * s) ^ 6 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 6) hP (by positivity) (by positivity)
  have h_y5Pz : тАЦy ^ 5 * P * zтАЦ тЙд (2 * s) ^ 5 * s ^ 2 * s :=
    calc тАЦy ^ 5 * P * zтАЦ тЙд тАЦy ^ 5 * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 5 * тАЦPтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦy ^ 5тАЦ * тАЦPтАЦ := norm_mul_le _ _
            _ тЙд _ := by gcongr; exact norm_pow_le y 5
      _ тЙд ((2 * s) ^ 5 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 5) hP
            (norm_nonneg _) (by positivity)
  have h_y4Pz2 : тАЦy ^ 4 * P * z ^ 2тАЦ тЙд (2 * s) ^ 4 * s ^ 2 * s ^ 2 :=
    calc тАЦy ^ 4 * P * z ^ 2тАЦ тЙд тАЦy ^ 4 * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 4 * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 4тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 4
          ┬╖ exact norm_pow_le z 2
      _ тЙд ((2 * s) ^ 4 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 4) hP
            (norm_nonneg _) (by positivity)
  have h_y3Pz3 : тАЦy ^ 3 * P * z ^ 3тАЦ тЙд (2 * s) ^ 3 * s ^ 2 * s ^ 3 :=
    calc тАЦy ^ 3 * P * z ^ 3тАЦ тЙд тАЦy ^ 3 * PтАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 3 * тАЦPтАЦ) * тАЦzтАЦ ^ 3 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 3тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 3
          ┬╖ exact norm_pow_le z 3
      _ тЙд ((2 * s) ^ 3 * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz4 : тАЦy ^ 2 * P * z ^ 4тАЦ тЙд (2 * s) ^ 2 * s ^ 2 * s ^ 4 :=
    calc тАЦy ^ 2 * P * z ^ 4тАЦ тЙд тАЦy ^ 2 * PтАЦ * тАЦz ^ 4тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 2 * тАЦPтАЦ) * тАЦzтАЦ ^ 4 := by
          gcongr
          ┬╖ calc _ тЙд тАЦy ^ 2тАЦ * тАЦPтАЦ := norm_mul_le _ _
              _ тЙд _ := by gcongr; exact norm_pow_le y 2
          ┬╖ exact norm_pow_le z 4
      _ тЙд ((2 * s) ^ 2 * s ^ 2) * s ^ 4 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 4)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz5 : тАЦy * P * z ^ 5тАЦ тЙд 2 * s * s ^ 2 * s ^ 5 :=
    calc тАЦy * P * z ^ 5тАЦ тЙд тАЦy * PтАЦ * тАЦz ^ 5тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 5 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 5
      _ тЙд (2 * s * s ^ 2) * s ^ 5 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 5)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz6 : тАЦP * z ^ 6тАЦ тЙд s ^ 2 * s ^ 6 :=
    calc тАЦP * z ^ 6тАЦ тЙд тАЦPтАЦ * тАЦz ^ 6тАЦ := norm_mul_le _ _
      _ тЙд тАЦPтАЦ * тАЦzтАЦ ^ 6 := by gcongr; exact norm_pow_le z 6
      _ тЙд s ^ 2 * s ^ 6 := mul_le_mul hP (pow_le_pow_leftтВА (norm_nonneg _) hzn 6)
          (by positivity) (by positivity)
  -- Sum via triangle inequality (6 norm_add_le applications)
  have ht1 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3 +
      y ^ 2 * P * z ^ 4 + y * P * z ^ 5) (P * z ^ 6)
  have ht2 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3 +
      y ^ 2 * P * z ^ 4) (y * P * z ^ 5)
  have ht3 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3)
    (y ^ 2 * P * z ^ 4)
  have ht4 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2) (y ^ 3 * P * z ^ 3)
  have ht5 := norm_add_le (y ^ 6 * P + y ^ 5 * P * z) (y ^ 4 * P * z ^ 2)
  have ht6 := norm_add_le (y ^ 6 * P) (y ^ 5 * P * z)
