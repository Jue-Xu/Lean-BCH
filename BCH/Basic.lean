private theorem I1_octic_residual_decomp_eq (ùïÇ : Type*) [RCLike ùïÇ] {ùî∏ : Type*}
    [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] (ea eb a b : ùî∏) :
    let D‚ÇÅ : ùî∏ := ea - 1 - a
