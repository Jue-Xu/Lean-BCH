    calc _ ‚â§ ‚Äñz * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ)‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñz‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ) * ‚Äñz‚Äñ := by gcongr; exact norm_mul_le _ _
