  have h_F1b2_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)‚Äñ ‚â§ s ^ 6 / 2 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚ÄñF‚ÇÅ * b ^ 2‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_F‚ÇÅb2_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_zRpRz_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * R + R * z)‚Äñ ‚â§ 6 * s ^ 6 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚Äñz * R + R * z‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * (12 * s ^ 6) := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_zRpRz_le (by norm_num)
      _ = 6 * s ^ 6 := by ring
  have h_T22_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ T22‚Äñ ‚â§ 15 * s ^ 6 / 2 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚ÄñT22‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * (15 * s ^ 6) := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_T22_le (by norm_num)
