set_option maxHeartbeats 800000 in
include ЁЭХВ in
/-- **Inner BCH septic remainder bound** (T2-F7e Phase A): the inner-BCH leg of
the symmetric BCH composition `bch(bch(┬╜a, b), ┬╜a)`, after subtracting the
explicit through-deg-6 expansion at `(┬╜a, b)`, satisfies an `O(sтБ╖)` bound for
`s = тАЦaтАЦ + тАЦbтАЦ < 1/4`.

Direct application of `norm_bch_septic_remainder_le` to `(┬╜a, b)` plus the
standard `sтВБ := тАЦ┬╜aтАЦ + тАЦbтАЦ тЙд s` and `2 - exp(sтВБ) тЙе 11/16` (from `sтВБ тЙд 1/4`).
The bound constant `1500000` is chosen to absorb `1000010┬╖(16/11) тЙИ 1454560`
with small margin. -/
theorem norm_bch_inner_septic_remainder_le (a b : ЁЭФ╕)
    (hab : тАЦaтАЦ + тАЦbтАЦ < 1 / 4) :
    тАЦbch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b - ((2 : ЁЭХВ)тБ╗┬╣ тАв a + b) -
      (2 : ЁЭХВ)тБ╗┬╣ тАв ((2 : ЁЭХВ)тБ╗┬╣ тАв a * b - b * ((2 : ЁЭХВ)тБ╗┬╣ тАв a)) -
      bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b -
      bch_quartic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b -
      bch_quintic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b -
      bch_sextic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) bтАЦ тЙд
      1500000 * (тАЦaтАЦ + тАЦbтАЦ) ^ 7 := by
  set a' : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв a with ha'_def
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  set sтВБ := тАЦa'тАЦ + тАЦbтАЦ with hsтВБ_def
  have h_half_norm : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have ha'_le : тАЦa'тАЦ тЙд тАЦaтАЦ / 2 := by
    calc тАЦa'тАЦ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦaтАЦ := norm_smul_le _ _
      _ = тАЦaтАЦ / 2 := by rw [h_half_norm]; ring
  have hs_nn : 0 тЙд s := by positivity
  have hs_lt : s < 1 / 4 := hab
  have hsтВБ_le : sтВБ тЙд s := by
    show тАЦa'тАЦ + тАЦbтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ; linarith [ha'_le, norm_nonneg a]
  have hsтВБ_nn : 0 тЙд sтВБ := by positivity
  have hln2 : (1 : тДЭ) / 4 < Real.log 2 := by
    rw [Real.lt_log_iff_exp_lt (by norm_num : (0:тДЭ) < 2)]
    linarith [real_exp_third_order_le_cube (by norm_num : (0:тДЭ) тЙд 1/4)
      (by norm_num : (1:тДЭ)/4 < 5/6)]
  have hsтВБ_lt_log2 : sтВБ < Real.log 2 := by linarith
  have hexp_sтВБ_lt : Real.exp sтВБ < 2 := by
    calc _ < Real.exp (Real.log 2) := Real.exp_strictMono hsтВБ_lt_log2
      _ = 2 := Real.exp_log (by norm_num)
  have hdenomтВБ : 0 < 2 - Real.exp sтВБ := by linarith
  have hexp_le : Real.exp sтВБ тЙд 1 + sтВБ + sтВБ ^ 2 := by
    nlinarith [real_exp_third_order_le_cube hsтВБ_nn (by linarith : sтВБ < 5/6)]
  have hdenom_lb : (11 : тДЭ) / 16 тЙд 2 - Real.exp sтВБ := by nlinarith
  -- Apply norm_bch_septic_remainder_le at (a', b).
  have hR_sept_le :
      тАЦbch (ЁЭХВ := ЁЭХВ) a' b - (a' + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') -
        bch_cubic_term ЁЭХВ a' b - bch_quartic_term ЁЭХВ a' b -
        bch_quintic_term ЁЭХВ a' b - bch_sextic_term ЁЭХВ a' bтАЦ тЙд
        1000010 * sтВБ ^ 7 / (2 - Real.exp sтВБ) :=
    norm_bch_septic_remainder_le (ЁЭХВ := ЁЭХВ) a' b hsтВБ_lt_log2
  -- Convert to sтБ╖ bound.
  have hX_s7 : 1000010 * sтВБ ^ 7 / (2 - Real.exp sтВБ) тЙд 1500000 * s ^ 7 := by
    rw [div_le_iffтВА hdenomтВБ]
    have hs_pow : sтВБ ^ 7 тЙд s ^ 7 := pow_le_pow_leftтВА hsтВБ_nn hsтВБ_le 7
    have hs7_nn : (0 : тДЭ) тЙд s ^ 7 := pow_nonneg hs_nn 7
    nlinarith [hdenom_lb, hs_pow, hs7_nn]
  linarith

