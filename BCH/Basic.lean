/-- **Helper (deg-7, local copy)**: `тАЦc тАв (lтВБ┬╖тАж┬╖l7)тАЦ тЙд cb ┬╖ s^7` if `тАЦcтАЦ тЙд cb`
and each `тАЦlс╡втАЦ тЙд s`. Local copy of `SymmetricQuintic.deg7_smul_word_le`
(unavailable upstream in Basic.lean). -/
private lemma deg7_smul_word_le_basic
    (c : ЁЭХВ) (cb : тДЭ) (hc : тАЦcтАЦ тЙд cb)
    (l1 l2 l3 l4 l5 l6 l7 : ЁЭФ╕) (s : тДЭ)
    (h1 : тАЦl1тАЦ тЙд s) (h2 : тАЦl2тАЦ тЙд s) (h3 : тАЦl3тАЦ тЙд s) (h4 : тАЦl4тАЦ тЙд s) (h5 : тАЦl5тАЦ тЙд s) (h6 : тАЦl6тАЦ тЙд s) (h7 : тАЦl7тАЦ тЙд s)
    (hcb : 0 тЙд cb) (hs : 0 тЙд s) :
    тАЦc тАв (l1 * l2 * l3 * l4 * l5 * l6 * l7)тАЦ тЙд cb * s ^ 7 := by
  calc тАЦc тАв (l1 * l2 * l3 * l4 * l5 * l6 * l7)тАЦ
      тЙд тАЦcтАЦ * тАЦl1 * l2 * l3 * l4 * l5 * l6 * l7тАЦ := norm_smul_le _ _
    _ тЙд cb * тАЦl1 * l2 * l3 * l4 * l5 * l6 * l7тАЦ :=
        mul_le_mul_of_nonneg_right hc (norm_nonneg _)
    _ тЙд cb * (тАЦl1тАЦ * тАЦl2тАЦ * тАЦl3тАЦ * тАЦl4тАЦ * тАЦl5тАЦ * тАЦl6тАЦ * тАЦl7тАЦ) :=
        mul_le_mul_of_nonneg_left (norm_7prod_le _ _ _ _ _ _ _) hcb
    _ тЙд cb * (s * s * s * s * s * s * s) := by
        refine mul_le_mul_of_nonneg_left ?_ hcb; gcongr
    _ = cb * s ^ 7 := by ring

