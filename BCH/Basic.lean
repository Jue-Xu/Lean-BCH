/-- **Lipschitz bound for `bch_quintic_term` in its first argument**:
`тАЦCтВЕ(z, y) тИТ CтВЕ(x, y)тАЦ тЙд (тАЦzтАЦ+тАЦxтАЦ+тАЦyтАЦ)тБ┤ ┬╖ тАЦz тИТ xтАЦ`.

Combines the 4 per-group Lipschitz bounds with the (720)тБ╗┬╣ scalar factor:
`(10 + 4┬╖25 + 6┬╖35 + 24┬╖5)/720 = 440/720 = 11/18 < 1`.

This is the analog of `norm_bch_cubic_term_diff_le` at degree 5; both are
key infrastructure for the parent T2-F7e discharge. With `z = (a'+b) + W`
(where тАЦWтАЦ = O(s┬▓)), this gives `тАЦCтВЕ(z, y) тИТ CтВЕ(a'+b, y)тАЦ тЙд K ┬╖ s┬▓ ┬╖ MтБ┤ тЙд
K ┬╖ sтБ╢`, the deg-6+ residual estimate needed in the extended hdecomp. -/
theorem norm_bch_quintic_term_diff_le (z x y : ЁЭФ╕) :
    тАЦbch_quintic_term ЁЭХВ z y - bch_quintic_term ЁЭХВ x yтАЦ тЙд
      (тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ) ^ 4 * тАЦz - xтАЦ := by
  set M := тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ with hM_def
  set d := тАЦz - xтАЦ with hd_def
  have hd_nn : 0 тЙд d := norm_nonneg _
  have hM_nn : 0 тЙд M := by positivity
  have hM4_nn : (0 : тДЭ) тЙд M ^ 4 := pow_nonneg hM_nn 4
  -- Per-group bounds.
  have hg1 := norm_bch_quintic_group_1_diff_le z x y
  have hg4 := norm_bch_quintic_group_4_diff_le z x y
  have hg6 := norm_bch_quintic_group_6_diff_le z x y
  have hg24 := norm_bch_quintic_group_24_diff_le z x y
  -- Identity: bch_quintic_term diff = (720)тБ╗┬╣ тАв (per-group diffs combo).
  have htel : bch_quintic_term ЁЭХВ z y - bch_quintic_term ЁЭХВ x y =
      (720 : ЁЭХВ)тБ╗┬╣ тАв (
        -(bch_quintic_group_1 z y - bch_quintic_group_1 x y)
        + (4 : ЁЭХВ) тАв (bch_quintic_group_4 z y - bch_quintic_group_4 x y)
        - (6 : ЁЭХВ) тАв (bch_quintic_group_6 z y - bch_quintic_group_6 x y)
        + (24 : ЁЭХВ) тАв (bch_quintic_group_24 z y - bch_quintic_group_24 x y)) := by
    unfold bch_quintic_term
    simp only [smul_sub, smul_add, smul_neg]
    abel
  rw [htel]
  -- Norm bound on the smul'd expression.
  set d1 : ЁЭФ╕ := bch_quintic_group_1 z y - bch_quintic_group_1 x y
  set d4 : ЁЭФ╕ := bch_quintic_group_4 z y - bch_quintic_group_4 x y
  set d6 : ЁЭФ╕ := bch_quintic_group_6 z y - bch_quintic_group_6 x y
  set d24 : ЁЭФ╕ := bch_quintic_group_24 z y - bch_quintic_group_24 x y
  -- Bounds on the smul'd diffs
  have h_neg_d1 : тАЦ-d1тАЦ тЙд 10 * M ^ 4 * d := by
    rw [norm_neg]; exact hg1
  have h_4_d4 : тАЦ((4 : ЁЭХВ)) тАв d4тАЦ тЙд 100 * M ^ 4 * d := by
    calc тАЦ((4 : ЁЭХВ)) тАв d4тАЦ тЙд тАЦ((4 : ЁЭХВ))тАЦ * тАЦd4тАЦ := norm_smul_le _ _
      _ = 4 * тАЦd4тАЦ := by rw [RCLike.norm_ofNat]
      _ тЙд 4 * (25 * M ^ 4 * d) := by gcongr
      _ = 100 * M ^ 4 * d := by ring
  have h_6_d6 : тАЦ((6 : ЁЭХВ)) тАв d6тАЦ тЙд 210 * M ^ 4 * d := by
    calc тАЦ((6 : ЁЭХВ)) тАв d6тАЦ тЙд тАЦ((6 : ЁЭХВ))тАЦ * тАЦd6тАЦ := norm_smul_le _ _
      _ = 6 * тАЦd6тАЦ := by rw [RCLike.norm_ofNat]
      _ тЙд 6 * (35 * M ^ 4 * d) := by gcongr
      _ = 210 * M ^ 4 * d := by ring
  have h_24_d24 : тАЦ((24 : ЁЭХВ)) тАв d24тАЦ тЙд 120 * M ^ 4 * d := by
    calc тАЦ((24 : ЁЭХВ)) тАв d24тАЦ тЙд тАЦ((24 : ЁЭХВ))тАЦ * тАЦd24тАЦ := norm_smul_le _ _
      _ = 24 * тАЦd24тАЦ := by rw [RCLike.norm_ofNat]
      _ тЙд 24 * (5 * M ^ 4 * d) := by gcongr
      _ = 120 * M ^ 4 * d := by ring
  -- Triangle inequality for the 4-term sum
  set S : ЁЭФ╕ := -d1 + (4 : ЁЭХВ) тАв d4 - (6 : ЁЭХВ) тАв d6 + (24 : ЁЭХВ) тАв d24 with hS_def
  have hS_eq : S = -d1 + (4 : ЁЭХВ) тАв d4 + (-((6 : ЁЭХВ) тАв d6)) + (24 : ЁЭХВ) тАв d24 := by
    rw [hS_def]; abel
  have hS_le : тАЦSтАЦ тЙд 440 * M ^ 4 * d := by
    rw [hS_eq]
    have a3 := norm_add_le (-d1 + (4 : ЁЭХВ) тАв d4 + (-((6 : ЁЭХВ) тАв d6))) ((24 : ЁЭХВ) тАв d24)
    have a2 := norm_add_le (-d1 + (4 : ЁЭХВ) тАв d4) (-((6 : ЁЭХВ) тАв d6))
    have a1 := norm_add_le (-d1) ((4 : ЁЭХВ) тАв d4)
    have h_neg : тАЦ-((6 : ЁЭХВ) тАв d6)тАЦ = тАЦ((6 : ЁЭХВ) тАв d6)тАЦ := norm_neg _
    rw [h_neg] at a2
    linarith
  -- Final smul bound
  have h720 : тАЦ((720 : ЁЭХВ)тБ╗┬╣)тАЦ = 1 / 720 := by
    rw [norm_inv, RCLike.norm_ofNat]; norm_num
  calc тАЦ((720 : ЁЭХВ)тБ╗┬╣) тАв SтАЦ
      тЙд тАЦ((720 : ЁЭХВ)тБ╗┬╣)тАЦ * тАЦSтАЦ := norm_smul_le _ _
    _ = (1 / 720) * тАЦSтАЦ := by rw [h720]
    _ тЙд (1 / 720) * (440 * M ^ 4 * d) := by
        apply mul_le_mul_of_nonneg_left hS_le (by norm_num)
    _ тЙд M ^ 4 * d := by nlinarith [hM4_nn, hd_nn]

/-! ### Per-group LQ decompositions for `bch_quintic_group_*`

These are the building blocks for `bch_quintic_term_LQ_decomp` (T2-F7e Phase E.2
step 4 foundation). Each decomposes `group_k(x+W, y) - group_k(x, y)` into
linear-in-W + quadratic-in-W + (cubic-in-W) + (quartic-in-W) parts.

For W = VтВВ = ┬╜┬╖[a',b] (degree 2 in (a, b)) and y = a' (degree 1), each piece
is naturally bounded:
- linear-in-W: MтБ┤┬╖тАЦWтАЦ scaling.
- quadratic-in-W: M┬│┬╖тАЦWтАЦ┬▓ scaling.
- cubic-in-W: M┬▓┬╖тАЦWтАЦ┬│ scaling.
- quartic-in-W: M┬╖тАЦWтАЦтБ┤ scaling.

When тАЦWтАЦ тЙд s┬▓/2 (VтВВ bound), each piece is O(sтБ╖). -/

