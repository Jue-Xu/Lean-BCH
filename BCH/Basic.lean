/-- Norm bound for `y┬▓ - z┬▓` (2-fold telescoping) where `z = y - P`,
given `тАЦyтАЦ тЙд 2s`, `тАЦPтАЦ тЙд s┬▓`, `тАЦzтАЦ тЙд s`. -/
private theorem norm_pow2_sub_zpow2_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 2 - (y - P) ^ 2тАЦ тЙд 3 * s ^ 3 := by
  have hY2_eq : y ^ 2 - (y - P) ^ 2 = y * P + P * (y - P) := by noncomm_ring
  rw [hY2_eq]
  have h_yP : тАЦy * PтАЦ тЙд 2 * s * s ^ 2 :=
    calc тАЦy * PтАЦ тЙд тАЦyтАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд 2 * s * s ^ 2 := mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz : тАЦP * (y - P)тАЦ тЙд s ^ 2 * s :=
    calc тАЦP * (y - P)тАЦ тЙд тАЦPтАЦ * тАЦy - PтАЦ := norm_mul_le _ _
      _ тЙд s ^ 2 * s := mul_le_mul hP hz (norm_nonneg _) (by positivity)
  calc тАЦy * P + P * (y - P)тАЦ тЙд тАЦy * PтАЦ + тАЦP * (y - P)тАЦ := norm_add_le _ _
    _ тЙд 2 * s * s ^ 2 + s ^ 2 * s := by linarith
    _ = 3 * s ^ 3 := by ring

/-- Norm bound for `y┬│ - z┬│` (3-fold telescoping). -/
private theorem norm_pow3_sub_zpow3_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 3 - (y - P) ^ 3тАЦ тЙд 7 * s ^ 4 := by
  rw [pow3_sub_zpow3_telescope]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  have h_y2P : тАЦy ^ 2 * PтАЦ тЙд (2 * s) ^ 2 * s ^ 2 :=
    calc тАЦy ^ 2 * PтАЦ тЙд тАЦy ^ 2тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд тАЦyтАЦ ^ 2 * тАЦPтАЦ := by gcongr; exact norm_pow_le y 2
      _ тЙд (2 * s) ^ 2 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 2) hP
            (by positivity) (by positivity)
  have h_yPz : тАЦy * P * zтАЦ тЙд 2 * s * s ^ 2 * s :=
    calc тАЦy * P * zтАЦ тЙд тАЦy * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ * тАЦPтАЦ) * тАЦzтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд (2 * s * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz2 : тАЦP * z ^ 2тАЦ тЙд s ^ 2 * s ^ 2 :=
    calc тАЦP * z ^ 2тАЦ тЙд тАЦPтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд тАЦPтАЦ * тАЦzтАЦ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ тЙд s ^ 2 * s ^ 2 := mul_le_mul hP (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
          (by positivity) (by positivity)
  have ht1 := norm_add_le (y ^ 2 * P + y * P * z) (P * z ^ 2)
  have ht2 := norm_add_le (y ^ 2 * P) (y * P * z)
  nlinarith

/-- Norm bound for `yтБ┤ - zтБ┤` (4-fold telescoping) where `z = y - P`,
given `тАЦyтАЦ тЙд 2s`, `тАЦPтАЦ тЙд s┬▓`, `тАЦzтАЦ тЙд s`. Bounds: `(2s)┬│┬╖s┬▓ + (2s)┬▓┬╖s┬▓┬╖s +
(2s)┬╖s┬▓┬╖s┬▓ + s┬▓┬╖s┬│ = 8sтБ╡ + 4sтБ╡ + 2sтБ╡ + sтБ╡ = 15sтБ╡`. -/
private theorem norm_pow4_sub_zpow4_le (y P : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2) :
    тАЦy ^ 4 - (y - P) ^ 4тАЦ тЙд 15 * s ^ 5 := by
  rw [pow4_sub_zpow4_telescope]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  have h_y3P : тАЦy ^ 3 * PтАЦ тЙд (2 * s) ^ 3 * s ^ 2 :=
    calc тАЦy ^ 3 * PтАЦ тЙд тАЦy ^ 3тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд тАЦyтАЦ ^ 3 * тАЦPтАЦ := by gcongr; exact norm_pow_le y 3
      _ тЙд (2 * s) ^ 3 * s ^ 2 :=
          mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 3) hP (by positivity) (by positivity)
  have h_y2Pz : тАЦy ^ 2 * P * zтАЦ тЙд (2 * s) ^ 2 * s ^ 2 * s :=
    calc тАЦy ^ 2 * P * zтАЦ тЙд тАЦy ^ 2 * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ ^ 2 * тАЦPтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦy ^ 2тАЦ * тАЦPтАЦ := norm_mul_le _ _
            _ тЙд _ := by gcongr; exact norm_pow_le y 2
      _ тЙд ((2 * s) ^ 2 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz2 : тАЦy * P * z ^ 2тАЦ тЙд 2 * s * s ^ 2 * s ^ 2 :=
    calc тАЦy * P * z ^ 2тАЦ тЙд тАЦy * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦyтАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд (2 * s * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz3 : тАЦP * z ^ 3тАЦ тЙд s ^ 2 * s ^ 3 :=
    calc тАЦP * z ^ 3тАЦ тЙд тАЦPтАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд тАЦPтАЦ * тАЦzтАЦ ^ 3 := by gcongr; exact norm_pow_le z 3
      _ тЙд s ^ 2 * s ^ 3 := mul_le_mul hP (pow_le_pow_leftтВА (norm_nonneg _) hzn 3)
          (by positivity) (by positivity)
  have ht1 := norm_add_le (y ^ 3 * P + y ^ 2 * P * z + y * P * z ^ 2) (P * z ^ 3)
  have ht2 := norm_add_le (y ^ 3 * P + y ^ 2 * P * z) (y * P * z ^ 2)
  have ht3 := norm_add_le (y ^ 3 * P) (y ^ 2 * P * z)
  nlinarith [pow_nonneg hs_nn 5]

/-- Norm bound for `yтБ┤ - zтБ┤ - y4_5` where `y4_5 = z┬│TтВВ + z┬▓TтВВz + zTтВВz┬▓ + TтВВz┬│`,
given the BCH-context norm bounds. The bound is `31┬╖sтБ╢`. -/
private theorem norm_y4_sub_z4_sub_y4_5_le (y P TтВВ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hy : тАЦyтАЦ тЙд 2 * s) (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3) :
    тАЦy ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * TтВВ + (y - P) ^ 2 * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) ^ 2 + TтВВ * (y - P) ^ 3)тАЦ тЙд 31 * s ^ 6 := by
  rw [y4_sub_z4_sub_y4_5_decomp]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  -- 7 terms to bound
  -- (y-P)^3 (P-TтВВ) etc.: тЙд s^3 * 5s^3 = 5s^6, four of these = 20s^6
  have h_z3PT : тАЦz ^ 3 * (P - TтВВ)тАЦ тЙд s ^ 3 * (5 * s ^ 3) :=
    calc тАЦz ^ 3 * (P - TтВВ)тАЦ тЙд тАЦz ^ 3тАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд тАЦzтАЦ ^ 3 * тАЦP - TтВВтАЦ := by gcongr; exact norm_pow_le z 3
      _ тЙд s ^ 3 * (5 * s ^ 3) := mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hzn 3)
          hPmTтВВ (norm_nonneg _) (by positivity)
  have h_z2PTz : тАЦz ^ 2 * (P - TтВВ) * zтАЦ тЙд s ^ 2 * (5 * s ^ 3) * s :=
    calc _ тЙд тАЦz ^ 2 * (P - TтВВ)тАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦzтАЦ ^ 2 * тАЦP - TтВВтАЦ) * тАЦzтАЦ := by
          gcongr
          calc _ тЙд тАЦz ^ 2тАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
            _ тЙд _ := by gcongr; exact norm_pow_le z 2
      _ тЙд (s ^ 2 * (5 * s ^ 3)) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_leftтВА (norm_nonneg _) hzn 2) hPmTтВВ
            (norm_nonneg _) (by positivity)
  have h_zPTz2 : тАЦz * (P - TтВВ) * z ^ 2тАЦ тЙд s * (5 * s ^ 3) * s ^ 2 :=
    calc _ тЙд тАЦz * (P - TтВВ)тАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦzтАЦ * тАЦP - TтВВтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд (s * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hzn hPmTтВВ (norm_nonneg _) (by positivity)
  have h_PTz3 : тАЦ(P - TтВВ) * z ^ 3тАЦ тЙд (5 * s ^ 3) * s ^ 3 :=
    calc _ тЙд тАЦP - TтВВтАЦ * тАЦz ^ 3тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВтАЦ * тАЦzтАЦ ^ 3 := by gcongr; exact norm_pow_le z 3
      _ тЙд (5 * s ^ 3) * s ^ 3 := mul_le_mul hPmTтВВ
          (pow_le_pow_leftтВА (norm_nonneg _) hzn 3) (by positivity) (by positivity)
  -- (y┬│ - z┬│) P term
  have hy3z3 := norm_pow3_sub_zpow3_le y P hs_nn hy hz hP
  have h_y3z3P : тАЦ(y ^ 3 - z ^ 3) * PтАЦ тЙд (7 * s ^ 4) * s ^ 2 :=
    calc _ тЙд тАЦy ^ 3 - z ^ 3тАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд (7 * s ^ 4) * s ^ 2 :=
          mul_le_mul hy3z3 hP (norm_nonneg _) (by positivity)
  -- (y┬▓ - z┬▓) P z term
  have hy2z2 := norm_pow2_sub_zpow2_le y P hs_nn hy hz hP
  have h_y2z2Pz : тАЦ(y ^ 2 - z ^ 2) * P * zтАЦ тЙд (3 * s ^ 3) * s ^ 2 * s :=
    calc _ тЙд тАЦ(y ^ 2 - z ^ 2) * PтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (тАЦy ^ 2 - z ^ 2тАЦ * тАЦPтАЦ) * тАЦzтАЦ := by gcongr; exact norm_mul_le _ _
      _ тЙд ((3 * s ^ 3) * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul hy2z2 hP (norm_nonneg _) (by positivity)
  -- P ┬╖ P ┬╖ z┬▓ term (note: P*P*z┬▓ in the decomp formula)
  have h_PPz2 : тАЦP * P * z ^ 2тАЦ тЙд s ^ 2 * s ^ 2 * s ^ 2 :=
    calc _ тЙд тАЦP * PтАЦ * тАЦz ^ 2тАЦ := norm_mul_le _ _
      _ тЙд (тАЦPтАЦ * тАЦPтАЦ) * тАЦzтАЦ ^ 2 := by
          gcongr
          ┬╖ exact norm_mul_le _ _
          ┬╖ exact norm_pow_le z 2
      _ тЙд (s ^ 2 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_leftтВА (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hP hP (norm_nonneg _) (by positivity)
  -- Sum via triangle inequality (7 terms)
  have ht := norm_add_le
    (z ^ 3 * (P - TтВВ) + z ^ 2 * (P - TтВВ) * z + z * (P - TтВВ) * z ^ 2 + (P - TтВВ) * z ^ 3 +
      (y ^ 3 - z ^ 3) * P + (y ^ 2 - z ^ 2) * P * z) (P * P * z ^ 2)
  have ht2 := norm_add_le
    (z ^ 3 * (P - TтВВ) + z ^ 2 * (P - TтВВ) * z + z * (P - TтВВ) * z ^ 2 + (P - TтВВ) * z ^ 3 +
      (y ^ 3 - z ^ 3) * P) ((y ^ 2 - z ^ 2) * P * z)
  have ht3 := norm_add_le
    (z ^ 3 * (P - TтВВ) + z ^ 2 * (P - TтВВ) * z + z * (P - TтВВ) * z ^ 2 + (P - TтВВ) * z ^ 3)
    ((y ^ 3 - z ^ 3) * P)
  have ht4 := norm_add_le
    (z ^ 3 * (P - TтВВ) + z ^ 2 * (P - TтВВ) * z + z * (P - TтВВ) * z ^ 2)
    ((P - TтВВ) * z ^ 3)
  have ht5 := norm_add_le
    (z ^ 3 * (P - TтВВ) + z ^ 2 * (P - TтВВ) * z) (z * (P - TтВВ) * z ^ 2)
  have ht6 := norm_add_le (z ^ 3 * (P - TтВВ)) (z ^ 2 * (P - TтВВ) * z)
  nlinarith [pow_nonneg hs_nn 6]

/-- Algebraic decomposition of `yтБ┤ - zтБ┤ - y4_5 - y4_6` where `z = y - P`,
`y4_5 = z┬│TтВВ + z┬▓TтВВz + zTтВВz┬▓ + TтВВz┬│` is the deg-5 leading contribution
to `yтБ┤ = (z + TтВВ + TтВГ + тАж)тБ┤`, and `y4_6` is the deg-6 contribution.

`y4_6` has 10 terms: 4 with `TтВГ` (the `(1,1,1,3)` perms `z^i┬╖TтВГ┬╖z^j`) plus
6 with `TтВВ┬▓` (the `(1,1,2,2)` perms `z^i┬╖TтВВ┬╖z^j┬╖TтВВ┬╖z^k` with `i+j+k=2`).

Expresses the difference as 16 deg-7+ terms:
- 4 weight-1 terms `z^i┬╖(P-TтВВ-TтВГ)┬╖z^j` (the `TтВГ` correction completes `P-TтВВ` to `P-TтВВ-TтВГ`).
- 7 terms from `(y┬│-z┬│)┬╖P тИТ (z┬▓TтВВ┬▓ + zTтВВzTтВВ + TтВВz┬▓TтВВ)`:
  `(y┬▓-z┬▓)┬╖P┬▓`, `z┬▓┬╖(P┬▓-TтВВ┬▓)`, `P┬▓┬╖z┬╖P`,
  `z┬╖(P-TтВВ)┬╖z┬╖P + z┬╖TтВВ┬╖z┬╖(P-TтВВ)`,
  `(P-TтВВ)┬╖z┬▓┬╖P + TтВВ┬╖z┬▓┬╖(P-TтВВ)`.
- 4 terms from `(y┬▓-z┬▓)┬╖P┬╖z тИТ (zTтВВ┬▓z + TтВВzTтВВz)`:
  `P┬│┬╖z`, `z┬╖(P┬▓-TтВВ┬▓)┬╖z`,
  `(P-TтВВ)┬╖z┬╖P┬╖z + TтВВ┬╖z┬╖(P-TтВВ)┬╖z`.
- 1 term from `P┬▓┬╖z┬▓ тИТ TтВВ┬▓┬╖z┬▓`: `(P┬▓-TтВВ┬▓)┬╖z┬▓`.

Each is bounded by тЙд 10┬╖sтБ╖ (or less) in the BCH context where
`тАЦyтАЦ тЙд 2s, тАЦzтАЦ тЙд s, тАЦPтАЦ тЙд s┬▓, тАЦTтВВтАЦ тЙд s┬▓, тАЦP-TтВВтАЦ тЙд 5s┬│, тАЦP-TтВВ-TтВГтАЦ тЙд 5sтБ┤`. -/
private theorem y4_sub_z4_sub_y4_5_sub_y4_6_decomp (y P TтВВ TтВГ : ЁЭФ╕) :
    y ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * TтВВ + (y - P) ^ 2 * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) ^ 2 + TтВВ * (y - P) ^ 3) -
      ((y - P) ^ 3 * TтВГ + (y - P) ^ 2 * TтВГ * (y - P) +
        (y - P) * TтВГ * (y - P) ^ 2 + TтВГ * (y - P) ^ 3 +
        (y - P) ^ 2 * TтВВ ^ 2 + (y - P) * TтВВ * (y - P) * TтВВ +
        (y - P) * TтВВ ^ 2 * (y - P) +
        TтВВ * (y - P) ^ 2 * TтВВ + TтВВ * (y - P) * TтВВ * (y - P) + TтВВ ^ 2 * (y - P) ^ 2) =
    (y - P) ^ 3 * (P - TтВВ - TтВГ) + (y - P) ^ 2 * (P - TтВВ - TтВГ) * (y - P) +
      (y - P) * (P - TтВВ - TтВГ) * (y - P) ^ 2 + (P - TтВВ - TтВГ) * (y - P) ^ 3 +
    (y ^ 2 - (y - P) ^ 2) * P ^ 2 +
    (y - P) ^ 2 * (P ^ 2 - TтВВ ^ 2) +
    P ^ 2 * (y - P) * P +
    (y - P) * (P - TтВВ) * (y - P) * P + (y - P) * TтВВ * (y - P) * (P - TтВВ) +
    (P - TтВВ) * (y - P) ^ 2 * P + TтВВ * (y - P) ^ 2 * (P - TтВВ) +
    P ^ 3 * (y - P) +
    (y - P) * (P ^ 2 - TтВВ ^ 2) * (y - P) +
    (P - TтВВ) * (y - P) * P * (y - P) + TтВВ * (y - P) * (P - TтВВ) * (y - P) +
    (P ^ 2 - TтВВ ^ 2) * (y - P) ^ 2 := by
  noncomm_ring

/-- Algebraic decomposition of `yтБ┤ - zтБ┤ - y4_5 - y4_6 - y4_7` where `z = y - P`.

Extends `y4_sub_z4_sub_y4_5_sub_y4_6_decomp` by subtracting the deg-7 contribution
`y4_7` (20 terms from compositions `(kтВБ,kтВВ,kтВГ,kтВД) тКв 7, kс╡в тЙе 1`):
- 4 with `TтВД` at position `p` (the `(1,1,1,4)` perms)
- 12 with one `TтВВ` and one `TтВГ` at non-trivial positions (`(1,1,2,3)` perms)
- 4 with `TтВВ┬│` at three positions (`(1,2,2,2)` perms)

Each `y4_7` item is exactly the deg-7 leading of one of the 16 terms in the
septic decomposition; absorbing them yields 24 deg-8+ terms. Used as the
`SтВГ'` piece bound in the octic small-s discharge (analog of
`y4_sub_z4_sub_y4_5_sub_y4_6_decomp` at one degree higher). -/
private theorem y4_sub_z4_sub_y4_5_sub_y4_6_sub_y4_7_decomp
    (y P TтВВ TтВГ TтВД : ЁЭФ╕) :
    y ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * TтВВ + (y - P) ^ 2 * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) ^ 2 + TтВВ * (y - P) ^ 3) -
      ((y - P) ^ 3 * TтВГ + (y - P) ^ 2 * TтВГ * (y - P) +
        (y - P) * TтВГ * (y - P) ^ 2 + TтВГ * (y - P) ^ 3 +
        (y - P) ^ 2 * TтВВ ^ 2 + (y - P) * TтВВ * (y - P) * TтВВ +
        (y - P) * TтВВ ^ 2 * (y - P) +
        TтВВ * (y - P) ^ 2 * TтВВ + TтВВ * (y - P) * TтВВ * (y - P) +
        TтВВ ^ 2 * (y - P) ^ 2) -
      ((y - P) * (y - P) * (y - P) * TтВД +
        (y - P) * (y - P) * TтВВ * TтВГ +
        (y - P) * (y - P) * TтВГ * TтВВ +
        (y - P) * (y - P) * TтВД * (y - P) +
        (y - P) * TтВВ * (y - P) * TтВГ +
        (y - P) * TтВВ * TтВВ * TтВВ +
        (y - P) * TтВВ * TтВГ * (y - P) +
        (y - P) * TтВГ * (y - P) * TтВВ +
        (y - P) * TтВГ * TтВВ * (y - P) +
        (y - P) * TтВД * (y - P) * (y - P) +
        TтВВ * (y - P) * (y - P) * TтВГ +
        TтВВ * (y - P) * TтВВ * TтВВ +
        TтВВ * (y - P) * TтВГ * (y - P) +
        TтВВ * TтВВ * (y - P) * TтВВ +
        TтВВ * TтВВ * TтВВ * (y - P) +
        TтВВ * TтВГ * (y - P) * (y - P) +
        TтВГ * (y - P) * (y - P) * TтВВ +
        TтВГ * (y - P) * TтВВ * (y - P) +
        TтВГ * TтВВ * (y - P) * (y - P) +
        TтВД * (y - P) * (y - P) * (y - P)) =
    -- Group A: 4 (P-TтВВ-TтВГ-TтВД) middle terms (absorbs 4 TтВД-perms)
    (y - P) ^ 3 * (P - TтВВ - TтВГ - TтВД) +
      (y - P) ^ 2 * (P - TтВВ - TтВГ - TтВД) * (y - P) +
      (y - P) * (P - TтВВ - TтВГ - TтВД) * (y - P) ^ 2 +
      (P - TтВВ - TтВГ - TтВД) * (y - P) ^ 3 +
    -- Group B5: 4 terms from `(y┬▓-z┬▓)┬╖P┬▓` split (absorbs items z┬╖TтВВ┬│, TтВВ┬╖z┬╖TтВВ┬▓)
    (y - P) * (P ^ 3 - TтВВ ^ 3) +
    TтВВ * (y - P) * (P ^ 2 - TтВВ ^ 2) +
    (P - TтВВ) * (y - P) * P ^ 2 +
    P ^ 4 +
    -- Group B6: 1 extended term (absorbs z┬▓┬╖TтВВTтВГ, z┬▓┬╖TтВГTтВВ)
    (y - P) ^ 2 * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) +
    -- Group B7: 3 terms from `P┬▓┬╖z┬╖P` split (absorbs TтВВ┬▓┬╖z┬╖TтВВ)
    TтВВ ^ 2 * (y - P) * (P - TтВВ) +
    (P ^ 2 - TтВВ ^ 2) * (y - P) * TтВВ +
    (P ^ 2 - TтВВ ^ 2) * (y - P) * (P - TтВВ) +
    -- Group B8: 2 terms (absorbs z┬╖TтВГ┬╖z┬╖TтВВ)
    (y - P) * (P - TтВВ - TтВГ) * (y - P) * TтВВ +
    (y - P) * (P - TтВВ) * (y - P) * (P - TтВВ) +
    -- Group B9: 1 extended term (absorbs z┬╖TтВВ┬╖z┬╖TтВГ)
    (y - P) * TтВВ * (y - P) * (P - TтВВ - TтВГ) +
    -- Group B10: 2 terms (absorbs TтВГ┬╖z┬▓┬╖TтВВ)
    (P - TтВВ - TтВГ) * (y - P) ^ 2 * TтВВ +
    (P - TтВВ) * (y - P) ^ 2 * (P - TтВВ) +
    -- Group B11: 1 extended term (absorbs TтВВ┬╖z┬▓┬╖TтВГ)
    TтВВ * (y - P) ^ 2 * (P - TтВВ - TтВГ) +
    -- Group B12: 1 extended term `(P┬│-TтВВ┬│)┬╖z` (absorbs TтВВ┬│┬╖z)
    (P ^ 3 - TтВВ ^ 3) * (y - P) +
    -- Group B13: 1 extended term (absorbs z┬╖TтВВTтВГ┬╖z, z┬╖TтВГTтВВ┬╖z)
    (y - P) * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * (y - P) +
    -- Group B14: 2 terms (absorbs TтВГ┬╖z┬╖TтВВ┬╖z)
    (P - TтВВ - TтВГ) * (y - P) * TтВВ * (y - P) +
    (P - TтВВ) * (y - P) * (P - TтВВ) * (y - P) +
    -- Group B15: 1 extended term (absorbs TтВВ┬╖z┬╖TтВГ┬╖z)
    TтВВ * (y - P) * (P - TтВВ - TтВГ) * (y - P) +
    -- Group B16: 1 extended term (absorbs TтВВTтВГ┬╖z┬▓, TтВГTтВВ┬╖z┬▓)
    (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * (y - P) ^ 2 := by
  noncomm_ring

/-- Algebraic decomposition of `yтБ╡ - zтБ╡ - y5_6` where `z = y - P` and
`y5_6 = zтБ┤TтВВ + z┬│TтВВz + z┬▓TтВВz┬▓ + zTтВВz┬│ + TтВВzтБ┤` is the deg-6 contribution
to `yтБ╡ = (z + TтВВ + ...)тБ╡` (the (1,1,1,1,2) perms). Each term is deg-7+
in the BCH context. -/
private theorem y5_sub_z5_sub_y5_6_decomp (y P TтВВ : ЁЭФ╕) :
    y ^ 5 - (y - P) ^ 5 -
      ((y - P) ^ 4 * TтВВ + (y - P) ^ 3 * TтВВ * (y - P) +
        (y - P) ^ 2 * TтВВ * (y - P) ^ 2 + (y - P) * TтВВ * (y - P) ^ 3 +
        TтВВ * (y - P) ^ 4) =
      (y ^ 4 - (y - P) ^ 4) * P + (y - P) ^ 4 * (P - TтВВ) +
      (y ^ 3 - (y - P) ^ 3) * P * (y - P) + (y - P) ^ 3 * (P - TтВВ) * (y - P) +
      (y ^ 2 - (y - P) ^ 2) * P * (y - P) ^ 2 +
        (y - P) ^ 2 * (P - TтВВ) * (y - P) ^ 2 +
      P * P * (y - P) ^ 3 + (y - P) * (P - TтВВ) * (y - P) ^ 3 +
      (P - TтВВ) * (y - P) ^ 4 := by
  noncomm_ring

/-- Algebraic decomposition of `yтБ╡ - zтБ╡ - y5_6 - y5_7` where `z = y - P`.

Extends `y5_sub_z5_sub_y5_6_decomp` by subtracting the deg-7 contribution
`y5_7` (15 terms from compositions `(kтВБ,..,kтВЕ) тКв 7, kс╡в тЙе 1`):
- 5 with TтВГ at one position (`(1,1,1,1,3)` perms)
- 10 with TтВВ at two positions (`(1,1,1,2,2)` perms)

Each `y5_7` item is the deg-7 leading of one of the 9 terms in the septic
decomposition. Absorbing yields 18 deg-8+ terms:
- 5 weight-1 (P-TтВВ-TтВГ) middle terms (absorb 5 TтВГ-perms).
- (yтБ┤-zтБ┤-y4_5)┬╖P + 4 perms of y4_5┬╖(P-TтВВ) (absorb 4 (TтВВ at positions p,5) items).
- (y┬│-z┬│-y3_4)┬╖P┬╖z + 3 perms of y3_4┬╖(P-TтВВ)┬╖z (absorb 3 (TтВВ at positions p,4) items).
- (y┬▓-z┬▓-y2_3)┬╖P┬╖z┬▓ + 2 perms of y2_3┬╖(P-TтВВ)┬╖z┬▓ (absorb 2 (TтВВ at positions p,3) items).
- (P┬▓-TтВВ┬▓)┬╖z┬│ (absorbs TтВВ┬▓┬╖z┬│). -/
private theorem y5_sub_z5_sub_y5_6_sub_y5_7_decomp (y P TтВВ TтВГ : ЁЭФ╕) :
    y ^ 5 - (y - P) ^ 5 -
      ((y - P) ^ 4 * TтВВ + (y - P) ^ 3 * TтВВ * (y - P) +
        (y - P) ^ 2 * TтВВ * (y - P) ^ 2 + (y - P) * TтВВ * (y - P) ^ 3 +
        TтВВ * (y - P) ^ 4) -
      ((y - P) * (y - P) * (y - P) * (y - P) * TтВГ +
        (y - P) * (y - P) * (y - P) * TтВГ * (y - P) +
        (y - P) * (y - P) * TтВГ * (y - P) * (y - P) +
        (y - P) * TтВГ * (y - P) * (y - P) * (y - P) +
        TтВГ * (y - P) * (y - P) * (y - P) * (y - P) +
        (y - P) * (y - P) * (y - P) * TтВВ * TтВВ +
        (y - P) * (y - P) * TтВВ * (y - P) * TтВВ +
        (y - P) * (y - P) * TтВВ * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) * (y - P) * TтВВ +
        (y - P) * TтВВ * (y - P) * TтВВ * (y - P) +
        (y - P) * TтВВ * TтВВ * (y - P) * (y - P) +
        TтВВ * (y - P) * (y - P) * (y - P) * TтВВ +
        TтВВ * (y - P) * (y - P) * TтВВ * (y - P) +
        TтВВ * (y - P) * TтВВ * (y - P) * (y - P) +
        TтВВ * TтВВ * (y - P) * (y - P) * (y - P)) =
    -- 5 (P-TтВВ-TтВГ) middle terms (absorbs 5 TтВГ-perms).
    (y - P) ^ 4 * (P - TтВВ - TтВГ) +
    (y - P) ^ 3 * (P - TтВВ - TтВГ) * (y - P) +
    (y - P) ^ 2 * (P - TтВВ - TтВГ) * (y - P) ^ 2 +
    (y - P) * (P - TтВВ - TтВГ) * (y - P) ^ 3 +
    (P - TтВВ - TтВГ) * (y - P) ^ 4 +
    -- (yтБ┤-zтБ┤-y4_5)┬╖P (1 compound term)
    (y ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * TтВВ + (y - P) ^ 2 * TтВВ * (y - P) +
        (y - P) * TтВВ * (y - P) ^ 2 + TтВВ * (y - P) ^ 3)) * P +
    -- 4 perms of y4_5┬╖(P-TтВВ)
    (y - P) ^ 3 * TтВВ * (P - TтВВ) +
    (y - P) ^ 2 * TтВВ * (y - P) * (P - TтВВ) +
