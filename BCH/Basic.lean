/-- Norm bound `тАЦy┬▓ - z┬▓ - y2_3тАЦ тЙд 11┬╖sтБ┤` where `z = y - P`,
`y2_3 = z┬╖TтВВ + TтВВ┬╖z`. Used in the y5 octic norm bound for the
`(y┬▓-z┬▓-y2_3)┬╖P┬╖z┬▓` compound term. -/
private theorem norm_y2_sub_z2_sub_y2_3_le (y P TтВВ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3) :
    тАЦy ^ 2 - (y - P) ^ 2 - ((y - P) * TтВВ + TтВВ * (y - P))тАЦ тЙд 11 * s ^ 4 := by
  -- y┬▓ - z┬▓ - y2_3 = z┬╖(P-TтВВ) + (P-TтВВ)┬╖z + P┬▓
  have heq : y ^ 2 - (y - P) ^ 2 - ((y - P) * TтВВ + TтВВ * (y - P)) =
      (y - P) * (P - TтВВ) + (P - TтВВ) * (y - P) + P ^ 2 := by noncomm_ring
  rw [heq]
  set z : ЁЭФ╕ := y - P with hz_def
  have hzn : тАЦzтАЦ тЙд s := hz
  have h1 : тАЦz * (P - TтВВ)тАЦ тЙд s * (5 * s ^ 3) :=
    calc _ тЙд тАЦzтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд s * (5 * s ^ 3) := mul_le_mul hzn hPmTтВВ (norm_nonneg _) (by positivity)
  have h2 : тАЦ(P - TтВВ) * zтАЦ тЙд (5 * s ^ 3) * s :=
    calc _ тЙд тАЦP - TтВВтАЦ * тАЦzтАЦ := norm_mul_le _ _
      _ тЙд (5 * s ^ 3) * s := mul_le_mul hPmTтВВ hzn (norm_nonneg _) (by positivity)
  have h3 : тАЦP ^ 2тАЦ тЙд (s ^ 2) ^ 2 :=
    calc _ тЙд тАЦPтАЦ ^ 2 := norm_pow_le P 2
      _ тЙд (s ^ 2) ^ 2 := pow_le_pow_leftтВА (norm_nonneg _) hP 2
  have ht1 := norm_add_le (z * (P - TтВВ) + (P - TтВВ) * z) (P ^ 2)
  have ht2 := norm_add_le (z * (P - TтВВ)) ((P - TтВВ) * z)
  nlinarith [pow_nonneg hs_nn 4]

/-- Norm bound `тАЦy┬│ - z┬│ - y3_4тАЦ тЙд 19┬╖sтБ╡` where `z = y - P`,
`y3_4 = z┬▓┬╖TтВВ + z┬╖TтВВ┬╖z + TтВВ┬╖z┬▓`, for `s тЙд 1`. Used in the y5 octic
norm bound for the `(y┬│-z┬│-y3_4)┬╖P┬╖z` compound term. -/
private theorem norm_y3_sub_z3_sub_y3_4_le (y P TтВВ : ЁЭФ╕) {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_le_one : s тЙд 1)
    (hz : тАЦy - PтАЦ тЙд s) (hP : тАЦPтАЦ тЙд s ^ 2)
    (hPmTтВВ : тАЦP - TтВВтАЦ тЙд 5 * s ^ 3) :
    тАЦy ^ 3 - (y - P) ^ 3 -
      ((y - P) ^ 2 * TтВВ + (y - P) * TтВВ * (y - P) + TтВВ * (y - P) ^ 2)тАЦ тЙд 19 * s ^ 5 := by
  -- y┬│ - z┬│ - y3_4 = (P-TтВВ)┬╖z┬▓ + z┬▓┬╖(P-TтВВ) + z┬╖(P-TтВВ)┬╖z + P┬╖z┬╖P + P┬▓┬╖z + P┬│ + z┬╖P┬▓
  have heq : y ^ 3 - (y - P) ^ 3 -
      ((y - P) ^ 2 * TтВВ + (y - P) * TтВВ * (y - P) + TтВВ * (y - P) ^ 2) =
      (P - TтВВ) * (y - P) ^ 2 + (y - P) ^ 2 * (P - TтВВ) +
        (y - P) * (P - TтВВ) * (y - P) +
