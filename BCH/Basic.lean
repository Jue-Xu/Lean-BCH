/-- Norm bound for the 7-fold telescoping: given `‚Äñy‚Äñ ‚â§ 2s`, `‚Äñz‚Äñ ‚â§ s`,
`‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñy‚Å∑ - z‚Å∑‚Äñ ‚â§ 127¬∑s‚Å∏`. Used in the small-s case of the octic
remainder bound (analog of `norm_pow6_sub_zpow6_le` at one degree higher).

Per-term bounds: `(2s)‚Å∂¬∑s¬≤ + (2s)‚Åµ¬∑s¬≤¬∑s + (2s)‚Å¥¬∑s¬≤¬∑s¬≤ + (2s)¬≥¬∑s¬≤¬∑s¬≥ +
                 (2s)¬≤¬∑s¬≤¬∑s‚Å¥ + (2s)¬∑s¬≤¬∑s‚Åµ + s¬≤¬∑s‚Å∂
                = 64s‚Å∏ + 32s‚Å∏ + 16s‚Å∏ + 8s‚Å∏ + 4s‚Å∏ + 2s‚Å∏ + s‚Å∏ = 127s‚Å∏`. -/
private theorem norm_pow7_sub_zpow7_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 7 - (y - P) ^ 7‚Äñ ‚â§ 127 * s ^ 8 := by
  rw [pow7_sub_zpow7_telescope]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  -- Seven terms, bounded individually.
  have h_y6P : ‚Äñy ^ 6 * P‚Äñ ‚â§ (2 * s) ^ 6 * s ^ 2 :=
    calc ‚Äñy ^ 6 * P‚Äñ ‚â§ ‚Äñy ^ 6‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñy‚Äñ ^ 6 * ‚ÄñP‚Äñ := by gcongr; exact norm_pow_le y 6
      _ ‚â§ (2 * s) ^ 6 * s ^ 2 :=
          mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 6) hP (by positivity) (by positivity)
  have h_y5Pz : ‚Äñy ^ 5 * P * z‚Äñ ‚â§ (2 * s) ^ 5 * s ^ 2 * s :=
    calc ‚Äñy ^ 5 * P * z‚Äñ ‚â§ ‚Äñy ^ 5 * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 5 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by
          gcongr
          calc _ ‚â§ ‚Äñy ^ 5‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
            _ ‚â§ _ := by gcongr; exact norm_pow_le y 5
      _ ‚â§ ((2 * s) ^ 5 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 5) hP
            (norm_nonneg _) (by positivity)
  have h_y4Pz2 : ‚Äñy ^ 4 * P * z ^ 2‚Äñ ‚â§ (2 * s) ^ 4 * s ^ 2 * s ^ 2 :=
    calc ‚Äñy ^ 4 * P * z ^ 2‚Äñ ‚â§ ‚Äñy ^ 4 * P‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 4 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 4‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 4
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ ((2 * s) ^ 4 * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 4) hP
            (norm_nonneg _) (by positivity)
  have h_y3Pz3 : ‚Äñy ^ 3 * P * z ^ 3‚Äñ ‚â§ (2 * s) ^ 3 * s ^ 2 * s ^ 3 :=
    calc ‚Äñy ^ 3 * P * z ^ 3‚Äñ ‚â§ ‚Äñy ^ 3 * P‚Äñ * ‚Äñz ^ 3‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 3 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 3 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 3‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 3
          ¬∑ exact norm_pow_le z 3
      _ ‚â§ ((2 * s) ^ 3 * s ^ 2) * s ^ 3 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 3) hP
            (norm_nonneg _) (by positivity)
  have h_y2Pz4 : ‚Äñy ^ 2 * P * z ^ 4‚Äñ ‚â§ (2 * s) ^ 2 * s ^ 2 * s ^ 4 :=
    calc ‚Äñy ^ 2 * P * z ^ 4‚Äñ ‚â§ ‚Äñy ^ 2 * P‚Äñ * ‚Äñz ^ 4‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 2 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 4 := by
          gcongr
          ¬∑ calc _ ‚â§ ‚Äñy ^ 2‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
              _ ‚â§ _ := by gcongr; exact norm_pow_le y 2
          ¬∑ exact norm_pow_le z 4
      _ ‚â§ ((2 * s) ^ 2 * s ^ 2) * s ^ 4 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 4)
            (by positivity) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz5 : ‚Äñy * P * z ^ 5‚Äñ ‚â§ 2 * s * s ^ 2 * s ^ 5 :=
    calc ‚Äñy * P * z ^ 5‚Äñ ‚â§ ‚Äñy * P‚Äñ * ‚Äñz ^ 5‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 5 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 5
      _ ‚â§ (2 * s * s ^ 2) * s ^ 5 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 5)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz6 : ‚ÄñP * z ^ 6‚Äñ ‚â§ s ^ 2 * s ^ 6 :=
    calc ‚ÄñP * z ^ 6‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñz ^ 6‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ * ‚Äñz‚Äñ ^ 6 := by gcongr; exact norm_pow_le z 6
      _ ‚â§ s ^ 2 * s ^ 6 := mul_le_mul hP (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 6)
          (by positivity) (by positivity)
  -- Sum via triangle inequality (6 norm_add_le applications)
  have ht1 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3 +
      y ^ 2 * P * z ^ 4 + y * P * z ^ 5) (P * z ^ 6)
  have ht2 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3 +
      y ^ 2 * P * z ^ 4) (y * P * z ^ 5)
  have ht3 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2 + y ^ 3 * P * z ^ 3)
    (y ^ 2 * P * z ^ 4)
  have ht4 := norm_add_le
    (y ^ 6 * P + y ^ 5 * P * z + y ^ 4 * P * z ^ 2) (y ^ 3 * P * z ^ 3)
  have ht5 := norm_add_le (y ^ 6 * P + y ^ 5 * P * z) (y ^ 4 * P * z ^ 2)
  have ht6 := norm_add_le (y ^ 6 * P) (y ^ 5 * P * z)
  nlinarith [pow_nonneg hs_nn 8]

/-- Norm bound for `y¬≤ - z¬≤` (2-fold telescoping) where `z = y - P`,
given `‚Äñy‚Äñ ‚â§ 2s`, `‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñz‚Äñ ‚â§ s`. -/
private theorem norm_pow2_sub_zpow2_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 2 - (y - P) ^ 2‚Äñ ‚â§ 3 * s ^ 3 := by
  have hY2_eq : y ^ 2 - (y - P) ^ 2 = y * P + P * (y - P) := by noncomm_ring
  rw [hY2_eq]
  have h_yP : ‚Äñy * P‚Äñ ‚â§ 2 * s * s ^ 2 :=
    calc ‚Äñy * P‚Äñ ‚â§ ‚Äñy‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ 2 * s * s ^ 2 := mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz : ‚ÄñP * (y - P)‚Äñ ‚â§ s ^ 2 * s :=
    calc ‚ÄñP * (y - P)‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñy - P‚Äñ := norm_mul_le _ _
      _ ‚â§ s ^ 2 * s := mul_le_mul hP hz (norm_nonneg _) (by positivity)
  calc ‚Äñy * P + P * (y - P)‚Äñ ‚â§ ‚Äñy * P‚Äñ + ‚ÄñP * (y - P)‚Äñ := norm_add_le _ _
    _ ‚â§ 2 * s * s ^ 2 + s ^ 2 * s := by linarith
    _ = 3 * s ^ 3 := by ring

/-- Norm bound for `y¬≥ - z¬≥` (3-fold telescoping). -/
private theorem norm_pow3_sub_zpow3_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 3 - (y - P) ^ 3‚Äñ ‚â§ 7 * s ^ 4 := by
  rw [pow3_sub_zpow3_telescope]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  have h_y2P : ‚Äñy ^ 2 * P‚Äñ ‚â§ (2 * s) ^ 2 * s ^ 2 :=
    calc ‚Äñy ^ 2 * P‚Äñ ‚â§ ‚Äñy ^ 2‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñy‚Äñ ^ 2 * ‚ÄñP‚Äñ := by gcongr; exact norm_pow_le y 2
      _ ‚â§ (2 * s) ^ 2 * s ^ 2 :=
          mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 2) hP
            (by positivity) (by positivity)
  have h_yPz : ‚Äñy * P * z‚Äñ ‚â§ 2 * s * s ^ 2 * s :=
    calc ‚Äñy * P * z‚Äñ ‚â§ ‚Äñy * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (2 * s * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz2 : ‚ÄñP * z ^ 2‚Äñ ‚â§ s ^ 2 * s ^ 2 :=
    calc ‚ÄñP * z ^ 2‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ * ‚Äñz‚Äñ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ ‚â§ s ^ 2 * s ^ 2 := mul_le_mul hP (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
          (by positivity) (by positivity)
  have ht1 := norm_add_le (y ^ 2 * P + y * P * z) (P * z ^ 2)
  have ht2 := norm_add_le (y ^ 2 * P) (y * P * z)
  nlinarith

/-- Norm bound for `y‚Å¥ - z‚Å¥` (4-fold telescoping) where `z = y - P`,
given `‚Äñy‚Äñ ‚â§ 2s`, `‚ÄñP‚Äñ ‚â§ s¬≤`, `‚Äñz‚Äñ ‚â§ s`. Bounds: `(2s)¬≥¬∑s¬≤ + (2s)¬≤¬∑s¬≤¬∑s +
(2s)¬∑s¬≤¬∑s¬≤ + s¬≤¬∑s¬≥ = 8s‚Åµ + 4s‚Åµ + 2s‚Åµ + s‚Åµ = 15s‚Åµ`. -/
private theorem norm_pow4_sub_zpow4_le (y P : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2) :
    ‚Äñy ^ 4 - (y - P) ^ 4‚Äñ ‚â§ 15 * s ^ 5 := by
  rw [pow4_sub_zpow4_telescope]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  have h_y3P : ‚Äñy ^ 3 * P‚Äñ ‚â§ (2 * s) ^ 3 * s ^ 2 :=
    calc ‚Äñy ^ 3 * P‚Äñ ‚â§ ‚Äñy ^ 3‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñy‚Äñ ^ 3 * ‚ÄñP‚Äñ := by gcongr; exact norm_pow_le y 3
      _ ‚â§ (2 * s) ^ 3 * s ^ 2 :=
          mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 3) hP (by positivity) (by positivity)
  have h_y2Pz : ‚Äñy ^ 2 * P * z‚Äñ ‚â§ (2 * s) ^ 2 * s ^ 2 * s :=
    calc ‚Äñy ^ 2 * P * z‚Äñ ‚â§ ‚Äñy ^ 2 * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ ^ 2 * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by
          gcongr
          calc _ ‚â§ ‚Äñy ^ 2‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
            _ ‚â§ _ := by gcongr; exact norm_pow_le y 2
      _ ‚â§ ((2 * s) ^ 2 * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy 2) hP
            (norm_nonneg _) (by positivity)
  have h_yPz2 : ‚Äñy * P * z ^ 2‚Äñ ‚â§ 2 * s * s ^ 2 * s ^ 2 :=
    calc ‚Äñy * P * z ^ 2‚Äñ ‚â§ ‚Äñy * P‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ (2 * s * s ^ 2) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hy hP (norm_nonneg _) (by positivity)
  have h_Pz3 : ‚ÄñP * z ^ 3‚Äñ ‚â§ s ^ 2 * s ^ 3 :=
    calc ‚ÄñP * z ^ 3‚Äñ ‚â§ ‚ÄñP‚Äñ * ‚Äñz ^ 3‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP‚Äñ * ‚Äñz‚Äñ ^ 3 := by gcongr; exact norm_pow_le z 3
      _ ‚â§ s ^ 2 * s ^ 3 := mul_le_mul hP (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3)
          (by positivity) (by positivity)
  have ht1 := norm_add_le (y ^ 3 * P + y ^ 2 * P * z + y * P * z ^ 2) (P * z ^ 3)
  have ht2 := norm_add_le (y ^ 3 * P + y ^ 2 * P * z) (y * P * z ^ 2)
  have ht3 := norm_add_le (y ^ 3 * P) (y ^ 2 * P * z)
  nlinarith [pow_nonneg hs_nn 5]

/-- Norm bound for `y‚Å¥ - z‚Å¥ - y4_5` where `y4_5 = z¬≥T‚ÇÇ + z¬≤T‚ÇÇz + zT‚ÇÇz¬≤ + T‚ÇÇz¬≥`,
given the BCH-context norm bounds. The bound is `31¬∑s‚Å∂`. -/
private theorem norm_y4_sub_z4_sub_y4_5_le (y P T‚ÇÇ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hy : ‚Äñy‚Äñ ‚â§ 2 * s) (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2)
    (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) :
    ‚Äñy ^ 4 - (y - P) ^ 4 -
      ((y - P) ^ 3 * T‚ÇÇ + (y - P) ^ 2 * T‚ÇÇ * (y - P) +
        (y - P) * T‚ÇÇ * (y - P) ^ 2 + T‚ÇÇ * (y - P) ^ 3)‚Äñ ‚â§ 31 * s ^ 6 := by
  rw [y4_sub_z4_sub_y4_5_decomp]
  set z : ùî∏ := y - P with hz_def
  have hzn : ‚Äñz‚Äñ ‚â§ s := hz
  -- 7 terms to bound
  -- (y-P)^3 (P-T‚ÇÇ) etc.: ‚â§ s^3 * 5s^3 = 5s^6, four of these = 20s^6
  have h_z3PT : ‚Äñz ^ 3 * (P - T‚ÇÇ)‚Äñ ‚â§ s ^ 3 * (5 * s ^ 3) :=
    calc ‚Äñz ^ 3 * (P - T‚ÇÇ)‚Äñ ‚â§ ‚Äñz ^ 3‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚Äñz‚Äñ ^ 3 * ‚ÄñP - T‚ÇÇ‚Äñ := by gcongr; exact norm_pow_le z 3
      _ ‚â§ s ^ 3 * (5 * s ^ 3) := mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3)
          hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have h_z2PTz : ‚Äñz ^ 2 * (P - T‚ÇÇ) * z‚Äñ ‚â§ s ^ 2 * (5 * s ^ 3) * s :=
    calc _ ‚â§ ‚Äñz ^ 2 * (P - T‚ÇÇ)‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñz‚Äñ ^ 2 * ‚ÄñP - T‚ÇÇ‚Äñ) * ‚Äñz‚Äñ := by
          gcongr
          calc _ ‚â§ ‚Äñz ^ 2‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
            _ ‚â§ _ := by gcongr; exact norm_pow_le z 2
      _ ‚â§ (s ^ 2 * (5 * s ^ 3)) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2) hPmT‚ÇÇ
            (norm_nonneg _) (by positivity)
  have h_zPTz2 : ‚Äñz * (P - T‚ÇÇ) * z ^ 2‚Äñ ‚â§ s * (5 * s ^ 3) * s ^ 2 :=
    calc _ ‚â§ ‚Äñz * (P - T‚ÇÇ)‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñz‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ (s * (5 * s ^ 3)) * s ^ 2 := by
          apply mul_le_mul _ (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 2)
            (by positivity) (by positivity)
          exact mul_le_mul hzn hPmT‚ÇÇ (norm_nonneg _) (by positivity)
  have h_PTz3 : ‚Äñ(P - T‚ÇÇ) * z ^ 3‚Äñ ‚â§ (5 * s ^ 3) * s ^ 3 :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz ^ 3‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz‚Äñ ^ 3 := by gcongr; exact norm_pow_le z 3
      _ ‚â§ (5 * s ^ 3) * s ^ 3 := mul_le_mul hPmT‚ÇÇ
          (pow_le_pow_left‚ÇÄ (norm_nonneg _) hzn 3) (by positivity) (by positivity)
  -- (y¬≥ - z¬≥) P term
  have hy3z3 := norm_pow3_sub_zpow3_le y P hs_nn hy hz hP
  have h_y3z3P : ‚Äñ(y ^ 3 - z ^ 3) * P‚Äñ ‚â§ (7 * s ^ 4) * s ^ 2 :=
    calc _ ‚â§ ‚Äñy ^ 3 - z ^ 3‚Äñ * ‚ÄñP‚Äñ := norm_mul_le _ _
      _ ‚â§ (7 * s ^ 4) * s ^ 2 :=
          mul_le_mul hy3z3 hP (norm_nonneg _) (by positivity)
  -- (y¬≤ - z¬≤) P z term
  have hy2z2 := norm_pow2_sub_zpow2_le y P hs_nn hy hz hP
  have h_y2z2Pz : ‚Äñ(y ^ 2 - z ^ 2) * P * z‚Äñ ‚â§ (3 * s ^ 3) * s ^ 2 * s :=
    calc _ ‚â§ ‚Äñ(y ^ 2 - z ^ 2) * P‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚Äñy ^ 2 - z ^ 2‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((3 * s ^ 3) * s ^ 2) * s := by
          apply mul_le_mul _ hzn (norm_nonneg _) (by positivity)
          exact mul_le_mul hy2z2 hP (norm_nonneg _) (by positivity)
  -- P ¬∑ P ¬∑ z¬≤ term (note: P*P*z¬≤ in the decomp formula)
  have h_PPz2 : ‚ÄñP * P * z ^ 2‚Äñ ‚â§ s ^ 2 * s ^ 2 * s ^ 2 :=
    calc _ ‚â§ ‚ÄñP * P‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP‚Äñ * ‚ÄñP‚Äñ) * ‚Äñz‚Äñ ^ 2 := by
          gcongr
          ¬∑ exact norm_mul_le _ _
          ¬∑ exact norm_pow_le z 2
      _ ‚â§ (s ^ 2 * s ^ 2) * s ^ 2 := by
