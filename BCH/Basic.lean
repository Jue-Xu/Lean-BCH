/-- **Homogeneity of bch_quintic_term**: ZтВЕ(c┬╖a, c┬╖b) = cтБ╡┬╖ZтВЕ(a,b). -/
theorem bch_quintic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_quintic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 5 тАв bch_quintic_term ЁЭХВ a b := by
