  have h2 : ‚Äñx * y * (z - x) * y * z‚Äñ ‚â§ M ^ 4 * d := by
    calc _ ‚â§ ‚Äñx‚Äñ * ‚Äñy‚Äñ * ‚Äñz - x‚Äñ * ‚Äñy‚Äñ * ‚Äñz‚Äñ := norm_5prod_le _ _ _ _ _
      _ ‚â§ M * M * d * M * M := by gcongr
      _ = M ^ 4 * d := by ring
  have h3 : ‚Äñx * y * x * y * (z - x)‚Äñ ‚â§ M ^ 4 * d := by
    calc _ ‚â§ ‚Äñx‚Äñ * ‚Äñy‚Äñ * ‚Äñx‚Äñ * ‚Äñy‚Äñ * ‚Äñz - x‚Äñ := norm_5prod_le _ _ _ _ _
      _ ‚â§ M * M * M * M * d := by gcongr
