            rw [sub_eq_add_neg]
            exact (norm_add_le _ _).trans (by rw [norm_neg])
        _ тЙд ╬▓ * ╬▒ + ╬▒ * ╬▓ := by gcongr <;> exact norm_mul_le _ _
        _ = 2 * ╬▒ * ╬▓ := by ring
    calc тАЦb * (b * a - a * b) - (b * a - a * b) * bтАЦ
        тЙд тАЦb * (b * a - a * b)тАЦ + тАЦ(b * a - a * b) * bтАЦ := by
          rw [sub_eq_add_neg]
          exact (norm_add_le _ _).trans (by rw [norm_neg])
      _ тЙд ╬▓ * (2 * ╬▒ * ╬▓) + (2 * ╬▒ * ╬▓) * ╬▓ := by
          gcongr
          ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_left hba_le h╬▓_nn)
          ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hba_le h╬▓_nn)
      _ = 4 * ╬▒ * ╬▓ ^ 2 := by ring
  -- Bound each scaled commutator
  have h1 : тАЦ(24 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a)тАЦ тЙд ╬▒ ^ 2 * ╬▓ := by
    calc _ тЙд тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦ_тАЦ := norm_smul_le _ _
      _ тЙд (1 / 24 : тДЭ) * (4 * ╬▒ ^ 2 * ╬▓) := by
          have : тАЦ(24 : ЁЭХВ)тБ╗┬╣тАЦ = (1 / 24 : тДЭ) := by
            rw [norm_inv, RCLike.norm_ofNat]; norm_num
          rw [this]; gcongr
      _ тЙд ╬▒ ^ 2 * ╬▓ := by nlinarith [sq_nonneg ╬▒, h╬▓_nn]
  have h2 : тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв (b * (b * a - a * b) - (b * a - a * b) * b)тАЦ тЙд ╬▒ * ╬▓ ^ 2 := by
    calc _ тЙд тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦ_тАЦ := norm_smul_le _ _
      _ тЙд (1 / 12 : тДЭ) * (4 * ╬▒ * ╬▓ ^ 2) := by
          have : тАЦ(12 : ЁЭХВ)тБ╗┬╣тАЦ = (1 / 12 : тДЭ) := by
            rw [norm_inv, RCLike.norm_ofNat]; norm_num
          rw [this]; gcongr
      _ тЙд ╬▒ * ╬▓ ^ 2 := by nlinarith [sq_nonneg ╬▓, h╬▒_nn]
  -- Combine via triangle inequality
  set X : ЁЭФ╕ := a * (a * b - b * a) - (a * b - b * a) * a
  set Y : ЁЭФ╕ := b * (b * a - a * b) - (b * a - a * b) * b
  calc тАЦ-((24 : ЁЭХВ)тБ╗┬╣ тАв X) + (12 : ЁЭХВ)тБ╗┬╣ тАв YтАЦ
      тЙд тАЦ-((24 : ЁЭХВ)тБ╗┬╣ тАв X)тАЦ + тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв YтАЦ := norm_add_le _ _
    _ = тАЦ(24 : ЁЭХВ)тБ╗┬╣ тАв XтАЦ + тАЦ(12 : ЁЭХВ)тБ╗┬╣ тАв YтАЦ := by rw [norm_neg]
    _ тЙд ╬▒ ^ 2 * ╬▓ + ╬▒ * ╬▓ ^ 2 := by linarith
    _ тЙд (╬▒ + ╬▓) ^ 3 := by nlinarith [sq_nonneg (╬▒ - ╬▓), h╬▒_nn, h╬▓_nn, sq_nonneg ╬▒, sq_nonneg ╬▓]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **sym_EтВГ alt-form identity**: the closed-form `symmetric_bch_cubic_poly` equals
the alt form `CтВГ(┬╜a,b) + CтВГ(┬╜a+b,┬╜a) - (1/16)┬╖DC_a`, where `DC_a = a┬╖[a,b] - [a,b]┬╖a`.

This is the key step relating the explicit polynomial definition to the form that
arises from applying `norm_bch_quintic_remainder_le` twice through the symmetric
composition. Verified by multiplying both sides by 48, clearing scalars, and
`noncomm_ring`. -/
theorem symmetric_bch_cubic_poly_alt_form (a b : ЁЭФ╕) :
    symmetric_bch_cubic_poly ЁЭХВ a b =
      bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b +
      bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a + b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) -
      (16 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a) := by
  unfold symmetric_bch_cubic_poly bch_cubic_term
  simp only [smul_sub, smul_add, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul]
  match_scalars <;> ring

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Key quartic cancellation for symmetric BCH**: the four degree-4 contributions to
`sym_bch_cubic - sym_EтВГ` sum to zero as a ring identity.

Specifically, writing `a' = ┬╜a`, the four contributions are:
- A := ┬╜[CтВГ(a',b), a']  (from the half-commutator ┬╜[w, a'] expansion, w = z-(a'+b))
- B := CтВД(a',b)         (the inner BCH quartic)
- C := -(1/96)┬╖[b, DC_a]  (the linear-in-wтВВ part of [CтВГ(z,a') - CтВГ(a'+b,a')],
                           where wтВВ = ┬╜(a'b-ba'); equals (1/12)┬╖([(a'+b),[wтВВ,a']] +
                           [wтВВ,[(a'+b),a']] + [a',[a',wтВВ]]) тАФ verified algebraically)
- D := CтВД(a'+b, a')     (the constant part of CтВД(z, a'))

The identity `A + B + C + D = 0` holds because, after expansion:
- A + D contributes `(1/48)┬╖[DC_b, a]` (the [DC_a,a] terms cancel between A and D).
- B + C contributes `-(1/48)┬╖[b, DC_a]`.
- And `[DC_b, a] = [b, DC_a]` is itself an associative-algebra identity (both expand
  to `b┬▓a┬▓ - 2baba + 2abab - a┬▓b┬▓`). -/
theorem symmetric_bch_quartic_identity (a b : ЁЭФ╕) :
    (2 : ЁЭХВ)тБ╗┬╣ тАв (bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b * ((2 : ЁЭХВ)тБ╗┬╣ тАв a) -
                  ((2 : ЁЭХВ)тБ╗┬╣ тАв a) * bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b) +
      bch_quartic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b +
      -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * (a * (a * b - b * a) - (a * b - b * a) * a) -
                       (a * (a * b - b * a) - (a * b - b * a) * a) * b)) +
      bch_quartic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a + b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) = 0 := by
  unfold bch_cubic_term bch_quartic_term
  simp only [smul_sub, smul_add, smul_neg, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul, тЖР mul_assoc]
  match_scalars <;> ring

set_option maxHeartbeats 16000000 in
include ЁЭХВ in
/-- **Symmetric BCH quintic remainder bound**: the symmetric BCH deviation equals the
cubic polynomial `symmetric_bch_cubic_poly` up to `O(sтБ╡)` error. This is the symmetric
analog of `norm_bch_quintic_remainder_le`, obtained by applying the quintic BCH theorem
twice through the composition `bch(bch(┬╜a, b), ┬╜a)` and collecting cubic contributions.

The constant `10тБ╖` is loose: the dominant contribution comes from the outer-BCH
quintic remainder RтВВ at norm `sтВВ = тАЦzтАЦ+тАЦa'тАЦ тЙд 57s/22`, giving RтВВ тЙд ~4┬╖10тБ╢┬╖sтБ╡.
A tighter form `K┬╖sтБ╡/(2-exp(2s))` would reduce it (analogous to
`norm_bch_quintic_remainder_le`), but the simpler `K┬╖sтБ╡` form suffices for
the Suzuki use case. -/
theorem norm_symmetric_bch_cubic_sub_poly_le (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < 1 / 4) :
    тАЦsymmetric_bch_cubic ЁЭХВ a b - symmetric_bch_cubic_poly ЁЭХВ a bтАЦ тЙд
      10000000 * (тАЦaтАЦ + тАЦbтАЦ) ^ 5 := by
  -- SETUP: a' = ┬╜a, s = тАЦaтАЦ+тАЦbтАЦ, sтВБ = тАЦa'тАЦ+тАЦbтАЦ тЙд s, z = bch(a', b)
  set a' : ЁЭФ╕ := (2 : ЁЭХВ)тБ╗┬╣ тАв a with ha'_def
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  set sтВБ := тАЦa'тАЦ + тАЦbтАЦ with hsтВБ_def
  have h_half_norm : тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ = (2 : тДЭ)тБ╗┬╣ := by rw [norm_inv, RCLike.norm_ofNat]
  have ha'_le : тАЦa'тАЦ тЙд тАЦaтАЦ / 2 := by
    calc тАЦa'тАЦ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦaтАЦ := norm_smul_le _ _
      _ = тАЦaтАЦ / 2 := by rw [h_half_norm]; ring
  have ha'_le_s : тАЦa'тАЦ тЙд s := by
    calc тАЦa'тАЦ тЙд тАЦaтАЦ / 2 := ha'_le
      _ тЙд тАЦaтАЦ := by linarith [norm_nonneg a]
      _ тЙд s := le_add_of_nonneg_right (norm_nonneg b)
  have hs_nn : 0 тЙд s := by positivity
  have hs_lt : s < 1 / 4 := hab
  have hs1 : s < 1 := by linarith
  have hsтВБ_le : sтВБ тЙд s := by
    show тАЦa'тАЦ + тАЦbтАЦ тЙд тАЦaтАЦ + тАЦbтАЦ; linarith [ha'_le, norm_nonneg a]
  have hsтВБ_nn : 0 тЙд sтВБ := by positivity
  have hln2 : (1 : тДЭ) / 4 < Real.log 2 := by
    rw [Real.lt_log_iff_exp_lt (by norm_num : (0:тДЭ) < 2)]
    linarith [real_exp_third_order_le_cube (by norm_num : (0:тДЭ) тЙд 1/4)
      (by norm_num : (1:тДЭ)/4 < 5/6)]
  have hsтВБ_lt_log2 : sтВБ < Real.log 2 := by linarith
  -- Inner BCH: z = bch(a', b)
  set z := bch (ЁЭХВ := ЁЭХВ) a' b with hz_def
  -- Quintic remainder of inner BCH: RтВБ = z - (a'+b) - ┬╜(a'b-ba') - CтВГ(a',b) - CтВД(a',b)
  set RтВБ := z - (a' + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') -
      bch_cubic_term ЁЭХВ a' b - bch_quartic_term ЁЭХВ a' b with hRтВБ_def
  -- Bound: тАЦRтВБтАЦ тЙд 3000┬╖sтВБтБ╡/(2-exp(sтВБ))
  have hRтВБ_le : тАЦRтВБтАЦ тЙд 3000 * sтВБ ^ 5 / (2 - Real.exp sтВБ) := by
    rw [hRтВБ_def]
    exact norm_bch_quintic_remainder_le (ЁЭХВ := ЁЭХВ) a' b hsтВБ_lt_log2
  -- Quadratic bound: тАЦz - (a'+b)тАЦ тЙд 3┬╖sтВБ┬▓/(2-exp(sтВБ))
  have hexp_sтВБ_lt : Real.exp sтВБ < 2 := by
    calc _ < Real.exp (Real.log 2) := Real.exp_strictMono hsтВБ_lt_log2
      _ = 2 := Real.exp_log (by norm_num)
  have hdenomтВБ : 0 < 2 - Real.exp sтВБ := by linarith
  set W := z - (a' + b) with hW_def
  have hW_le : тАЦWтАЦ тЙд 3 * sтВБ ^ 2 / (2 - Real.exp sтВБ) := by
    rw [hW_def]; exact norm_bch_sub_add_le (ЁЭХВ := ЁЭХВ) a' b hsтВБ_lt_log2
  -- sтВВ = тАЦzтАЦ + тАЦa'тАЦ < log 2 (for the second quintic application)
  have hexp_le : Real.exp sтВБ тЙд 1 + sтВБ + sтВБ ^ 2 := by
    nlinarith [real_exp_third_order_le_cube hsтВБ_nn (by linarith : sтВБ < 5/6)]
  have hdenom_lb : (11 : тДЭ) / 16 тЙд 2 - Real.exp sтВБ := by nlinarith
  have hquad_bound : 3 * sтВБ ^ 2 / (2 - Real.exp sтВБ) тЙд 3 / 11 := by
    rw [div_le_div_iffтВА hdenomтВБ (by norm_num : (0:тДЭ) < 11)]
    nlinarith [sq_nonneg sтВБ, sq_nonneg (1/4 - sтВБ)]
  have hz_le : тАЦzтАЦ тЙд sтВБ + 3 * sтВБ ^ 2 / (2 - Real.exp sтВБ) := by
    calc тАЦzтАЦ = тАЦ(z - (a' + b)) + (a' + b)тАЦ := by congr 1; abel
      _ тЙд тАЦz - (a' + b)тАЦ + тАЦa' + bтАЦ := norm_add_le _ _
      _ тЙд 3 * sтВБ ^ 2 / (2 - Real.exp sтВБ) + sтВБ := by
          have hsum : тАЦa' + bтАЦ тЙд sтВБ := norm_add_le _ _
          linarith [hW_le, hW_def]
      _ = sтВБ + 3 * sтВБ ^ 2 / (2 - Real.exp sтВБ) := by ring
  have hln2_611 : (6 : тДЭ) / 11 < Real.log 2 := by
    rw [Real.lt_log_iff_exp_lt (by norm_num : (0:тДЭ) < 2)]
    linarith [real_exp_third_order_le_cube (by norm_num : (0:тДЭ) тЙд 6/11)
      (by norm_num : (6:тДЭ)/11 < 5/6)]
  have hsтВВ_lt_log2 : тАЦzтАЦ + тАЦa'тАЦ < Real.log 2 := by
    calc тАЦzтАЦ + тАЦa'тАЦ тЙд (sтВБ + 3 / 11) + тАЦa'тАЦ := by linarith [hz_le, hquad_bound]
      _ тЙд s + 3 / 11 := by linarith [ha'_le_s]
      _ < 1/4 + 3 / 11 := by linarith
      _ = 23 / 44 := by norm_num
      _ < 6 / 11 := by norm_num
      _ < Real.log 2 := hln2_611
  -- Outer quintic remainder: RтВВ = bch(z,a') - (z+a') - ┬╜(z┬╖a'-a'┬╖z) - CтВГ(z,a') - CтВД(z,a')
  set RтВВ := bch (ЁЭХВ := ЁЭХВ) z a' - (z + a') - (2 : ЁЭХВ)тБ╗┬╣ тАв (z * a' - a' * z) -
      bch_cubic_term ЁЭХВ z a' - bch_quartic_term ЁЭХВ z a' with hRтВВ_def
  have hRтВВ_le : тАЦRтВВтАЦ тЙд 3000 * (тАЦzтАЦ + тАЦa'тАЦ) ^ 5 / (2 - Real.exp (тАЦzтАЦ + тАЦa'тАЦ)) := by
    rw [hRтВВ_def]
    exact norm_bch_quintic_remainder_le (ЁЭХВ := ЁЭХВ) z a' hsтВВ_lt_log2
  -- Key commutator helper: ┬╝[(a'b - ba'), a'] = -(1/16)┬╖DC_a
  set DC_a : ЁЭФ╕ := a * (a * b - b * a) - (a * b - b * a) * a with hDC_a_def
  -- KEY DECOMPOSITION: sym_bch_cubic - sym_EтВГ as a sum of 6 terms.
  -- 1. RтВБ + RтВВ  (each O(sтБ╡) by quintic BCH)
  -- 2. ┬╜[RтВБ, a']     (O(s┬╖sтБ╡) = O(sтБ╢) тЙд O(sтБ╡))
  -- 3. ┬╜[CтВД(a',b), a']     (O(sтБ┤┬╖s) = O(sтБ╡))
  -- 4. quartic_identity_sum = 0 (by symmetric_bch_quartic_identity)
  -- 5. CтВГ(z,a') - CтВГ(a'+b, a') - C_d4  (O(sтБ╡) residual after subtracting
  --    the degree-4 part; the degree-4 part is C_d4 = -(1/96)┬╖[b, DC_a])
  -- 6. CтВД(z,a') - CтВД(a'+b, a')  (O(sтБ╡) residual after degree-4)
  --
  -- The algebraic decomposition (provable by `abel` after unfolding RтВБ, RтВВ and
  -- the sym_EтВГ тЖТ alt form rewrite, plus the quartic identity for degree-4 cancel):
  have hdecomp : symmetric_bch_cubic ЁЭХВ a b - symmetric_bch_cubic_poly ЁЭХВ a b =
      RтВБ + RтВВ +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (RтВБ * a' - a' * RтВБ) +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (bch_quartic_term ЁЭХВ a' b * a' - a' * bch_quartic_term ЁЭХВ a' b) +
      (bch_cubic_term ЁЭХВ z a' - bch_cubic_term ЁЭХВ (a' + b) a' -
        -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b))) +
      (bch_quartic_term ЁЭХВ z a' - bch_quartic_term ЁЭХВ (a' + b) a') := by
    rw [symmetric_bch_cubic_poly_alt_form (ЁЭХВ := ЁЭХВ)]
    have hbch_z_a' : bch (ЁЭХВ := ЁЭХВ) z a' = (z + a') + (2 : ЁЭХВ)тБ╗┬╣ тАв (z * a' - a' * z) +
        bch_cubic_term ЁЭХВ z a' + bch_quartic_term ЁЭХВ z a' + RтВВ := by
      rw [hRтВВ_def]; abel
    have hzcom : z * a' - a' * z = (a' + b) * a' - a' * (a' + b) +
        ((z - (a' + b)) * a' - a' * (z - (a' + b))) := by noncomm_ring
    have hW_eq : z - (a' + b) =
        (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') + bch_cubic_term ЁЭХВ a' b +
          bch_quartic_term ЁЭХВ a' b + RтВБ := by
      rw [hRтВБ_def, hW_def]; abel
    have hz_eq : z = a' + b + (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') + bch_cubic_term ЁЭХВ a' b +
        bch_quartic_term ЁЭХВ a' b + RтВБ := by
      rw [show z = (z - (a' + b)) + (a' + b) from by abel, hW_eq]; abel
    have hQI := symmetric_bch_quartic_identity (ЁЭХВ := ЁЭХВ) a b
    show bch (ЁЭХВ := ЁЭХВ) (bch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) - (a + b) -
        (bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b +
         bch_cubic_term ЁЭХВ ((2 : ЁЭХВ)тБ╗┬╣ тАв a + b) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) -
         (16 : ЁЭХВ)тБ╗┬╣ тАв (a * (a * b - b * a) - (a * b - b * a) * a)) = _
    have hbch_inner : bch (ЁЭХВ := ЁЭХВ) ((2 : ЁЭХВ)тБ╗┬╣ тАв a) b = z := by rw [hz_def, ha'_def]
    rw [hbch_inner, hbch_z_a', hzcom, hW_eq]
    have hQI_rearr : bch_quartic_term ЁЭХВ (a' + b) a' =
        -((2 : ЁЭХВ)тБ╗┬╣ тАв (bch_cubic_term ЁЭХВ a' b * a' - a' * bch_cubic_term ЁЭХВ a' b)) -
        bch_quartic_term ЁЭХВ a' b +
        (96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b) := by
      have h := hQI
      have h' : ((2 : ЁЭХВ)тБ╗┬╣ тАв (bch_cubic_term ЁЭХВ a' b * a' - a' * bch_cubic_term ЁЭХВ a' b) +
                  bch_quartic_term ЁЭХВ a' b +
                  -((96 : ЁЭХВ)тБ╗┬╣ тАв (b * DC_a - DC_a * b))) +
                 bch_quartic_term ЁЭХВ (a' + b) a' = 0 := by
        simp only [ha'_def, hDC_a_def]
        convert h using 2
      have hW := eq_neg_of_add_eq_zero_right h'
      rw [hW]; abel
    rw [hQI_rearr]
    simp only [smul_sub, smul_add, smul_mul_assoc, mul_smul_comm, add_mul, mul_add,
      sub_mul, mul_sub, ha'_def, hDC_a_def, smul_smul,
