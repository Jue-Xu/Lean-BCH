  have hB3 := norm_add_le (T₃ * T₅ + T₅ * T₃ + T₄ ^ 2 +
    T₄ * T₅ + T₅ * T₄ + T₅ ^ 2 +
    T₂ * (P - T₂ - T₃ - T₄ - T₅) + (P - T₂ - T₃ - T₄ - T₅) * T₂ +
    T₃ * (P - T₂ - T₃ - T₄ - T₅) + (P - T₂ - T₃ - T₄ - T₅) * T₃ +
    T₄ * (P - T₂ - T₃ - T₄ - T₅) + (P - T₂ - T₃ - T₄ - T₅) * T₄)
    (T₅ * (P - T₂ - T₃ - T₄ - T₅))
  have hB4 := norm_add_le (T₃ * T₅ + T₅ * T₃ + T₄ ^ 2 +
    T₄ * T₅ + T₅ * T₄ + T₅ ^ 2 +
    T₂ * (P - T₂ - T₃ - T₄ - T₅) + (P - T₂ - T₃ - T₄ - T₅) * T₂ +
    T₃ * (P - T₂ - T₃ - T₄ - T₅) + (P - T₂ - T₃ - T₄ - T₅) * T₃ +
    T₄ * (P - T₂ - T₃ - T₄ - T₅))
