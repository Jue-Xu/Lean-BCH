    norm_exp_sub_one_sub_sub_le (ùïÇ := ùïÇ) a
  have hE‚ÇÇ_le : ‚ÄñE‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 :=
    norm_exp_sub_one_sub_sub_le (ùïÇ := ùïÇ) b
  have hF‚ÇÅ_le : ‚ÄñF‚ÇÅ‚Äñ ‚â§ Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ùïÇ := ùïÇ) a
  have hF‚ÇÇ_le : ‚ÄñF‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 :=
    norm_exp_sub_one_sub_sub_sub_le (ùïÇ := ùïÇ) b
  have hG‚ÇÅ_le : ‚ÄñG‚ÇÅ‚Äñ ‚â§ Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ùïÇ := ùïÇ) a
  have hG‚ÇÇ_le : ‚ÄñG‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 - Œ≤ ^ 4 / 24 :=
    norm_exp_sub_one_sub_sub_sub_sub_le (ùïÇ := ùïÇ) b
  have hH‚ÇÅ_le : ‚ÄñH‚ÇÅ‚Äñ ‚â§ Real.exp Œ± - 1 - Œ± - Œ± ^ 2 / 2 - Œ± ^ 3 / 6 - Œ± ^ 4 / 24 - Œ± ^ 5 / 120 :=
    norm_exp_sub_one_sub_sub_sub_sub_sub_le (ùïÇ := ùïÇ) a
  have hH‚ÇÇ_le : ‚ÄñH‚ÇÇ‚Äñ ‚â§ Real.exp Œ≤ - 1 - Œ≤ - Œ≤ ^ 2 / 2 - Œ≤ ^ 3 / 6 - Œ≤ ^ 4 / 24 - Œ≤ ^ 5 / 120 :=
