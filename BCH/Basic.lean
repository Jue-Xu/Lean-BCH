end ExpNormBounds

/-! ### Smallness condition for the BCH element -/

include ùïÇ in
/-- When `‚Äña‚Äñ + ‚Äñb‚Äñ < ln 2`, we have `‚Äñexp(a) ¬∑ exp(b) - 1‚Äñ < 1`.
This is the key smallness condition ensuring the log series converges. -/
theorem norm_exp_mul_exp_sub_one_lt_one (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) :
    ‚Äñexp a * exp b - 1‚Äñ < 1 := by
  -- Factor: exp(a) * exp(b) - 1 = (exp(a) - 1) * exp(b) + (exp(b) - 1)
  have hfactor : exp a * exp b - 1 = (exp a - 1) * exp b + (exp b - 1) := by
    rw [sub_mul, one_mul]; abel
  rw [hfactor]
  have hexp_a_ge : 0 ‚â§ Real.exp ‚Äña‚Äñ - 1 := by
    linarith [Real.add_one_le_exp ‚Äña‚Äñ, norm_nonneg a]
  have hexp_b_pos : 0 ‚â§ Real.exp ‚Äñb‚Äñ := (Real.exp_pos _).le
  calc ‚Äñ(exp a - 1) * exp b + (exp b - 1)‚Äñ
      ‚â§ ‚Äñ(exp a - 1) * exp b‚Äñ + ‚Äñexp b - 1‚Äñ := norm_add_le _ _
    _ ‚â§ ‚Äñexp a - 1‚Äñ * ‚Äñexp b‚Äñ + ‚Äñexp b - 1‚Äñ := by
        gcongr; exact norm_mul_le _ _
    _ ‚â§ (Real.exp ‚Äña‚Äñ - 1) * Real.exp ‚Äñb‚Äñ + (Real.exp ‚Äñb‚Äñ - 1) := by
        gcongr
        ¬∑ exact norm_exp_sub_one_le (ùïÇ := ùïÇ) a
        ¬∑ exact norm_exp_le (ùïÇ := ùïÇ) b
        ¬∑ exact norm_exp_sub_one_le (ùïÇ := ùïÇ) b
    _ = Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ) - 1 := by rw [Real.exp_add]; ring
    _ < 1 := by
        have : Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ) < 2 := by
          calc Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)
              < Real.exp (Real.log 2) := Real.exp_strictMono hab
            _ = 2 := Real.exp_log (by norm_num)
        linarith

include ùïÇ in
/-- When `‚Äña‚Äñ < ln 2`, we have `‚Äñexp(a) - 1‚Äñ < 1`. -/
theorem norm_exp_sub_one_lt_one (a : ùî∏) (ha : ‚Äña‚Äñ < Real.log 2) :
    ‚Äñexp a - 1‚Äñ < 1 := by
  have h := norm_exp_mul_exp_sub_one_lt_one (ùïÇ := ùïÇ) a (0 : ùî∏) (by simpa)
  simpa [exp_zero] using h

/-! ### Definition of the BCH element -/

include ùïÇ in
/-- The Baker-Campbell-Hausdorff element: the unique Z such that `exp(Z) = exp(a) ¬∑ exp(b)`.
Defined as `logOnePlus(exp(a) ¬∑ exp(b) - 1)` which converges when `‚Äña‚Äñ + ‚Äñb‚Äñ < ln 2`. -/
noncomputable def bch (a b : ùî∏) : ùî∏ := logOnePlus (ùïÇ := ùïÇ) (exp a * exp b - 1)

/-! ### The fundamental BCH identity -/

include ùïÇ in
/-- **The structural BCH theorem**: `exp(bch a b) = exp(a) ¬∑ exp(b)`.

This is the fundamental identity: the BCH element exponentiates back to the product.
The proof combines the log series convergence (from the smallness condition
`‚Äñexp(a)¬∑exp(b) - 1‚Äñ < 1`) with the `exp ‚àò log = id` identity from Phase 1. -/
theorem exp_bch (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) :
    exp (bch (ùïÇ := ùïÇ) a b) = exp a * exp b := by
  unfold bch
  have h : ‚Äñexp a * exp b - 1‚Äñ < 1 :=
    norm_exp_mul_exp_sub_one_lt_one (ùïÇ := ùïÇ) a b hab
  have key := exp_logOnePlus (ùïÇ := ùïÇ) (exp a * exp b - 1) h
  -- key : exp (logOnePlus (exp a * exp b - 1)) = 1 + (exp a * exp b - 1)
  -- 1 + (exp a * exp b - 1) = exp a * exp b
  rw [key]; abel

/-! ### Continuity of logOnePlus on the open unit ball -/

include ùïÇ in
omit [CompleteSpace ùî∏] in
/-- Each log series term `y ‚Ü¶ logSeriesTerm y n` is continuous. -/
private lemma continuous_logSeriesTerm (n : ‚Ñï) :
    Continuous (fun y : ùî∏ => logSeriesTerm (ùïÇ := ùïÇ) y n) := by
  unfold logSeriesTerm
  exact continuous_const.smul (continuous_id.pow (n + 1))

/-- The geometric series `‚àë (max 0 r)^(n+1)` is summable when `r < 1`. -/
private lemma summable_geometric_succ_max {r : ‚Ñù} (hr : r < 1) :
    Summable (fun n : ‚Ñï => (max 0 r) ^ (n + 1)) :=
  ((summable_geometric_of_lt_one (le_max_left 0 r) (max_lt (by linarith) hr)).mul_left
    (max 0 r)).congr fun n => by ring

include ùïÇ in
/-- `logOnePlus` is continuous on `closedBall 0 r` for any `r < 1`. -/
private lemma continuousOn_logOnePlus {r : ‚Ñù} (hr : r < 1) :
    ContinuousOn (logOnePlus (ùïÇ := ùïÇ)) (Metric.closedBall (0 : ùî∏) r) := by
  unfold logOnePlus
  apply continuousOn_tsum
  ¬∑ exact fun n => (continuous_logSeriesTerm (ùïÇ := ùïÇ) n).continuousOn
  ¬∑ exact summable_geometric_succ_max hr
  ¬∑ intro n y hy
    calc ‚ÄñlogSeriesTerm (ùïÇ := ùïÇ) y n‚Äñ
        ‚â§ ‚Äñy‚Äñ ^ (n + 1) := norm_logSeriesTerm_le (ùïÇ := ùïÇ) y n
      _ ‚â§ (max 0 r) ^ (n + 1) := by
          apply pow_le_pow_left‚ÇÄ (norm_nonneg _)
          rw [Metric.mem_closedBall, dist_zero_right] at hy
          exact hy.trans (le_max_right 0 r)

/-! ### The log ‚àò exp identity -/

include ùïÇ in
/-- `logOnePlus(exp(a) - 1) = a` for `‚Äña‚Äñ < ln 2`: the logarithm inverts the exponential.

The proof proceeds by a chain-of-neighborhoods argument:
1. Define `h(t) = logOnePlus(exp(ta) - 1) - ta` for `t ‚àà [0,1]`.
2. Show `h(0) = 0` and `exp(h(t)) = 1` for all `t`.
3. Show `h` is continuous on `[0,1]`.
4. By uniform continuity on `[0,1]` (compact), find `Œ¥ > 0` s.t. `‚Äñh(t) - h(s)‚Äñ < ln 2`
   whenever `|t-s| < Œ¥`.
5. By induction with step size `1/N < Œ¥`: `h(k/N) = 0` for all `k ‚â§ N`.
6. In particular `h(1) = 0`. -/
theorem logOnePlus_exp_sub_one (a : ùî∏) (ha : ‚Äña‚Äñ < Real.log 2) :
    logOnePlus (ùïÇ := ùïÇ) (exp a - 1) = a := by
  -- Reduce to ‚Ñù scalars
  rw [logOnePlus_eq_real (ùïÇ := ùïÇ)]
  set inst‚Ñù := NormedAlgebra.restrictScalars ‚Ñù ùïÇ ùî∏
  letI : NormedAlgebra ‚Ñù ùî∏ := inst‚Ñù
  -- Define h(t) = logOnePlus(exp(ta) - 1) - ta
  set h : ‚Ñù ‚Üí ùî∏ := fun t =>
    @logOnePlus ‚Ñù _ ùî∏ _ inst‚Ñù (exp (t ‚Ä¢ a) - 1) - t ‚Ä¢ a with hh_def
  -- It suffices to show h(1) = 0
  suffices h1 : h 1 = 0 by
    simp only [h, one_smul] at h1
    exact sub_eq_zero.mp h1
  -- Step 1: h(0) = 0
  have h0 : h 0 = 0 := by
    simp [h, logOnePlus, logSeriesTerm, tsum_zero]
  -- Step 2: exp(h(t)) = 1 for t ‚àà [0,1]
  letI : NormedAlgebra ‚Ñö ùî∏ := NormedAlgebra.restrictScalars ‚Ñö ‚Ñù ùî∏
  have hexp_ht : ‚àÄ t : ‚Ñù, t * ‚Äña‚Äñ < Real.log 2 ‚Üí 0 ‚â§ t ‚Üí
      exp (h t) = 1 := by
    intro t ht ht_nn
    -- exp(logOnePlus(exp(ta)-1)) = exp(ta) from exp_logOnePlus
    have hnorm : ‚Äñexp (t ‚Ä¢ a) - 1‚Äñ < 1 := by
      apply @norm_exp_sub_one_lt_one ‚Ñù _ ùî∏ _ inst‚Ñù _ _
      calc ‚Äñt ‚Ä¢ a‚Äñ ‚â§ ‚Äñt‚Äñ * ‚Äña‚Äñ := norm_smul_le t a
        _ = |t| * ‚Äña‚Äñ := by rw [Real.norm_eq_abs]
        _ = t * ‚Äña‚Äñ := by rw [abs_of_nonneg ht_nn]
        _ < Real.log 2 := ht
    have hexp_log := @exp_logOnePlus ‚Ñù _ ùî∏ _ inst‚Ñù _ _ (exp (t ‚Ä¢ a) - 1) hnorm
    -- logOnePlus(exp(ta)-1) commutes with a
    have hcomm_exp_a : Commute (exp (t ‚Ä¢ a) - 1) a := by
      apply Commute.sub_left _ (Commute.one_left a)
      exact (Commute.refl a).smul_left t |>.exp_left
    have hcomm : Commute (@logOnePlus ‚Ñù _ ùî∏ _ inst‚Ñù (exp (t ‚Ä¢ a) - 1)) a :=
      @commute_logOnePlus_of_commute ‚Ñù _ ùî∏ _ inst‚Ñù _ _ (exp (t ‚Ä¢ a) - 1) a hcomm_exp_a
    -- exp(L - ta) = exp(L) * exp(-ta) since L commutes with ta
    have hcomm_ta : Commute (@logOnePlus ‚Ñù _ ùî∏ _ inst‚Ñù (exp (t ‚Ä¢ a) - 1)) (t ‚Ä¢ a) :=
      hcomm.smul_right t
    set L := @logOnePlus ‚Ñù _ ùî∏ _ inst‚Ñù (exp (t ‚Ä¢ a) - 1)
    show exp (L - t ‚Ä¢ a) = 1
    rw [show L - t ‚Ä¢ a = L + (-(t ‚Ä¢ a)) from sub_eq_add_neg L (t ‚Ä¢ a),
        exp_add_of_commute (hcomm_ta.neg_right), hexp_log,
        show (1 + (exp (t ‚Ä¢ a) - 1)) = exp (t ‚Ä¢ a) from by abel,
        ‚Üê exp_add_of_commute ((Commute.refl (t ‚Ä¢ a)).neg_right),
        add_neg_cancel, exp_zero]
  -- Step 3: h is continuous on [0, 1]
  have hcont : ContinuousOn h (Set.Icc 0 1) := by
    -- h = logOnePlus ‚àò (exp(¬∑a) - 1) - (¬∑ ‚Ä¢ a)
    apply ContinuousOn.sub
    ¬∑ -- logOnePlus(exp(ta)-1) is continuous
      -- The inner function maps [0,1] into closedBall 0 œÅ where œÅ = exp(‚Äña‚Äñ)-1 < 1
      set œÅ := Real.exp ‚Äña‚Äñ - 1 with hœÅ_def
      have hœÅ_lt : œÅ < 1 := by
        have : Real.exp ‚Äña‚Äñ < 2 := by
          calc Real.exp ‚Äña‚Äñ < Real.exp (Real.log 2) := Real.exp_strictMono ha
            _ = 2 := Real.exp_log (by norm_num)
        linarith
      -- Inner function maps [0,1] into closedBall 0 œÅ
      have hmaps : Set.MapsTo (fun t : ‚Ñù => exp (t ‚Ä¢ a) - 1)
          (Set.Icc 0 1) (Metric.closedBall (0 : ùî∏) œÅ) := by
        intro t ht
        rw [Metric.mem_closedBall, dist_zero_right]
        calc ‚Äñexp (t ‚Ä¢ a) - 1‚Äñ
            ‚â§ Real.exp ‚Äñt ‚Ä¢ a‚Äñ - 1 := @norm_exp_sub_one_le ‚Ñù _ ùî∏ _ inst‚Ñù _ _ (t ‚Ä¢ a)
          _ ‚â§ Real.exp (t * ‚Äña‚Äñ) - 1 := by
              gcongr
              calc ‚Äñt ‚Ä¢ a‚Äñ ‚â§ |t| * ‚Äña‚Äñ := norm_smul_le t a
                _ = t * ‚Äña‚Äñ := by rw [abs_of_nonneg ht.1]
          _ ‚â§ Real.exp (1 * ‚Äña‚Äñ) - 1 := by
              gcongr; exact ht.2
          _ = œÅ := by rw [one_mul]
      -- Inner function is continuous
      have hinner_cont : ContinuousOn (fun t : ‚Ñù => exp (t ‚Ä¢ a) - 1) (Set.Icc 0 1) :=
        ContinuousOn.sub
          (NormedSpace.exp_continuous.continuousOn.comp
            ((continuous_id.smul continuous_const).continuousOn) (Set.mapsTo_univ _ _))
          continuousOn_const
      exact ContinuousOn.comp (continuousOn_logOnePlus (ùïÇ := ‚Ñù) hœÅ_lt) hinner_cont hmaps
    ¬∑ exact (continuous_id.smul continuous_const).continuousOn
  -- Step 4-6: Chain of neighborhoods argument
  -- By uniform continuity on [0,1], find Œ¥
  have hcompact : IsCompact (Set.Icc (0:‚Ñù) 1) := isCompact_Icc
  have huc := hcompact.uniformContinuousOn_of_continuous hcont
  rw [Metric.uniformContinuousOn_iff] at huc
  obtain ‚ü®Œ¥, hŒ¥_pos, hŒ¥‚ü© := huc (Real.log 2) (Real.log_pos (by norm_num))
  -- Choose N with 1/N < Œ¥
  obtain ‚ü®N, hN‚ü© := exists_nat_gt (1 / Œ¥)
  have hN_pos : 0 < N := by
    rcases N with _ | n
    ¬∑ simp at hN; linarith [div_pos one_pos hŒ¥_pos]
    ¬∑ exact Nat.succ_pos n
  -- Induction: h(k/N) = 0 for all k ‚â§ N
  suffices hind : ‚àÄ k : ‚Ñï, k ‚â§ N ‚Üí h (k / N) = 0 by
    have := hind N le_rfl
    rwa [show (N : ‚Ñù) / N = 1 from div_self (Nat.cast_ne_zero.mpr (by omega))] at this
  intro k hk
  induction k with
  | zero => simp [h0]
  | succ k ih =>
    have hk_le : k ‚â§ N := by omega
    have hprev := ih hk_le
    -- Membership in [0,1]
    have hN_pos_real : (0 : ‚Ñù) < N := Nat.cast_pos.mpr hN_pos
    have hkN_mem : (k : ‚Ñù) / N ‚àà Set.Icc (0:‚Ñù) 1 :=
      ‚ü®div_nonneg (Nat.cast_nonneg k) hN_pos_real.le,
       div_le_one_of_le‚ÇÄ (Nat.cast_le.mpr hk_le) hN_pos_real.le‚ü©
    have hk1N_mem : ((k+1 : ‚Ñï) : ‚Ñù) / N ‚àà Set.Icc (0:‚Ñù) 1 :=
      ‚ü®div_nonneg (Nat.cast_nonneg _) hN_pos_real.le,
       div_le_one_of_le‚ÇÄ (Nat.cast_le.mpr hk) hN_pos_real.le‚ü©
    -- |(k+1)/N - k/N| = 1/N < Œ¥
    have h1N_lt : (1 : ‚Ñù) / N < Œ¥ := by
      rw [one_div]
      exact (inv_lt_comm‚ÇÄ hŒ¥_pos hN_pos_real).mp (by rwa [one_div] at hN)
    have hdist' : dist ((‚Üë(k + 1) : ‚Ñù) / ‚ÜëN) (‚Üëk / ‚ÜëN) < Œ¥ := by
      rw [dist_comm, Real.dist_eq, show (k : ‚Ñù) / N - ((k + 1 : ‚Ñï) : ‚Ñù) / N = -(1 / N) from by
        push_cast; field_simp; ring, abs_neg, abs_of_nonneg (by positivity : (0 : ‚Ñù) ‚â§ 1 / N)]
      exact h1N_lt
    -- Apply uniform continuity
    have hnorm_small : ‚Äñh ((k+1 : ‚Ñï) / N) - h (k / N)‚Äñ < Real.log 2 := by
      rw [‚Üê dist_eq_norm]
      exact hŒ¥ _ hk1N_mem _ hkN_mem hdist'
    -- Since h(k/N) = 0, ‚Äñh((k+1)/N)‚Äñ < ln 2
    rw [hprev, sub_zero] at hnorm_small
    -- exp(h((k+1)/N)) = 1
    have hexp1 : exp (h ((k+1 : ‚Ñï) / N)) = 1 :=
      hexp_ht _ (by calc ((k+1 : ‚Ñï) : ‚Ñù) / N * ‚Äña‚Äñ
            ‚â§ 1 * ‚Äña‚Äñ := by gcongr; exact hk1N_mem.2
          _ = ‚Äña‚Äñ := one_mul _
          _ < Real.log 2 := ha) hk1N_mem.1
    -- By exp_eq_one_of_norm_lt
    exact exp_eq_one_of_norm_lt (ùïÇ := ùïÇ) _ hexp1 hnorm_small

/-! ### Norm estimate for `bch a b - (a + b)` -/

include ùïÇ in
/-- The BCH remainder bound: `‚Äñbch(a,b) - (a+b)‚Äñ` is quadratically small.

More precisely: `‚Äñbch(a,b) - (a+b)‚Äñ ‚â§ 3s¬≤/(2-eÀ¢)` where `s = ‚Äña‚Äñ + ‚Äñb‚Äñ`.
The bound diverges at `s = ln 2` (the radius of convergence) and satisfies
`3s¬≤/(2-eÀ¢) ~ 3s¬≤/2` for small `s`.

The proof decomposes `bch(a,b) - (a+b) = (logOnePlus(y) - y) + (y - (a+b))`
where `y = exp(a)¬∑exp(b) - 1`, bounds each piece, and uses the key inequality
`exp(s)¬∑(1+s) ‚â§ 1 + 2s + 3s¬≤` for `s ‚àà [0, ln 2)`. -/
theorem norm_bch_sub_add_le (a b : ùî∏) (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) :
    ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b)‚Äñ ‚â§
      3 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 2 / (2 - Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)) := by
  set y := exp a * exp b - 1 with hy_def
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ with hs_def
  have hs_nn : 0 ‚â§ s := by positivity
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have h_denom_pos : 0 < 2 - Real.exp s := by linarith
  have hy_lt : ‚Äñy‚Äñ < 1 := norm_exp_mul_exp_sub_one_lt_one (ùïÇ := ùïÇ) a b hab
  have hy_le : ‚Äñy‚Äñ ‚â§ Real.exp s - 1 := by
    have : y = (exp a - 1) * exp b + (exp b - 1) := by rw [hy_def, sub_mul, one_mul]; abel
    calc ‚Äñy‚Äñ = ‚Äñ(exp a - 1) * exp b + (exp b - 1)‚Äñ := by rw [this]
      _ ‚â§ ‚Äñexp a - 1‚Äñ * ‚Äñexp b‚Äñ + ‚Äñexp b - 1‚Äñ := by
          calc _ ‚â§ ‚Äñ(exp a - 1) * exp b‚Äñ + _ := norm_add_le _ _
            _ ‚â§ _ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (Real.exp ‚Äña‚Äñ - 1) * Real.exp ‚Äñb‚Äñ + (Real.exp ‚Äñb‚Äñ - 1) := by
          have h1 := norm_exp_sub_one_le (ùïÇ := ùïÇ) a
          have h2 := norm_exp_le (ùïÇ := ùïÇ) b
          have h3 := norm_exp_sub_one_le (ùïÇ := ùïÇ) b
          apply add_le_add
          ¬∑ exact mul_le_mul h1 h2 (norm_nonneg _) (by linarith [Real.add_one_le_exp ‚Äña‚Äñ, norm_nonneg a])
          ¬∑ exact h3
      _ = Real.exp s - 1 := by rw [hs_def, Real.exp_add]; ring
  -- Decomposition
  have hdecomp : bch (ùïÇ := ùïÇ) a b - (a + b) =
      (logOnePlus (ùïÇ := ùïÇ) y - y) + (y - (a + b)) := by unfold bch; abel
  -- Part 1: log remainder
  have hpart1 : ‚ÄñlogOnePlus (ùïÇ := ùïÇ) y - y‚Äñ ‚â§ (Real.exp s - 1) ^ 2 / (2 - Real.exp s) := by
    calc _ ‚â§ ‚Äñy‚Äñ ^ 2 / (1 - ‚Äñy‚Äñ) := norm_logOnePlus_sub_le (ùïÇ := ùïÇ) y hy_lt
      _ ‚â§ (Real.exp s - 1) ^ 2 / (2 - Real.exp s) := by
          exact div_le_div‚ÇÄ (sq_nonneg _)
            (pow_le_pow_left‚ÇÄ (norm_nonneg _) hy_le _) h_denom_pos (by linarith)
  -- Part 2: exp factorization
  have hpart2 : ‚Äñy - (a + b)‚Äñ ‚â§ Real.exp s - 1 - s := by
    have hident : y - (a + b) = (exp a - 1) * (exp b - 1) + (exp a - 1 - a) + (exp b - 1 - b) := by
      rw [hy_def]; noncomm_ring
    rw [hident]
    calc _ ‚â§ ‚Äñ(exp a - 1) * (exp b - 1)‚Äñ + ‚Äñexp a - 1 - a‚Äñ + ‚Äñexp b - 1 - b‚Äñ := by
          calc _ ‚â§ ‚Äñ(exp a - 1) * (exp b - 1) + (exp a - 1 - a)‚Äñ + _ := norm_add_le _ _
            _ ‚â§ _ := by gcongr; exact norm_add_le _ _
      _ ‚â§ (Real.exp ‚Äña‚Äñ - 1) * (Real.exp ‚Äñb‚Äñ - 1) +
          (Real.exp ‚Äña‚Äñ - 1 - ‚Äña‚Äñ) + (Real.exp ‚Äñb‚Äñ - 1 - ‚Äñb‚Äñ) := by
          have ha1 := norm_exp_sub_one_le (ùïÇ := ùïÇ) a
          have hb1 := norm_exp_sub_one_le (ùïÇ := ùïÇ) b
          have ha2 := norm_exp_sub_one_sub_le (ùïÇ := ùïÇ) a
          have hb2 := norm_exp_sub_one_sub_le (ùïÇ := ùïÇ) b
          have ha_nn : 0 ‚â§ Real.exp ‚Äña‚Äñ - 1 := by
            linarith [Real.add_one_le_exp ‚Äña‚Äñ, norm_nonneg a]
          have hb_nn : 0 ‚â§ Real.exp ‚Äñb‚Äñ - 1 := by
            linarith [Real.add_one_le_exp ‚Äñb‚Äñ, norm_nonneg b]
          apply add_le_add (add_le_add _ ha2) hb2
          exact (norm_mul_le _ _).trans (mul_le_mul ha1 hb1 (norm_nonneg _) ha_nn)
      _ = Real.exp s - 1 - s := by rw [hs_def, Real.exp_add]; ring
  -- Combine and bound: (E-1)¬≤/(2-E) + (E-1-s) ‚â§ 3s¬≤/(2-E)
  -- Equivalent to: (E-1)¬≤ + (E-1-s)(2-E) ‚â§ 3s¬≤, i.e., E(1+s) - (1+2s) ‚â§ 3s¬≤
  rw [hdecomp]
  calc _ ‚â§ ‚ÄñlogOnePlus (ùïÇ := ùïÇ) y - y‚Äñ + ‚Äñy - (a + b)‚Äñ := norm_add_le _ _
    _ ‚â§ (Real.exp s - 1) ^ 2 / (2 - Real.exp s) + (Real.exp s - 1 - s) :=
        add_le_add hpart1 hpart2
    _ ‚â§ 3 * s ^ 2 / (2 - Real.exp s) := by
        -- Need: (E-1)¬≤/(2-E) + (E-1-s) ‚â§ 3s¬≤/(2-E)
        -- Combine LHS into single fraction, then compare numerators
        rw [div_add' _ _ _ (ne_of_gt h_denom_pos)]
        apply div_le_div_of_nonneg_right _ h_denom_pos.le
        -- Goal: (E-1)¬≤ + (E-1-s)*(2-E) ‚â§ 3s¬≤
        set E := Real.exp s
        -- s < 1 because 1+s ‚â§ E < 2
        have hs_lt_one : s < 1 := by linarith [Real.add_one_le_exp s]
        -- E ‚â§ 1+s+s¬≤ from Real.norm_exp_sub_one_sub_id_le (for |s| ‚â§ 1)
        have hE_taylor : E - 1 - s ‚â§ s ^ 2 := by
          have h := Real.norm_exp_sub_one_sub_id_le (show ‚Äñs‚Äñ ‚â§ 1 by rw [Real.norm_eq_abs, abs_of_nonneg hs_nn]; linarith)
          rw [Real.norm_eq_abs, abs_of_nonneg (by linarith [Real.add_one_le_exp s]),
              Real.norm_eq_abs, abs_of_nonneg hs_nn] at h
          exact h
        -- E ‚â§ 1+s+s¬≤
        have hE_le : E ‚â§ 1 + s + s ^ 2 := by linarith
        -- E(1+s) ‚â§ (1+s+s¬≤)(1+s) = 1+2s+2s¬≤+s¬≥ ‚â§ 1+2s+3s¬≤ (since s¬≥ ‚â§ s¬≤)
        -- (E-1)¬≤ + (E-1-s)(2-E) = E(1+s) - (1+2s) by ring
        -- So need E(1+s) - (1+2s) ‚â§ 3s¬≤
        nlinarith [sq_nonneg s, mul_self_nonneg (s * s),
                   show s ^ 3 ‚â§ s ^ 2 from by
                     calc s ^ 3 = s ^ 2 * s := by ring
                       _ ‚â§ s ^ 2 * 1 := by nlinarith [sq_nonneg s]
                       _ = s ^ 2 := by ring]
/-! ### Cubic Taylor remainder bound for exp -/

/-- `exp(s)-1-s-s¬≤/2 ‚â§ s¬≥/(6(1-s))` for `0 ‚â§ s < 1`,
from the termwise bound `1/n! ‚â§ 1/6` for `n ‚â• 3`. -/
private lemma real_exp_third_order_le_div {s : ‚Ñù} (hs : 0 ‚â§ s) (hs1 : s < 1) :
    Real.exp s - 1 - s - s ^ 2 / 2 ‚â§ s ^ 3 / (6 * (1 - s)) := by
  -- exp(s) - 1 - s - s¬≤/2 = Œ£_{n‚â•3} s‚Åø/n! ‚â§ Œ£_{n‚â•3} s‚Åø/6 = s¬≥/(6(1-s))
  have h_rexp := hasSum_real_exp s
  -- The n‚â•3 tail: Œ£_{n‚â•0} s^(n+3)/(n+3)! = exp(s)-1-s-s¬≤/2
  have h_summ3 : Summable (fun n => ((n + 3) !‚Åª¬π : ‚Ñù) * s ^ (n + 3)) :=
    (summable_nat_add_iff 3).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 3) !‚Åª¬π : ‚Ñù) * s ^ (n + 3))
      (Real.exp s - 1 - s - s ^ 2 / 2) := by
    rw [h_summ3.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3
    linarith
  -- The comparison: Œ£_{n‚â•0} s^(n+3)/6 = s¬≥/(6(1-s))
  have h_geom_summ : Summable (fun n => s ^ (n + 3) / 6) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs1).mul_left (s ^ 3) |>.congr fun n => by ring
  -- Termwise bound: (n+3)!‚Åª¬π ‚â§ 6‚Åª¬π since (n+3)! ‚â• 3! = 6
  have hterm : ‚àÄ n, ((n + 3) !‚Åª¬π : ‚Ñù) * s ^ (n + 3) ‚â§ s ^ (n + 3) * (6 : ‚Ñù)‚Åª¬π := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_inv‚ÇÄ (by positivity : (0 : ‚Ñù) < (n + 3)!) (by positivity : (0 : ‚Ñù) < 6)]
    have : (3 : ‚Ñï)! ‚â§ (n + 3)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  -- The comparison series sums to s¬≥/(6(1-s))
  have h_geom : HasSum (fun n => s ^ (n + 3) * (6 : ‚Ñù)‚Åª¬π) (s ^ 3 * (1 - s)‚Åª¬π * (6 : ‚Ñù)‚Åª¬π) := by
    have hg := (hasSum_geometric_of_lt_one hs hs1).mul_left (s ^ 3)
    have h_eq : (fun n => s ^ 3 * s ^ n) = (fun n => s ^ (n + 3)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (6 : ‚Ñù)‚Åª¬π
  calc Real.exp s - 1 - s - s ^ 2 / 2
      = ‚àë' n, ((n + 3) !‚Åª¬π : ‚Ñù) * s ^ (n + 3) := h_val.tsum_eq.symm
    _ ‚â§ ‚àë' n, (s ^ (n + 3) * (6 : ‚Ñù)‚Åª¬π) :=
        h_summ3.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 3 * (1 - s)‚Åª¬π * (6 : ‚Ñù)‚Åª¬π := h_geom.tsum_eq
    _ = s ^ 3 / (6 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring

/-- For `0 ‚â§ s` with `s < 5/6`, the third-order Taylor remainder satisfies
`exp(s)-1-s-s¬≤/2 ‚â§ s¬≥`. -/
lemma real_exp_third_order_le_cube {s : ‚Ñù} (hs : 0 ‚â§ s) (hs1 : s < 5 / 6) :
    Real.exp s - 1 - s - s ^ 2 / 2 ‚â§ s ^ 3 := by
  have hs_lt1 : s < 1 := by linarith
  calc Real.exp s - 1 - s - s ^ 2 / 2
      ‚â§ s ^ 3 / (6 * (1 - s)) := real_exp_third_order_le_div hs hs_lt1
    _ ‚â§ s ^ 3 := by
