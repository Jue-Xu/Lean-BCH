          ┬╖ exact (norm_mul_le _ _).trans (mul_le_mul_of_nonneg_right hab_le h╬▒_nn)
      _ = 4 * ╬▒ ^ 2 * ╬▓ := by ring
  have h_bba : тАЦb * (b * a - a * b) - (b * a - a * b) * bтАЦ тЙд 4 * ╬▒ * ╬▓ ^ 2 := by
    have hba_le : тАЦb * a - a * bтАЦ тЙд 2 * ╬▒ * ╬▓ := by
