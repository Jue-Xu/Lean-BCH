    calc _ ‚â§ ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ * ‚Äñz ^ 2‚Äñ := norm_mul_le _ _
      _ ‚â§ ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ * ‚Äñz‚Äñ ^ 2 := by gcongr; exact norm_pow_le z 2
      _ ‚â§ (K_PmT5 * s ^ 6) * s ^ 2 :=
          mul_le_mul hPmT5_le (pow_le_pow_left‚ÇÄ (norm_nonneg _) hz 2)
            (by positivity) (by positivity)
  have h4 : ‚Äñz * (P ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
                  T‚ÇÇ * T‚ÇÑ - T‚ÇÉ * T‚ÇÉ - T‚ÇÑ * T‚ÇÇ)‚Äñ ‚â§ s * (K_P2' * s ^ 7) :=
    calc _ ‚â§ ‚Äñz‚Äñ * ‚ÄñP ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
