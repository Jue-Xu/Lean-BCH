/-! ### Norm bound for exp in Banach algebras

We prove `‚Äñexp x‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ`, which Mathlib has for ‚ÑÇ but not for general
Banach algebras. The proof goes through the power series representation.
-/

section ExpNormBounds

omit [NormedRing ùî∏] [NormedAlgebra ùïÇ ùî∏] [NormOneClass ùî∏] [CompleteSpace ùî∏] in
/-- Helper: the real exp series evaluated at r gives a HasSum to Real.exp r. -/
private lemma hasSum_real_exp (r : ‚Ñù) :
    HasSum (fun n => (n !‚Åª¬π : ‚Ñù) * r ^ n) (Real.exp r) := by
  have h := exp_series_hasSum_exp' (ùïÇ := ‚Ñù) (ùî∏ := ‚Ñù) r
  simp only [smul_eq_mul] at h
  rwa [congr_fun Real.exp_eq_exp_‚Ñù r]

omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
private lemma summable_real_exp_norm_shift (x : ùî∏) :
    Summable (fun n => ((n + 1) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 1)) :=
  (summable_nat_add_iff 1).mpr (hasSum_real_exp ‚Äñx‚Äñ).summable

omit [NormOneClass ùî∏] [CompleteSpace ùî∏] in
private lemma hasSum_real_exp_norm_shift (x : ùî∏) :
    HasSum (fun n => ((n + 1) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 1)) (Real.exp ‚Äñx‚Äñ - 1) := by
  -- Strategy: the full series sums to exp ‚Äñx‚Äñ, its 0th term is 1,
  -- so the tail sums to exp ‚Äñx‚Äñ - 1.
  have h := hasSum_real_exp ‚Äñx‚Äñ
  -- Use Summable.hasSum_iff to prove the shifted sum has the right value.
  have hsumm : Summable (fun n => ((n + 1) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 1)) :=
    summable_real_exp_norm_shift x
  rw [hsumm.hasSum_iff]
  -- Need: ‚àë' n, ((n+1)!‚Åª¬π * ‚Äñx‚Äñ^(n+1)) = Real.exp ‚Äñx‚Äñ - 1
  -- From h: ‚àë' n, (n!‚Åª¬π * ‚Äñx‚Äñ^n) = Real.exp ‚Äñx‚Äñ
  have h_full := h.tsum_eq
  -- The full tsum = 0th term + shifted tsum
  have h_split : ‚àë' n, (n !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ n =
      (0 !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ 0 + ‚àë' n, ((n + 1) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 1) :=
    h.summable.tsum_eq_zero_add
  rw [h_full] at h_split
  simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero] at h_split
  linarith

include ùïÇ in
omit [CompleteSpace ùî∏] in
/-- The exp series term norm bound: `‚Äñ(n!)‚Åª¬π ‚Ä¢ x^n‚Äñ ‚â§ (n!)‚Åª¬π * ‚Äñx‚Äñ^n`. -/
private lemma norm_expSeries_term_le' (x : ùî∏) (n : ‚Ñï) :
    ‚Äñ(n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n‚Äñ ‚â§ (n !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ n := by
  calc ‚Äñ(n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n‚Äñ
      ‚â§ ‚Äñ(n !‚Åª¬π : ùïÇ)‚Äñ * ‚Äñx ^ n‚Äñ := norm_smul_le _ _
    _ ‚â§ (n !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ n := by
        gcongr
        ¬∑ rw [norm_inv, RCLike.norm_natCast]
        ¬∑ exact norm_pow_le x n

include ùïÇ in
omit [CompleteSpace ùî∏] in
/-- `‚Äñexp x‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ` in any complete normed algebra with `‚Äñ1‚Äñ = 1`. -/
theorem norm_exp_le (x : ùî∏) : ‚Äñexp x‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ := by
  rw [congr_fun (exp_eq_tsum ùïÇ (ùî∏ := ùî∏)) x]
  exact tsum_of_norm_bounded (hasSum_real_exp ‚Äñx‚Äñ)
    (norm_expSeries_term_le' (ùïÇ := ùïÇ) x)

include ùïÇ in
/-- `‚Äñexp x - 1‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ - 1` in any complete normed algebra with `‚Äñ1‚Äñ = 1`. -/
theorem norm_exp_sub_one_le (x : ùî∏) : ‚Äñexp x - 1‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ - 1 := by
  -- exp x - 1 = ‚àë'_{n‚â•1} (n!)‚Åª¬π x^n. Bound term-by-term.
  set f : ‚Ñï ‚Üí ùî∏ := fun n => (n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ùïÇ := ùïÇ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hexp_eq : exp x = ‚àë' n, f n := congr_fun (exp_eq_tsum ùïÇ (ùî∏ := ùî∏)) x
  have h_sub : exp x - 1 = ‚àë' n, f (n + 1) := by
    rw [hexp_eq, hf_summ.tsum_eq_zero_add, hf0, add_sub_cancel_left]
  rw [h_sub]
  exact tsum_of_norm_bounded (hasSum_real_exp_norm_shift x)
    (fun n => norm_expSeries_term_le' (ùïÇ := ùïÇ) x (n + 1))

include ùïÇ in
theorem norm_exp_sub_one_sub_le (x : ùî∏) :
    ‚Äñexp x - 1 - x‚Äñ ‚â§ Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ := by
  set f : ‚Ñï ‚Üí ùî∏ := fun n => (n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ùïÇ := ùïÇ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have h_sub : exp x - 1 - x = ‚àë' n, f (n + 2) := by
    rw [congr_fun (exp_eq_tsum ùïÇ (ùî∏ := ùî∏)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add; simp only [hf1] at h2
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp ‚Äñx‚Äñ
  have h_summ2 : Summable (fun n => ((n + 2) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 2)) :=
    (summable_nat_add_iff 2).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 2) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 2)) (Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ) := by
    rw [h_summ2.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2; linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ùïÇ := ùïÇ) x (n + 2))

include ùïÇ in
/-- Third-order exp remainder: `‚Äñexp(x) - 1 - x - x¬≤/2‚Äñ ‚â§ exp(‚Äñx‚Äñ) - 1 - ‚Äñx‚Äñ - ‚Äñx‚Äñ¬≤/2`. -/
theorem norm_exp_sub_one_sub_sub_le (x : ùî∏) :
    ‚Äñexp x - 1 - x - (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2‚Äñ ‚â§
      Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ - ‚Äñx‚Äñ ^ 2 / 2 := by
  set f : ‚Ñï ‚Üí ùî∏ := fun n => (n !‚Åª¬π : ùïÇ) ‚Ä¢ x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ùïÇ := ùïÇ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have hf2 : f 2 = (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    ring
  have h_sub : exp x - 1 - x - (2 : ùïÇ)‚Åª¬π ‚Ä¢ x ^ 2 = ‚àë' n, f (n + 3) := by
    rw [congr_fun (exp_eq_tsum ùïÇ (ùî∏ := ùî∏)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp ‚Äñx‚Äñ
  have h_summ3 : Summable (fun n => ((n + 3) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 3)) :=
    (summable_nat_add_iff 3).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 3) !‚Åª¬π : ‚Ñù) * ‚Äñx‚Äñ ^ (n + 3))
      (Real.exp ‚Äñx‚Äñ - 1 - ‚Äñx‚Äñ - ‚Äñx‚Äñ ^ 2 / 2) := by
    rw [h_summ3.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ùïÇ := ùïÇ) x (n + 3))

include ùïÇ in
theorem exp_eq_one_of_norm_lt (z : ùî∏) (hz : exp z = 1) (hn : ‚Äñz‚Äñ < Real.log 2) :
    z = 0 := by
  have hkey : z = -(exp z - 1 - z) := by rw [hz]; simp
  have hbound : ‚Äñz‚Äñ ‚â§ Real.exp ‚Äñz‚Äñ - 1 - ‚Äñz‚Äñ := by
    calc ‚Äñz‚Äñ = ‚Äñ-(exp z - 1 - z)‚Äñ := by conv_lhs => rw [hkey]
      _ = ‚Äñexp z - 1 - z‚Äñ := norm_neg _
      _ ‚â§ Real.exp ‚Äñz‚Äñ - 1 - ‚Äñz‚Äñ := norm_exp_sub_one_sub_le (ùïÇ := ùïÇ) z
  by_contra h
  have hzpos : 0 < ‚Äñz‚Äñ := norm_pos_iff.mpr h
  have hexp_lt : Real.exp ‚Äñz‚Äñ < 2 := by
    calc Real.exp ‚Äñz‚Äñ < Real.exp (Real.log 2) := Real.exp_strictMono hn
      _ = 2 := Real.exp_log (by norm_num)
  have h_half : ‚Äñz‚Äñ < 1 / 2 := by linarith
  have h_exp_bound : Real.exp ‚Äñz‚Äñ * (1 - ‚Äñz‚Äñ) ‚â§ 1 := by
    have h_exp := hasSum_real_exp ‚Äñz‚Äñ
    have h_geom := hasSum_geometric_of_lt_one (norm_nonneg z) (by linarith)
    have : Real.exp ‚Äñz‚Äñ ‚â§ (1 - ‚Äñz‚Äñ)‚Åª¬π := by
      calc Real.exp ‚Äñz‚Äñ = ‚àë' n, (n !‚Åª¬π : ‚Ñù) * ‚Äñz‚Äñ ^ n := h_exp.tsum_eq.symm
        _ ‚â§ ‚àë' n, ‚Äñz‚Äñ ^ n := by
            exact h_exp.summable.tsum_le_tsum
              (fun n => by
                calc (n !‚Åª¬π : ‚Ñù) * ‚Äñz‚Äñ ^ n ‚â§ 1 * ‚Äñz‚Äñ ^ n := by
                      apply mul_le_mul_of_nonneg_right _ (pow_nonneg (norm_nonneg z) n)
                      exact inv_le_one_of_one_le‚ÇÄ
                        (by exact_mod_cast Nat.one_le_iff_ne_zero.mpr (Nat.factorial_ne_zero n))
                  _ = ‚Äñz‚Äñ ^ n := one_mul _)
              h_geom.summable
        _ = (1 - ‚Äñz‚Äñ)‚Åª¬π := h_geom.tsum_eq
    calc Real.exp ‚Äñz‚Äñ * (1 - ‚Äñz‚Äñ) ‚â§ (1 - ‚Äñz‚Äñ)‚Åª¬π * (1 - ‚Äñz‚Äñ) := by gcongr; linarith
      _ = 1 := inv_mul_cancel‚ÇÄ (by linarith)
  nlinarith

include ùïÇ in
theorem commute_logOnePlus_of_commute (x a : ùî∏) (hxa : Commute x a) :
    Commute (logOnePlus (ùïÇ := ùïÇ) x) a := by
  unfold logOnePlus logSeriesTerm
  apply Commute.tsum_left
  intro n
