        тЙд тАЦyтВБтАЦ * тАЦyтВВтАЦ * тАЦyтВГтАЦ * тАЦyтВДтАЦ * тАЦxтВЕ - yтВЕтАЦ * тАЦxтВЖтАЦ * тАЦxтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд N * N * N * N * тАЦxтВЕ - yтВЕтАЦ * N * N := by gcongr
      _ = N ^ 6 * тАЦxтВЕ - yтВЕтАЦ := by ring
  have htтВЖ : тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВЖ - yтВЖтАЦ := by
    calc тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗтАЦ
        тЙд тАЦyтВБтАЦ * тАЦyтВВтАЦ * тАЦyтВГтАЦ * тАЦyтВДтАЦ * тАЦyтВЕтАЦ * тАЦxтВЖ - yтВЖтАЦ * тАЦxтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд N * N * N * N * N * тАЦxтВЖ - yтВЖтАЦ * N := by gcongr
      _ = N ^ 6 * тАЦxтВЖ - yтВЖтАЦ := by ring
  have htтВЗ : тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ)тАЦ тЙд N ^ 6 * тАЦxтВЗ - yтВЗтАЦ := by
    calc тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ)тАЦ
        тЙд тАЦyтВБтАЦ * тАЦyтВВтАЦ * тАЦyтВГтАЦ * тАЦyтВДтАЦ * тАЦyтВЕтАЦ * тАЦyтВЖтАЦ * тАЦxтВЗ - yтВЗтАЦ := norm_7prod_le _ _ _ _ _ _ _
      _ тЙд N * N * N * N * N * N * тАЦxтВЗ - yтВЗтАЦ := by gcongr
      _ = N ^ 6 * тАЦxтВЗ - yтВЗтАЦ := by ring
  calc тАЦ(xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ +
        yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ +
        yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ +
        yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ +
        yтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗ +
        yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗ +
        yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ)тАЦ
      тЙд тАЦ(xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ +
          тАЦyтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ +
          тАЦyтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗтАЦ +
          тАЦyтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗтАЦ +
          тАЦyтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗтАЦ +
          тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗтАЦ +
          тАЦyтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ)тАЦ := by
        have a1 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗ)
              (yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * (xтВЗ - yтВЗ))
        have a2 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗ)
              (yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * (xтВЖ - yтВЖ) * xтВЗ)
        have a3 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ)
              (yтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗ)
        have a4 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ)
              (yтВБ * yтВВ * yтВГ * (xтВД - yтВД) * xтВЕ * xтВЖ * xтВЗ)
        have a5 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ + yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ)
              (yтВБ * yтВВ * (xтВГ - yтВГ) * xтВД * xтВЕ * xтВЖ * xтВЗ)
        have a6 := norm_add_le
              ((xтВБ - yтВБ) * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ)
              (yтВБ * (xтВВ - yтВВ) * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ)
        linarith
    _ тЙд N ^ 6 * тАЦxтВБ - yтВБтАЦ + N ^ 6 * тАЦxтВВ - yтВВтАЦ + N ^ 6 * тАЦxтВГ - yтВГтАЦ + N ^ 6 * тАЦxтВД - yтВДтАЦ + N ^ 6 * тАЦxтВЕ - yтВЕтАЦ + N ^ 6 * тАЦxтВЖ - yтВЖтАЦ + N ^ 6 * тАЦxтВЗ - yтВЗтАЦ := by
        linarith [htтВБ, htтВВ, htтВГ, htтВД, htтВЕ, htтВЖ, htтВЗ]
    _ = N ^ 6 * (тАЦxтВБ - yтВБтАЦ + тАЦxтВВ - yтВВтАЦ + тАЦxтВГ - yтВГтАЦ + тАЦxтВД - yтВДтАЦ + тАЦxтВЕ - yтВЕтАЦ + тАЦxтВЖ - yтВЖтАЦ + тАЦxтВЗ - yтВЗтАЦ) := by ring

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- **Scaled 7-letter Lipschitz** (local copy):
`тАЦcтАв(xтВБ┬╖тАж┬╖xтВЗ) тИТ cтАв(yтВБ┬╖тАж┬╖yтВЗ)тАЦ тЙд cb┬╖7┬╖NтБ╢┬╖D` when `тАЦcтАЦ тЙд cb`,
`тАЦxс╡втАЦ, тАЦyс╡втАЦ тЙд N`, and `тАЦxс╡в тИТ yс╡втАЦ тЙд D`.
Local copy of `SymmetricQuintic.deg7_smul_word_diff_le`. -/
private lemma deg7_smul_word_diff_le_basic
    (c : ЁЭХВ) (cb : тДЭ) (hc : тАЦcтАЦ тЙд cb)
    (xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ xтВЗ yтВБ yтВВ yтВГ yтВД yтВЕ yтВЖ yтВЗ : ЁЭФ╕) (N D : тДЭ)
    (hxтВБ : тАЦxтВБтАЦ тЙд N) (hxтВВ : тАЦxтВВтАЦ тЙд N) (hxтВГ : тАЦxтВГтАЦ тЙд N) (hxтВД : тАЦxтВДтАЦ тЙд N)
    (hxтВЕ : тАЦxтВЕтАЦ тЙд N) (hxтВЖ : тАЦxтВЖтАЦ тЙд N) (hxтВЗ : тАЦxтВЗтАЦ тЙд N)
    (hyтВБ : тАЦyтВБтАЦ тЙд N) (hyтВВ : тАЦyтВВтАЦ тЙд N) (hyтВГ : тАЦyтВГтАЦ тЙд N) (hyтВД : тАЦyтВДтАЦ тЙд N)
    (hyтВЕ : тАЦyтВЕтАЦ тЙд N) (hyтВЖ : тАЦyтВЖтАЦ тЙд N) (hyтВЗ : тАЦyтВЗтАЦ тЙд N)
    (hdтВБ : тАЦxтВБ - yтВБтАЦ тЙд D) (hdтВВ : тАЦxтВВ - yтВВтАЦ тЙд D) (hdтВГ : тАЦxтВГ - yтВГтАЦ тЙд D)
    (hdтВД : тАЦxтВД - yтВДтАЦ тЙд D) (hdтВЕ : тАЦxтВЕ - yтВЕтАЦ тЙд D) (hdтВЖ : тАЦxтВЖ - yтВЖтАЦ тЙд D) (hdтВЗ : тАЦxтВЗ - yтВЗтАЦ тЙд D)
    (hcb : 0 тЙд cb) (hN_nn : 0 тЙд N) (hD_nn : 0 тЙд D) :
    тАЦc тАв (xтВБ * xтВВ * xтВГ * xтВД * xтВЕ * xтВЖ * xтВЗ) - c тАв (yтВБ * yтВВ * yтВГ * yтВД * yтВЕ * yтВЖ * yтВЗ)тАЦ тЙд
      cb * 7 * N^6 * D := by
  rw [тЖР smul_sub]
  have hwd : тАЦxтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗтАЦ тЙд
             N^6 * (тАЦxтВБ - yтВБтАЦ + тАЦxтВВ - yтВВтАЦ + тАЦxтВГ - yтВГтАЦ + тАЦxтВД - yтВДтАЦ + тАЦxтВЕ - yтВЕтАЦ + тАЦxтВЖ - yтВЖтАЦ + тАЦxтВЗ - yтВЗтАЦ) :=
    word_7_diff_le_basic xтВБ xтВВ xтВГ xтВД xтВЕ xтВЖ xтВЗ yтВБ yтВВ yтВГ yтВД yтВЕ yтВЖ yтВЗ N hxтВБ hxтВВ hxтВГ hxтВД hxтВЕ hxтВЖ hxтВЗ hyтВБ hyтВВ hyтВГ hyтВД hyтВЕ hyтВЖ hyтВЗ hN_nn
  have hwd_bound : N^6 * (тАЦxтВБ - yтВБтАЦ + тАЦxтВВ - yтВВтАЦ + тАЦxтВГ - yтВГтАЦ + тАЦxтВД - yтВДтАЦ + тАЦxтВЕ - yтВЕтАЦ + тАЦxтВЖ - yтВЖтАЦ + тАЦxтВЗ - yтВЗтАЦ) тЙд
             7 * N^6 * D := by
    have hN6_nn : 0 тЙд N^6 := pow_nonneg hN_nn 6
    nlinarith [hdтВБ, hdтВВ, hdтВГ, hdтВД, hdтВЕ, hdтВЖ, hdтВЗ, hN6_nn]
  have hwd2 : тАЦxтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗтАЦ тЙд 7 * N^6 * D := le_trans hwd hwd_bound
  have h_pos : 0 тЙд 7 * N^6 * D := by positivity
  calc тАЦc тАв (xтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗ)тАЦ
      тЙд тАЦcтАЦ * тАЦxтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗтАЦ := norm_smul_le _ _
    _ тЙд cb * тАЦxтВБ*xтВВ*xтВГ*xтВД*xтВЕ*xтВЖ*xтВЗ - yтВБ*yтВВ*yтВГ*yтВД*yтВЕ*yтВЖ*yтВЗтАЦ := mul_le_mul_of_nonneg_right hc (norm_nonneg _)
    _ тЙд cb * (7 * N^6 * D) := mul_le_mul_of_nonneg_left hwd2 hcb
    _ = cb * 7 * N^6 * D := by ring

-- Per-i diff bound: `тАЦbchSepticTerm z y i тИТ bchSepticTerm x y iтАЦ тЙд (216/30240) ┬╖ 7 ┬╖ MтБ╢ ┬╖ тАЦzтИТxтАЦ`
-- (uniform over all 126 indices, since each word has тЙд 7 'a'-positions).
set_option maxHeartbeats 64000000 in
private lemma bchSepticTerm_diff_norm_le (z x y : ЁЭФ╕) (M : тДЭ)
    (hz : тАЦzтАЦ тЙд M) (hx : тАЦxтАЦ тЙд M) (hy : тАЦyтАЦ тЙд M) (hM_nn : 0 тЙд M) :
    тИА i : Fin 126, тАЦbchSepticTerm (ЁЭХВ := ЁЭХВ) z y i -
                     bchSepticTerm (ЁЭХВ := ЁЭХВ) x y iтАЦ тЙд
      (216 / 30240 : тДЭ) * 7 * M^6 * тАЦz - xтАЦ := by
  intro i
  set D := тАЦz - xтАЦ with hD_def
  have hD_nn : 0 тЙд D := norm_nonneg _
  have hzx_le_D : тАЦz - xтАЦ тЙд D := le_refl _
  have hyy_le_D : тАЦy - yтАЦ тЙд D := by rw [sub_self, norm_zero]; exact hD_nn
  match i with
  | тЯи0, _тЯй =>
    show тАЦ(1 / 30240 : ЁЭХВ) тАв (z * z * z * z * z * z * y) - (1 / 30240 : ЁЭХВ) тАв (x * x * x * x * x * x * y)тАЦ тЙд
         (216 / 30240 : тДЭ) * 7 * M^6 * D
    exact deg7_smul_word_diff_le_basic (1 / 30240 : ЁЭХВ) (216 / 30240 : тДЭ)
        (by rw [norm_div]; simp [RCLike.norm_ofNat] <;> norm_num)
        z z z z z z y
        x x x x x x y
        M D
        hz hz hz hz hz hz hy
        hx hx hx hx hx hx hy
        hzx_le_D hzx_le_D hzx_le_D hzx_le_D hzx_le_D hzx_le_D hyy_le_D
