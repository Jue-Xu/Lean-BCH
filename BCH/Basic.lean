/-- **Homogeneity of `bch_sextic_term`**: `ZтВЖ(cтАвa, cтАвb) = cтБ╢ тАв ZтВЖ(a,b)`. -/
theorem bch_sextic_term_smul (a b : ЁЭФ╕) (c : ЁЭХВ) :
    bch_sextic_term ЁЭХВ (c тАв a) (c тАв b) = c ^ 6 тАв bch_sextic_term ЁЭХВ a b := by
  unfold bch_sextic_term
  simp only [six_fold_smul_mul c, smul_comm _ (c ^ 6 : ЁЭХВ), тЖР smul_add]

