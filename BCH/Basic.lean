/-! ### Quintic algebraic identity for BCH -/

-- The degree-4 pure identity: verified by noncomm_ring at Ring level (no ЁЭХВ needed).
-- After ├Ч24 clearing: the YтВД-┬╜(YтВБYтВГ+YтВВ┬▓+YтВГYтВБ)+тЕУ(YтВБ┬▓YтВВ+...)-┬╝YтВБтБ┤+CтВД = 0.
omit [NormedAlgebra ЁЭХВ ЁЭФ╕] [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
theorem quintic_pure_identity_cleared (a b : ЁЭФ╕) :
    -- 24├Ч[YтВД-┬╜(YтВБYтВГ+YтВВ┬▓+YтВГYтВБ)+тЕУ(YтВБ┬▓YтВВ+YтВБYтВВYтВБ+YтВВYтВБ┬▓)-┬╝YтВБтБ┤+CтВД] = 0
    -- z := a+b, U := 2ab+a┬▓+b┬▓ (= 2YтВВ)
    (a ^ 4 + 4 тАв (a ^ 3 * b) + 6 тАв (a ^ 2 * b ^ 2) + 4 тАв (a * b ^ 3) + b ^ 4) -
    2 тАв ((a + b) * (a ^ 3 + 3 тАв (a ^ 2 * b) + 3 тАв (a * b ^ 2) + b ^ 3) +
         (a ^ 3 + 3 тАв (a ^ 2 * b) + 3 тАв (a * b ^ 2) + b ^ 3) * (a + b)) -
    3 тАв ((2 тАв (a * b) + a ^ 2 + b ^ 2) * (2 тАв (a * b) + a ^ 2 + b ^ 2)) +
    4 тАв ((a + b) ^ 2 * (2 тАв (a * b) + a ^ 2 + b ^ 2) +
         (a + b) * (2 тАв (a * b) + a ^ 2 + b ^ 2) * (a + b) +
         (2 тАв (a * b) + a ^ 2 + b ^ 2) * (a + b) ^ 2) -
    6 тАв (a + b) ^ 4 +
    (b * (a * (a * b - b * a) - (a * b - b * a) * a) -
     (a * (a * b - b * a) - (a * b - b * a) * a) * b) = 0 := by
  noncomm_ring

