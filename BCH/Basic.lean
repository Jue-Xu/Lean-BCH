private theorem norm_y3_sub_z3_sub_y3_4_le (y P T‚ÇÇ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hs_le_one : s ‚â§ 1)
    (hz : ‚Äñy - P‚Äñ ‚â§ s) (hP : ‚ÄñP‚Äñ ‚â§ s ^ 2)
    (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) :
    ‚Äñy ^ 3 - (y - P) ^ 3 -
      ((y - P) ^ 2 * T‚ÇÇ + (y - P) * T‚ÇÇ * (y - P) + T‚ÇÇ * (y - P) ^ 2)‚Äñ ‚â§ 19 * s ^ 5 := by
  -- y¬≥ - z¬≥ - y3_4 = (P-T‚ÇÇ)¬∑z¬≤ + z¬≤¬∑(P-T‚ÇÇ) + z¬∑(P-T‚ÇÇ)¬∑z + P¬∑z¬∑P + P¬≤¬∑z + P¬≥ + z¬∑P¬≤
  have heq : y ^ 3 - (y - P) ^ 3 -
      ((y - P) ^ 2 * T‚ÇÇ + (y - P) * T‚ÇÇ * (y - P) + T‚ÇÇ * (y - P) ^ 2) =
      (P - T‚ÇÇ) * (y - P) ^ 2 + (y - P) ^ 2 * (P - T‚ÇÇ) +
        (y - P) * (P - T‚ÇÇ) * (y - P) +
