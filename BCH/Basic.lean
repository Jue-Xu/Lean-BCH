private theorem norm_I2_octic_residual_RHS_le (z P T‚ÇÇ T‚ÇÉ T‚ÇÑ T‚ÇÖ : ùî∏)
    {s K_PmT5 K_P2' K_PzP' K_P3' : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hK_PmT5_nn : 0 ‚â§ K_PmT5) (hK_P2'_nn : 0 ‚â§ K_P2')
    (hK_PzP'_nn : 0 ‚â§ K_PzP') (hK_P3'_nn : 0 ‚â§ K_P3')
    (hz : ‚Äñz‚Äñ ‚â§ s)
    (hPmT5_le : ‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ‚Äñ ‚â§ K_PmT5 * s ^ 6)
    (hP2'_le :
        ‚ÄñP ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
            T‚ÇÇ * T‚ÇÑ - T‚ÇÉ * T‚ÇÉ - T‚ÇÑ * T‚ÇÇ‚Äñ ‚â§ K_P2' * s ^ 7)
    (hPzP'_le :
        ‚ÄñP * z * P - T‚ÇÇ * z * T‚ÇÇ - T‚ÇÇ * z * T‚ÇÉ - T‚ÇÉ * z * T‚ÇÇ -
            T‚ÇÇ * z * T‚ÇÑ - T‚ÇÉ * z * T‚ÇÉ - T‚ÇÑ * z * T‚ÇÇ‚Äñ ‚â§ K_PzP' * s ^ 8)
    (hP3'_le :
        ‚ÄñP ^ 3 - T‚ÇÇ ^ 3 - T‚ÇÇ ^ 2 * T‚ÇÉ - T‚ÇÇ * T‚ÇÉ * T‚ÇÇ - T‚ÇÉ * T‚ÇÇ ^ 2‚Äñ ‚â§
            K_P3' * s ^ 8) :
    ‚Äñz ^ 2 * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) + z * (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * z +
      (P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ - T‚ÇÖ) * z ^ 2 +
      z * (P ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
           T‚ÇÇ * T‚ÇÑ - T‚ÇÉ * T‚ÇÉ - T‚ÇÑ * T‚ÇÇ) +
      (P * z * P - T‚ÇÇ * z * T‚ÇÇ - T‚ÇÇ * z * T‚ÇÉ - T‚ÇÉ * z * T‚ÇÇ -
           T‚ÇÇ * z * T‚ÇÑ - T‚ÇÉ * z * T‚ÇÉ - T‚ÇÑ * z * T‚ÇÇ) +
      (P ^ 2 - T‚ÇÇ ^ 2 - T‚ÇÇ * T‚ÇÉ - T‚ÇÉ * T‚ÇÇ -
           T‚ÇÇ * T‚ÇÑ - T‚ÇÉ * T‚ÇÉ - T‚ÇÑ * T‚ÇÇ) * z +
      (P ^ 3 - T‚ÇÇ ^ 3 - T‚ÇÇ ^ 2 * T‚ÇÉ - T‚ÇÇ * T‚ÇÉ * T‚ÇÇ - T‚ÇÉ * T‚ÇÇ ^ 2)‚Äñ ‚â§
      (3 * K_PmT5 + 2 * K_P2' + K_PzP' + K_P3') * s ^ 8 := by
  -- Bound each of the 7 outer terms.
