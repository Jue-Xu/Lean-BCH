/-! ### Norm bound for exp in Banach algebras

We prove `тАЦexp xтАЦ тЙд Real.exp тАЦxтАЦ`, which Mathlib has for тДВ but not for general
Banach algebras. The proof goes through the power series representation.
-/

section ExpNormBounds

omit [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
/-- Helper: the real exp series evaluated at r gives a HasSum to Real.exp r. -/
private lemma hasSum_real_exp (r : тДЭ) :
    HasSum (fun n => (n !тБ╗┬╣ : тДЭ) * r ^ n) (Real.exp r) := by
  have h := exp_series_hasSum_exp' (ЁЭХВ := тДЭ) (ЁЭФ╕ := тДЭ) r
  simp only [smul_eq_mul] at h
  rwa [congr_fun Real.exp_eq_exp_тДЭ r]

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
private lemma summable_real_exp_norm_shift (x : ЁЭФ╕) :
    Summable (fun n => ((n + 1) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 1)) :=
  (summable_nat_add_iff 1).mpr (hasSum_real_exp тАЦxтАЦ).summable

omit [NormOneClass ЁЭФ╕] [CompleteSpace ЁЭФ╕] in
private lemma hasSum_real_exp_norm_shift (x : ЁЭФ╕) :
    HasSum (fun n => ((n + 1) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 1)) (Real.exp тАЦxтАЦ - 1) := by
  -- Strategy: the full series sums to exp тАЦxтАЦ, its 0th term is 1,
  -- so the tail sums to exp тАЦxтАЦ - 1.
  have h := hasSum_real_exp тАЦxтАЦ
  -- Use Summable.hasSum_iff to prove the shifted sum has the right value.
  have hsumm : Summable (fun n => ((n + 1) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 1)) :=
    summable_real_exp_norm_shift x
  rw [hsumm.hasSum_iff]
  -- Need: тИС' n, ((n+1)!тБ╗┬╣ * тАЦxтАЦ^(n+1)) = Real.exp тАЦxтАЦ - 1
  -- From h: тИС' n, (n!тБ╗┬╣ * тАЦxтАЦ^n) = Real.exp тАЦxтАЦ
  have h_full := h.tsum_eq
  -- The full tsum = 0th term + shifted tsum
  have h_split : тИС' n, (n !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ n =
      (0 !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ 0 + тИС' n, ((n + 1) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 1) :=
    h.summable.tsum_eq_zero_add
  rw [h_full] at h_split
  simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero] at h_split
  linarith

include ЁЭХВ in
omit [CompleteSpace ЁЭФ╕] in
/-- The exp series term norm bound: `тАЦ(n!)тБ╗┬╣ тАв x^nтАЦ тЙд (n!)тБ╗┬╣ * тАЦxтАЦ^n`. -/
private lemma norm_expSeries_term_le' (x : ЁЭФ╕) (n : тДХ) :
    тАЦ(n !тБ╗┬╣ : ЁЭХВ) тАв x ^ nтАЦ тЙд (n !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ n := by
  calc тАЦ(n !тБ╗┬╣ : ЁЭХВ) тАв x ^ nтАЦ
      тЙд тАЦ(n !тБ╗┬╣ : ЁЭХВ)тАЦ * тАЦx ^ nтАЦ := norm_smul_le _ _
    _ тЙд (n !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ n := by
        gcongr
        ┬╖ rw [norm_inv, RCLike.norm_natCast]
        ┬╖ exact norm_pow_le x n

include ЁЭХВ in
omit [CompleteSpace ЁЭФ╕] in
/-- `тАЦexp xтАЦ тЙд Real.exp тАЦxтАЦ` in any complete normed algebra with `тАЦ1тАЦ = 1`. -/
theorem norm_exp_le (x : ЁЭФ╕) : тАЦexp xтАЦ тЙд Real.exp тАЦxтАЦ := by
  rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
  exact tsum_of_norm_bounded (hasSum_real_exp тАЦxтАЦ)
    (norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x)

include ЁЭХВ in
/-- `тАЦexp x - 1тАЦ тЙд Real.exp тАЦxтАЦ - 1` in any complete normed algebra with `тАЦ1тАЦ = 1`. -/
theorem norm_exp_sub_one_le (x : ЁЭФ╕) : тАЦexp x - 1тАЦ тЙд Real.exp тАЦxтАЦ - 1 := by
  -- exp x - 1 = тИС'_{nтЙе1} (n!)тБ╗┬╣ x^n. Bound term-by-term.
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ЁЭХВ := ЁЭХВ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hexp_eq : exp x = тИС' n, f n := congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x
  have h_sub : exp x - 1 = тИС' n, f (n + 1) := by
    rw [hexp_eq, hf_summ.tsum_eq_zero_add, hf0, add_sub_cancel_left]
  rw [h_sub]
  exact tsum_of_norm_bounded (hasSum_real_exp_norm_shift x)
    (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 1))

include ЁЭХВ in
theorem norm_exp_sub_one_sub_le (x : ЁЭФ╕) :
    тАЦexp x - 1 - xтАЦ тЙд Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ := by
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ЁЭХВ := ЁЭХВ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have h_sub : exp x - 1 - x = тИС' n, f (n + 2) := by
    rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add; simp only [hf1] at h2
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp тАЦxтАЦ
  have h_summ2 : Summable (fun n => ((n + 2) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 2)) :=
    (summable_nat_add_iff 2).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 2) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 2)) (Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ) := by
    rw [h_summ2.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2; linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 2))

include ЁЭХВ in
/-- Third-order exp remainder: `тАЦexp(x) - 1 - x - x┬▓/2тАЦ тЙд exp(тАЦxтАЦ) - 1 - тАЦxтАЦ - тАЦxтАЦ┬▓/2`. -/
theorem norm_exp_sub_one_sub_sub_le (x : ЁЭФ╕) :
    тАЦexp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2тАЦ тЙд
      Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 := by
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ЁЭХВ := ЁЭХВ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have hf2 : f 2 = (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    ring
  have h_sub : exp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 = тИС' n, f (n + 3) := by
    rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp тАЦxтАЦ
  have h_summ3 : Summable (fun n => ((n + 3) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 3)) :=
    (summable_nat_add_iff 3).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 3) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 3))
      (Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2) := by
    rw [h_summ3.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 3))

include ЁЭХВ in
theorem exp_eq_one_of_norm_lt (z : ЁЭФ╕) (hz : exp z = 1) (hn : тАЦzтАЦ < Real.log 2) :
    z = 0 := by
  have hkey : z = -(exp z - 1 - z) := by rw [hz]; simp
  have hbound : тАЦzтАЦ тЙд Real.exp тАЦzтАЦ - 1 - тАЦzтАЦ := by
    calc тАЦzтАЦ = тАЦ-(exp z - 1 - z)тАЦ := by conv_lhs => rw [hkey]
      _ = тАЦexp z - 1 - zтАЦ := norm_neg _
      _ тЙд Real.exp тАЦzтАЦ - 1 - тАЦzтАЦ := norm_exp_sub_one_sub_le (ЁЭХВ := ЁЭХВ) z
  by_contra h
  have hzpos : 0 < тАЦzтАЦ := norm_pos_iff.mpr h
  have hexp_lt : Real.exp тАЦzтАЦ < 2 := by
    calc Real.exp тАЦzтАЦ < Real.exp (Real.log 2) := Real.exp_strictMono hn
      _ = 2 := Real.exp_log (by norm_num)
  have h_half : тАЦzтАЦ < 1 / 2 := by linarith
  have h_exp_bound : Real.exp тАЦzтАЦ * (1 - тАЦzтАЦ) тЙд 1 := by
    have h_exp := hasSum_real_exp тАЦzтАЦ
    have h_geom := hasSum_geometric_of_lt_one (norm_nonneg z) (by linarith)
    have : Real.exp тАЦzтАЦ тЙд (1 - тАЦzтАЦ)тБ╗┬╣ := by
      calc Real.exp тАЦzтАЦ = тИС' n, (n !тБ╗┬╣ : тДЭ) * тАЦzтАЦ ^ n := h_exp.tsum_eq.symm
        _ тЙд тИС' n, тАЦzтАЦ ^ n := by
            exact h_exp.summable.tsum_le_tsum
              (fun n => by
                calc (n !тБ╗┬╣ : тДЭ) * тАЦzтАЦ ^ n тЙд 1 * тАЦzтАЦ ^ n := by
                      apply mul_le_mul_of_nonneg_right _ (pow_nonneg (norm_nonneg z) n)
                      exact inv_le_one_of_one_leтВА
                        (by exact_mod_cast Nat.one_le_iff_ne_zero.mpr (Nat.factorial_ne_zero n))
                  _ = тАЦzтАЦ ^ n := one_mul _)
              h_geom.summable
        _ = (1 - тАЦzтАЦ)тБ╗┬╣ := h_geom.tsum_eq
    calc Real.exp тАЦzтАЦ * (1 - тАЦzтАЦ) тЙд (1 - тАЦzтАЦ)тБ╗┬╣ * (1 - тАЦzтАЦ) := by gcongr; linarith
      _ = 1 := inv_mul_cancelтВА (by linarith)
  nlinarith

include ЁЭХВ in
theorem commute_logOnePlus_of_commute (x a : ЁЭФ╕) (hxa : Commute x a) :
    Commute (logOnePlus (ЁЭХВ := ЁЭХВ) x) a := by
  unfold logOnePlus logSeriesTerm
  apply Commute.tsum_left
  intro n
  exact (hxa.pow_left (n + 1)).smul_left _

end ExpNormBounds

/-! ### Smallness condition for the BCH element -/

include ЁЭХВ in
/-- When `тАЦaтАЦ + тАЦbтАЦ < ln 2`, we have `тАЦexp(a) ┬╖ exp(b) - 1тАЦ < 1`.
This is the key smallness condition ensuring the log series converges. -/
theorem norm_exp_mul_exp_sub_one_lt_one (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    тАЦexp a * exp b - 1тАЦ < 1 := by
  -- Factor: exp(a) * exp(b) - 1 = (exp(a) - 1) * exp(b) + (exp(b) - 1)
  have hfactor : exp a * exp b - 1 = (exp a - 1) * exp b + (exp b - 1) := by
    rw [sub_mul, one_mul]; abel
  rw [hfactor]
  have hexp_a_ge : 0 тЙд Real.exp тАЦaтАЦ - 1 := by
    linarith [Real.add_one_le_exp тАЦaтАЦ, norm_nonneg a]
  have hexp_b_pos : 0 тЙд Real.exp тАЦbтАЦ := (Real.exp_pos _).le
  calc тАЦ(exp a - 1) * exp b + (exp b - 1)тАЦ
      тЙд тАЦ(exp a - 1) * exp bтАЦ + тАЦexp b - 1тАЦ := norm_add_le _ _
    _ тЙд тАЦexp a - 1тАЦ * тАЦexp bтАЦ + тАЦexp b - 1тАЦ := by
        gcongr; exact norm_mul_le _ _
    _ тЙд (Real.exp тАЦaтАЦ - 1) * Real.exp тАЦbтАЦ + (Real.exp тАЦbтАЦ - 1) := by
        gcongr
        ┬╖ exact norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) a
        ┬╖ exact norm_exp_le (ЁЭХВ := ЁЭХВ) b
        ┬╖ exact norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) b
    _ = Real.exp (тАЦaтАЦ + тАЦbтАЦ) - 1 := by rw [Real.exp_add]; ring
    _ < 1 := by
        have : Real.exp (тАЦaтАЦ + тАЦbтАЦ) < 2 := by
          calc Real.exp (тАЦaтАЦ + тАЦbтАЦ)
              < Real.exp (Real.log 2) := Real.exp_strictMono hab
            _ = 2 := Real.exp_log (by norm_num)
        linarith

include ЁЭХВ in
/-- When `тАЦaтАЦ < ln 2`, we have `тАЦexp(a) - 1тАЦ < 1`. -/
theorem norm_exp_sub_one_lt_one (a : ЁЭФ╕) (ha : тАЦaтАЦ < Real.log 2) :
    тАЦexp a - 1тАЦ < 1 := by
  have h := norm_exp_mul_exp_sub_one_lt_one (ЁЭХВ := ЁЭХВ) a (0 : ЁЭФ╕) (by simpa)
  simpa [exp_zero] using h

/-! ### Definition of the BCH element -/

include ЁЭХВ in
/-- The Baker-Campbell-Hausdorff element: the unique Z such that `exp(Z) = exp(a) ┬╖ exp(b)`.
Defined as `logOnePlus(exp(a) ┬╖ exp(b) - 1)` which converges when `тАЦaтАЦ + тАЦbтАЦ < ln 2`. -/
noncomputable def bch (a b : ЁЭФ╕) : ЁЭФ╕ := logOnePlus (ЁЭХВ := ЁЭХВ) (exp a * exp b - 1)

/-! ### The fundamental BCH identity -/

include ЁЭХВ in
/-- **The structural BCH theorem**: `exp(bch a b) = exp(a) ┬╖ exp(b)`.

This is the fundamental identity: the BCH element exponentiates back to the product.
The proof combines the log series convergence (from the smallness condition
`тАЦexp(a)┬╖exp(b) - 1тАЦ < 1`) with the `exp тИШ log = id` identity from Phase 1. -/
theorem exp_bch (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    exp (bch (ЁЭХВ := ЁЭХВ) a b) = exp a * exp b := by
  unfold bch
  have h : тАЦexp a * exp b - 1тАЦ < 1 :=
    norm_exp_mul_exp_sub_one_lt_one (ЁЭХВ := ЁЭХВ) a b hab
  have key := exp_logOnePlus (ЁЭХВ := ЁЭХВ) (exp a * exp b - 1) h
  -- key : exp (logOnePlus (exp a * exp b - 1)) = 1 + (exp a * exp b - 1)
  -- 1 + (exp a * exp b - 1) = exp a * exp b
  rw [key]; abel

/-! ### Continuity of logOnePlus on the open unit ball -/

include ЁЭХВ in
omit [CompleteSpace ЁЭФ╕] in
/-- Each log series term `y тЖж logSeriesTerm y n` is continuous. -/
private lemma continuous_logSeriesTerm (n : тДХ) :
    Continuous (fun y : ЁЭФ╕ => logSeriesTerm (ЁЭХВ := ЁЭХВ) y n) := by
  unfold logSeriesTerm
  exact continuous_const.smul (continuous_id.pow (n + 1))

/-- The geometric series `тИС (max 0 r)^(n+1)` is summable when `r < 1`. -/
private lemma summable_geometric_succ_max {r : тДЭ} (hr : r < 1) :
    Summable (fun n : тДХ => (max 0 r) ^ (n + 1)) :=
  ((summable_geometric_of_lt_one (le_max_left 0 r) (max_lt (by linarith) hr)).mul_left
    (max 0 r)).congr fun n => by ring

include ЁЭХВ in
/-- `logOnePlus` is continuous on `closedBall 0 r` for any `r < 1`. -/
private lemma continuousOn_logOnePlus {r : тДЭ} (hr : r < 1) :
    ContinuousOn (logOnePlus (ЁЭХВ := ЁЭХВ)) (Metric.closedBall (0 : ЁЭФ╕) r) := by
  unfold logOnePlus
  apply continuousOn_tsum
  ┬╖ exact fun n => (continuous_logSeriesTerm (ЁЭХВ := ЁЭХВ) n).continuousOn
  ┬╖ exact summable_geometric_succ_max hr
  ┬╖ intro n y hy
    calc тАЦlogSeriesTerm (ЁЭХВ := ЁЭХВ) y nтАЦ
        тЙд тАЦyтАЦ ^ (n + 1) := norm_logSeriesTerm_le (ЁЭХВ := ЁЭХВ) y n
      _ тЙд (max 0 r) ^ (n + 1) := by
          apply pow_le_pow_leftтВА (norm_nonneg _)
          rw [Metric.mem_closedBall, dist_zero_right] at hy
          exact hy.trans (le_max_right 0 r)

/-! ### The log тИШ exp identity -/

include ЁЭХВ in
/-- `logOnePlus(exp(a) - 1) = a` for `тАЦaтАЦ < ln 2`: the logarithm inverts the exponential.

The proof proceeds by a chain-of-neighborhoods argument:
1. Define `h(t) = logOnePlus(exp(ta) - 1) - ta` for `t тИИ [0,1]`.
2. Show `h(0) = 0` and `exp(h(t)) = 1` for all `t`.
3. Show `h` is continuous on `[0,1]`.
4. By uniform continuity on `[0,1]` (compact), find `╬┤ > 0` s.t. `тАЦh(t) - h(s)тАЦ < ln 2`
   whenever `|t-s| < ╬┤`.
5. By induction with step size `1/N < ╬┤`: `h(k/N) = 0` for all `k тЙд N`.
6. In particular `h(1) = 0`. -/
theorem logOnePlus_exp_sub_one (a : ЁЭФ╕) (ha : тАЦaтАЦ < Real.log 2) :
    logOnePlus (ЁЭХВ := ЁЭХВ) (exp a - 1) = a := by
  -- Reduce to тДЭ scalars
  rw [logOnePlus_eq_real (ЁЭХВ := ЁЭХВ)]
  set instтДЭ := NormedAlgebra.restrictScalars тДЭ ЁЭХВ ЁЭФ╕
  letI : NormedAlgebra тДЭ ЁЭФ╕ := instтДЭ
  -- Define h(t) = logOnePlus(exp(ta) - 1) - ta
  set h : тДЭ тЖТ ЁЭФ╕ := fun t =>
    @logOnePlus тДЭ _ ЁЭФ╕ _ instтДЭ (exp (t тАв a) - 1) - t тАв a with hh_def
  -- It suffices to show h(1) = 0
  suffices h1 : h 1 = 0 by
    simp only [h, one_smul] at h1
    exact sub_eq_zero.mp h1
  -- Step 1: h(0) = 0
  have h0 : h 0 = 0 := by
    simp [h, logOnePlus, logSeriesTerm, tsum_zero]
  -- Step 2: exp(h(t)) = 1 for t тИИ [0,1]
  letI : NormedAlgebra тДЪ ЁЭФ╕ := NormedAlgebra.restrictScalars тДЪ тДЭ ЁЭФ╕
  have hexp_ht : тИА t : тДЭ, t * тАЦaтАЦ < Real.log 2 тЖТ 0 тЙд t тЖТ
      exp (h t) = 1 := by
    intro t ht ht_nn
    -- exp(logOnePlus(exp(ta)-1)) = exp(ta) from exp_logOnePlus
    have hnorm : тАЦexp (t тАв a) - 1тАЦ < 1 := by
      apply @norm_exp_sub_one_lt_one тДЭ _ ЁЭФ╕ _ instтДЭ _ _
      calc тАЦt тАв aтАЦ тЙд тАЦtтАЦ * тАЦaтАЦ := norm_smul_le t a
        _ = |t| * тАЦaтАЦ := by rw [Real.norm_eq_abs]
        _ = t * тАЦaтАЦ := by rw [abs_of_nonneg ht_nn]
        _ < Real.log 2 := ht
    have hexp_log := @exp_logOnePlus тДЭ _ ЁЭФ╕ _ instтДЭ _ _ (exp (t тАв a) - 1) hnorm
    -- logOnePlus(exp(ta)-1) commutes with a
    have hcomm_exp_a : Commute (exp (t тАв a) - 1) a := by
      apply Commute.sub_left _ (Commute.one_left a)
      exact (Commute.refl a).smul_left t |>.exp_left
    have hcomm : Commute (@logOnePlus тДЭ _ ЁЭФ╕ _ instтДЭ (exp (t тАв a) - 1)) a :=
      @commute_logOnePlus_of_commute тДЭ _ ЁЭФ╕ _ instтДЭ _ _ (exp (t тАв a) - 1) a hcomm_exp_a
    -- exp(L - ta) = exp(L) * exp(-ta) since L commutes with ta
    have hcomm_ta : Commute (@logOnePlus тДЭ _ ЁЭФ╕ _ instтДЭ (exp (t тАв a) - 1)) (t тАв a) :=
      hcomm.smul_right t
    set L := @logOnePlus тДЭ _ ЁЭФ╕ _ instтДЭ (exp (t тАв a) - 1)
    show exp (L - t тАв a) = 1
    rw [show L - t тАв a = L + (-(t тАв a)) from sub_eq_add_neg L (t тАв a),
        exp_add_of_commute (hcomm_ta.neg_right), hexp_log,
        show (1 + (exp (t тАв a) - 1)) = exp (t тАв a) from by abel,
        тЖР exp_add_of_commute ((Commute.refl (t тАв a)).neg_right),
        add_neg_cancel, exp_zero]
  -- Step 3: h is continuous on [0, 1]
  have hcont : ContinuousOn h (Set.Icc 0 1) := by
    -- h = logOnePlus тИШ (exp(┬╖a) - 1) - (┬╖ тАв a)
    apply ContinuousOn.sub
    ┬╖ -- logOnePlus(exp(ta)-1) is continuous
      -- The inner function maps [0,1] into closedBall 0 ╧Б where ╧Б = exp(тАЦaтАЦ)-1 < 1
      set ╧Б := Real.exp тАЦaтАЦ - 1 with h╧Б_def
      have h╧Б_lt : ╧Б < 1 := by
        have : Real.exp тАЦaтАЦ < 2 := by
          calc Real.exp тАЦaтАЦ < Real.exp (Real.log 2) := Real.exp_strictMono ha
            _ = 2 := Real.exp_log (by norm_num)
        linarith
      -- Inner function maps [0,1] into closedBall 0 ╧Б
      have hmaps : Set.MapsTo (fun t : тДЭ => exp (t тАв a) - 1)
          (Set.Icc 0 1) (Metric.closedBall (0 : ЁЭФ╕) ╧Б) := by
        intro t ht
        rw [Metric.mem_closedBall, dist_zero_right]
        calc тАЦexp (t тАв a) - 1тАЦ
            тЙд Real.exp тАЦt тАв aтАЦ - 1 := @norm_exp_sub_one_le тДЭ _ ЁЭФ╕ _ instтДЭ _ _ (t тАв a)
          _ тЙд Real.exp (t * тАЦaтАЦ) - 1 := by
              gcongr
              calc тАЦt тАв aтАЦ тЙд |t| * тАЦaтАЦ := norm_smul_le t a
                _ = t * тАЦaтАЦ := by rw [abs_of_nonneg ht.1]
          _ тЙд Real.exp (1 * тАЦaтАЦ) - 1 := by
              gcongr; exact ht.2
          _ = ╧Б := by rw [one_mul]
      -- Inner function is continuous
      have hinner_cont : ContinuousOn (fun t : тДЭ => exp (t тАв a) - 1) (Set.Icc 0 1) :=
        ContinuousOn.sub
          (NormedSpace.exp_continuous.continuousOn.comp
            ((continuous_id.smul continuous_const).continuousOn) (Set.mapsTo_univ _ _))
          continuousOn_const
      exact ContinuousOn.comp (continuousOn_logOnePlus (ЁЭХВ := тДЭ) h╧Б_lt) hinner_cont hmaps
    ┬╖ exact (continuous_id.smul continuous_const).continuousOn
  -- Step 4-6: Chain of neighborhoods argument
  -- By uniform continuity on [0,1], find ╬┤
  have hcompact : IsCompact (Set.Icc (0:тДЭ) 1) := isCompact_Icc
  have huc := hcompact.uniformContinuousOn_of_continuous hcont
  rw [Metric.uniformContinuousOn_iff] at huc
  obtain тЯи╬┤, h╬┤_pos, h╬┤тЯй := huc (Real.log 2) (Real.log_pos (by norm_num))
  -- Choose N with 1/N < ╬┤
  obtain тЯиN, hNтЯй := exists_nat_gt (1 / ╬┤)
  have hN_pos : 0 < N := by
    rcases N with _ | n
    ┬╖ simp at hN; linarith [div_pos one_pos h╬┤_pos]
    ┬╖ exact Nat.succ_pos n
  -- Induction: h(k/N) = 0 for all k тЙд N
  suffices hind : тИА k : тДХ, k тЙд N тЖТ h (k / N) = 0 by
    have := hind N le_rfl
    rwa [show (N : тДЭ) / N = 1 from div_self (Nat.cast_ne_zero.mpr (by omega))] at this
  intro k hk
  induction k with
  | zero => simp [h0]
  | succ k ih =>
    have hk_le : k тЙд N := by omega
    have hprev := ih hk_le
    -- Membership in [0,1]
    have hN_pos_real : (0 : тДЭ) < N := Nat.cast_pos.mpr hN_pos
    have hkN_mem : (k : тДЭ) / N тИИ Set.Icc (0:тДЭ) 1 :=
      тЯиdiv_nonneg (Nat.cast_nonneg k) hN_pos_real.le,
       div_le_one_of_leтВА (Nat.cast_le.mpr hk_le) hN_pos_real.leтЯй
    have hk1N_mem : ((k+1 : тДХ) : тДЭ) / N тИИ Set.Icc (0:тДЭ) 1 :=
      тЯиdiv_nonneg (Nat.cast_nonneg _) hN_pos_real.le,
       div_le_one_of_leтВА (Nat.cast_le.mpr hk) hN_pos_real.leтЯй
    -- |(k+1)/N - k/N| = 1/N < ╬┤
    have h1N_lt : (1 : тДЭ) / N < ╬┤ := by
      rw [one_div]
      exact (inv_lt_commтВА h╬┤_pos hN_pos_real).mp (by rwa [one_div] at hN)
    have hdist' : dist ((тЖС(k + 1) : тДЭ) / тЖСN) (тЖСk / тЖСN) < ╬┤ := by
      rw [dist_comm, Real.dist_eq, show (k : тДЭ) / N - ((k + 1 : тДХ) : тДЭ) / N = -(1 / N) from by
        push_cast; field_simp; ring, abs_neg, abs_of_nonneg (by positivity : (0 : тДЭ) тЙд 1 / N)]
      exact h1N_lt
    -- Apply uniform continuity
    have hnorm_small : тАЦh ((k+1 : тДХ) / N) - h (k / N)тАЦ < Real.log 2 := by
      rw [тЖР dist_eq_norm]
      exact h╬┤ _ hk1N_mem _ hkN_mem hdist'
    -- Since h(k/N) = 0, тАЦh((k+1)/N)тАЦ < ln 2
    rw [hprev, sub_zero] at hnorm_small
    -- exp(h((k+1)/N)) = 1
    have hexp1 : exp (h ((k+1 : тДХ) / N)) = 1 :=
      hexp_ht _ (by calc ((k+1 : тДХ) : тДЭ) / N * тАЦaтАЦ
            тЙд 1 * тАЦaтАЦ := by gcongr; exact hk1N_mem.2
          _ = тАЦaтАЦ := one_mul _
          _ < Real.log 2 := ha) hk1N_mem.1
    -- By exp_eq_one_of_norm_lt
    exact exp_eq_one_of_norm_lt (ЁЭХВ := ЁЭХВ) _ hexp1 hnorm_small

/-! ### Norm estimate for `bch a b - (a + b)` -/

include ЁЭХВ in
/-- The BCH remainder bound: `тАЦbch(a,b) - (a+b)тАЦ` is quadratically small.

More precisely: `тАЦbch(a,b) - (a+b)тАЦ тЙд 3s┬▓/(2-e╦в)` where `s = тАЦaтАЦ + тАЦbтАЦ`.
The bound diverges at `s = ln 2` (the radius of convergence) and satisfies
`3s┬▓/(2-e╦в) ~ 3s┬▓/2` for small `s`.

The proof decomposes `bch(a,b) - (a+b) = (logOnePlus(y) - y) + (y - (a+b))`
where `y = exp(a)┬╖exp(b) - 1`, bounds each piece, and uses the key inequality
`exp(s)┬╖(1+s) тЙд 1 + 2s + 3s┬▓` for `s тИИ [0, ln 2)`. -/
theorem norm_bch_sub_add_le (a b : ЁЭФ╕) (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b)тАЦ тЙд
      3 * (тАЦaтАЦ + тАЦbтАЦ) ^ 2 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  set y := exp a * exp b - 1 with hy_def
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  have hs_nn : 0 тЙд s := by positivity
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have h_denom_pos : 0 < 2 - Real.exp s := by linarith
  have hy_lt : тАЦyтАЦ < 1 := norm_exp_mul_exp_sub_one_lt_one (ЁЭХВ := ЁЭХВ) a b hab
  have hy_le : тАЦyтАЦ тЙд Real.exp s - 1 := by
    have : y = (exp a - 1) * exp b + (exp b - 1) := by rw [hy_def, sub_mul, one_mul]; abel
    calc тАЦyтАЦ = тАЦ(exp a - 1) * exp b + (exp b - 1)тАЦ := by rw [this]
      _ тЙд тАЦexp a - 1тАЦ * тАЦexp bтАЦ + тАЦexp b - 1тАЦ := by
          calc _ тЙд тАЦ(exp a - 1) * exp bтАЦ + _ := norm_add_le _ _
            _ тЙд _ := by gcongr; exact norm_mul_le _ _
      _ тЙд (Real.exp тАЦaтАЦ - 1) * Real.exp тАЦbтАЦ + (Real.exp тАЦbтАЦ - 1) := by
          have h1 := norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) a
          have h2 := norm_exp_le (ЁЭХВ := ЁЭХВ) b
          have h3 := norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) b
          apply add_le_add
          ┬╖ exact mul_le_mul h1 h2 (norm_nonneg _) (by linarith [Real.add_one_le_exp тАЦaтАЦ, norm_nonneg a])
          ┬╖ exact h3
      _ = Real.exp s - 1 := by rw [hs_def, Real.exp_add]; ring
  -- Decomposition
  have hdecomp : bch (ЁЭХВ := ЁЭХВ) a b - (a + b) =
      (logOnePlus (ЁЭХВ := ЁЭХВ) y - y) + (y - (a + b)) := by unfold bch; abel
  -- Part 1: log remainder
  have hpart1 : тАЦlogOnePlus (ЁЭХВ := ЁЭХВ) y - yтАЦ тЙд (Real.exp s - 1) ^ 2 / (2 - Real.exp s) := by
    calc _ тЙд тАЦyтАЦ ^ 2 / (1 - тАЦyтАЦ) := norm_logOnePlus_sub_le (ЁЭХВ := ЁЭХВ) y hy_lt
      _ тЙд (Real.exp s - 1) ^ 2 / (2 - Real.exp s) := by
          exact div_le_divтВА (sq_nonneg _)
            (pow_le_pow_leftтВА (norm_nonneg _) hy_le _) h_denom_pos (by linarith)
  -- Part 2: exp factorization
  have hpart2 : тАЦy - (a + b)тАЦ тЙд Real.exp s - 1 - s := by
    have hident : y - (a + b) = (exp a - 1) * (exp b - 1) + (exp a - 1 - a) + (exp b - 1 - b) := by
      rw [hy_def]; noncomm_ring
    rw [hident]
    calc _ тЙд тАЦ(exp a - 1) * (exp b - 1)тАЦ + тАЦexp a - 1 - aтАЦ + тАЦexp b - 1 - bтАЦ := by
          calc _ тЙд тАЦ(exp a - 1) * (exp b - 1) + (exp a - 1 - a)тАЦ + _ := norm_add_le _ _
            _ тЙд _ := by gcongr; exact norm_add_le _ _
      _ тЙд (Real.exp тАЦaтАЦ - 1) * (Real.exp тАЦbтАЦ - 1) +
          (Real.exp тАЦaтАЦ - 1 - тАЦaтАЦ) + (Real.exp тАЦbтАЦ - 1 - тАЦbтАЦ) := by
          have ha1 := norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) a
          have hb1 := norm_exp_sub_one_le (ЁЭХВ := ЁЭХВ) b
          have ha2 := norm_exp_sub_one_sub_le (ЁЭХВ := ЁЭХВ) a
          have hb2 := norm_exp_sub_one_sub_le (ЁЭХВ := ЁЭХВ) b
          have ha_nn : 0 тЙд Real.exp тАЦaтАЦ - 1 := by
            linarith [Real.add_one_le_exp тАЦaтАЦ, norm_nonneg a]
          have hb_nn : 0 тЙд Real.exp тАЦbтАЦ - 1 := by
            linarith [Real.add_one_le_exp тАЦbтАЦ, norm_nonneg b]
          apply add_le_add (add_le_add _ ha2) hb2
          exact (norm_mul_le _ _).trans (mul_le_mul ha1 hb1 (norm_nonneg _) ha_nn)
      _ = Real.exp s - 1 - s := by rw [hs_def, Real.exp_add]; ring
  -- Combine and bound: (E-1)┬▓/(2-E) + (E-1-s) тЙд 3s┬▓/(2-E)
  -- Equivalent to: (E-1)┬▓ + (E-1-s)(2-E) тЙд 3s┬▓, i.e., E(1+s) - (1+2s) тЙд 3s┬▓
  rw [hdecomp]
  calc _ тЙд тАЦlogOnePlus (ЁЭХВ := ЁЭХВ) y - yтАЦ + тАЦy - (a + b)тАЦ := norm_add_le _ _
    _ тЙд (Real.exp s - 1) ^ 2 / (2 - Real.exp s) + (Real.exp s - 1 - s) :=
        add_le_add hpart1 hpart2
    _ тЙд 3 * s ^ 2 / (2 - Real.exp s) := by
        -- Need: (E-1)┬▓/(2-E) + (E-1-s) тЙд 3s┬▓/(2-E)
        -- Combine LHS into single fraction, then compare numerators
        rw [div_add' _ _ _ (ne_of_gt h_denom_pos)]
        apply div_le_div_of_nonneg_right _ h_denom_pos.le
        -- Goal: (E-1)┬▓ + (E-1-s)*(2-E) тЙд 3s┬▓
        set E := Real.exp s
        -- s < 1 because 1+s тЙд E < 2
        have hs_lt_one : s < 1 := by linarith [Real.add_one_le_exp s]
        -- E тЙд 1+s+s┬▓ from Real.norm_exp_sub_one_sub_id_le (for |s| тЙд 1)
        have hE_taylor : E - 1 - s тЙд s ^ 2 := by
          have h := Real.norm_exp_sub_one_sub_id_le (show тАЦsтАЦ тЙд 1 by rw [Real.norm_eq_abs, abs_of_nonneg hs_nn]; linarith)
          rw [Real.norm_eq_abs, abs_of_nonneg (by linarith [Real.add_one_le_exp s]),
              Real.norm_eq_abs, abs_of_nonneg hs_nn] at h
          exact h
        -- E тЙд 1+s+s┬▓
        have hE_le : E тЙд 1 + s + s ^ 2 := by linarith
        -- E(1+s) тЙд (1+s+s┬▓)(1+s) = 1+2s+2s┬▓+s┬│ тЙд 1+2s+3s┬▓ (since s┬│ тЙд s┬▓)
        -- (E-1)┬▓ + (E-1-s)(2-E) = E(1+s) - (1+2s) by ring
        -- So need E(1+s) - (1+2s) тЙд 3s┬▓
        nlinarith [sq_nonneg s, mul_self_nonneg (s * s),
                   show s ^ 3 тЙд s ^ 2 from by
                     calc s ^ 3 = s ^ 2 * s := by ring
                       _ тЙд s ^ 2 * 1 := by nlinarith [sq_nonneg s]
                       _ = s ^ 2 := by ring]
/-! ### Cubic Taylor remainder bound for exp -/

/-- `exp(s)-1-s-s┬▓/2 тЙд s┬│/(6(1-s))` for `0 тЙд s < 1`,
from the termwise bound `1/n! тЙд 1/6` for `n тЙе 3`. -/
private lemma real_exp_third_order_le_div {s : тДЭ} (hs : 0 тЙд s) (hs1 : s < 1) :
    Real.exp s - 1 - s - s ^ 2 / 2 тЙд s ^ 3 / (6 * (1 - s)) := by
  -- exp(s) - 1 - s - s┬▓/2 = ╬г_{nтЙе3} sтБ┐/n! тЙд ╬г_{nтЙе3} sтБ┐/6 = s┬│/(6(1-s))
  have h_rexp := hasSum_real_exp s
  -- The nтЙе3 tail: ╬г_{nтЙе0} s^(n+3)/(n+3)! = exp(s)-1-s-s┬▓/2
  have h_summ3 : Summable (fun n => ((n + 3) !тБ╗┬╣ : тДЭ) * s ^ (n + 3)) :=
    (summable_nat_add_iff 3).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 3) !тБ╗┬╣ : тДЭ) * s ^ (n + 3))
      (Real.exp s - 1 - s - s ^ 2 / 2) := by
    rw [h_summ3.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3
    linarith
  -- The comparison: ╬г_{nтЙе0} s^(n+3)/6 = s┬│/(6(1-s))
  have h_geom_summ : Summable (fun n => s ^ (n + 3) / 6) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs1).mul_left (s ^ 3) |>.congr fun n => by ring
  -- Termwise bound: (n+3)!тБ╗┬╣ тЙд 6тБ╗┬╣ since (n+3)! тЙе 3! = 6
  have hterm : тИА n, ((n + 3) !тБ╗┬╣ : тДЭ) * s ^ (n + 3) тЙд s ^ (n + 3) * (6 : тДЭ)тБ╗┬╣ := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_invтВА (by positivity : (0 : тДЭ) < (n + 3)!) (by positivity : (0 : тДЭ) < 6)]
    have : (3 : тДХ)! тЙд (n + 3)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  -- The comparison series sums to s┬│/(6(1-s))
  have h_geom : HasSum (fun n => s ^ (n + 3) * (6 : тДЭ)тБ╗┬╣) (s ^ 3 * (1 - s)тБ╗┬╣ * (6 : тДЭ)тБ╗┬╣) := by
    have hg := (hasSum_geometric_of_lt_one hs hs1).mul_left (s ^ 3)
    have h_eq : (fun n => s ^ 3 * s ^ n) = (fun n => s ^ (n + 3)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (6 : тДЭ)тБ╗┬╣
  calc Real.exp s - 1 - s - s ^ 2 / 2
      = тИС' n, ((n + 3) !тБ╗┬╣ : тДЭ) * s ^ (n + 3) := h_val.tsum_eq.symm
    _ тЙд тИС' n, (s ^ (n + 3) * (6 : тДЭ)тБ╗┬╣) :=
        h_summ3.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 3 * (1 - s)тБ╗┬╣ * (6 : тДЭ)тБ╗┬╣ := h_geom.tsum_eq
    _ = s ^ 3 / (6 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring

