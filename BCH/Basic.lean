    calc _ тЙд тАЦP - TтВВтАЦ * тАЦPтАЦ := norm_mul_le _ _
      _ тЙд (5 * s ^ 3) * s ^ 2 := mul_le_mul hPmTтВВ hP (norm_nonneg _) (by positivity)
  have ht2 : тАЦTтВВ * (P - TтВВ)тАЦ тЙд s ^ 2 * (5 * s ^ 3) :=
    calc _ тЙд тАЦTтВВтАЦ * тАЦP - TтВВтАЦ := norm_mul_le _ _
      _ тЙд s ^ 2 * (5 * s ^ 3) := mul_le_mul hTтВВ hPmTтВВ (norm_nonneg _) (by positivity)
  have hadd := norm_add_le ((P - TтВВ) * P) (TтВВ * (P - TтВВ))
  nlinarith [pow_nonneg hs_nn 5]

/-- Norm bound for `тАЦP┬│ - TтВВ┬│тАЦ тЙд 15┬╖sтБ╖` via the 3-fold telescoping
`P┬│ - TтВВ┬│ = (P-TтВВ)┬╖P┬▓ + TтВВ┬╖(P-TтВВ)┬╖P + TтВВ┬▓┬╖(P-TтВВ)`. Each term тЙд 5┬╖s┬│┬╖sтБ┤ = 5┬╖sтБ╖
