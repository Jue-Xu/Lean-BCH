/-! ### Quartic algebraic identity for BCH -/

set_option maxHeartbeats 64000000 in
/-- The quartic algebraic identity: `┬╜W_H1 + тЕУ(a+b)┬│ - bch_cubic_term` equals
a specific combination of quartic+ terms (FтВБ, FтВВ, E┬╖b, a┬╖E, DтВБDтВВ, cross, P┬▓).

Proof: clear all scalar denominators by multiplying by 12 (via the injectivity trick
from H1), then verify with `noncomm_ring`. -/
private theorem quartic_identity (ЁЭХВ : Type*) [RCLike ЁЭХВ] {ЁЭФ╕ : Type*}
    [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕] (ea eb a b : ЁЭФ╕) :
    let DтВБ := ea - 1 - a
    let DтВВ := eb - 1 - b
    let P := ea * eb - 1 - (a + b)
    let EтВБ := DтВБ - (2 : ЁЭХВ)тБ╗┬╣ тАв a ^ 2
    let EтВВ := DтВВ - (2 : ЁЭХВ)тБ╗┬╣ тАв b ^ 2
    let Q := a * DтВВ + DтВБ * b + DтВБ * DтВВ
    let FтВБ := EтВБ - (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3
    let FтВВ := EтВВ - (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3
    -- LHS: ┬╜W_H1 + тЕУ(a+b)┬│ - bch_cubic_term
    (2 : ЁЭХВ)тБ╗┬╣ тАв ((2 : ЁЭХВ) тАв (EтВБ + EтВВ + a * DтВВ + DтВБ * b + DтВБ * DтВВ) -
          (a + b) * P - P * (a + b) - P ^ 2) +
        (3 : ЁЭХВ)тБ╗┬╣ тАв (a + b) ^ 3 - bch_cubic_term ЁЭХВ a b =
    -- RHS: quartic+ terms
    FтВБ + FтВВ + a * EтВВ + EтВБ * b + DтВБ * DтВВ -
    (2 : ЁЭХВ)тБ╗┬╣ тАв ((a + b) * (EтВБ + EтВВ + Q) + (EтВБ + EтВВ + Q) * (a + b)) -
    (2 : ЁЭХВ)тБ╗┬╣ тАв P ^ 2 := by
  -- DECOMPOSITION: reduce to a pure identity in (a,b) that noncomm_ring can handle.
  --
  -- Step 1: ┬╜W = EтВБ+EтВВ+aDтВВ+DтВБb+DтВБDтВВ - ┬╜((a+b)P+P(a+b)+P┬▓)
  -- Step 2: Substitute E=F+тЕЩx┬│, aDтВВ=aEтВВ+┬╜ab┬▓, DтВБb=EтВБb+┬╜a┬▓b
  -- Step 3: Split (a+b)P using P=ab+DтВБ+DтВВ+Q and D=E+┬╜x┬▓
  -- Step 4: After cancellation, a pure identity in a,b remains, provable by noncomm_ring.
  --
  -- The pure identity (verified by hand, all 8 noncomm monomials cancel):
  -- тЕЩa┬│+тЕЩb┬│+┬╜ab┬▓+┬╜a┬▓b - ┬╜((a+b)┬╖ab+ab┬╖(a+b))
  --   - ┬╝((a+b)(a┬▓+b┬▓)+(a┬▓+b┬▓)(a+b)) + тЕУ(a+b)┬│ - bch_cubic_term = 0
  have h2ne : (2 : ЁЭХВ) тЙа 0 := two_ne_zero
  -- Sub-identity 1: the pure cubic identity (no ea,eb тАФ just a,b)
  -- After multiplying by 12 to clear denominators:
  -- 2a┬│+2b┬│+6ab┬▓+6a┬▓b - 6((a+b)ab+ab(a+b)) - 3((a+b)(a┬▓+b┬▓)+(a┬▓+b┬▓)(a+b))
  --   + 4(a+b)┬│ - [a,[a,b]] - [b,[b,a]] = 0
  have hpure : (6 : ЁЭХВ)тБ╗┬╣ тАв a ^ 3 + (6 : ЁЭХВ)тБ╗┬╣ тАв b ^ 3 +
      (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b ^ 2) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a ^ 2 * b) -
      (2 : ЁЭХВ)тБ╗┬╣ тАв ((a + b) * (a * b) + a * b * (a + b)) -
      (2 : ЁЭХВ)тБ╗┬╣ тАв (2 : ЁЭХВ)тБ╗┬╣ тАв ((a + b) * (a ^ 2 + b ^ 2) + (a ^ 2 + b ^ 2) * (a + b)) +
      (3 : ЁЭХВ)тБ╗┬╣ тАв (a + b) ^ 3 - bch_cubic_term ЁЭХВ a b = 0 := by
    -- Multiply by 12
    have h12ne : (12 : ЁЭХВ) тЙа 0 := by exact_mod_cast (show (12 : тДХ) тЙа 0 by norm_num)
    have hinj : Function.Injective ((12 : ЁЭХВ) тАв ┬╖ : ЁЭФ╕ тЖТ ЁЭФ╕) := by
      intro xтВА yтВА hxy
      have := congrArg ((12 : ЁЭХВ)тБ╗┬╣ тАв ┬╖) hxy
      simp only [smul_smul, inv_mul_cancelтВА h12ne, one_smul] at this; exact this
    apply hinj; simp only [smul_zero]
    unfold bch_cubic_term
    simp only [smul_sub, smul_add, smul_smul]
    -- Clear scalar products: 12┬╖(6тБ╗┬╣)=2, 12┬╖(2тБ╗┬╣)=6, 12┬╖(3тБ╗┬╣)=4, 12┬╖(12тБ╗┬╣)=1,
    -- 12┬╖(2тБ╗┬╣┬╖2тБ╗┬╣)=3
    have h12_6 : (12 : ЁЭХВ) * (6 : ЁЭХВ)тБ╗┬╣ = 2 := by push_cast; norm_num
    have h12_2 : (12 : ЁЭХВ) * (2 : ЁЭХВ)тБ╗┬╣ = 6 := by push_cast; norm_num
    have h12_3 : (12 : ЁЭХВ) * (3 : ЁЭХВ)тБ╗┬╣ = 4 := by push_cast; norm_num
    have h12_12 : (12 : ЁЭХВ) * (12 : ЁЭХВ)тБ╗┬╣ = 1 := mul_inv_cancelтВА h12ne
    have h12_22 : (12 : ЁЭХВ) * ((2 : ЁЭХВ)тБ╗┬╣ * (2 : ЁЭХВ)тБ╗┬╣) = 3 := by push_cast; norm_num
    simp only [h12_6, h12_2, h12_3, h12_12, h12_22, one_smul, mul_one]
    -- Now expand nтАвx to sums
    simp only [two_smul ЁЭХВ, show тИА x : ЁЭФ╕, (3 : ЁЭХВ) тАв x = x + x + x from by
        intro x; rw [show (3:ЁЭХВ) = 2+1 from by push_cast; norm_num, add_smul, two_smul, one_smul],
      show тИА x : ЁЭФ╕, (4 : ЁЭХВ) тАв x = x + x + x + x from by
        intro x; rw [show (4:ЁЭХВ) = 2+2 from by push_cast; norm_num, add_smul, two_smul]; abel,
      show тИА x : ЁЭФ╕, (6 : ЁЭХВ) тАв x = x + x + x + x + x + x from by
        intro x; rw [show (6:ЁЭХВ) = 2+2+2 from by push_cast; norm_num,
          add_smul, add_smul, two_smul]; abel]
    noncomm_ring
  -- Connection: multiply by 24, clear scalar denominators, convert to тДХ-smul, noncomm_ring.
  dsimp only
  unfold bch_cubic_term
  rw [тЖР sub_eq_zero]
  -- Multiply by 24 to clear all denominators (deepest scalar nesting: 2тБ╗┬╣┬╖2тБ╗┬╣┬╖2тБ╗┬╣ = 8тБ╗┬╣)
  have h24ne : (24 : ЁЭХВ) тЙа 0 := by exact_mod_cast (show (24 : тДХ) тЙа 0 by norm_num)
  have hinj : Function.Injective ((24 : ЁЭХВ) тАв ┬╖ : ЁЭФ╕ тЖТ ЁЭФ╕) := by
    intro xтВА yтВА hxy; have := congrArg ((24 : ЁЭХВ)тБ╗┬╣ тАв ┬╖) hxy
    simp only [smul_smul, inv_mul_cancelтВА h24ne, one_smul] at this; exact this
  apply hinj; simp only [smul_zero]
  -- Pull all smul out of products and merge nested smuls
  simp only [smul_sub, smul_add, smul_smul, mul_smul_comm, smul_mul_assoc,
    mul_add, add_mul, mul_sub, sub_mul]
  -- Clear scalar products: use mul_assoc to right-associate, then cancel n*nтБ╗┬╣ and nтБ╗┬╣*n.
  -- The h24_* lemmas handle direct products 24*cтБ╗┬╣; mul_assoc + cancel handle deeper nesting.
  simp only [mul_assoc,
    -- n * nтБ╗┬╣ = 1 and nтБ╗┬╣ * n = 1
    mul_inv_cancelтВА h2ne, inv_mul_cancelтВА h2ne,
    -- 24 * cтБ╗┬╣ products (after right-association by mul_assoc)
    show (24 : ЁЭХВ) * (2 : ЁЭХВ)тБ╗┬╣ = 12 from by norm_num,
    show (24 : ЁЭХВ) * (3 : ЁЭХВ)тБ╗┬╣ = 8 from by norm_num,
    show (24 : ЁЭХВ) * (6 : ЁЭХВ)тБ╗┬╣ = 4 from by norm_num,
    show (24 : ЁЭХВ) * (12 : ЁЭХВ)тБ╗┬╣ = 2 from by norm_num,
    -- 24 * 2тБ╗┬╣ * 2тБ╗┬╣ (two-level nesting)
    show (24 : ЁЭХВ) * ((2 : ЁЭХВ)тБ╗┬╣ * (2 : ЁЭХВ)тБ╗┬╣) = 6 from by norm_num,
    -- Cleanup
    one_smul, mul_one]
  -- Convert (n : ЁЭХВ) тАв x to (n : тДХ) тАв x so noncomm_ring (which uses abel) can close.
  simp only [ofNat_smul_eq_nsmul (R := ЁЭХВ)]
  noncomm_ring

/-! ### Fourth-order BCH expansion -/

-- Fourth-order exp remainder: тАЦexp(x)-1-x-┬╜x┬▓-тЕЩx┬│тАЦ тЙд exp(тАЦxтАЦ)-1-тАЦxтАЦ-тАЦxтАЦ┬▓/2-тАЦxтАЦ┬│/6
include ЁЭХВ in
private theorem norm_exp_sub_one_sub_sub_sub_le (x : ЁЭФ╕) :
    тАЦexp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3тАЦ тЙд
      Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 - тАЦxтАЦ ^ 3 / 6 := by
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ЁЭХВ := ЁЭХВ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have hf2 : f 2 = (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    ring
  have hf3 : f 3 = (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 := by
    simp only [f, Nat.factorial, Nat.mul_one, Nat.cast_ofNat, pow_succ, pow_zero, one_mul]
    norm_num
  have h_sub : exp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 = тИС' n, f (n + 4) := by
    rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    have h4 := ((summable_nat_add_iff 3).mpr hf_summ).tsum_eq_zero_add
    simp only [hf3] at h4
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left,
        h4, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp тАЦxтАЦ
  have h_summ4 : Summable (fun n => ((n + 4) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 4)) :=
    (summable_nat_add_iff 4).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 4) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 4))
      (Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 - тАЦxтАЦ ^ 3 / 6) := by
    rw [h_summ4.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 4))

-- For 0 тЙд s with s < 3/4, the fourth-order Taylor remainder satisfies
-- exp(s)-1-s-s┬▓/2-s┬│/6 тЙд sтБ┤.
private lemma real_exp_fourth_order_le_quartic {s : тДЭ} (hs : 0 тЙд s) (hs1 : s < 3 / 4) :
    Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 тЙд s ^ 4 := by
  have hs_lt1 : s < 1 := by linarith
  -- exp(s)-1-s-s┬▓/2 тЙд s┬│/(6(1-s)) from real_exp_third_order_le_div
  -- So exp(s)-1-s-s┬▓/2-s┬│/6 = (exp(s)-1-s-s┬▓/2) - s┬│/6
  -- The nтЙе4 tail: ╬г_{nтЙе0} s^(n+4)/(n+4)!
  have h_rexp := hasSum_real_exp s
  have h_summ4 : Summable (fun n => ((n + 4) !тБ╗┬╣ : тДЭ) * s ^ (n + 4)) :=
    (summable_nat_add_iff 4).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 4) !тБ╗┬╣ : тДЭ) * s ^ (n + 4))
      (Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6) := by
    rw [h_summ4.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4
    linarith
  -- Comparison: (n+4)!тБ╗┬╣ * s^(n+4) тЙд (24)тБ╗┬╣ * s^(n+4) since (n+4)! тЙе 4! = 24
  -- So tail тЙд sтБ┤/(24(1-s)) тЙд sтБ┤ for s < 23/24
  have h_geom_summ : Summable (fun n => s ^ (n + 4) / 24) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 4) |>.congr fun n => by ring
  have hterm : тИА n, ((n + 4) !тБ╗┬╣ : тДЭ) * s ^ (n + 4) тЙд s ^ (n + 4) * (24 : тДЭ)тБ╗┬╣ := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_invтВА (by positivity : (0 : тДЭ) < (n + 4)!) (by positivity : (0 : тДЭ) < 24)]
    have : (4 : тДХ)! тЙд (n + 4)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  have h_geom : HasSum (fun n => s ^ (n + 4) * (24 : тДЭ)тБ╗┬╣) (s ^ 4 * (1 - s)тБ╗┬╣ * (24 : тДЭ)тБ╗┬╣) := by
    have hg := (hasSum_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 4)
    have h_eq : (fun n => s ^ 4 * s ^ n) = (fun n => s ^ (n + 4)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (24 : тДЭ)тБ╗┬╣
  calc Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6
      = тИС' n, ((n + 4) !тБ╗┬╣ : тДЭ) * s ^ (n + 4) := h_val.tsum_eq.symm
    _ тЙд тИС' n, (s ^ (n + 4) * (24 : тДЭ)тБ╗┬╣) :=
        h_summ4.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 4 * (1 - s)тБ╗┬╣ * (24 : тДЭ)тБ╗┬╣ := h_geom.tsum_eq
    _ = s ^ 4 / (24 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring
    _ тЙд s ^ 4 := by
        rw [div_le_iffтВА (by nlinarith : (0 : тДЭ) < 24 * (1 - s))]
        nlinarith [sq_nonneg s, pow_nonneg hs 4]

