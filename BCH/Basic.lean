    calc _ тЙд тАЦ(2 : ЁЭХВ)тБ╗┬╣тАЦ * тАЦ╬┤ * a' - a' * ╬┤тАЦ := norm_smul_le _ _
      _ тЙд (2 : тДЭ)тБ╗┬╣ * (тАЦ╬┤ * a'тАЦ + тАЦa' * ╬┤тАЦ) := by
