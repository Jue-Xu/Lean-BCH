      _ тЙд N * N * N * тАЦxтВД - yтВДтАЦ * N * N * N := by gcongr
      _ = N ^ 6 * тАЦxтВД - yтВДтАЦ := by ring
  have htтВЕ : тАЦyтВБ * yтВВ * yтВГ * yтВД * (xтВЕ - yтВЕ) * xтВЖ * xтВЗтАЦ тЙд N ^ 6 * тАЦxтВЕ - yтВЕтАЦ := by
