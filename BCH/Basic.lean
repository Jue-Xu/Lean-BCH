/-- Norm bound `‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ ‚â§ 5¬∑s‚Å¥` where P = exp(a)*exp(b)-1-(a+b),
T‚ÇÇ = ab+¬Ωa¬≤+¬Ωb¬≤, T‚ÇÉ = ‚Öôa¬≥+¬Ωa¬≤b+¬Ωab¬≤+‚Öôb¬≥. Algebraic identity:
`P - T‚ÇÇ - T‚ÇÉ = F‚ÇÅ + F‚ÇÇ + a¬∑E‚ÇÇ + E‚ÇÅ¬∑b + D‚ÇÅ¬∑D‚ÇÇ` where each piece has deg-4+
structure. -/
private theorem norm_P_sub_T2_sub_T3_le (a b : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hs34 : s < 3 / 4) (hŒ±_le : ‚Äña‚Äñ ‚â§ s) (hŒ≤_le : ‚Äñb‚Äñ ‚â§ s) :
    ‚Äñexp a * exp b - 1 - (a + b) -
      (a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2) -
      ((6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3)‚Äñ ‚â§ 5 * s ^ 4 := by
  set Œ± := ‚Äña‚Äñ
  set Œ≤ := ‚Äñb‚Äñ
  have hŒ±_nn : (0 : ‚Ñù) ‚â§ Œ± := norm_nonneg a
  have hŒ≤_nn : (0 : ‚Ñù) ‚â§ Œ≤ := norm_nonneg b
  have hs56 : s < 5 / 6 := by linarith
  -- Set up D, E, F variables
  set D‚ÇÅ := exp a - 1 - a with hD‚ÇÅ_def
  set D‚ÇÇ := exp b - 1 - b with hD‚ÇÇ_def
  set E‚ÇÅ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 with hE‚ÇÅ_def
  set E‚ÇÇ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2 with hE‚ÇÇ_def
  set F‚ÇÅ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 with hF‚ÇÅ_def
  set F‚ÇÇ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3 with hF‚ÇÇ_def
  -- Algebraic identity: P - T‚ÇÇ - T‚ÇÉ = F‚ÇÅ + F‚ÇÇ + a¬∑E‚ÇÇ + E‚ÇÅ¬∑b + D‚ÇÅ¬∑D‚ÇÇ
