          (pow_le_pow_left‚ÇÄ hŒ≤_nn hŒ≤_le 3) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have ha2b4s : Œ± ^ 2 * Œ≤ ^ 4 ‚â§ s ^ 6 := by
