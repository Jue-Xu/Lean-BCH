      (a * b + (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2) -
      ((6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b) +
        (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3) -
      ((24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b) +
        (4 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 2) + (6 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4) -
      ((120 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5 + (24 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 4 * b) +
        (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 3 * b ^ 2) + (12 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 3) +
        (24 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 4) + (120 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5) =
      H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ) := by
    have h := P_sub_T2_sub_T3_sub_T4_sub_T5_decomp_eq ùïÇ (exp a) (exp b) a b
    simp only [hH‚ÇÅ_def, hH‚ÇÇ_def, hG‚ÇÅ_def, hG‚ÇÇ_def, hF‚ÇÅ_def, hF‚ÇÇ_def,
      hE‚ÇÅ_def, hE‚ÇÇ_def, hD‚ÇÅ_def, hD‚ÇÇ_def] at h
