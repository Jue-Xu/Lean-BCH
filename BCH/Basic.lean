  have hs‚ÇÇ_le_const : ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ 57 / 88 := by
    calc ‚Äñz‚Äñ + ‚Äña'‚Äñ ‚â§ 57/22 * s := hs‚ÇÇ_mult
