  have h2 : ‚Äñ(P - T‚ÇÇ) * z‚Äñ ‚â§ (5 * s ^ 3) * s :=
    calc _ ‚â§ ‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz‚Äñ := norm_mul_le _ _
      _ ‚â§ (5 * s ^ 3) * s := mul_le_mul hPmT‚ÇÇ hzn (norm_nonneg _) (by positivity)
  have h3 : ‚ÄñP ^ 2‚Äñ ‚â§ (s ^ 2) ^ 2 :=
    calc _ ‚â§ ‚ÄñP‚Äñ ^ 2 := norm_pow_le P 2
      _ ‚â§ (s ^ 2) ^ 2 := pow_le_pow_left‚ÇÄ (norm_nonneg _) hP 2
