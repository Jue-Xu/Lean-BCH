  set u2 : ùî∏ := z ^ 3 * (P - T‚ÇÇ - T‚ÇÉ) * z
  set u3 : ùî∏ := z ^ 2 * (P - T‚ÇÇ - T‚ÇÉ) * z ^ 2
  set u4 : ùî∏ := z * (P - T‚ÇÇ - T‚ÇÉ) * z ^ 3
  set u5 : ùî∏ := (P - T‚ÇÇ - T‚ÇÉ) * z ^ 4
  set u6 : ùî∏ := (y ^ 4 - z ^ 4 -
      (z ^ 3 * T‚ÇÇ + z ^ 2 * T‚ÇÇ * z + z * T‚ÇÇ * z ^ 2 + T‚ÇÇ * z ^ 3)) * P
  set u7 : ùî∏ := z ^ 3 * T‚ÇÇ * (P - T‚ÇÇ)
  set u8 : ùî∏ := z ^ 2 * T‚ÇÇ * z * (P - T‚ÇÇ)
