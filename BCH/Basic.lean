/-- Helper: `тАЦ((k:ЁЭХВ)/1440) тАв wтАЦ тЙд |k|/1440┬╖sтБ╢` for a 6-letter word `w`. -/
private lemma norm_sextic_word_le {ЁЭФ╕ : Type*} [NormedRing ЁЭФ╕] [NormedAlgebra ЁЭХВ ЁЭФ╕]
    (k : тДд) (w : ЁЭФ╕) (s : тДЭ) (hw : тАЦwтАЦ тЙд s ^ 6) (hs_nn : 0 тЙд s) :
    тАЦ((k : ЁЭХВ) / 1440) тАв wтАЦ тЙд |(k : тДЭ)| / 1440 * s ^ 6 := by
  have h1440_norm : тАЦ(1440 : ЁЭХВ)тАЦ = 1440 := by
    rw [show (1440 : ЁЭХВ) = ((1440 : тДХ) : ЁЭХВ) from by norm_cast, RCLike.norm_natCast]
    norm_num
  have hc_nn : (0 : тДЭ) тЙд |(k : тДЭ)| / 1440 := by positivity
  have hk_norm : тАЦ((k : тДд) : ЁЭХВ)тАЦ = |(k : тДЭ)| := by
    rw [show ((k : тДд) : ЁЭХВ) = ((k : тДЭ) : ЁЭХВ) from by push_cast; rfl, RCLike.norm_ofReal]
  calc тАЦ((k : ЁЭХВ) / 1440) тАв wтАЦ
      тЙд тАЦ((k : ЁЭХВ) / 1440)тАЦ * тАЦwтАЦ := norm_smul_le _ _
    _ = |(k : тДЭ)| / 1440 * тАЦwтАЦ := by rw [norm_div, h1440_norm, hk_norm]
    _ тЙд |(k : тДЭ)| / 1440 * s ^ 6 := mul_le_mul_of_nonneg_left hw hc_nn

