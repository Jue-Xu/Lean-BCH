    (hcb : 0 ‚â§ cb) (hs : 0 ‚â§ s) :
    ‚Äñc ‚Ä¢ (l1 * l2 * l3 * l4 * l5 * l6 * l7 * l8)‚Äñ ‚â§ cb * s ^ 8 := by
  calc ‚Äñc ‚Ä¢ (l1 * l2 * l3 * l4 * l5 * l6 * l7 * l8)‚Äñ
      ‚â§ ‚Äñc‚Äñ * ‚Äñl1 * l2 * l3 * l4 * l5 * l6 * l7 * l8‚Äñ := norm_smul_le _ _
