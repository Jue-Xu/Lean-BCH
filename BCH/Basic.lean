-- For 0 тЙд s with s < 3/4, the fifth-order Taylor remainder satisfies
-- exp(s)-1-s-s┬▓/2-s┬│/6-sтБ┤/24 тЙд sтБ╡.
private lemma real_exp_fifth_order_le_quintic {s : тДЭ} (hs : 0 тЙд s) (hs1 : s < 3 / 4) :
