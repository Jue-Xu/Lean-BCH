/-- **Sixth-order BCH remainder, large-s case** (private helper for the future
`norm_bch_sextic_remainder_le`).

Crude bound for `тАЦaтАЦ+тАЦbтАЦ тЙе 1/10`: combines `norm_bch_quintic_remainder_le`
with `тАЦCтВЕтАЦ тЙд sтБ╡` to give

  `тАЦLHS_sexticтАЦ тЙд 3001┬╖sтБ╡/(2-exp(s)) тЙд 100000┬╖sтБ╢/(2-exp(s))`

(since `3001 тЙд 100000┬╖s` when `s тЙе 1/10`).

This is the crude case of the full sextic remainder theorem. The full
theorem requires the small-s analytic case (`s < 1/10`), which uses
`sextic_pure_identity` for the deg-5 cancellation (~700 lines, deferred to
future session). See `claude/sextic_remainder_strategy.md`. -/
private theorem norm_bch_sextic_remainder_large_s_le (a b : ЁЭФ╕)
    (hab : тАЦaтАЦ + тАЦbтАЦ < Real.log 2) (hs_large : 1 / 10 тЙд тАЦaтАЦ + тАЦbтАЦ) :
    тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b -
      bch_quintic_term ЁЭХВ a bтАЦ тЙд
      100000 * (тАЦaтАЦ + тАЦbтАЦ) ^ 6 / (2 - Real.exp (тАЦaтАЦ + тАЦbтАЦ)) := by
  set s := тАЦaтАЦ + тАЦbтАЦ with hs_def
  have hs_nn : 0 тЙд s := by positivity
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hdenom_le1 : 2 - Real.exp s тЙд 1 := by linarith [Real.add_one_le_exp s]
  have hRтВД := norm_bch_quintic_remainder_le (ЁЭХВ := ЁЭХВ) a b hab
  have hCтВЕ : тАЦbch_quintic_term ЁЭХВ a bтАЦ тЙд s ^ 5 := norm_bch_quintic_term_le a b
  -- Algebraic split: LHS_sextic = LHS_quintic - CтВЕ
  have hLHS_eq : bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b - bch_quintic_term ЁЭХВ a b =
      (bch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
       bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b) - bch_quintic_term ЁЭХВ a b := by abel
  -- тАЦLHSтАЦ тЙд 3000sтБ╡/(2-exp(s)) + sтБ╡ тЙд 3001 sтБ╡/(2-exp(s))
  have hLHS_3001 : тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
      bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a b - bch_quintic_term ЁЭХВ a bтАЦ тЙд
      3001 * s ^ 5 / (2 - Real.exp s) := by
    rw [hLHS_eq]
    calc _ тЙд тАЦbch (ЁЭХВ := ЁЭХВ) a b - (a + b) - (2 : ЁЭХВ)тБ╗┬╣ тАв (a * b - b * a) -
          bch_cubic_term ЁЭХВ a b - bch_quartic_term ЁЭХВ a bтАЦ + тАЦbch_quintic_term ЁЭХВ a bтАЦ :=
        norm_sub_le _ _
      _ тЙд 3000 * s ^ 5 / (2 - Real.exp s) + s ^ 5 := by linarith
      _ тЙд 3000 * s ^ 5 / (2 - Real.exp s) + s ^ 5 / (2 - Real.exp s) := by
          gcongr; rw [le_div_iffтВА hdenom]
          nlinarith [pow_nonneg hs_nn 5]
      _ = 3001 * s ^ 5 / (2 - Real.exp s) := by ring
  -- Bound 3001┬╖sтБ╡ тЙд 100000┬╖sтБ╢ via 3001 тЙд 100000┬╖s (using s тЙе 1/10)
  have h_le : 3001 * s ^ 5 тЙд 100000 * s ^ 6 := by
    have h3001 : 3001 тЙд 100000 * s := by linarith
    nlinarith [pow_nonneg hs_nn 5]
  calc _ тЙд 3001 * s ^ 5 / (2 - Real.exp s) := hLHS_3001
    _ тЙд 100000 * s ^ 6 / (2 - Real.exp s) :=
        div_le_div_of_nonneg_right h_le hdenom.le

