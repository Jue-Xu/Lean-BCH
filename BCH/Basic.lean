  set E‚ÇÅ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2 with hE‚ÇÅ_def
  set E‚ÇÇ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2 with hE‚ÇÇ_def
  set F‚ÇÅ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3 with hF‚ÇÅ_def
  set F‚ÇÇ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3 with hF‚ÇÇ_def
  set G‚ÇÅ := F‚ÇÅ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4 with hG‚ÇÅ_def
  set G‚ÇÇ := F‚ÇÇ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4 with hG‚ÇÇ_def
  set H‚ÇÅ := G‚ÇÅ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 5 with hH‚ÇÅ_def
  set H‚ÇÇ := G‚ÇÇ - (120 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 5 with hH‚ÇÇ_def
  -- Algebraic identity
