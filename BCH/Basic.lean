  have hwd_bound : N^7 * (тАЦxтВБ - yтВБтАЦ + тАЦxтВВ - yтВВтАЦ + тАЦxтВГ - yтВГтАЦ + тАЦxтВД - yтВДтАЦ + тАЦxтВЕ - yтВЕтАЦ + тАЦxтВЖ - yтВЖтАЦ + тАЦxтВЗ - yтВЗтАЦ + тАЦxтВИ - yтВИтАЦ) тЙд
             8 * N^7 * D := by
