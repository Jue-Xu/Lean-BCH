    (h1 : ‚Äñl1‚Äñ ‚â§ s) (h2 : ‚Äñl2‚Äñ ‚â§ s) (h3 : ‚Äñl3‚Äñ ‚â§ s) (h4 : ‚Äñl4‚Äñ ‚â§ s) (h5 : ‚Äñl5‚Äñ ‚â§ s) (h6 : ‚Äñl6‚Äñ ‚â§ s) (h7 : ‚Äñl7‚Äñ ‚â§ s)
    (hcb : 0 ‚â§ cb) (hs : 0 ‚â§ s) :
    ‚Äñc ‚Ä¢ (l1 * l2 * l3 * l4 * l5 * l6 * l7)‚Äñ ‚â§ cb * s ^ 7 := by
  calc ‚Äñc ‚Ä¢ (l1 * l2 * l3 * l4 * l5 * l6 * l7)‚Äñ
      ‚â§ ‚Äñc‚Äñ * ‚Äñl1 * l2 * l3 * l4 * l5 * l6 * l7‚Äñ := norm_smul_le _ _
