      have hIтВБ_quartic : IтВБ =
          FтВБ + FтВВ + a * EтВВ + EтВБ * b + DтВБ * DтВВ -
          (2 : ЁЭХВ)тБ╗┬╣ тАв (z * (EтВБ + EтВВ + Q) + (EтВБ + EтВВ + Q) * z) -
          (2 : ЁЭХВ)тБ╗┬╣ тАв P ^ 2 := by
        rw [hIтВБ_eq2]; exact quartic_identity ЁЭХВ (exp a) (exp b) a b
      -- Step 6c: Define degree-4 correction terms (matching quintic_pure_identity)
