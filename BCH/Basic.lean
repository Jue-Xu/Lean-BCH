    let E‚ÇÅ : ùî∏ := D‚ÇÅ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 2
    let E‚ÇÇ : ùî∏ := D‚ÇÇ - (2 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 2
    let F‚ÇÅ : ùî∏ := E‚ÇÅ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 3
    let F‚ÇÇ : ùî∏ := E‚ÇÇ - (6 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 3
    let G‚ÇÅ : ùî∏ := F‚ÇÅ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 4
    let G‚ÇÇ : ùî∏ := F‚ÇÇ - (24 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 4
    let Q : ùî∏ := a * D‚ÇÇ + D‚ÇÅ * b + D‚ÇÅ * D‚ÇÇ
