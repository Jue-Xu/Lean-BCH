  have ha4b2s : Œ± ^ 4 * Œ≤ ^ 2 ‚â§ s ^ 6 := by
    calc Œ± ^ 4 * Œ≤ ^ 2 ‚â§ s ^ 4 * s ^ 2 := mul_le_mul (pow_le_pow_left‚ÇÄ hŒ±_nn hŒ±_le 4)
          (pow_le_pow_left‚ÇÄ hŒ≤_nn hŒ≤_le 2) (by positivity) (by positivity)
      _ = s ^ 6 := by ring
  have ha3b3s : Œ± ^ 3 * Œ≤ ^ 3 ‚â§ s ^ 6 := by
