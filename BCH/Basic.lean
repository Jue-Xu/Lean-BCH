        (24 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * b ^ 4) + (60 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b ^ 5) +
        (360 : ùïÇ)‚Åª¬π ‚Ä¢ b ^ 6 -
        (z * T‚ÇÖ + T‚ÇÇ * T‚ÇÑ + T‚ÇÉ * T‚ÇÉ + T‚ÇÑ * T‚ÇÇ + T‚ÇÖ * z)
    let W7 : ùî∏ := (2520 : ùïÇ)‚Åª¬π ‚Ä¢ a ^ 7 + (360 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 6 * b) +
