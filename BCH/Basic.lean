      (2 : ùïÇ)‚Åª¬π ‚Ä¢ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a * b - b * ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a)) -
      bch_cubic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b -
      bch_quartic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b -
      bch_quintic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b -
      bch_sextic_term ùïÇ ((2 : ùïÇ)‚Åª¬π ‚Ä¢ a) b‚Äñ ‚â§
      1500000 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 7 := by
  set a' : ùî∏ := (2 : ùïÇ)‚Åª¬π ‚Ä¢ a with ha'_def
