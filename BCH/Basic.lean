/-- Lipschitz bound for word #1 (a┬╖a┬╖a┬╖a┬╖b┬╖b, 4 a-positions, |coef|=1). -/
private lemma bch_sextic_word01_diff_le (z x y : ЁЭФ╕) :
    тАЦz * z * z * z * y * y - x * x * x * x * y * yтАЦ тЙд
      4 * (тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ) ^ 5 * тАЦz - xтАЦ := by
  have htel : z * z * z * z * y * y - x * x * x * x * y * y =
      (z - x) * z * z * z * y * y + x * (z - x) * z * z * y * y +
      x * x * (z - x) * z * y * y + x * x * x * (z - x) * y * y := by
    noncomm_ring
  rw [htel]
  set M := тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ
  set d := тАЦz - xтАЦ
  have hd_nn : 0 тЙд d := norm_nonneg _
  have hz_le : тАЦzтАЦ тЙд M := by
    show тАЦzтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg x, norm_nonneg y]
  have hx_le : тАЦxтАЦ тЙд M := by
    show тАЦxтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg y]
  have hy_le : тАЦyтАЦ тЙд M := by
    show тАЦyтАЦ тЙд тАЦzтАЦ + тАЦxтАЦ + тАЦyтАЦ; linarith [norm_nonneg z, norm_nonneg x]
  have h1 : тАЦ(z - x) * z * z * z * y * yтАЦ тЙд M ^ 5 * d := by
    calc _ тЙд тАЦz - xтАЦ * тАЦzтАЦ * тАЦzтАЦ * тАЦzтАЦ * тАЦyтАЦ * тАЦyтАЦ := norm_6prod_le _ _ _ _ _ _
      _ тЙд d * M * M * M * M * M := by gcongr
      _ = M ^ 5 * d := by ring
  have h2 : тАЦx * (z - x) * z * z * y * yтАЦ тЙд M ^ 5 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦz - xтАЦ * тАЦzтАЦ * тАЦzтАЦ * тАЦyтАЦ * тАЦyтАЦ := norm_6prod_le _ _ _ _ _ _
      _ тЙд M * d * M * M * M * M := by gcongr
      _ = M ^ 5 * d := by ring
  have h3 : тАЦx * x * (z - x) * z * y * yтАЦ тЙд M ^ 5 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦzтАЦ * тАЦyтАЦ * тАЦyтАЦ := norm_6prod_le _ _ _ _ _ _
      _ тЙд M * M * d * M * M * M := by gcongr
      _ = M ^ 5 * d := by ring
  have h4 : тАЦx * x * x * (z - x) * y * yтАЦ тЙд M ^ 5 * d := by
    calc _ тЙд тАЦxтАЦ * тАЦxтАЦ * тАЦxтАЦ * тАЦz - xтАЦ * тАЦyтАЦ * тАЦyтАЦ := norm_6prod_le _ _ _ _ _ _
      _ тЙд M * M * M * d * M * M := by gcongr
      _ = M ^ 5 * d := by ring
  set s1 : ЁЭФ╕ := (z - x) * z * z * z * y * y
  set s2 : ЁЭФ╕ := x * (z - x) * z * z * y * y
  set s3 : ЁЭФ╕ := x * x * (z - x) * z * y * y
  set s4 : ЁЭФ╕ := x * x * x * (z - x) * y * y
  have a3 := norm_add_le (s1 + s2 + s3) s4
  have a2 := norm_add_le (s1 + s2) s3
  have a1 := norm_add_le s1 s2
  linarith

