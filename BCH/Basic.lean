    (c : 𝕂) (cb : ℝ) (hc : ‖c‖ ≤ cb)
    (l1 l2 l3 l4 l5 l6 l7 l8 : 𝔸) (s : ℝ)
    (h1 : ‖l1‖ ≤ s) (h2 : ‖l2‖ ≤ s) (h3 : ‖l3‖ ≤ s) (h4 : ‖l4‖ ≤ s)
