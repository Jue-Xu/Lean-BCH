    calc _ тЙд тАЦP - TтВВтАЦ * тАЦz ^ 5тАЦ := norm_mul_le _ _
      _ тЙд тАЦP - TтВВтАЦ * тАЦzтАЦ ^ 5 := by gcongr; exact norm_pow_le z 5
      _ тЙд (5 * s ^ 3) * s ^ 5 := mul_le_mul hPmTтВВ
          (pow_le_pow_leftтВА (norm_nonneg _) hzn 5) (by positivity) (by positivity)
  have ht1 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - TтВВ) * z ^ 2 +
    (y ^ 2 - z ^ 2) * P * z ^ 3 + z ^ 2 * (P - TтВВ) * z ^ 3 +
    P * P * z ^ 4 + z * (P - TтВВ) * z ^ 4) ((P - TтВВ) * z ^ 5)
  have ht2 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - TтВВ) * z ^ 2 +
    (y ^ 2 - z ^ 2) * P * z ^ 3 + z ^ 2 * (P - TтВВ) * z ^ 3 +
    P * P * z ^ 4) (z * (P - TтВВ) * z ^ 4)
  have ht3 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - TтВВ) * z ^ 2 +
    (y ^ 2 - z ^ 2) * P * z ^ 3 + z ^ 2 * (P - TтВВ) * z ^ 3) (P * P * z ^ 4)
  have ht4 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - TтВВ) * z ^ 2 +
    (y ^ 2 - z ^ 2) * P * z ^ 3) (z ^ 2 * (P - TтВВ) * z ^ 3)
  have ht5 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2 + z ^ 3 * (P - TтВВ) * z ^ 2)
    ((y ^ 2 - z ^ 2) * P * z ^ 3)
  have ht6 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z +
    (y ^ 3 - z ^ 3) * P * z ^ 2) (z ^ 3 * (P - TтВВ) * z ^ 2)
  have ht7 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z + z ^ 4 * (P - TтВВ) * z)
    ((y ^ 3 - z ^ 3) * P * z ^ 2)
  have ht8 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ) +
    (y ^ 4 - z ^ 4) * P * z) (z ^ 4 * (P - TтВВ) * z)
  have ht9 := norm_add_le ((y ^ 5 - z ^ 5) * P + z ^ 5 * (P - TтВВ))
    ((y ^ 4 - z ^ 4) * P * z)
  have ht10 := norm_add_le ((y ^ 5 - z ^ 5) * P) (z ^ 5 * (P - TтВВ))
  nlinarith [pow_nonneg hs_nn 8]

/-- **IтВВ residual decomposition**: pure ring identity in `(z, P, TтВВ, TтВГ)` for
`(z+P)┬│ - z┬│ - (z┬▓TтВВ+zTтВВz+TтВВz┬▓) - (z┬▓TтВГ+zTтВГz+TтВГz┬▓+zTтВВ┬▓+TтВВzTтВВ+TтВВ┬▓z)`,
which when multiplied by `(3:ЁЭХВ)тБ╗┬╣` becomes `IтВВ - corrтВВ - corrтВВ_5`.

Each summand on the RHS has deg-6+ structure (since `P-TтВВ-TтВГ` has deg-4+,
`P┬▓-TтВВ┬▓` has deg-5+, `PzP-TтВВzTтВВ` has deg-6+, `P┬│` has deg-6). -/
private theorem I2_residual_decomp_eq (z P TтВВ TтВГ : ЁЭФ╕) :
    (z + P) ^ 3 - z ^ 3 -
      (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2) -
      (z ^ 2 * TтВГ + z * TтВГ * z + TтВГ * z ^ 2 +
        z * TтВВ ^ 2 + TтВВ * z * TтВВ + TтВВ ^ 2 * z) =
    z ^ 2 * (P - TтВВ - TтВГ) + z * (P - TтВВ - TтВГ) * z + (P - TтВВ - TтВГ) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2) + (P * z * P - TтВВ * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2) * z + P ^ 3 := by
  noncomm_ring

/-- **IтВВ septic residual decomposition**: extends `I2_residual_decomp_eq`
by subtracting the deg-6 leading part `y3_6 = (3 TтВД terms) + (6 TтВВ┬╖TтВГ
permutations) + TтВВ┬│` to give a pure ring identity in `(z, P, TтВВ, TтВГ, TтВД)`
where each RHS term is deg-7+.

Pairings:
- `(3 TтВД terms)` extend the 3 weight-1 (P-TтВВ-TтВГ) terms into (P-TтВВ-TтВГ-TтВД).
- `(6 TтВВ┬╖TтВГ perms)` are absorbed into the 3 weight-2 (P┬▓-TтВВ┬▓) compound
  forms, giving `z(P┬▓-TтВВ┬▓-TтВВTтВГ-TтВГTтВВ)`, `(PzP-TтВВzTтВВ-TтВВzTтВГ-TтВГzTтВВ)`,
  `(P┬▓-TтВВ┬▓-TтВВTтВГ-TтВГTтВВ)z`.
- `TтВВ┬│` is absorbed into `P┬│`, giving `P┬│ - TтВВ┬│` (deg-7+ via telescoping).

Each summand on the RHS is deg-7+ in the BCH context.
Proof: `noncomm_ring` (pure ring identity, no scalar coefficients). -/
private theorem I2_septic_residual_decomp_eq (z P TтВВ TтВГ TтВД : ЁЭФ╕) :
    (z + P) ^ 3 - z ^ 3 -
      (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2) -
      (z ^ 2 * TтВГ + z * TтВГ * z + TтВГ * z ^ 2 +
        z * TтВВ ^ 2 + TтВВ * z * TтВВ + TтВВ ^ 2 * z) -
      (z ^ 2 * TтВД + z * TтВД * z + TтВД * z ^ 2 +
        z * TтВВ * TтВГ + z * TтВГ * TтВВ +
        TтВВ * z * TтВГ + TтВГ * z * TтВВ +
        TтВВ * TтВГ * z + TтВГ * TтВВ * z +
        TтВВ ^ 3) =
    z ^ 2 * (P - TтВВ - TтВГ - TтВД) + z * (P - TтВВ - TтВГ - TтВД) * z +
      (P - TтВВ - TтВГ - TтВД) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ) * z +
    (P ^ 3 - TтВВ ^ 3) := by
  noncomm_ring

/-- **IтВВ octic residual decomposition**: extends `I2_septic_residual_decomp_eq`
by subtracting the deg-7 leading part `y3_7` (15 terms: 3 with TтВЕ, 6 with
TтВВ┬╖TтВД + TтВД┬╖TтВВ perms, 3 with TтВГ┬▓ perms, 3 with TтВВ┬▓┬╖TтВГ perms) to give a pure
ring identity in `(z, P, TтВВ, TтВГ, TтВД, TтВЕ)` where each RHS term is deg-8+.

Pairings (additions on top of septic):
- 3 weight-1 terms `z^i┬╖(P-TтВВ-TтВГ-TтВД)┬╖z^j` extend to `z^i┬╖(P-TтВВ-TтВГ-TтВД-TтВЕ)┬╖z^j`.
- `z┬╖TтВВ┬╖TтВД` and `z┬╖TтВД┬╖TтВВ` + `z┬╖TтВГ┬▓` get absorbed into
  `z┬╖(P┬▓ - TтВВ┬▓ - TтВВTтВГ - TтВГTтВВ)` тЖТ `z┬╖(P┬▓ - TтВВ┬▓ - TтВВTтВГ - TтВГTтВВ - TтВВTтВД - TтВГ┬▓ - TтВДTтВВ)`.
- Conjugates `(...)┬╖z` and `T_aux┬╖z┬╖T_aux` get the analogous extensions.
- `TтВВ┬▓┬╖TтВГ`, `TтВВ┬╖TтВГ┬╖TтВВ`, `TтВГ┬╖TтВВ┬▓` get absorbed into `P┬│`:
  `(P┬│ - TтВВ┬│)` тЖТ `(P┬│ - TтВВ┬│ - TтВВ┬▓┬╖TтВГ - TтВВ┬╖TтВГ┬╖TтВВ - TтВГ┬╖TтВВ┬▓)`.

Each RHS summand is deg-8+ in the BCH context.
Proof: `noncomm_ring` (pure ring identity, no scalar coefficients). -/
private theorem I2_octic_residual_decomp_eq (z P TтВВ TтВГ TтВД TтВЕ : ЁЭФ╕) :
    (z + P) ^ 3 - z ^ 3 -
      (z ^ 2 * TтВВ + z * TтВВ * z + TтВВ * z ^ 2) -
      (z ^ 2 * TтВГ + z * TтВГ * z + TтВГ * z ^ 2 +
        z * TтВВ ^ 2 + TтВВ * z * TтВВ + TтВВ ^ 2 * z) -
      (z ^ 2 * TтВД + z * TтВД * z + TтВД * z ^ 2 +
        z * TтВВ * TтВГ + z * TтВГ * TтВВ +
        TтВВ * z * TтВГ + TтВГ * z * TтВВ +
        TтВВ * TтВГ * z + TтВГ * TтВВ * z +
        TтВВ ^ 3) -
      (z ^ 2 * TтВЕ + z * TтВЕ * z + TтВЕ * z ^ 2 +
        z * TтВВ * TтВД + z * TтВГ * TтВГ + z * TтВД * TтВВ +
        TтВВ * z * TтВД + TтВГ * z * TтВГ + TтВД * z * TтВВ +
        TтВВ * TтВД * z + TтВГ * TтВГ * z + TтВД * TтВВ * z +
        TтВВ * TтВВ * TтВГ + TтВВ * TтВГ * TтВВ + TтВГ * TтВВ * TтВВ) =
    z ^ 2 * (P - TтВВ - TтВГ - TтВД - TтВЕ) + z * (P - TтВВ - TтВГ - TтВД - TтВЕ) * z +
      (P - TтВВ - TтВГ - TтВД - TтВЕ) * z ^ 2 +
    z * (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) +
    (P * z * P - TтВВ * z * TтВВ - TтВВ * z * TтВГ - TтВГ * z * TтВВ -
         TтВВ * z * TтВД - TтВГ * z * TтВГ - TтВД * z * TтВВ) +
    (P ^ 2 - TтВВ ^ 2 - TтВВ * TтВГ - TтВГ * TтВВ -
         TтВВ * TтВД - TтВГ * TтВГ - TтВД * TтВВ) * z +
    (P ^ 3 - TтВВ ^ 3 - TтВВ ^ 2 * TтВГ - TтВВ * TтВГ * TтВВ - TтВГ * TтВВ ^ 2) := by
  noncomm_ring

