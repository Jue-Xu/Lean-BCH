  have h_D5zT4 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * z * T‚ÇÑ‚Äñ ‚â§ (6 * s ^ 5) * s * s ^ 4 :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ) * z‚Äñ * ‚ÄñT‚ÇÑ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ - T‚ÇÉ - T‚ÇÑ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÑ‚Äñ := by gcongr; exact norm_mul_le _ _
