    _ = s ^ 5 * (1 - s)тБ╗┬╣ * (120 : тДЭ)тБ╗┬╣ := h_geom.tsum_eq
    _ = s ^ 5 / (120 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring
    _ тЙд s ^ 5 := by
