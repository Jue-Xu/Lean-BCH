/-! ### Sixth-order BCH remainder bound

The public theorem `norm_bch_sextic_remainder_le` extends
`norm_bch_quintic_remainder_le` by one degree, providing the order-6 bound
needed for the B1.c (`norm_symmetric_bch_quintic_sub_poly_le`) discharge.

The large-s case (`s ‚â• 1/10`) is fully proved as
`norm_bch_sextic_remainder_large_s_le`. The small-s case (`s < 1/10`) is
introduced as a scoped private axiom; the proof requires combining
`pieceB_sextic_decomp` with the per-term bounds (`norm_I1_residual_RHS_le`,
`norm_I2_residual_inner_le`, `norm_y4_sub_z4_sub_y4_5_le`,
`norm_pow5_sub_zpow5_le`) ‚Äî see Task #17b in `claude/` for the discharge
plan.
-/

set_option maxHeartbeats 4000000000 in
include ùïÇ in
/-- **Sixth-order BCH remainder, small-s case** (Tier-1 of B1.c).

For `s = ‚Äña‚Äñ+‚Äñb‚Äñ < 1/10`: `‚ÄñLHS_sextic‚Äñ ‚â§ 100¬∑s‚Å∂/(2-exp(s))`.

Combines `pieceB_sextic_decomp` (the central decomposition from QPI+SPI)
with per-term bounds: `norm_I1_residual_RHS_le` (S‚ÇÅ ‚â§ 20¬∑s‚Å∂),
`norm_I2_residual_inner_le` (‚Üí S‚ÇÇ ‚â§ 17¬∑s‚Å∂), `norm_y4_sub_z4_sub_y4_5_le`
(‚Üí S‚ÇÉ ‚â§ 8¬∑s‚Å∂), `norm_pow5_sub_zpow5_le` (‚Üí S‚ÇÑ ‚â§ 7¬∑s‚Å∂). Total ‚â§ 52¬∑s‚Å∂.
Plus pieceA ‚â§ 2¬∑s‚Å∂/(2-exp(s)) for `s ‚â§ 1/10`. Final ‚â§ 100¬∑s‚Å∂/(2-exp(s)).

Mirrors the quintic proof's `hH1` + `hI‚ÇÅ_quartic` pattern, extended one
degree higher. -/
private theorem norm_bch_sextic_remainder_small_s_le (a b : ùî∏)
    (hab : ‚Äña‚Äñ + ‚Äñb‚Äñ < Real.log 2) (hs_small : ‚Äña‚Äñ + ‚Äñb‚Äñ < 1 / 10) :
    ‚Äñbch (ùïÇ := ùïÇ) a b - (a + b) - (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a * b - b * a) -
      bch_cubic_term ùïÇ a b - bch_quartic_term ùïÇ a b -
      bch_quintic_term ùïÇ a b‚Äñ ‚â§
      100 * (‚Äña‚Äñ + ‚Äñb‚Äñ) ^ 6 / (2 - Real.exp (‚Äña‚Äñ + ‚Äñb‚Äñ)) := by
  -- SETUP.
  set s := ‚Äña‚Äñ + ‚Äñb‚Äñ with hs_def
  set Œ± := ‚Äña‚Äñ
  set Œ≤ := ‚Äñb‚Äñ
  have hs_nn : 0 ‚â§ s := by positivity
  have hŒ±_nn : (0 : ‚Ñù) ‚â§ Œ± := norm_nonneg a
  have hŒ≤_nn : (0 : ‚Ñù) ‚â§ Œ≤ := norm_nonneg b
  have hŒ±_le : Œ± ‚â§ s := le_add_of_nonneg_right hŒ≤_nn
  have hŒ≤_le : Œ≤ ‚â§ s := le_add_of_nonneg_left hŒ±_nn
  have hs_small_le : s ‚â§ 1 / 10 := hs_small.le
  have hexp_lt : Real.exp s < 2 := by
    calc Real.exp s < Real.exp (Real.log 2) := Real.exp_strictMono hab
      _ = 2 := Real.exp_log (by norm_num)
  have hdenom : 0 < 2 - Real.exp s := by linarith
  have hdenom_le1 : 2 - Real.exp s ‚â§ 1 := by linarith [Real.add_one_le_exp s]
  have hs1 : s < 1 := by linarith
  have hs34 : s < 3 / 4 := by linarith
  have hs56 : s < 5 / 6 := by linarith
  have h2ne : (2 : ùïÇ) ‚âÝ 0 := two_ne_zero
  set y := exp a * exp b - 1 with hy_def
  set z := a + b with hz_def
  set P := y - z with hP_def
  have hy_lt : ‚Äñy‚Äñ < 1 := norm_exp_mul_exp_sub_one_lt_one (ùïÇ := ùïÇ) a b hab
  have hy_le : ‚Äñy‚Äñ ‚â§ Real.exp s - 1 := by
    have hy_eq : y = (exp a - 1) * exp b + (exp b - 1) := by
      rw [hy_def, sub_mul, one_mul]; abel
    calc ‚Äñy‚Äñ = ‚Äñ(exp a - 1) * exp b + (exp b - 1)‚Äñ := by rw [hy_eq]
      _ ‚â§ ‚Äñexp a - 1‚Äñ * ‚Äñexp b‚Äñ + ‚Äñexp b - 1‚Äñ := by
          calc _ ‚â§ ‚Äñ(exp a - 1) * exp b‚Äñ + _ := norm_add_le _ _
            _ ‚â§ _ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (Real.exp Œ± - 1) * Real.exp Œ≤ + (Real.exp Œ≤ - 1) := by
          apply add_le_add
          ¬∑ exact mul_le_mul (norm_exp_sub_one_le (ùïÇ := ùïÇ) a) (norm_exp_le (ùïÇ := ùïÇ) b)
