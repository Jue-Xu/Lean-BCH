    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have hf4 : f 4 = (24 : ЁЭХВ)тБ╗┬╣ тАв x ^ 4 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have hf5 : f 5 = (120 : ЁЭХВ)тБ╗┬╣ тАв x ^ 5 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have h_sub : exp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 -
      (24 : ЁЭХВ)тБ╗┬╣ тАв x ^ 4 - (120 : ЁЭХВ)тБ╗┬╣ тАв x ^ 5 = тИС' n, f (n + 6) := by
    rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    have h4 := ((summable_nat_add_iff 3).mpr hf_summ).tsum_eq_zero_add
    simp only [hf3] at h4
    have h5 := ((summable_nat_add_iff 4).mpr hf_summ).tsum_eq_zero_add
    simp only [hf4] at h5
    have h6 := ((summable_nat_add_iff 5).mpr hf_summ).tsum_eq_zero_add
    simp only [hf5] at h6
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left,
        h4, add_sub_cancel_left, h5, add_sub_cancel_left, h6, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp тАЦxтАЦ
  have h_summ6 : Summable (fun n => ((n + 6) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 6)) :=
    (summable_nat_add_iff 6).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 6) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 6))
      (Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 - тАЦxтАЦ ^ 3 / 6 - тАЦxтАЦ ^ 4 / 24 -
        тАЦxтАЦ ^ 5 / 120) := by
    rw [h_summ6.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split5 := ((summable_nat_add_iff 4).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split6 := ((summable_nat_add_iff 5).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4 h_split5 h_split6
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 6))

-- For 0 тЙд s with s < 3/4, the sixth-order Taylor remainder satisfies
-- exp(s) - 1 - s - s┬▓/2 - s┬│/6 - sтБ┤/24 - sтБ╡/120 тЙд sтБ╢.
private lemma real_exp_sixth_order_le_sextic {s : тДЭ} (hs : 0 тЙд s) (hs1 : s < 3 / 4) :
    Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120 тЙд s ^ 6 := by
  have hs_lt1 : s < 1 := by linarith
  have h_rexp := hasSum_real_exp s
  have h_summ6 : Summable (fun n => ((n + 6) !тБ╗┬╣ : тДЭ) * s ^ (n + 6)) :=
    (summable_nat_add_iff 6).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 6) !тБ╗┬╣ : тДЭ) * s ^ (n + 6))
      (Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120) := by
    rw [h_summ6.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split5 := ((summable_nat_add_iff 4).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split6 := ((summable_nat_add_iff 5).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4 h_split5 h_split6
    linarith
  -- Comparison: (n+6)!тБ╗┬╣ * s^(n+6) тЙд (720)тБ╗┬╣ * s^(n+6) since (n+6)! тЙе 6! = 720
  have h_geom_summ : Summable (fun n => s ^ (n + 6) / 720) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 6) |>.congr fun n => by ring
  have hterm : тИА n, ((n + 6) !тБ╗┬╣ : тДЭ) * s ^ (n + 6) тЙд s ^ (n + 6) * (720 : тДЭ)тБ╗┬╣ := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_invтВА (by positivity : (0 : тДЭ) < (n + 6)!) (by positivity : (0 : тДЭ) < 720)]
    have : (6 : тДХ)! тЙд (n + 6)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  have h_geom : HasSum (fun n => s ^ (n + 6) * (720 : тДЭ)тБ╗┬╣) (s ^ 6 * (1 - s)тБ╗┬╣ * (720 : тДЭ)тБ╗┬╣) := by
    have hg := (hasSum_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 6)
    have h_eq : (fun n => s ^ 6 * s ^ n) = (fun n => s ^ (n + 6)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (720 : тДЭ)тБ╗┬╣
  calc Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120
      = тИС' n, ((n + 6) !тБ╗┬╣ : тДЭ) * s ^ (n + 6) := h_val.tsum_eq.symm
    _ тЙд тИС' n, (s ^ (n + 6) * (720 : тДЭ)тБ╗┬╣) :=
        h_summ6.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 6 * (1 - s)тБ╗┬╣ * (720 : тДЭ)тБ╗┬╣ := h_geom.tsum_eq
    _ = s ^ 6 / (720 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring
    _ тЙд s ^ 6 := by
        rw [div_le_iffтВА (by nlinarith : (0 : тДЭ) < 720 * (1 - s))]
        nlinarith [sq_nonneg s, pow_nonneg hs 6]

/-! ### Seventh-order exp helpers -/

-- Seventh-order exp remainder:
--   тАЦexp(x) - 1 - x - ┬╜x┬▓ - тЕЩx┬│ - (1/24)xтБ┤ - (1/120)xтБ╡ - (1/720)xтБ╢тАЦ тЙд
--   exp(тАЦxтАЦ) - 1 - тАЦxтАЦ - тАЦxтАЦ┬▓/2 - тАЦxтАЦ┬│/6 - тАЦxтАЦтБ┤/24 - тАЦxтАЦтБ╡/120 - тАЦxтАЦтБ╢/720
include ЁЭХВ in
private theorem norm_exp_sub_one_sub_sub_sub_sub_sub_sub_le (x : ЁЭФ╕) :
    тАЦexp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 - (24 : ЁЭХВ)тБ╗┬╣ тАв x ^ 4 -
        (120 : ЁЭХВ)тБ╗┬╣ тАв x ^ 5 - (720 : ЁЭХВ)тБ╗┬╣ тАв x ^ 6тАЦ тЙд
      Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 - тАЦxтАЦ ^ 3 / 6 - тАЦxтАЦ ^ 4 / 24 -
        тАЦxтАЦ ^ 5 / 120 - тАЦxтАЦ ^ 6 / 720 := by
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
  have hf_summ : Summable f := NormedSpace.expSeries_summable' (ЁЭХВ := ЁЭХВ) x
  have hf0 : f 0 = 1 := by simp [f]
  have hf1 : f 1 = x := by simp [f]
  have hf2 : f 2 = (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    ring
  have hf3 : f 3 = (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have hf4 : f 4 = (24 : ЁЭХВ)тБ╗┬╣ тАв x ^ 4 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have hf5 : f 5 = (120 : ЁЭХВ)тБ╗┬╣ тАв x ^ 5 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have hf6 : f 6 = (720 : ЁЭХВ)тБ╗┬╣ тАв x ^ 6 := by
    simp only [f, Nat.factorial, Nat.mul_one, pow_succ, pow_zero, one_mul]
    norm_num
  have h_sub : exp x - 1 - x - (2 : ЁЭХВ)тБ╗┬╣ тАв x ^ 2 - (6 : ЁЭХВ)тБ╗┬╣ тАв x ^ 3 -
      (24 : ЁЭХВ)тБ╗┬╣ тАв x ^ 4 - (120 : ЁЭХВ)тБ╗┬╣ тАв x ^ 5 - (720 : ЁЭХВ)тБ╗┬╣ тАв x ^ 6 =
      тИС' n, f (n + 7) := by
    rw [congr_fun (exp_eq_tsum ЁЭХВ (ЁЭФ╕ := ЁЭФ╕)) x]
    have h1 := hf_summ.tsum_eq_zero_add; rw [hf0] at h1
    have h2 := ((summable_nat_add_iff 1).mpr hf_summ).tsum_eq_zero_add
    simp only [hf1] at h2
    have h3 := ((summable_nat_add_iff 2).mpr hf_summ).tsum_eq_zero_add
    simp only [hf2] at h3
    have h4 := ((summable_nat_add_iff 3).mpr hf_summ).tsum_eq_zero_add
    simp only [hf3] at h4
    have h5 := ((summable_nat_add_iff 4).mpr hf_summ).tsum_eq_zero_add
    simp only [hf4] at h5
    have h6 := ((summable_nat_add_iff 5).mpr hf_summ).tsum_eq_zero_add
    simp only [hf5] at h6
    have h7 := ((summable_nat_add_iff 6).mpr hf_summ).tsum_eq_zero_add
    simp only [hf6] at h7
    rw [h1, add_sub_cancel_left, h2, add_sub_cancel_left, h3, add_sub_cancel_left,
        h4, add_sub_cancel_left, h5, add_sub_cancel_left, h6, add_sub_cancel_left,
        h7, add_sub_cancel_left]
  rw [h_sub]
  have h_rexp := hasSum_real_exp тАЦxтАЦ
  have h_summ7 : Summable (fun n => ((n + 7) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 7)) :=
    (summable_nat_add_iff 7).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 7) !тБ╗┬╣ : тДЭ) * тАЦxтАЦ ^ (n + 7))
      (Real.exp тАЦxтАЦ - 1 - тАЦxтАЦ - тАЦxтАЦ ^ 2 / 2 - тАЦxтАЦ ^ 3 / 6 - тАЦxтАЦ ^ 4 / 24 -
        тАЦxтАЦ ^ 5 / 120 - тАЦxтАЦ ^ 6 / 720) := by
    rw [h_summ7.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split5 := ((summable_nat_add_iff 4).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split6 := ((summable_nat_add_iff 5).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split7 := ((summable_nat_add_iff 6).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4 h_split5 h_split6 h_split7
    linarith
  exact tsum_of_norm_bounded h_val (fun n => norm_expSeries_term_le' (ЁЭХВ := ЁЭХВ) x (n + 7))

-- For 0 тЙд s with s < 3/4, the seventh-order Taylor remainder satisfies
-- exp(s) - 1 - s - s┬▓/2 - s┬│/6 - sтБ┤/24 - sтБ╡/120 - sтБ╢/720 тЙд sтБ╖.
private lemma real_exp_seventh_order_le_septic {s : тДЭ} (hs : 0 тЙд s) (hs1 : s < 3 / 4) :
    Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120 -
        s ^ 6 / 720 тЙд s ^ 7 := by
  have hs_lt1 : s < 1 := by linarith
  have h_rexp := hasSum_real_exp s
  have h_summ7 : Summable (fun n => ((n + 7) !тБ╗┬╣ : тДЭ) * s ^ (n + 7)) :=
    (summable_nat_add_iff 7).mpr h_rexp.summable
  have h_val : HasSum (fun n => ((n + 7) !тБ╗┬╣ : тДЭ) * s ^ (n + 7))
      (Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120 -
        s ^ 6 / 720) := by
    rw [h_summ7.hasSum_iff]
    have h_split := h_rexp.summable.tsum_eq_zero_add; rw [h_rexp.tsum_eq] at h_split
    have h_split2 := ((summable_nat_add_iff 1).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split3 := ((summable_nat_add_iff 2).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split4 := ((summable_nat_add_iff 3).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split5 := ((summable_nat_add_iff 4).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split6 := ((summable_nat_add_iff 5).mpr h_rexp.summable).tsum_eq_zero_add
    have h_split7 := ((summable_nat_add_iff 6).mpr h_rexp.summable).tsum_eq_zero_add
    simp only [Nat.factorial_zero, Nat.cast_one, inv_one, one_mul, pow_zero,
      Nat.factorial_one, pow_one, zero_add] at h_split h_split2 h_split3 h_split4 h_split5 h_split6 h_split7
    linarith
  -- Comparison: (n+7)!тБ╗┬╣ * s^(n+7) тЙд (5040)тБ╗┬╣ * s^(n+7) since (n+7)! тЙе 7! = 5040
  have h_geom_summ : Summable (fun n => s ^ (n + 7) / 5040) := by
    apply Summable.div_const
    exact (summable_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 7) |>.congr fun n => by ring
  have hterm : тИА n, ((n + 7) !тБ╗┬╣ : тДЭ) * s ^ (n + 7) тЙд s ^ (n + 7) * (5040 : тДЭ)тБ╗┬╣ := by
    intro n
    rw [mul_comm]
    apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs _)
    rw [inv_le_invтВА (by positivity : (0 : тДЭ) < (n + 7)!) (by positivity : (0 : тДЭ) < 5040)]
    have : (7 : тДХ)! тЙд (n + 7)! := Nat.factorial_le (by omega)
    exact_mod_cast this
  have h_geom : HasSum (fun n => s ^ (n + 7) * (5040 : тДЭ)тБ╗┬╣)
      (s ^ 7 * (1 - s)тБ╗┬╣ * (5040 : тДЭ)тБ╗┬╣) := by
    have hg := (hasSum_geometric_of_lt_one hs hs_lt1).mul_left (s ^ 7)
    have h_eq : (fun n => s ^ 7 * s ^ n) = (fun n => s ^ (n + 7)) := by ext n; ring
    rw [h_eq] at hg
    exact hg.mul_right (5040 : тДЭ)тБ╗┬╣
  calc Real.exp s - 1 - s - s ^ 2 / 2 - s ^ 3 / 6 - s ^ 4 / 24 - s ^ 5 / 120 -
        s ^ 6 / 720
      = тИС' n, ((n + 7) !тБ╗┬╣ : тДЭ) * s ^ (n + 7) := h_val.tsum_eq.symm
    _ тЙд тИС' n, (s ^ (n + 7) * (5040 : тДЭ)тБ╗┬╣) :=
        h_summ7.tsum_le_tsum hterm h_geom.summable
    _ = s ^ 7 * (1 - s)тБ╗┬╣ * (5040 : тДЭ)тБ╗┬╣ := h_geom.tsum_eq
    _ = s ^ 7 / (5040 * (1 - s)) := by rw [div_eq_mul_inv, mul_inv_rev]; ring
    _ тЙд s ^ 7 := by
        rw [div_le_iffтВА (by nlinarith : (0 : тДЭ) < 5040 * (1 - s))]
        nlinarith [sq_nonneg s, pow_nonneg hs 7]

/-- For `0 тЙд s тЙд 1/10`, `(Real.exp s - 1)^7 тЙд 2 ┬╖ s^7`. Used in the small-s
septic remainder assembly. Analog of the inline `hexp6` calculation for the
sextic case, extended one degree. -/
private lemma real_exp_sub_one_pow7_le_small {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_small : s тЙд 1 / 10) :
    (Real.exp s - 1) ^ 7 тЙд 2 * s ^ 7 := by
  have hE1_nn : 0 тЙд Real.exp s - 1 := by linarith [Real.add_one_le_exp s]
  have hs_lt1 : s < 1 := by linarith
  have hEs2 : Real.exp s - 1 - s тЙд s ^ 2 := by
    have h := Real.norm_exp_sub_one_sub_id_le
      (show тАЦsтАЦ тЙд 1 by rw [Real.norm_eq_abs, abs_of_nonneg hs_nn]; linarith)
    have hEs_nn : 0 тЙд Real.exp s - 1 - s := by
      linarith [Real.quadratic_le_exp_of_nonneg hs_nn, sq_nonneg s]
    rwa [Real.norm_eq_abs, abs_of_nonneg hEs_nn,
         Real.norm_eq_abs, abs_of_nonneg hs_nn] at h
  calc (Real.exp s - 1) ^ 7 тЙд (s + s ^ 2) ^ 7 :=
        pow_le_pow_leftтВА hE1_nn (by linarith) 7
    _ = s ^ 7 * (1 + s) ^ 7 := by ring
    _ тЙд s ^ 7 * 2 := by
        apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs_nn 7)
        have h1 : (1 + s) ^ 7 тЙд (1 + 1/10) ^ 7 :=
          pow_le_pow_leftтВА (by linarith) (by linarith) 7
        have h2 : (1 + 1/10 : тДЭ) ^ 7 тЙд 2 := by norm_num
        linarith
    _ = 2 * s ^ 7 := by ring

/-- For `0 тЙд s тЙд 1/10`, `(Real.exp s - 1)^8 тЙд 3 ┬╖ s^8`. Used in the small-s
octic remainder assembly. Analog of `real_exp_sub_one_pow7_le_small` at one
degree higher; constant is 3 (not 2) because `(1+1/10)^8 тЙИ 2.14`. -/
private lemma real_exp_sub_one_pow8_le_small {s : тДЭ} (hs_nn : 0 тЙд s)
    (hs_small : s тЙд 1 / 10) :
    (Real.exp s - 1) ^ 8 тЙд 3 * s ^ 8 := by
  have hE1_nn : 0 тЙд Real.exp s - 1 := by linarith [Real.add_one_le_exp s]
  have hs_lt1 : s < 1 := by linarith
  have hEs2 : Real.exp s - 1 - s тЙд s ^ 2 := by
    have h := Real.norm_exp_sub_one_sub_id_le
      (show тАЦsтАЦ тЙд 1 by rw [Real.norm_eq_abs, abs_of_nonneg hs_nn]; linarith)
    have hEs_nn : 0 тЙд Real.exp s - 1 - s := by
      linarith [Real.quadratic_le_exp_of_nonneg hs_nn, sq_nonneg s]
    rwa [Real.norm_eq_abs, abs_of_nonneg hEs_nn,
         Real.norm_eq_abs, abs_of_nonneg hs_nn] at h
  calc (Real.exp s - 1) ^ 8 тЙд (s + s ^ 2) ^ 8 :=
        pow_le_pow_leftтВА hE1_nn (by linarith) 8
    _ = s ^ 8 * (1 + s) ^ 8 := by ring
    _ тЙд s ^ 8 * 3 := by
        apply mul_le_mul_of_nonneg_left _ (pow_nonneg hs_nn 8)
        have h1 : (1 + s) ^ 8 тЙд (1 + 1/10) ^ 8 :=
          pow_le_pow_leftтВА (by linarith) (by linarith) 8
        have h2 : (1 + 1/10 : тДЭ) ^ 8 тЙд 3 := by norm_num
        linarith
    _ = 3 * s ^ 8 := by ring

/-- **Eighth-order noncommutative exp tail bound**: norm of the deg-8+ tail
of `exp(x) = тИС xтБ┐/n!` is bounded by the corresponding real tail.

Adds one more level to `norm_exp_sub_one_sub_sub_sub_sub_sub_sub_le`. -/
private theorem norm_exp_sub_one_sub_sub_sub_sub_sub_sub_sub_le (x : ЁЭФ╕) :
