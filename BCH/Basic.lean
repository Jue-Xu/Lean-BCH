        тАЦxтАЦ ^ 5 / 120 - тАЦxтАЦ ^ 6 / 720 - тАЦxтАЦ ^ 7 / 5040 := by
  set f : тДХ тЖТ ЁЭФ╕ := fun n => (n !тБ╗┬╣ : ЁЭХВ) тАв x ^ n
