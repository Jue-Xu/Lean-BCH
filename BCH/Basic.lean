    have hsmul_expand : (2 : ЁЭХВ)тБ╗┬╣ тАв (╬┤ * a' - a' * ╬┤) =
        (2 : ЁЭХВ)тБ╗┬╣ тАв (z * a' - a' * z) + (2 : ЁЭХВ)тБ╗┬╣ тАв (a' * b - b * a') := by
