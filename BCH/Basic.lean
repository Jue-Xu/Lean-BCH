  have hs6 : s ^ 6 ‚â§ s ^ 5 / 10 := by
    have h_eq : s ^ 6 = s ^ 5 * s := by ring
    rw [h_eq]
    have : s ^ 5 * s ‚â§ s ^ 5 * (1 / 10) := by
      apply mul_le_mul_of_nonneg_left hs_small (pow_nonneg hs_nn 5)
    linarith
  have ha1 := norm_add_le (G‚ÇÅ + G‚ÇÇ + a * F‚ÇÇ + F‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ +
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (E‚ÇÅ * b ^ 2)) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * E‚ÇÇ))
  have ha2 := norm_add_le (G‚ÇÅ + G‚ÇÇ + a * F‚ÇÇ + F‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ)
    ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (E‚ÇÅ * b ^ 2))
  have ha3 := norm_add_le (G‚ÇÅ + G‚ÇÇ + a * F‚ÇÇ + F‚ÇÅ * b) (E‚ÇÅ * E‚ÇÇ)
  have ha4 := norm_add_le (G‚ÇÅ + G‚ÇÇ + a * F‚ÇÇ) (F‚ÇÅ * b)
  have ha5 := norm_add_le (G‚ÇÅ + G‚ÇÇ) (a * F‚ÇÇ)
  have ha6 := norm_add_le G‚ÇÅ G‚ÇÇ
  linarith [pow_nonneg hs_nn 5, pow_nonneg hs_nn 6]

/-- Norm bound `‚ÄñR+T‚ÇÖ residual sum‚Äñ ‚â§ 6¬∑s‚Å∂` from precomputed component bounds.
The 7 terms come from `R_plus_T5_eq_neg_deg6_residual`:
H‚ÇÅ+H‚ÇÇ+a¬∑G‚ÇÇ+G‚ÇÅ¬∑b+E‚ÇÅ¬∑E‚ÇÇ+¬Ω¬∑F‚ÇÅ¬∑b¬≤+¬Ω¬∑a¬≤¬∑F‚ÇÇ. Analog of `norm_R_residual_sum_le`
at one degree higher; all inputs are already deg-6, so no `s ‚â§ 1/10`
constraint is needed. -/
private theorem norm_R_plus_T5_residual_sum_le (H‚ÇÅ H‚ÇÇ G‚ÇÅ G‚ÇÇ F‚ÇÅ F‚ÇÇ E‚ÇÅ E‚ÇÇ a b : ùî∏)
    {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hH‚ÇÅ_le : ‚ÄñH‚ÇÅ‚Äñ ‚â§ s ^ 6) (hH‚ÇÇ_le : ‚ÄñH‚ÇÇ‚Äñ ‚â§ s ^ 6)
    (h_aG‚ÇÇ_le : ‚Äña * G‚ÇÇ‚Äñ ‚â§ s ^ 6) (h_G‚ÇÅb_le : ‚ÄñG‚ÇÅ * b‚Äñ ‚â§ s ^ 6)
    (h_E‚ÇÅE‚ÇÇ_le : ‚ÄñE‚ÇÅ * E‚ÇÇ‚Äñ ‚â§ s ^ 6)
    (h_F‚ÇÅb2_le : ‚ÄñF‚ÇÅ * b ^ 2‚Äñ ‚â§ s ^ 6)
    (h_a2F‚ÇÇ_le : ‚Äña ^ 2 * F‚ÇÇ‚Äñ ‚â§ s ^ 6) :
    ‚ÄñH‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ)‚Äñ ‚â§ 6 * s ^ 6 := by
  have h2eq : ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ = (2 : ‚Ñù)‚Åª¬π := by rw [norm_inv, RCLike.norm_ofNat]
  have h_F1b2_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)‚Äñ ‚â§ s ^ 6 / 2 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚ÄñF‚ÇÅ * b ^ 2‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_F‚ÇÅb2_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have h_a2F2_smul : ‚Äñ(2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ)‚Äñ ‚â§ s ^ 6 / 2 := by
    calc _ ‚â§ ‚Äñ(2 : ùïÇ)‚Åª¬π‚Äñ * ‚Äña ^ 2 * F‚ÇÇ‚Äñ := norm_smul_le _ _
      _ ‚â§ (2 : ‚Ñù)‚Åª¬π * s ^ 6 := by
          rw [h2eq]; exact mul_le_mul_of_nonneg_left h_a2F‚ÇÇ_le (by norm_num)
      _ = s ^ 6 / 2 := by ring
  have ha1 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ +
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ))
  have ha2 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b + E‚ÇÅ * E‚ÇÇ)
    ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2))
  have ha3 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b) (E‚ÇÅ * E‚ÇÇ)
  have ha4 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ) (G‚ÇÅ * b)
  have ha5 := norm_add_le (H‚ÇÅ + H‚ÇÇ) (a * G‚ÇÇ)
  have ha6 := norm_add_le H‚ÇÅ H‚ÇÇ
  -- Total: 5¬∑s‚Å∂ + s‚Å∂/2 + s‚Å∂/2 = 6¬∑s‚Å∂
  linarith [pow_nonneg hs_nn 6]

/-- Norm bound for `‚ÄñPzP - T‚ÇÇzT‚ÇÇ‚Äñ ‚â§ 13¬∑s‚Å∂` for small s (`s < 1/10`).
Splits via `P = T‚ÇÇ + (P-T‚ÇÇ)` into 3 terms each bounded by Cs‚Å∂. -/
private theorem norm_PzP_sub_T2zT2_le (z P T‚ÇÇ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hs_small : s ‚â§ 1 / 10) (hz : ‚Äñz‚Äñ ‚â§ s) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2)
    (hPmT‚ÇÇ : ‚ÄñP - T‚ÇÇ‚Äñ ‚â§ 5 * s ^ 3) :
    ‚ÄñP * z * P - T‚ÇÇ * z * T‚ÇÇ‚Äñ ‚â§ 13 * s ^ 6 := by
  have heq : P * z * P - T‚ÇÇ * z * T‚ÇÇ =
      T‚ÇÇ * z * (P - T‚ÇÇ) + (P - T‚ÇÇ) * z * T‚ÇÇ + (P - T‚ÇÇ) * z * (P - T‚ÇÇ) := by
    have hP : P = T‚ÇÇ + (P - T‚ÇÇ) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  have ht1 : ‚ÄñT‚ÇÇ * z * (P - T‚ÇÇ)‚Äñ ‚â§ s ^ 2 * s * (5 * s ^ 3) :=
    calc _ ‚â§ ‚ÄñT‚ÇÇ * z‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñT‚ÇÇ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP - T‚ÇÇ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 2 * s) * (5 * s ^ 3) := by
          apply mul_le_mul _ hPmT‚ÇÇ (norm_nonneg _) (by positivity)
          exact mul_le_mul hT‚ÇÇ hz (norm_nonneg _) (by positivity)
  have ht2 : ‚Äñ(P - T‚ÇÇ) * z * T‚ÇÇ‚Äñ ‚â§ (5 * s ^ 3) * s * s ^ 2 :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ) * z‚Äñ * ‚ÄñT‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÇ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((5 * s ^ 3) * s) * s ^ 2 := by
          apply mul_le_mul _ hT‚ÇÇ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmT‚ÇÇ hz (norm_nonneg _) (by positivity)
  have ht3 : ‚Äñ(P - T‚ÇÇ) * z * (P - T‚ÇÇ)‚Äñ ‚â§ (5 * s ^ 3) * s * (5 * s ^ 3) :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ) * z‚Äñ * ‚ÄñP - T‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP - T‚ÇÇ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((5 * s ^ 3) * s) * (5 * s ^ 3) := by
          apply mul_le_mul _ hPmT‚ÇÇ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmT‚ÇÇ hz (norm_nonneg _) (by positivity)
  have hadd1 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ) + (P - T‚ÇÇ) * z * T‚ÇÇ)
    ((P - T‚ÇÇ) * z * (P - T‚ÇÇ))
  have hadd2 := norm_add_le (T‚ÇÇ * z * (P - T‚ÇÇ)) ((P - T‚ÇÇ) * z * T‚ÇÇ)
  -- Total: 5s‚Å∂ + 5s‚Å∂ + 25s‚Å∑ ‚â§ 5 + 5 + 25¬∑(1/10)¬∑s‚Å∂ = 12.5s‚Å∂ ‚â§ 13s‚Å∂
  nlinarith [pow_nonneg hs_nn 6, pow_nonneg hs_nn 7]

/-- Norm bound for `‚ÄñPzP - T‚ÇÇzT‚ÇÇ - T‚ÇÇzT‚ÇÉ - T‚ÇÉzT‚ÇÇ‚Äñ ‚â§ 13¬∑s‚Å∑` for small s
(`s ‚â§ 1/10`). Decomposes via `P = T‚ÇÇ + T‚ÇÉ + (P-T‚ÇÇ-T‚ÇÉ)` into 6 terms.
The "I2 sandwich" piece for the septic residual; provides K_PzP = 13. -/
private theorem norm_PzP_sub_T2zT2_etc_le (z P T‚ÇÇ T‚ÇÉ : ùî∏) {s : ‚Ñù} (hs_nn : 0 ‚â§ s)
    (hs_small : s ‚â§ 1 / 10) (hz : ‚Äñz‚Äñ ‚â§ s) (hT‚ÇÇ : ‚ÄñT‚ÇÇ‚Äñ ‚â§ s ^ 2)
    (hT‚ÇÉ : ‚ÄñT‚ÇÉ‚Äñ ‚â§ s ^ 3)
    (hPmT‚ÇÇmT‚ÇÉ : ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ ‚â§ 5 * s ^ 4) :
    ‚ÄñP * z * P - T‚ÇÇ * z * T‚ÇÇ - T‚ÇÇ * z * T‚ÇÉ - T‚ÇÉ * z * T‚ÇÇ‚Äñ ‚â§ 13 * s ^ 7 := by
  have heq : P * z * P - T‚ÇÇ * z * T‚ÇÇ - T‚ÇÇ * z * T‚ÇÉ - T‚ÇÉ * z * T‚ÇÇ =
      T‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ) + T‚ÇÉ * z * T‚ÇÉ + T‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ) +
      (P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÇ + (P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÉ +
      (P - T‚ÇÇ - T‚ÇÉ) * z * (P - T‚ÇÇ - T‚ÇÉ) := by
    have hP : P = T‚ÇÇ + T‚ÇÉ + (P - T‚ÇÇ - T‚ÇÉ) := by abel
    rw [hP]; noncomm_ring
  rw [heq]
  have h1 : ‚ÄñT‚ÇÇ * z * (P - T‚ÇÇ - T‚ÇÉ)‚Äñ ‚â§ s ^ 2 * s * (5 * s ^ 4) :=
    calc _ ‚â§ ‚ÄñT‚ÇÇ * z‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñT‚ÇÇ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 2 * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmT‚ÇÇmT‚ÇÉ (norm_nonneg _) (by positivity)
          exact mul_le_mul hT‚ÇÇ hz (norm_nonneg _) (by positivity)
  have h2 : ‚ÄñT‚ÇÉ * z * T‚ÇÉ‚Äñ ‚â§ s ^ 3 * s * s ^ 3 :=
    calc _ ‚â§ ‚ÄñT‚ÇÉ * z‚Äñ * ‚ÄñT‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñT‚ÇÉ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 3 * s) * s ^ 3 := by
          apply mul_le_mul _ hT‚ÇÉ (norm_nonneg _) (by positivity)
          exact mul_le_mul hT‚ÇÉ hz (norm_nonneg _) (by positivity)
  have h3 : ‚ÄñT‚ÇÉ * z * (P - T‚ÇÇ - T‚ÇÉ)‚Äñ ‚â§ s ^ 3 * s * (5 * s ^ 4) :=
    calc _ ‚â§ ‚ÄñT‚ÇÉ * z‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñT‚ÇÉ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ (s ^ 3 * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmT‚ÇÇmT‚ÇÉ (norm_nonneg _) (by positivity)
          exact mul_le_mul hT‚ÇÉ hz (norm_nonneg _) (by positivity)
  have h4 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÇ‚Äñ ‚â§ (5 * s ^ 4) * s * s ^ 2 :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z‚Äñ * ‚ÄñT‚ÇÇ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÇ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((5 * s ^ 4) * s) * s ^ 2 := by
          apply mul_le_mul _ hT‚ÇÇ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmT‚ÇÇmT‚ÇÉ hz (norm_nonneg _) (by positivity)
  have h5 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z * T‚ÇÉ‚Äñ ‚â§ (5 * s ^ 4) * s * s ^ 3 :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z‚Äñ * ‚ÄñT‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñT‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((5 * s ^ 4) * s) * s ^ 3 := by
          apply mul_le_mul _ hT‚ÇÉ (norm_nonneg _) (by positivity)
          exact mul_le_mul hPmT‚ÇÇmT‚ÇÉ hz (norm_nonneg _) (by positivity)
  have h6 : ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z * (P - T‚ÇÇ - T‚ÇÉ)‚Äñ ‚â§ (5 * s ^ 4) * s * (5 * s ^ 4) :=
    calc _ ‚â§ ‚Äñ(P - T‚ÇÇ - T‚ÇÉ) * z‚Äñ * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := norm_mul_le _ _
      _ ‚â§ (‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ * ‚Äñz‚Äñ) * ‚ÄñP - T‚ÇÇ - T‚ÇÉ‚Äñ := by gcongr; exact norm_mul_le _ _
      _ ‚â§ ((5 * s ^ 4) * s) * (5 * s ^ 4) := by
          apply mul_le_mul _ hPmT‚ÇÇmT‚ÇÉ (norm_nonneg _) (by positivity)
