      have hDb2 : Real.exp β - 1 - β ≤ β ^ 2 := by
        have h := Real.norm_exp_sub_one_sub_id_le
          (show ‖β‖ ≤ 1 by rw [Real.norm_eq_abs, abs_of_nonneg hβ_nn]; linarith)
        rwa [Real.norm_eq_abs, abs_of_nonneg hDb_nn,
