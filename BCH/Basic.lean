  -- Triangle inequality on the 9-term sum
  -- Outer: (H‚ÇÅ+H‚ÇÇ+a*G‚ÇÇ+G‚ÇÅ*b) + inner_3 + ¬Ω(zR+Rz) + ¬ΩT22
  -- Inner_3 = E‚ÇÅ*E‚ÇÇ + ¬Ω(a¬≤*F‚ÇÇ) + ¬Ω(F‚ÇÅ*b¬≤)
  have h_inner3 : ‚ÄñE‚ÇÅ * E‚ÇÇ + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ) +
      (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)‚Äñ ‚â§ s ^ 6 + s ^ 6 / 2 + s ^ 6 / 2 := by
    have hi1 := norm_add_le (E‚ÇÅ * E‚ÇÇ + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ))
      ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2))
    have hi2 := norm_add_le (E‚ÇÅ * E‚ÇÇ) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ))
    linarith
  -- Outer chain: 4 + inner + 2 = 7 norm_add_le applications
  have ha1 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b +
    (E‚ÇÅ * E‚ÇÇ + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (a ^ 2 * F‚ÇÇ) + (2 : ùïÇ)‚Åª¬π ‚Ä¢ (F‚ÇÅ * b ^ 2)) +
    (2 : ùïÇ)‚Åª¬π ‚Ä¢ (z * R + R * z)) ((2 : ùïÇ)‚Åª¬π ‚Ä¢ T22)
  have ha2 := norm_add_le (H‚ÇÅ + H‚ÇÇ + a * G‚ÇÇ + G‚ÇÅ * b +
