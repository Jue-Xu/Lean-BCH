  -- Full algebraic decomposition:
  -- bch(z, a') - (a+b) = RтВГ'' + ┬╜(╬┤a'-a'╬┤) + RтВГ'
  have hfull_decomp : bch (ЁЭХВ := ЁЭХВ) z a' - (a + b) =
      (bch (ЁЭХВ := ЁЭХВ) z a' - (z + a') - (2 : ЁЭХВ)тБ╗┬╣ тАв (z * a' - a' * z)) +
      ((2 : ЁЭХВ)тБ╗┬╣ тАв (╬┤ * a' - a' * ╬┤)) +
