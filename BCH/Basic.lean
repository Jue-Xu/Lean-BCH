  -- Step 1: Telescoping algebraic identity
  have htel : bch_quintic_group_1 z y - bch_quintic_group_1 x y =
      (z - x) * z * z * z * y + x * (z - x) * z * z * y +
      x * x * (z - x) * z * y + x * x * x * (z - x) * y +
      (z - x) * y * y * y * y +
      y * (z - x) * z * z * z + y * x * (z - x) * z * z +
      y * x * x * (z - x) * z + y * x * x * x * (z - x) +
