          calc _ ≤ ‖(x₁ - y₁) * x₂ * x₃ * x₄ * x₅ * x₆‖ * ‖x₇‖ := norm_mul_le _ _
            _ ≤ ‖(x₁ - y₁) * x₂ * x₃ * x₄ * x₅‖ * ‖x₆‖ * ‖x₇‖ := by
                gcongr; exact norm_mul_le _ _
            _ ≤ ‖(x₁ - y₁) * x₂ * x₃ * x₄‖ * ‖x₅‖ * ‖x₆‖ * ‖x₇‖ := by
                gcongr; exact norm_mul_le _ _
