  have hd₇_nn : 0 ≤ ‖x₇ - y₇‖ := norm_nonneg _
  have ht₁ : ‖(x₁ - y₁) * x₂ * x₃ * x₄ * x₅ * x₆ * x₇‖ ≤ N ^ 6 * ‖x₁ - y₁‖ := by
