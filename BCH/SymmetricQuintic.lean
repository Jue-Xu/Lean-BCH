  have ht₂ : ‖y₁ * (x₂ - y₂) * x₃ * x₄ * x₅‖ ≤ N ^ 4 * ‖x₂ - y₂‖ := by
    calc ‖y₁ * (x₂ - y₂) * x₃ * x₄ * x₅‖
