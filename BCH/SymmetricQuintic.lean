  -- TERM A: ‖C₇(z, a') − C₇(a'+b, a')‖ ≤ 200000·s⁸.
  have hCA : ‖bch_septic_term 𝕂 z a' - bch_septic_term 𝕂 (a' + b) a'‖ ≤
