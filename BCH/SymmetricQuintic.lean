      y₁ * y₂ * y₃ * y₄ * y₅ * (x₆ - y₆) * x₇ +
      y₁ * y₂ * y₃ * y₄ * y₅ * y₆ * (x₇ - y₇) := by noncomm_ring
  rw [hid]
  have hN_pow_nn : (0 : ℝ) ≤ N ^ 6 := pow_nonneg hN_nn 6
