      (-20 / 46080 : 𝕂) • (a * a * b * b * b * a) +
      (-8 / 46080 : 𝕂) • (a * a * b * b * b * b) +
      (36 / 46080 : 𝕂) • (a * b * a * a * a * b) +
      (-32 / 46080 : 𝕂) • (a * b * a * a * b * b) +
      (30 / 46080 : 𝕂) • (a * b * a * b * a * a) +
      (128 / 46080 : 𝕂) • (a * b * a * b * a * b) +
      (40 / 46080 : 𝕂) • (a * b * a * b * b * a) +
