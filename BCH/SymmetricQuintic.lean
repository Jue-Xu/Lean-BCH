private theorem septic_d7_perturbation_poly_pieces_decomp
    {𝕂 : Type*} [RCLike 𝕂] {𝔸 : Type*} [NormedRing 𝔸] [NormedAlgebra 𝕂 𝔸]
    (a b : 𝔸) :
